        If rbencounter.Value = True Then
          $rData = modDatabase.$myConn.Exec("select fldid,fldchk,fldsave_report,fldtest_type,fldtestid,fldsampletype,fldsampleid,fldtime_sample,fldabnormal,fldid,fldid,fldstatus,flduserid_sample,flduserid_report,flduserid_verify,fldrefername,fldcondition,fldsampleid,fldsampletype,fldtime_sample,fldtime_report,fldtime_report,fldprint,fldorder,fldtestid,fldcomment from tblpatlabtest where fldsave_report=&1 and fldencounterval=&2 and (fldstatus=&3 or fldstatus=&4) and flvisible=&5 and fldtestid in(select fldtestid from tbltest where fldcategory like &6) and fldtime_sample>=&7 and fldtime_sample<=&8" & GetReportOrder("Test"), True, Trim(txtencid.Text), reprt, vrfd, "Visible", cmbcategory.Text, dtfrom.Value, dtto.Value)                                                   ''
