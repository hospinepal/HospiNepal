Public Sub GridView1_Data(Row As Integer, Column As Integer)

  $rData.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView1, Row)
  If Column = 1 Then
    GridView1.Data.Picture = modBasic.$PictureUnchecked
    GridView1.Data.Text = ""
  Else If Column = 2 Then
    GridView1.Data.Picture = modBasic.$PictureUnchecked
    GridView1.Data.Text = ""
  Else If Column = 7 Then
    GridView1.Data.Text = modReportVar.GetDateTimeReport($rData["fldtime_sample"], gb.GeneralDate)
  Else If Column = 8 Then
    GridView1.Data.Picture = Picture[modGridView.GetGridIcon($rData["fldabnormal"])]
    GridView1.Data.Text = ""
  Else If Column = 9 Then
    GridView1.Data.RichText = modLabTest.GetLabTestValueGridString($rData["fldid"], modLabTest.GetTestUnitFromButton(rbsi, rbmetric), False)
  Else If Column = 10 Then
    GridView1.Data.Text = modLabTest.GetTestLimitSrting($rData["fldid"], modLabTest.GetTestUnitFromButton(rbsi, rbmetric))
  Else If Column = 21 Then
    GridView1.Data.Text = modReportVar.GetDateTimeReport($rData["fldtime_report"], gb.GeneralDate)
  Else If Column = 22 Then
    GridView1.Data.Picture = Picture[modGridView.SetGridCheckIcon($rData["fldprint"])]
    GridView1.Data.Text = ""
  Else If Column = 24 Then
    GridView1.Data.Text = modFixLab.GetLabTestCategory($rData["fldtestid"])
  Else
    GridView1.Data.Text = $rData[$aMyFields[Column]]
  Endif

End

Private Sub GetTestItemList()

  Dim testList As String[]
  Dim i As Integer

  testList = New String[]
  For i = 0 To GridView1.Rows.Count - 1
    testList.Add(GridView1[i, 4].Text)
  Next
  cmbfootest.List = testList

End

Public Sub GridView1_Click()

  Dim xx As String
  Dim col As Integer
  Dim row As Integer

  col = GridView1.Column
  row = GridView1.Row
  SHowQualiSUbTest(0) ''false grid to make grid empty
  $TestID = GridView1[GridView1.Row, 0].Text
  If GridView1.Column = 1 Then
    modGridView.CheckUncheckGridNoDB(GridView1, 1)
    EnableSelected()
  Else If GridView1.Column = 2 Then
    If GridView1[GridView1.Row, 3].Text = "Qualitative" Then
      SHowQualiSUbTest(GridView1[GridView1.Row, 0].Text)
      modGridView.CheckUncheckGridNoDB(GridView1, 2)
      ManipulateSecondGrid(GridView1.Row, GridView1[GridView1.Row, 0].Text)
    Endif
  Else If GridView1.Column = 23 Then
    xx = InputBox(("Enter Order Number"), ("Test Order"), GridView1[GridView1.Row, 23].Text)
    If xx Then
      modLabTest.UpdateLabTestOrder(GridView1[GridView1.Row, 0].Text, CInt(xx))
      FillLabtable()
    Endif
  Else If GridView1.Column > 2 Then
    If GridView1[GridView1.Row, 3].Text = "Qualitative" Then
      SHowQualiSUbTest(GridView1[GridView1.Row, 0].Text)
    Endif
  Endif
  GridView1.Column = col
  GridView1.Row = row

End

Private Sub ManipulateSecondGrid(Row As Integer, testid As Long)

  Dim res As Result
  Dim i As Integer

  res = modDatabase.$myConn.Edit("tblpatlabsubtest", "fldtestid=&1 and fldsave=&2", testid, True)
  If GridView1[Row, 2].Picture = modBasic.$PictureChecked Then
    For Each res
      res["fldchk"] = True
      res["xyz"] = False
      res.Update
    Next
    For i = 0 To GridView2.Rows.Count - 1
      GridView2[i, 1].Picture = modBasic.$PictureChecked
    Next

  Else If GridView1[Row, 2].Picture = modBasic.$PictureUnchecked Then
    For Each res
      res["fldchk"] = False
      res["xyz"] = False
      res.Update
    Next
    For i = 0 To GridView2.Rows.Count - 1
      GridView2[i, 1].Picture = modBasic.$PictureUnchecked
    Next

  Endif

End

Private Sub SHowQualiSUbTest(serial As Long)

  Dim sql As String
  Dim $rData1 As Result
  Dim Column As Integer
  Dim fld As ResultField

  GridView2.Clear
  sql = "select fldid,fldchk,fldsubtest,fldabnormal,fldreport,fldorder from tblpatlabsubtest where fldtestid=&1 and fldsave=&2" & GetReportOrder("SubTest")
  $rData1 = modDatabase.$myConn.Exec(sql, serial, True)

  GridView2.Columns.Count = $rData1.Fields.Count
  GridView2.Rows.Count = $rData1.Count

  For Each $rData1
    Column = 0
    For Each fld In $rData1.Fields
      modGeneralMain.GridExplicitDecoration(GridView2, $rData1.Index, Column)
      If Column = 1 Then
        GridView2[$rData1.Index, Column].Picture = Picture[modGridView.SetGridCheckIcon($rData1["fldchk"])]
        GridView2[$rData1.Index, Column].Text = ""
      Else If Column = 3 Then
        GridView2[$rData1.Index, Column].Picture = Picture[modGridView.GetGridIcon($rData1["fldabnormal"])]
        GridView2[$rData1.Index, Column].Text = ""
      Else If Column = 4 Then
        GridView2[$rData1.Index, Column].RichText = $rData1[fld.Name]
      Else
        GridView2[$rData1.Index, Column].Text = $rData1[fld.Name]
      Endif
      Column = Column + 1
    Next
  Next
  GridView2.Row = 0

  With GridView2
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 1
    .Columns[1].Width = 20
    .Columns[2].Width = 175 * modBasic.$AppWidthRatio
    .Columns[3].Width = 20
    .Columns[4].Width = 400 * modBasic.$AppWidthRatio
    .Columns[5].Width = 30 * modBasic.$AppWidthRatio
    .Columns[2].Text = "SubTest"
    .Columns[4].Text = "Observation"
  End With

End

Public Sub GridView2_Click()

  Dim xx As String

  If GridView2.Column = 5 Then
    xx = InputBox(("Enter Order Number"), ("Test Order"), GridView2[GridView2.Row, 5].Text)
    If xx Then
      modLabTest.UpdateLabSubTestOrder(GridView2[GridView2.Row, 0].Text, CInt(xx))
      SHowQualiSUbTest($TestID)
    Endif
  Else
    modGridView.CheckUncheckGrid(modDatabase.$myConn, GridView2, 1, "fldchk", "fldid", "tblpatlabsubtest", GridView2[GridView2.Row, 0].Text)
  Endif

End

Private Function SensiFormat() As String

  Dim xsens As String
  Dim xsumm As String

  xsens = modSettings.ShowSettingFromFIle("Laboratory/SensitivityReport")
  If xsens Then
    xsumm = xsens
  Else
    xsumm = "Table"
  Endif
  Return xsumm

End

Private Sub ShowPatLaboratoryReport(sType As String)

  Dim $BillingReport As CReportHTML
  Dim res As Result
  Dim asx As New String[0]
  Dim unt As String
  Dim i As Integer

  Dim categ As String[]
  Dim newCateg As String[]
  Dim xx As String
  Dim dtcont As String
  Dim xintrp As String
  Dim xexlabel As String
  Dim xval As String
  Dim xquali As String
  Dim xsection As String
  Dim xspecolm As String

  Dim repor As String
  Dim verif As String
  Dim xrefstr As String
  Dim yrefstr As String

  Dim xfontcol1 As String
  Dim xfontcol2 As String
  Dim xfontbod As String
  Dim col1Font As String
  Dim col2Font As String

  Dim aa As String
  Dim bb As String
  Dim cc As String
  Dim dd As String

  Dim $reportedBy As String[]
  Dim $verifiedBy As String[]
  Dim $referName As String[]
  Dim $condiName As String[]
  Dim $sampleID As String[]
  Dim $sampleType As String[]
  Dim $sampleDate As String[]
  Dim $ReportDate As String[]

  Inc Application.Busy

  xfontbod = modSettings.ShowSettingFromFIle("ReportFormat/ReportBody_ContentFont")
  xfontcol1 = modSettings.ShowSettingFromFIle("ReportFormat/ReportBody_Font_Column1")
  xfontcol2 = modSettings.ShowSettingFromFIle("ReportFormat/ReportBody_Font_Column2")
  xintrp = modSettings.ShowSettingFromFIle("Laboratory/Intrepretation_Report")
  xspecolm = modSettings.ShowSettingFromFIle("Laboratory/ExtraColumn")

  If xfontcol1 Then
    col1Font = xfontcol1
  Else
    If xfontbod Then
      col1Font = xfontbod
    Else
      col1Font = "Bold"
    Endif
  Endif

  If xfontcol2 Then
    col2Font = xfontcol2
  Else
    If xfontbod Then
      col2Font = xfontbod
    Else
      col2Font = ""
    Endif
  Endif

  If rbsi.Value = True Then
    unt = "SI"
  Else
    unt = "Metric"
  Endif

  $SensTable = New String[]
  If $CategList.Count Then
    newCateg = $CategList
  Else
    categ = New String[]
    For i = 0 To GridView1.Rows.Count - 1
      If GridView1[i, 1].Picture = modBasic.$PictureChecked Then
        xval = GridView1[i, 24].Text

        If categ.Count = 0 Then
          categ.Add(xval)
        Else
          If categ.Exist(xval) = False Then
            categ.Add(xval)
          Endif
        Endif

      Endif
    Next

    newCateg = categ
  Endif

  If rbimage.Value = True Then
    If xspecolm = "Specimen" Then
      $BillingReport = New CReportHTML([("Examination"), ("Specimen"), ("Observation"), ("Images")], modHelpVariable.$htmlDirectory, "LaboratoryReport", $encid)
    Else If xspecolm = "Comment" Then
      $BillingReport = New CReportHTML([("Examination"), ("Comment"), ("Observation"), ("Images")], modHelpVariable.$htmlDirectory, "LaboratoryReport", $encid)
    Else
      $BillingReport = New CReportHTML([("Examination"), ("Observation"), ("Images")], modHelpVariable.$htmlDirectory, "LaboratoryReport", $encid)
    Endif
  Else
    If rbform1.Value = True Then
      If xspecolm = "Specimen" Then
        $BillingReport = New CReportHTML([("Examination"), ("Specimen"), ("Observation")], modHelpVariable.$htmlDirectory, "LaboratoryReport", $encid)
      Else If xspecolm = "Comment" Then
        $BillingReport = New CReportHTML([("Examination"), ("Comment"), ("Observation")], modHelpVariable.$htmlDirectory, "LaboratoryReport", $encid)
      Else
        $BillingReport = New CReportHTML([("Examination"), ("Observation")], modHelpVariable.$htmlDirectory, "LaboratoryReport", $encid)
      Endif
    Else If rbform3.Value = True Then
      $BillingReport = New CReportHTML([("Examination")], modHelpVariable.$htmlDirectory, "LaboratoryReport", $encid)
    Else If rbform4.Value = True Then
      If xspecolm = "Specimen" Then
        $BillingReport = New CReportHTML([("Examination"), ("Specimen"), ("Observation"), ("Reference Range"), ("Method")], modHelpVariable.$htmlDirectory, "LaboratoryReport", $encid)
      Else If xspecolm = "Comment" Then
        $BillingReport = New CReportHTML([("Examination"), ("Comment"), ("Observation"), ("Reference Range"), ("Method")], modHelpVariable.$htmlDirectory, "LaboratoryReport", $encid)
      Else
        $BillingReport = New CReportHTML([("Examination"), ("Observation"), ("Reference Range"), ("Method")], modHelpVariable.$htmlDirectory, "LaboratoryReport", $encid)
      Endif
    Else
      If xspecolm = "Specimen" Then
        $BillingReport = New CReportHTML([("Examination"), ("Specimen"), ("Observation"), ("Reference Range")], modHelpVariable.$htmlDirectory, "LaboratoryReport", $encid)
      Else If xspecolm = "Comment" Then
        $BillingReport = New CReportHTML([("Examination"), ("Comment"), ("Observation"), ("Reference Range")], modHelpVariable.$htmlDirectory, "LaboratoryReport", $encid)
      Else
        $BillingReport = New CReportHTML([("Examination"), ("Observation"), ("Reference Range")], modHelpVariable.$htmlDirectory, "LaboratoryReport", $encid)
      Endif
    Endif
  Endif

  xsection = modSettings.ShowSettingFromFIle("Laboratory/ReportSections")
  If xsection = "Separate" Then
    ''=========== For separate Report ============
    For Each xx In newCateg
      $BillingReport.UserData.Add("SECTION", "Report")
      $BillingReport.UserData.Add(xx, "PARAM1")

      $reportedBy = New String[]
      $verifiedBy = New String[]
      $referName = New String[]
      $condiName = New String[]
      $sampleID = New String[]
      $sampleType = New String[]
      $sampleDate = New String[]
      $ReportDate = New String[]

      dtcont = modSettings.ShowSettingFromFIle("Laboratory/DateContent")
      For i = 0 To GridView1.Rows.Count - 1
        If GridView1[i, 1].Picture = modBasic.$PictureChecked And If GridView1[i, 24].Text = xx Then
          $reportedBy.Add(GridView1[i, 13].Text)
          $verifiedBy.Add(GridView1[i, 14].Text)
          $referName.Add(GridView1[i, 15].Text)
          $condiName.Add(GridView1[i, 16].Text)
          $sampleID.Add(GridView1[i, 17].Text)
          $sampleType.Add(GridView1[i, 18].Text)
          If dtcont = "DateTime" Then
            $sampleDate.Add(modReportVar.GetDateTimeReport(GridView1[i, 19].Text, gb.GeneralDate))
            $ReportDate.Add(modReportVar.GetDateTimeReport(GridView1[i, 20].Text, gb.GeneralDate))
          Else
            $sampleDate.Add(modReportVar.GetDateTimeReport(GridView1[i, 19].Text, gb.MediumDate))
            $ReportDate.Add(modReportVar.GetDateTimeReport(GridView1[i, 20].Text, gb.MediumDate))
          Endif

          With asx
            If rbimage.Value = True Then
              aa = modLabTest.GetTestnameFromTestID(GridView1[i, 0].Text)
              If GridView1[i, 3].Text = "Quantitative" Then
                xrefstr = modLabTest.TestInterpretByTestID(GridView1[i, 0].Text)
                If xintrp = "Yes" And If xrefstr Then
                  bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True) & " [" & modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt) & "]" & gb.NewLine & "RESULT :" & xrefstr
                Else
                  bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True) & " [" & modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt) & "]"
                Endif
              Else If GridView1[i, 3].Text = "Qualitative" Then
                xrefstr = modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt)
                If xrefstr Then
                  bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True) & " [" & xrefstr & "]"
                Else
                  bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True)
                Endif
              Endif
              .Add(aa)
              If xspecolm = "Specimen" Then
                .Add(GridView1[i, 18].Text)
              Else If xspecolm = "Comment" Then
                .Add(GridView1[i, 25].Text)
              Endif
              .Add(bb)
              .Add(modString.GetImageListForHTML(modImage.ShowTestExamImagePathList("Test", GridView1[i, 0].Text, $encid)))

            Else
              If rbform1.Value = True Then
                aa = modLabTest.GetTestnameFromTestID(GridView1[i, 0].Text)
                If GridView1[i, 3].Text = "Quantitative" Then
                  xrefstr = modLabTest.TestInterpretByTestID(GridView1[i, 0].Text)
                  If xintrp = "Yes" And If xrefstr Then
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True) & " [" & modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt) & "]" & gb.NewLine & "RESULT :" & xrefstr
                  Else
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True) & " [" & modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt) & "]"
                  Endif
                Else If GridView1[i, 3].Text = "Qualitative" Then
                  xrefstr = modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt)
                  If xrefstr Then
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True) & " [" & xrefstr & "]"
                  Else
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True)
                  Endif
                Endif
                .Add(aa)
                If xspecolm = "Specimen" Then
                  .Add(GridView1[i, 18].Text)
                Else If xspecolm = "Comment" Then
                  .Add(GridView1[i, 25].Text)
                Endif
                .Add(bb)

              Else If rbform3.Value = True Then
                aa = modLabTest.GetTestnameFromTestID(GridView1[i, 0].Text)
                If GridView1[i, 3].Text = "Quantitative" Then
                  xrefstr = modLabTest.TestInterpretByTestID(GridView1[i, 0].Text)
                  If xintrp = "Yes" And If xrefstr Then
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True) & " [" & modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt) & "]" & gb.NewLine & "RESULT :" & xrefstr
                  Else
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True) & " [" & modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt) & "]"
                  Endif
                Else If GridView1[i, 3].Text = "Qualitative" Then
                  xrefstr = modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt)
                  If xrefstr Then
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True) & " [" & xrefstr & "]"
                  Else
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True)
                  Endif
                Endif
                If xspecolm = "Specimen" Then
                  .Add(modString.GetFormatTextFontString(aa & " [" & GridView1[i, 18].Text & "]", col1Font) & "<br>" & modString.GetFormatTextFontString(bb, col2Font))
                Else If xspecolm = "Comment" Then
                  .Add(modString.GetFormatTextFontString(aa & " [" & GridView1[i, 25].Text & "]", col1Font) & "<br>" & modString.GetFormatTextFontString(bb, col2Font))
                Else
                  .Add(modString.GetFormatTextFontString(aa, col1Font) & "<br>" & modString.GetFormatTextFontString(bb, col2Font))
                Endif

              Else If rbform4.Value = True Then
                aa = modLabTest.GetTestnameFromTestID(GridView1[i, 0].Text)
                dd = modLabTest.GetTestMethodLabID(GridView1[i, 0].Text)
                If GridView1[i, 3].Text = "Quantitative" Then
                  xrefstr = modLabTest.TestInterpretByTestID(GridView1[i, 0].Text)
                  If xintrp = "Yes" And If xrefstr Then
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True) & gb.NewLine & "RESULT :" & xrefstr
                  Else
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True)
                  Endif
                  cc = modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt)
                Else If GridView1[i, 3].Text = "Qualitative" Then
                  bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True)
                  cc = modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt)
                Endif
                .Add(aa)
                If xspecolm = "Specimen" Then
                  .Add(GridView1[i, 18].Text)
                Else If xspecolm = "Comment" Then
                  .Add(GridView1[i, 25].Text)
                Endif
                .Add(bb)
                .Add(cc)
                .Add(dd)

              Else
                aa = modLabTest.GetTestnameFromTestID(GridView1[i, 0].Text)
                If GridView1[i, 3].Text = "Quantitative" Then
                  xrefstr = modLabTest.TestInterpretByTestID(GridView1[i, 0].Text)
                  If xintrp = "Yes" And If xrefstr Then
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True) & gb.NewLine & "RESULT :" & xrefstr
                  Else
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True)
                  Endif
                  cc = modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt)
                Else If GridView1[i, 3].Text = "Qualitative" Then
                  bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True)
                  cc = modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt)
                Endif
                .Add(aa)
                If xspecolm = "Specimen" Then
                  .Add(GridView1[i, 18].Text)
                Else If xspecolm = "Comment" Then
                  .Add(GridView1[i, 25].Text)
                Endif
                .Add(bb)
                .Add(cc)

              Endif
            Endif
          End With
          $BillingReport.Add(asx)
          asx.Clear()

          If GridView1[i, 3].Text = "Qualitative" Then

            res = modDatabase.$myConn.Exec("select fldsubtest,fldreport,fldid,fldtestid,fldtanswertype from tblpatlabsubtest where fldtestid=&1 and fldchk=&2 and fldsave=&3" & GetReportOrder("SubTest"), GridView1[i, 0].Text, True, True)
            If res.Available = True Then
              For Each res
                If res!fldtanswertype = "Multiple Selection" Then
                  xquali = modLabTest.GetSubTestTableReportString(res!fldtestid, res!fldid, False)
                Else If res!fldtanswertype = "Text Table" Then
                  xquali = modLabTest.GetSubTestTableReportString(res!fldtestid, res!fldid, True)
                Else If res!fldtanswertype = "Dual Columns" Then
                  xquali = modLabTest.GetSubTestDualTableString(res!fldtestid, res!fldid, True)
                Else If res!fldtanswertype = "Single Column" Then
                  xquali = modLabTest.GetSubTestTableReportString(res!fldtestid, res!fldid, True)
                Else If res!fldtanswertype = "Drug Sensitivity" Then
                  xquali = modLabTest.GetSubSensiTableReportString(res!fldtanswertype, res!fldtestid, res!fldid, True)
                Else
                  xquali = res!fldreport
                Endif

                If xquali Then
                  With asx
                    If rbform1.Value = True Then
                      aa = modString.HTMLBlankSpace(4) & res!fldsubtest
                      yrefstr = modFixLab.GetSubLatTestQualiReference(modLabTest.GetTestnameFromTestID(GridView1[i, 0].Text), res!fldsubtest)
                      If yrefstr Then
                        bb = xquali & gb.NewLine & " [" & yrefstr & " ]"
                      Else
                        bb = xquali
                      Endif
                      .Add(aa)
                      If xspecolm = "Specimen" Then
                        .Add("")
                      Else If xspecolm = "Comment" Then
                        .Add("")
                      Endif
                      .Add(bb)

                    Else If rbform3.Value = True Then
                      aa = res!fldsubtest
                      yrefstr = modFixLab.GetSubLatTestQualiReference(modLabTest.GetTestnameFromTestID(GridView1[i, 0].Text), res!fldsubtest)
                      If yrefstr Then
                        bb = xquali & gb.NewLine & " [" & yrefstr & " ]"
                      Else
                        bb = xquali
                      Endif
                      .Add(modString.GetFormatTextFontString(aa, col1Font) & "<br>" & modString.GetFormatTextFontString(bb, col2Font))

                    Else If rbform4.Value = True Then
                      aa = modString.HTMLBlankSpace(4) & res!fldsubtest
                      bb = xquali
                      cc = modFixLab.GetSubLatTestQualiReference(modLabTest.GetTestnameFromTestID(GridView1[i, 0].Text), res!fldsubtest)
                      dd = ""
                      .Add(aa)
                      If xspecolm = "Specimen" Then
                        .Add("")
                      Else If xspecolm = "Comment" Then
                        .Add("")
                      Endif
                      .Add(bb)
                      .Add(cc)
                      .Add(dd)

                    Else
                      aa = modString.HTMLBlankSpace(4) & res!fldsubtest
                      bb = xquali
                      cc = modFixLab.GetSubLatTestQualiReference(modLabTest.GetTestnameFromTestID(GridView1[i, 0].Text), res!fldsubtest)
                      .Add(aa)
                      If xspecolm = "Specimen" Then
                        .Add("")
                      Else If xspecolm = "Comment" Then
                        .Add("")
                      Endif
                      .Add(bb)
                      .Add(cc)

                    Endif
                  End With
                  $BillingReport.Add(asx)
                  asx.Clear()
                Endif

              Next
            Endif
          Endif

        Endif
      Next

      ''default footer
      $BillingReport.UserData.Add(txtcomment.RichText, "FooterSummary")
      repor = modSettings.ShowSettingFromFIle("Laboratory/Footer_ReportedBy")
      verif = modSettings.ShowSettingFromFIle("Laboratory/Footer_VerifiedBy")

      modReportVar.$FoottUser1 = ""
      modReportVar.$FoottUser2 = ""
      modReportVar.$FoottUser3 = ""

      If repor = "Column1" Then
        modReportVar.$FoottUser1 = modString.GetDistinctStringArray($reportedBy).Join(",")
      Else If repor = "Column2" Then
        modReportVar.$FoottUser2 = modString.GetDistinctStringArray($reportedBy).Join(",")
      Else If repor = "Column3" Then
        modReportVar.$FoottUser3 = modString.GetDistinctStringArray($reportedBy).Join(",")
      Endif

      If verif = "Column1" Then
        modReportVar.$FoottUser1 = modString.GetDistinctStringArray($verifiedBy).Join(",")
      Else If verif = "Column2" Then
        modReportVar.$FoottUser2 = modString.GetDistinctStringArray($verifiedBy).Join(",")
      Else If verif = "Column3" Then
        modReportVar.$FoottUser3 = modString.GetDistinctStringArray($verifiedBy).Join(",")
      Endif

      ''header
      $BillingReport.UserData.Add("", "EXTRA1")
      $BillingReport.UserData.Add("", "EXTRA2")
      $BillingReport.UserData.Add("", "EXTRA3")
      $BillingReport.UserData.Add("", "EXTRA4")
      $BillingReport.UserData.Add("", "EXTRA5")
      $BillingReport.UserData.Add("", "EXTRA6")

      xexlabel = modSettings.ShowSettingFromFIle("Laboratory/Show_ExtraLabel")
      If xexlabel = "Yes" Then
        If modLabTest.GetColumnName("SampleDate") Then
          $BillingReport.UserData.Add("Sampling Date: " & modString.GetDistinctStringArray($sampleDate).Join(","), modLabTest.GetColumnName("SampleDate"))
        Endif
        If modLabTest.GetColumnName("ReportDate") Then
          $BillingReport.UserData.Add("Reporting Date: " & modString.GetDistinctStringArray($ReportDate).Join(","), modLabTest.GetColumnName("ReportDate"))
        Endif
        If modLabTest.GetColumnName("SampleID") Then
          $BillingReport.UserData.Add("Sample No: " & modString.GetDistinctStringArray($sampleID).Join(","), modLabTest.GetColumnName("SampleID"))
        Endif
        If modLabTest.GetColumnName("Specimen") Then
          $BillingReport.UserData.Add("Specimen: " & modString.GetDistinctStringArray($sampleType).Join(","), modLabTest.GetColumnName("Specimen"))
        Endif
        If modLabTest.GetColumnName("ReferBy") Then
          $BillingReport.UserData.Add("Reffered By: " & modString.GetDistinctStringArray($referName).Join(","), modLabTest.GetColumnName("ReferBy"))
        Endif
        If modLabTest.GetColumnName("Condition") Then
          $BillingReport.UserData.Add("Clinical Note: " & modString.GetDistinctStringArray($condiName).Join(","), modLabTest.GetColumnName("Condition"))
        Endif

      Else
        If modLabTest.GetColumnName("SampleDate") Then
          $BillingReport.UserData.Add(modString.GetDistinctStringArray($sampleDate).Join(","), modLabTest.GetColumnName("SampleDate"))
        Endif
        If modLabTest.GetColumnName("ReportDate") Then
          $BillingReport.UserData.Add(modString.GetDistinctStringArray($ReportDate).Join(","), modLabTest.GetColumnName("ReportDate"))
        Endif
        If modLabTest.GetColumnName("Specimen") Then
          $BillingReport.UserData.Add(modString.GetDistinctStringArray($sampleType).Join(","), modLabTest.GetColumnName("Specimen"))
        Endif
        If modLabTest.GetColumnName("SampleID") Then
          $BillingReport.UserData.Add(modString.GetDistinctStringArray($sampleID).Join(","), modLabTest.GetColumnName("SampleID"))
        Endif
        If modLabTest.GetColumnName("ReferBy") Then
          $BillingReport.UserData.Add(modString.GetDistinctStringArray($referName).Join(","), modLabTest.GetColumnName("ReferBy"))
        Endif
        If modLabTest.GetColumnName("Condition") Then
          $BillingReport.UserData.Add(modString.GetDistinctStringArray($condiName).Join(","), modLabTest.GetColumnName("Condition"))
        Endif

      Endif
      Dec Application.Busy

      ''final print
      If sType = "Report" Then
        modPrint.OpenHTMLPreview($encid, $BillingReport.NewHTMLPath(), "ReportSize")
      Else If sType = "FTP" Then
        SendFTPSMS($BillingReport.NewHTMLPath())
      Else If sType = "Save" Then
        SaveReportAsHTML($BillingReport.NewHTMLPath())
      Endif
    Next

  Else
    ''=========== For combined Report ============
    $BillingReport.UserData.Add("SECTION", "Report")
    $BillingReport.UserData.Add(newCateg.Join(";"), "PARAM1")

    $reportedBy = New String[]
    $verifiedBy = New String[]
    $referName = New String[]
    $condiName = New String[]
    $sampleID = New String[]
    $sampleType = New String[]
    $sampleDate = New String[]
    $ReportDate = New String[]

    dtcont = modSettings.ShowSettingFromFIle("Laboratory/DateContent")
    For Each xx In newCateg
      $BillingReport.AddSection(xx, True)

      For i = 0 To GridView1.Rows.Count - 1
        If GridView1[i, 1].Picture = modBasic.$PictureChecked And If GridView1[i, 24].Text = xx Then
          $reportedBy.Add(GridView1[i, 13].Text)
          $verifiedBy.Add(GridView1[i, 14].Text)
          $referName.Add(GridView1[i, 15].Text)
          $condiName.Add(GridView1[i, 16].Text)
          $sampleID.Add(GridView1[i, 17].Text)
          $sampleType.Add(GridView1[i, 18].Text)
          If dtcont = "DateTime" Then
            $sampleDate.Add(modReportVar.GetDateTimeReport(GridView1[i, 19].Text, gb.GeneralDate))
            $ReportDate.Add(modReportVar.GetDateTimeReport(GridView1[i, 20].Text, gb.GeneralDate))
          Else
            $sampleDate.Add(modReportVar.GetDateTimeReport(GridView1[i, 19].Text, gb.MediumDate))
            $ReportDate.Add(modReportVar.GetDateTimeReport(GridView1[i, 20].Text, gb.MediumDate))
          Endif

          With asx
            If rbimage.Value = True Then
              aa = modLabTest.GetTestnameFromTestID(GridView1[i, 0].Text)
              If GridView1[i, 3].Text = "Quantitative" Then
                xrefstr = modLabTest.TestInterpretByTestID(GridView1[i, 0].Text)
                If xintrp = "Yes" And If xrefstr Then
                  bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True) & " [" & modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt) & "]" & gb.NewLine & "RESULT :" & xrefstr
                Else
                  bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True) & " [" & modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt) & "]"
                Endif
              Else If GridView1[i, 3].Text = "Qualitative" Then
                xrefstr = modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt)
                If xrefstr Then
                  bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True) & " [" & xrefstr & "]"
                Else
                  bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True)
                Endif
              Endif
              .Add(aa)
              If xspecolm = "Specimen" Then
                .Add(GridView1[i, 18].Text)
              Else If xspecolm = "Comment" Then
                .Add(GridView1[i, 25].Text)
              Endif
              .Add(bb)
              .Add(modString.GetImageListForHTML(modImage.ShowTestExamImagePathList("Test", GridView1[i, 0].Text, $encid)))

            Else
              If rbform1.Value = True Then
                aa = modLabTest.GetTestnameFromTestID(GridView1[i, 0].Text)
                If GridView1[i, 3].Text = "Quantitative" Then
                  xrefstr = modLabTest.TestInterpretByTestID(GridView1[i, 0].Text)
                  If xintrp = "Yes" And If xrefstr Then
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True) & " [" & modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt) & "]" & gb.NewLine & "RESULT :" & xrefstr
                  Else
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True) & " [" & modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt) & "]"
                  Endif
                Else If GridView1[i, 3].Text = "Qualitative" Then
                  xrefstr = modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt)
                  If xrefstr Then
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True) & " [" & xrefstr & "]"
                  Else
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True)
                  Endif
                Endif
                .Add(aa)
                If xspecolm = "Specimen" Then
                  .Add(GridView1[i, 18].Text)
                Else If xspecolm = "Comment" Then
                  .Add(GridView1[i, 25].Text)
                Endif
                .Add(bb)

              Else If rbform3.Value = True Then
                aa = modLabTest.GetTestnameFromTestID(GridView1[i, 0].Text)
                If GridView1[i, 3].Text = "Quantitative" Then
                  xrefstr = modLabTest.TestInterpretByTestID(GridView1[i, 0].Text)
                  If xintrp = "Yes" And If xrefstr Then
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True) & " [" & modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt) & "]" & gb.NewLine & "RESULT :" & xrefstr
                  Else
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True) & " [" & modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt) & "]"
                  Endif
                Else If GridView1[i, 3].Text = "Qualitative" Then
                  xrefstr = modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt)
                  If xrefstr Then
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True) & " [" & xrefstr & "]"
                  Else
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True)
                  Endif
                Endif
                If xspecolm = "Specimen" Then
                  .Add(modString.GetFormatTextFontString(aa & " [" & GridView1[i, 18].Text & "]", col1Font) & "<br>" & modString.GetFormatTextFontString(bb, col2Font))
                Else If xspecolm = "Comment" Then
                  .Add(modString.GetFormatTextFontString(aa & " [" & GridView1[i, 25].Text & "]", col1Font) & "<br>" & modString.GetFormatTextFontString(bb, col2Font))
                Else
                  .Add(modString.GetFormatTextFontString(aa, col1Font) & "<br>" & modString.GetFormatTextFontString(bb, col2Font))
                Endif

              Else If rbform4.Value = True Then
                aa = modLabTest.GetTestnameFromTestID(GridView1[i, 0].Text)
                dd = modLabTest.GetTestMethodLabID(GridView1[i, 0].Text)
                If GridView1[i, 3].Text = "Quantitative" Then
                  xrefstr = modLabTest.TestInterpretByTestID(GridView1[i, 0].Text)
                  If xintrp = "Yes" And If xrefstr Then
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True) & gb.NewLine & "RESULT :" & xrefstr
                  Else
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True)
                  Endif
                  cc = modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt)
                Else If GridView1[i, 3].Text = "Qualitative" Then
                  bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True)
                  cc = modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt)
                Endif
                .Add(aa)
                If xspecolm = "Specimen" Then
                  .Add(GridView1[i, 18].Text)
                Else If xspecolm = "Comment" Then
                  .Add(GridView1[i, 25].Text)
                Endif
                .Add(bb)
                .Add(cc)
                .Add(dd)

              Else
                aa = modLabTest.GetTestnameFromTestID(GridView1[i, 0].Text)
                If GridView1[i, 3].Text = "Quantitative" Then
                  xrefstr = modLabTest.TestInterpretByTestID(GridView1[i, 0].Text)
                  If xintrp = "Yes" And If xrefstr Then
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True) & gb.NewLine & "RESULT :" & xrefstr
                  Else
                    bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True)
                  Endif
                  cc = modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt)
                Else If GridView1[i, 3].Text = "Qualitative" Then
                  bb = modLabTest.GetLabTestValueGridString(GridView1[i, 0].Text, unt, True)
                  cc = modLabTest.GetTestLimitSrting(GridView1[i, 0].Text, unt)
                Endif
                .Add(aa)
                If xspecolm = "Specimen" Then
                  .Add(GridView1[i, 18].Text)
                Else If xspecolm = "Comment" Then
                  .Add(GridView1[i, 25].Text)
                Endif
                .Add(bb)
                .Add(cc)

              Endif
            Endif
          End With
          $BillingReport.Add(asx)
          asx.Clear()

          If GridView1[i, 3].Text = "Qualitative" Then
            If SensiFormat() = "Summary" Then
              $SensTable.Add(modLabTest.GetSensitivityTable($encid, GridView1[i, 0].Text))
            Endif

            res = modDatabase.$myConn.Exec("select fldsubtest,fldreport,fldid,fldtestid,fldtanswertype from tblpatlabsubtest where fldtestid=&1 and fldchk=&2 and fldsave=&3" & GetReportOrder("SubTest"), GridView1[i, 0].Text, True, True)
            If res.Available = True Then
              For Each res
                If res!fldtanswertype = "Multiple Selection" Then
                  xquali = modLabTest.GetSubTestTableReportString(res!fldtestid, res!fldid, False)
                Else If res!fldtanswertype = "Text Table" Then
                  xquali = modLabTest.GetSubTestTableReportString(res!fldtestid, res!fldid, True)
                Else If res!fldtanswertype = "Dual Columns" Then
                  xquali = modLabTest.GetSubTestDualTableString(res!fldtestid, res!fldid, True)
                Else If res!fldtanswertype = "Single Column" Then
                  xquali = modLabTest.GetSubTestTableReportString(res!fldtestid, res!fldid, True)
                Else If res!fldtanswertype = "Drug Sensitivity" Then
                  If SensiFormat() = "Table" Then
                    xquali = modLabTest.GetSubSensiTableReportString(res!fldtanswertype, res!fldtestid, res!fldid, True)
                  Endif
                Else
                  xquali = res!fldreport
                Endif

                If xquali Then
                  With asx
                    If rbform1.Value = True Then
                      aa = modString.HTMLBlankSpace(4) & res!fldsubtest
                      yrefstr = modFixLab.GetSubLatTestQualiReference(modLabTest.GetTestnameFromTestID(GridView1[i, 0].Text), res!fldsubtest)
                      If yrefstr Then
                        bb = xquali & gb.NewLine & " [" & yrefstr & " ]"
                      Else
                        bb = xquali
                      Endif
                      .Add(aa)
                      If xspecolm = "Specimen" Then
                        .Add("")
                      Else If xspecolm = "Comment" Then
                        .Add("")
                      Endif
                      .Add(bb)

                    Else If rbform3.Value = True Then
                      aa = res!fldsubtest
                      yrefstr = modFixLab.GetSubLatTestQualiReference(modLabTest.GetTestnameFromTestID(GridView1[i, 0].Text), res!fldsubtest)
                      If yrefstr Then
                        bb = xquali & gb.NewLine & " [" & yrefstr & " ]"
                      Else
                        bb = xquali
                      Endif
                      .Add(modString.GetFormatTextFontString(aa, col1Font) & "<br>" & modString.GetFormatTextFontString(bb, col2Font))

                    Else If rbform4.Value = True Then
                      aa = modString.HTMLBlankSpace(4) & res!fldsubtest
                      bb = xquali
                      cc = modFixLab.GetSubLatTestQualiReference(modLabTest.GetTestnameFromTestID(GridView1[i, 0].Text), res!fldsubtest)
                      dd = ""
                      .Add(aa)
                      If xspecolm = "Specimen" Then
                        .Add("")
                      Else If xspecolm = "Comment" Then
                        .Add("")
                      Endif
                      .Add(bb)
                      .Add(cc)
                      .Add(dd)

                    Else
                      aa = modString.HTMLBlankSpace(4) & res!fldsubtest
                      bb = xquali
                      cc = modFixLab.GetSubLatTestQualiReference(modLabTest.GetTestnameFromTestID(GridView1[i, 0].Text), res!fldsubtest)
                      .Add(aa)
                      If xspecolm = "Specimen" Then
                        .Add("")
                      Else If xspecolm = "Comment" Then
                        .Add("")
                      Endif
                      .Add(bb)
                      .Add(cc)

                    Endif
                  End With
                  $BillingReport.Add(asx)
                  asx.Clear()
                Endif

              Next
            Endif
          Endif

        Endif
      Next

    Next

    ''default footer
    If SensiFormat() = "Summary" Then
      $BillingReport.UserData.Add($SensTable.Join(gb.NewLine) & gb.NewLine & txtcomment.RichText, "FooterSummary")
    Else
      $BillingReport.UserData.Add(txtcomment.RichText, "FooterSummary")
    Endif
    repor = modSettings.ShowSettingFromFIle("Laboratory/Footer_ReportedBy")
    verif = modSettings.ShowSettingFromFIle("Laboratory/Footer_VerifiedBy")

    modReportVar.$FoottUser1 = ""
    modReportVar.$FoottUser2 = ""
    modReportVar.$FoottUser3 = ""

    If repor = "Column1" Then
      modReportVar.$FoottUser1 = modString.GetDistinctStringArray($reportedBy).Join(",")
    Else If repor = "Column2" Then
      modReportVar.$FoottUser2 = modString.GetDistinctStringArray($reportedBy).Join(",")
    Else If repor = "Column3" Then
      modReportVar.$FoottUser3 = modString.GetDistinctStringArray($reportedBy).Join(",")
    Endif

    If verif = "Column1" Then
      modReportVar.$FoottUser1 = modString.GetDistinctStringArray($verifiedBy).Join(",")
    Else If verif = "Column2" Then
      modReportVar.$FoottUser2 = modString.GetDistinctStringArray($verifiedBy).Join(",")
    Else If verif = "Column3" Then
      modReportVar.$FoottUser3 = modString.GetDistinctStringArray($verifiedBy).Join(",")
    Endif

    ''header
    $BillingReport.UserData.Add("", "EXTRA1")
    $BillingReport.UserData.Add("", "EXTRA2")
    $BillingReport.UserData.Add("", "EXTRA3")
    $BillingReport.UserData.Add("", "EXTRA4")
    $BillingReport.UserData.Add("", "EXTRA5")
    $BillingReport.UserData.Add("", "EXTRA6")

    xexlabel = modSettings.ShowSettingFromFIle("Laboratory/Show_ExtraLabel")
    If xexlabel = "Yes" Then
      If modLabTest.GetColumnName("SampleDate") Then
        $BillingReport.UserData.Add("Sampling Date: " & modString.GetDistinctStringArray($sampleDate).Join(","), modLabTest.GetColumnName("SampleDate"))
      Endif
      If modLabTest.GetColumnName("ReportDate") Then
        $BillingReport.UserData.Add("Reporting Date: " & modString.GetDistinctStringArray($ReportDate).Join(","), modLabTest.GetColumnName("ReportDate"))
      Endif
      If modLabTest.GetColumnName("SampleID") Then
        $BillingReport.UserData.Add("Sample No: " & modString.GetDistinctStringArray($sampleID).Join(","), modLabTest.GetColumnName("SampleID"))
      Endif
      If modLabTest.GetColumnName("Specimen") Then
        $BillingReport.UserData.Add("Specimen: " & modString.GetDistinctStringArray($sampleType).Join(","), modLabTest.GetColumnName("Specimen"))
      Endif
      If modLabTest.GetColumnName("ReferBy") Then
        $BillingReport.UserData.Add("Reffered By: " & modString.GetDistinctStringArray($referName).Join(","), modLabTest.GetColumnName("ReferBy"))
      Endif
      If modLabTest.GetColumnName("Condition") Then
        $BillingReport.UserData.Add("Clinical Note: " & modString.GetDistinctStringArray($condiName).Join(","), modLabTest.GetColumnName("Condition"))
      Endif

    Else
      If modLabTest.GetColumnName("SampleDate") Then
        $BillingReport.UserData.Add(modString.GetDistinctStringArray($sampleDate).Join(","), modLabTest.GetColumnName("SampleDate"))
      Endif
      If modLabTest.GetColumnName("ReportDate") Then
        $BillingReport.UserData.Add(modString.GetDistinctStringArray($ReportDate).Join(","), modLabTest.GetColumnName("ReportDate"))
      Endif
      If modLabTest.GetColumnName("Specimen") Then
        $BillingReport.UserData.Add(modString.GetDistinctStringArray($sampleType).Join(","), modLabTest.GetColumnName("Specimen"))
      Endif
      If modLabTest.GetColumnName("SampleID") Then
        $BillingReport.UserData.Add(modString.GetDistinctStringArray($sampleID).Join(","), modLabTest.GetColumnName("SampleID"))
      Endif
      If modLabTest.GetColumnName("ReferBy") Then
        $BillingReport.UserData.Add(modString.GetDistinctStringArray($referName).Join(","), modLabTest.GetColumnName("ReferBy"))
      Endif
      If modLabTest.GetColumnName("Condition") Then
        $BillingReport.UserData.Add(modString.GetDistinctStringArray($condiName).Join(","), modLabTest.GetColumnName("Condition"))
      Endif

    Endif
    Dec Application.Busy

    ''final print
    If sType = "Report" Then
      modPrint.OpenHTMLPreview($encid, $BillingReport.NewHTMLPath(), "ReportSize")
    Else If sType = "FTP" Then
      SendFTPSMS($BillingReport.NewHTMLPath())
    Else If sType = "Save" Then
      SaveReportAsHTML($BillingReport.NewHTMLPath())
    Endif

  Endif   ''if combined or separate

End

Private Sub SaveReportAsHTML(sHTML As String)

  Dim xx As String
  Dim sType As String
  Dim sPath As String
  Dim sInt As String

  sInt = modString.GetNowString()
  sPath = modPrint.ConvertHTMLToPDFString(sHTML, "ReportSize", sInt)
  sType = "Diagnostic Tests"
  xx = InputBox(("Title of Report"), sType, cmbcategory.Text)
  modImage.SavePatientDataForGeneral($encid, sType, xx, sPath)
  SendSMSPatient("")

End

Private Sub SendSMSPatient(sInt As String)

  Dim sText As String
  Dim phno As String

  If modSettings.ShowSettingFromFIle("Laboratory/Patient_EnableSMS") = "Yes" Then
    sText = modSettings.ShowSettingFromFIle("Laboratory/Patient_SMSText") & " Report No: " & sInt
    phno = modPatient.GetPatientContactByEnc($encid)
    If phno Then
      If sText Then

        sText = modReportVar.GetReportVarPatient($encid, sText)
        sText = modReportVar.GetReportVarEncounter($encid, sText)
        modGeneralMain.SaveSMSEntry(phno, sText)

      Endif
    Endif
  Endif

End

Private Sub SendFTPSMS(sHTML As String)

  Dim sPath As String
  Dim sInt As String

  If Desktop.NetworkAvailable = True Then

    sInt = modString.GetNowString()
    sPath = modPrint.ConvertHTMLToPDFString(sHTML, "ReportSize", sInt)

    Inc Application.Busy
    modDevice.SendFileToRemoteFTP(sPath)
    SendSMSPatient(sInt)
    If modBasic.$ReportLogFTP = "Yes" Then
      modImage.SaveReportLog("FTP", sPath)
    Endif
    Dec Application.Busy

  Endif

End

Public Sub btnreport_Click()

  If txtencid.Text Then
    If modNonMedical.AllowEntryWithDeposit($encid, "Test") = True
      MarkPrintedSelected()
      ShowPatLaboratoryReport("Report")
      FillLabtable()
    Endif
  Endif

End

Public Sub btnrecord_Click()

  If txtencid.Text Then
    If modNonMedical.AllowEntryWithDeposit($encid, "Test") = True
      MarkPrintedSelected()
      ShowPatLaboratoryReport("Save")
      FillLabtable()
    Endif
  Endif

End

Public Sub btnftp_Click()

  If txtencid.Text Then
    If modNonMedical.AllowEntryWithDeposit($encid, "Test") = True
      MarkPrintedSelected()
      ShowPatLaboratoryReport("FTP")
      FillLabtable()
    Endif
  Endif

End

Private Sub MarkPrintedSelected()

  Dim i As Integer
  Dim res As Result

  If chkmark.Value = True Then
    For i = 0 To GridView1.Rows.Count - 1
      If GridView1[i, 1].Picture = modBasic.$PictureChecked
        res = modDatabase.$myConn.Edit("tblpatlabtest", "fldid=&1", GridView1[i, 0].Text)
        res["fldprint"] = True
        res["xyz"] = False
        res.Update
      Endif
    Next
  Endif

End

Public Sub GridView1_Menu()

  mnuhide.Popup

End

Public Sub mnuselall_Click()

  Dim i As Integer
  Dim res As Result

  Inc Application.Busy
  SHowQualiSUbTest(0) ''false grid to make grid empty
  For i = 0 To GridView1.Rows.Count - 1
    GridView1[i, 1].Picture = modBasic.$PictureChecked
    res = modDatabase.$myConn.Edit("tblpatlabsubtest", "fldtestid=&1", GridView1[i, 0].Text)
    If res.Available = True Then
      GridView1[i, 2].Picture = modBasic.$PictureChecked
      For Each res
        res["fldchk"] = True
        res["xyz"] = False
        res.Update
      Next
    Endif
  Next
  EnableButton(True)
  Dec Application.Busy

End

Public Sub mnudselal_Click()

  Dim i As Integer
  Dim res As Result

  Inc Application.Busy
  SHowQualiSUbTest(0) ''false grid to make grid empty
  For i = 0 To GridView1.Rows.Count - 1
    GridView1[i, 1].Picture = modBasic.$PictureUnchecked
    res = modDatabase.$myConn.Edit("tblpatlabsubtest", "fldtestid=&1", GridView1[i, 0].Text)
    If res.Available = True Then
      GridView1[i, 2].Picture = modBasic.$PictureUnchecked
      For Each res
        res["fldchk"] = False
        res["xyz"] = False
        res.Update
      Next
    Endif
  Next
  EnableButton(False)
  Dec Application.Busy

End

Public Sub mnureport_Click()

  Dim xx As String

  If GridView1.Rows.Selection.Count > 0 Then
    xx = GetRichTextArea(GridView1[GridView1.Row, 4].Text, modLabTest.GetLabTestValueSubString(GridView1[GridView1.Row, 0].Text, modLabTest.GetTestUnitFromButton(rbsi, rbmetric)))
  Endif

End

Public Sub btnsearch_Click()

  txtencid.Text = PatSearch("Encounter")

End

Public Sub btnorder_Click()

  Dim categ As String[]
  Dim i As Integer

  categ = New String[]
  For i = 0 To GridView1.Rows.Count - 1
    If GridView1[i, 1].Picture = modBasic.$PictureChecked Then
      categ.Add(GridView1[i, 24].Text)
    Endif
  Next

  $CategList = ListOrder(("Reorder Items"), modString.GetDistinctStringArray(categ))

End

Public Sub btnfootlist_Click()

  Dim xlst As String[]
  Dim i As Integer
  Dim xx As String
  Dim xlink As String
  Dim sText As String[]

  xlst = SelectListView(("Select Foot Notes"), modLabTest.ListFooterNoteList(), False)
  If xlst Then
    sText = New String[]
    For i = 1 To 50
      xx = modSettings.ShowSettingFromFIle("FooterNote/Name_" & CStr(i))
      If xlst.Exist(xx) Then
        xlink = modSettings.ShowSettingFromFIle("FooterNote/Link_" & CStr(i))
        If Exist(xlink) Then
          sText.Add(File.Load(xlink))
        Endif
      Endif
    Next
    txtcomment.RichText = sText.Join(gb.NewLine & "<br>")
  Endif

End

Public Sub cmbfootest_Click()

  If cmbfootest.Text Then
    If txtcomment.Text Then
      txtcomment.Text = txtcomment.Text & gb.NewLine & modFixLab.GetLabToolTip(cmbfootest.Text)
    Else
      txtcomment.Text = modFixLab.GetLabToolTip(cmbfootest.Text)
    Endif
  Endif

End

Public Sub txtencid_KeyPress()

  If Key.Code = Key.Down Then
    If modBasic.$AutoEncSuffix = "Yes" Then
      txtencid.Text = txtencid.Text & modBasic.$HospCode
    Endif
  Else
    modGeneralMain.InputUpCaseOnly()
  Endif

End
