' Gambas class file

Private $rData As Result
Private $aMyFields As String[]

Private $encid As String
Private $TestID As Long
Private $CategList As String[]
Private $SensTable As String[]

Public Sub _new(encid As String)

  txtencid.Text = encid

End

Public Sub Form_Open()

  modGeneralMain.ArrangeEmbedForms(Me, Panel1, "Vertical")
  Me.Icon = Picture[modGeneralMain.$strLogo]
  cmbcategory.List = modMedicine.GetPathoCategoryList("Test")
  cmbcategory.Add("%")
  cmbcategory.Text = modSettings.ShowSettingFromFIle("Laboratory/DefaultDepartment")

  modLabTest.DisplayDefaultTestUnit(rbsi, rbmetric)
  DefaultTestReportFormat()
  DisplayDefaultViewID()
  modSettings.ShowCheckBox(chknew, "TestReportFormat/NewItems")
  modSettings.ShowCheckBox(chkprinted, "TestReportFormat/PrintedItems")
  modSettings.ShowCheckBox(chkmark, "TestReportFormat/MarkPrinted")
  modMisc.LockReportOutput(rbreported, rbverified, Panel3)

  rbtext.Value = True
  dtfrom.Value = modDate.StartSqlDate(Now())
  dtto.Value = modDate.EndSqlDate(Now())
  DateSelectionSett()
  txtencid.SetFocus

End

Public Sub Form_Close()

  modSettings.SaveSettingsToFile("Laboratory/DefaultDepartment", cmbcategory.Text)
  modGeneralMain.RecordFormExit(Me)

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub Form_Activate()

  If Not txtencid.Text Then
    txtencid.SetFocus
  Endif

End

Public Sub Form_KeyRelease()

  If Key.Code = Key["F"] And If Key.Control Then
    txtencid.Text = GetEncid()
  Else If Key.Code = Key["X"] And If Key.Control Then
    Me.Close()
  Endif

End

Public Sub chknew_Click()

  modSettings.EnterCheckSetting(chknew, "TestReportFormat/NewItems")

End

Public Sub chkprinted_Click()

  modSettings.EnterCheckSetting(chkprinted, "TestReportFormat/PrintedItems")

End

Public Sub chkmark_Click()

  modSettings.EnterCheckSetting(chkmark, "TestReportFormat/MarkPrinted")

End

Private Sub EnableButton(sval As Boolean)

  If sval = True Then
    btnrecord.Enabled = True
    btnftp.Enabled = True
    btnreport.Enabled = True
  Else If sval = False Then
    btnrecord.Enabled = False
    btnftp.Enabled = False
    btnreport.Enabled = False
  Endif

End

Private Sub EnableSelected()

  Dim sval As Integer
  Dim i As Integer

  sval = 0
  For i = 0 To GridView1.Rows.Count - 1
    If GridView1[i, 1].Picture = modBasic.$PictureChecked Then
      sval = sval + 1
    Endif
  Next
  If sval Then
    EnableButton(True)
  Else
    EnableButton(False)
  Endif

End

Private Sub DefaultTestReportFormat()

  Dim def As String

  def = modSettings.ShowSettingFromFIle("TestReportFormat/Format")
  If def Then
    If def = "A" Then
      rbform1.Value = True
    Else If def = "B" Then
      rbform2.Value = True
    Else If def = "C" Then
      rbform3.Value = True
    Else If def = "D" Then
      rbform4.Value = True
    Endif
  Else
    rbform2.Value = True
  Endif

End

Private Sub DisplayDefaultViewID()

  Dim def As String

  def = modSettings.ShowSettingFromFIle("TestReportFormat/ViewID")
  If def Then
    If def = "Encounter" Then
      rbencounter.Value = True
    Else If def = "Sample" Then
      rbsample.Value = True
    Endif
  Else
    rbencounter.Value = True
  Endif

End

Public Sub rbencounter_Click()

  modSettings.SaveSettingsToFile("TestReportFormat/ViewID", "Encounter")

End

Public Sub rbsample_Click()

  modSettings.SaveSettingsToFile("TestReportFormat/ViewID", "Sample")

End

Public Sub rbsi_Click()

  modSettings.SaveSettingsToFile("TestUnit/Default", "SI")

End

Public Sub rbmetric_Click()

  modSettings.SaveSettingsToFile("TestUnit/Default", "Metric")

End

Public Sub rbform1_Click()

  modSettings.SaveSettingsToFile("TestReportFormat/Format", "A")

End

Public Sub rbform2_Click()

  modSettings.SaveSettingsToFile("TestReportFormat/Format", "B")

End

Public Sub rbform3_Click()

  modSettings.SaveSettingsToFile("TestReportFormat/Format", "C")

End

Public Sub rbform4_Click()

  modSettings.SaveSettingsToFile("TestReportFormat/Format", "D")

End

Public Sub btnshow_Click()

  If txtencid.Text And If cmbcategory.Text Then
    If rbencounter.Value = True Then
      $encid = Trim(txtencid.Text)
    Else If rbsample.Value = True Then
      $encid = modLabTest.GetEncounterFromSampleID(txtencid.Text)
    Endif
    txtpatientname.Text = modPatient.GetPatientNameByEnc($encid)
    txtgender.Text = modPatient.GetPatientAgeString($encid, Now()) & "/" & modPatient.GetPatientSex($encid)
    txtpatientcontact.Text = modPatient.GetLocationSetting($encid)
    modGeneralMain.RecordPatientActivity("Patient Data", Me.Name, "EncounterID", $encid)
    $CategList = New String[]
    If modPatient.AllowEncIDHistory($encid, modDatabase.$myConn) = True Then
      FillLabtable()
      txtcomment.Text = ""
      GridView1.SetFocus
    Else
      Me.Enabled = False
    Endif
  Endif

End

Private Function GetReportOrder(sType As String) As String

  Dim xx As String
  Dim xorder As String

  xorder = modSettings.ShowSettingFromFIle("Laboratory/Report_Order")
  If xorder = "ASC" Then
    If sType = "Test" Then
      xx = " ORDER BY fldtestid ASC"
    Else If sType = "SubTest" Then
      xx = " ORDER BY fldsubtest ASC"
    Endif
  Else If xorder = "DESC" Then
    If sType = "Test" Then
      xx = " ORDER BY fldtestid DESC"
    Else If sType = "SubTest" Then
      xx = " ORDER BY fldsubtest DESC"
    Endif
  Else If xorder = "Manual" Then
    If sType = "Test" Then
      xx = " ORDER BY fldorder ASC"
    Else If sType = "SubTest" Then
      xx = " ORDER BY fldorder ASC"
    Endif
  Else
    If sType = "Test" Then
      xx = ""
    Else If sType = "SubTest" Then
      xx = ""
    Endif
  Endif

  Return xx

End

Private Sub DateSelectionSett()

  If chkdate.Value = True Then
    Panel9.Enabled = True
  Else
    Panel9.Enabled = False
  Endif

End

Public Sub chkdate_Click()

  DateSelectionSett()

End

Private Sub FillLabtable()

  Dim reprt As String
  Dim vrfd As String
  Dim sprt As Boolean

