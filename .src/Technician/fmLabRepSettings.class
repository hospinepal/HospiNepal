    vrfd = "Verified"
    reprt = "Verified"
  Endif

  If chkdate.Value = True Then
    If chknew.Value And If chkprinted.Value Then
      If cmbcategory.Text = "%" Then
        If rbencounter.Value = True Then
          $rData = modDatabase.$myConn.Exec("select fldid,fldchk,fldsave_report,fldtest_type,fldtestid,fldsampletype,fldsampleid,fldtime_sample,fldabnormal,fldid,fldid,fldstatus,flduserid_sample,flduserid_report,flduserid_verify,fldrefername,fldcondition,fldsampleid,fldsampletype,fldtime_sample,fldtime_report,fldtime_report,fldprint,fldorder,fldtestid,fldcomment from tblpatlabtest where fldsave_report=&1 and fldencounterval=&2 and (fldstatus=&3 or fldstatus=&4) and flvisible=&5 and fldtime_sample>=&6 and fldtime_sample<=&7" & GetReportOrder("Test"), True, Trim(txtencid.Text), reprt, vrfd, "Visible", dtfrom.Value, dtto.Value)                                                   ''
