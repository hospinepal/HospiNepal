# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,117,64)
  Text = ("Patient Images")
  Resizable = False
  { dgimage GridView
    MoveScaled(1,5,38,58)
    Mode = Select.Single
    AutoResize = False
    Sorted = True
  }
  { ScrollView1 ScrollView
    MoveScaled(40,9,75,38)
    { PictureBox1 ImageView
      MoveScaled(1,1,73,36)
    }
  }
  { btnOpen Button
    MoveScaled(103,47,4,4)
    Picture = Picture["icon:/small/open"]
  }
  { btnwebcam Button
    MoveScaled(107,47,4,4)
    Picture = Picture["icon:/small/camera"]
  }
  { btnOK Button
    MoveScaled(99,51,16,4)
    Text = Shortcut(("Add"), "A")
    Picture = Picture["icon:/small/add"]
  }
  { btnChange Button
    MoveScaled(99,55,16,4)
    Text = Shortcut(("Edit"), "E")
    Picture = Picture["icon:/small/edit"]
  }
  { btnCancel Button
    MoveScaled(99,59,16,4)
    Text = ("Export")
    Picture = Picture["icon:/small/html"]
  }
  { lbltest Label
    MoveScaled(14,1,54,3)
    Border = Border.Plain
  }
  { lblobs Label
    MoveScaled(69,1,46,3)
    Border = Border.Plain
  }
  { txttitle TextBox
    MoveScaled(40,5,70,3.5333)
  }
  { txtdetail TextArea
    MoveScaled(40,56,58,7)
    Wrap = True
    ScrollBar = Scroll.Vertical
  }
  { btnplay Button
    MoveScaled(111,5,4,3.5333)
    Picture = Picture["icon:/small/play"]
  }
  { Slider1 Slider
    MoveScaled(40,48,58,3)
    MinValue = 1
    MaxValue = 1000
    Value = 100
  }
  { txtid ValueBox
    MoveScaled(1,1,12,3)
    Enabled = False
  }
  { Label1 Label
    MoveScaled(40,52,7,3)
    Text = ("Keys")
    Border = Border.Plain
  }
  { txtkeyword TextBox
    MoveScaled(48,52,50,3)
  }
  { btnpencil Button
    MoveScaled(111,47,4,4)
    Picture = Picture["icon:/small/pen"]
  }
  { btnscan Button
    MoveScaled(99,47,4,4)
    Picture = Picture["icon:/small/scanner"]
  }
}
