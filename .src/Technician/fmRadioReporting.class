' Gambas class file

Private $encid As String
Private $rData As Result

Private $rData2 As Result
Private $aMyFields2 As String[]

Private $rData3 As Result
Private $aMyFields3 As String[]
Private $rData4 As Result

Public Sub Form_Open()

  modGeneralMain.ArrangeEmbedForms(Me, Panel1, "Column")
  Me.Icon = Picture[modGeneralMain.$strLogo]
  btnimage.Menu = "mnuimage"
  cmbcategory.List = modMedicine.GetPathoCategoryList("Radio")
  cmbcategory.Text = modSettings.ShowSettingFromFIle("Radiology/DefaultDepartment")
  cmbcategorynew.List = modMedicine.GetPathoCategoryList("Radio")
  cmbcategorynew.Add("%")
  cmbcategorynew.Text = modSettings.ShowSettingFromFIle("Radiology/DefaultDepartment")
  dtsort.Value = Date()
  If modGlobalSetting.ShowSettingFromDB("GeneralSettings/Radiology_TestAddition") = "Yes" Then
    mnuaddtest.Enabled = True
    mnuaddgroup.Enabled = True
  Endif
  txtencid.SetFocus

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.F2 Then
    TabPanel1.Index = 0
  Else If Key.Code = Key.F3 Then
    TabPanel1.Index = 1
  Else If Key.Code = Key.F1 Then
    btnnewsearch_Click()
  Else If Key.Code = Key["O"] And If Key.Control Then
    btnwebcam_Click()
  Else If Key.Code = Key["F"] And If Key.Control Then
    txtencid.Text = GetEncid()
  Else If Key.Code = Key["B"] And If Key.Control Then
    Me.Close
    Wait
    modHelpVariable.AddNewFormToWorkspace(fmRadioReporting)
  Else If Key.Code = Key["R"] And If Key.Control Then
    If TabPanel1.Index = 0 Then
      btnnewrefresh_Click()
    Else If TabPanel1.Index = 1 Then
      btnrefresh_Click()
    Endif
  Else If Key.Code = Key["X"] And If Key.Control Then
    Me.Close()
  Endif

End

Public Sub Form_Close()

  modSettings.SaveSettingsToFile("Radiology/DefaultDepartment", cmbcategorynew.Text)
  modGeneralMain.RecordFormExit(Me)

End

Public Sub btnnewrefresh_Click()

  Inc Application.Busy
  FillNewSamplingEncounters()
  ShowNewEncounterTests("")
  Dec Application.Busy
  GridView3.SetFocus

End

''---------------------------- sample grids -------------------------
Public Sub btnnewsearch_Click()

  Dim enc As String

  If modBasic.$AutoEncPrefix = "Yes" Then
    enc = InputBox(("Encounter ID of Patient"), ("Search Patient"), modBasic.$EncIdPrefix)
  Else
    enc = InputBox(("Encounter ID of Patient"), ("Search Patient"), "")
  Endif
  If enc Then
    FillNewSamplingSelectedEncounter(Trim(enc))
  Endif

End

Private Sub FillNewSamplingEncounters()

  Dim sql As String
  Dim xcomp As String
  Dim xstr As String

  If modBasic.$LabSamplingComp Then
    xcomp = modBasic.$LabSamplingComp
  Else
    xcomp = "%"
  Endif
  If modBasic.$LabSamplingFrom = "Not From" Then
    xstr = "fldordcomp not like &6 ORDER BY fldid ASC"
  Else
    xstr = "fldordcomp like &6 ORDER BY fldid ASC"
  Endif

  If cmbcategorynew.Text = "%" Then
    sql = "select distinct(fldencounterval) as fldencounterval,fldencounterval,fldencounterval,fldordcomp from tblpatbilling where flditemtype=&1 and fldsample=&2 and fldsave=&3 and fldtarget=&4 and flditemname like &5 and flditemqty>fldretqty and " & xstr                                                         ''
    $rData3 = modDatabase.$myConn.Exec(sql, "Radio Diagnostics", "Waiting", True, modGeneralMain.compID, "%", xcomp)
  Else
    sql = "select distinct(fldencounterval) as fldencounterval,fldencounterval,fldencounterval,fldordcomp from tblpatbilling where flditemtype=&1 and fldsample=&2 and fldsave=&3 and fldtarget=&4 and flditemname in(select fldgroupname from tblgroupradio where fldtestid in(select fldexamid from tblradio where fldcategory like &5)) and flditemqty>fldretqty and " & xstr                                                         ''
    $rData3 = modDatabase.$myConn.Exec(sql, "Radio Diagnostics", "Waiting", True, modGeneralMain.compID, cmbcategorynew.Text, xcomp)
  Endif
  $aMyFields3 = New String[]
  modGridView.ReadSmallData(GridView3, $rData3, $aMyFields3)
  DisplayInitialGrid()

End

Private Sub FillNewSamplingSelectedEncounter(encid As String)

  Dim sql As String

  If cmbcategorynew.Text = "%" Then
    sql = "select distinct(fldencounterval) as fldencounterval,fldencounterval,fldencounterval,fldordcomp from tblpatbilling where flditemtype=&1 and fldsample=&2 and fldsave=&3 and fldtarget=&4 and flditemname like &5 and fldencounterval=&6 and flditemqty>fldretqty"                                                                         ''
    $rData3 = modDatabase.$myConn.Exec(sql, "Radio Diagnostics", "Waiting", True, modGeneralMain.compID, "%", encid)
  Else
    sql = "select distinct(fldencounterval) as fldencounterval,fldencounterval,fldencounterval,fldordcomp from tblpatbilling where flditemtype=&1 and fldsample=&2 and fldsave=&3 and fldtarget=&4 and flditemname in(select fldgroupname from tblgroupradio where fldtestid in(select fldexamid from tblradio where fldcategory like &5)) and fldencounterval=&6 and flditemqty>fldretqty"                                                                         ''
    $rData3 = modDatabase.$myConn.Exec(sql, "Radio Diagnostics", "Waiting", True, modGeneralMain.compID, cmbcategorynew.Text, encid)
  Endif
  $aMyFields3 = New String[]
  modGridView.ReadSmallData(GridView3, $rData3, $aMyFields3)
  DisplayInitialGrid()

End

Private Sub DisplayInitialGrid()

  With GridView3
    .Columns[0].Width = 75 * modBasic.$AppWidthRatio
    .Columns[1].Width = 10 * modBasic.$AppWidthRatio
    .Columns[2].Width = 200 * modBasic.$AppWidthRatio
    .Columns[0].Text = "EncID"
    .Columns[2].Text = "Name"
    .Columns[3].Text = "Sender"
  End With

End

Public Sub GridView3_Data(Row As Integer, Column As Integer)

  $rData3.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView3, Row)
  If Column = 1 Then
    GridView3.Data.Text = ""
    GridView3.Data.Background = modPatient.GetPatientColor($rData3[$aMyFields3[Column]])
  Else If Column = 2 Then
    GridView3.Data.Text = modPatient.GetPatientNameByEnc($rData3[$aMyFields3[Column]])
  Else
    GridView3.Data.Text = $rData3[$aMyFields3[Column]]
  Endif

End

Public Sub GridView3_Click()

  If GridView3.Rows.Selection.Count > 0 Then
    txtencid.Text = GridView3[GridView3.Row, 0].Text
    ShowNewEncounterTests(GridView3[GridView3.Row, 0].Text)
    GridView4.SetFocus
  Endif

End

Private Sub ShowNewEncounterTests(encid As String)

  Dim sql As String
  Dim Column As Integer
  Dim fld As ResultField

  If cmbcategorynew.Text = "%" Then
    sql = "select flditemname,fldtime,fldid,fldencounterval from tblpatbilling where flditemtype=&1 and fldsample=&2 and fldencounterval=&3 and fldsave=&4 and fldtarget=&5 and flditemqty>fldretqty"
  Else
    sql = "select flditemname,fldtime,fldid,fldencounterval from tblpatbilling where flditemtype=&1 and fldsample=&2 and fldencounterval=&3 and fldsave=&4 and fldtarget=&5 and flditemname in(select fldgroupname from tblgroupradio where fldtestid in(select fldexamid from tblradio where fldcategory like &6)) and flditemqty>fldretqty"
  Endif
  $rData4 = modDatabase.$myConn.Exec(sql, "Radio Diagnostics", "Waiting", encid, True, modGeneralMain.compID, cmbcategorynew.Text)

  GridView4.Clear
  GridView4.Columns.Count = $rData4.Fields.Count
  GridView4.Rows.Count = $rData4.Count

  For Each $rData4
    Column = 0
    For Each fld In $rData4.Fields
      modGeneralMain.GridExplicitDecoration(GridView4, $rData4.Index, Column)
      If Column = 1 Then
        GridView4[$rData4.Index, Column].Text = modReportVar.GetDateTimeReport($rData4["fldtime"], gb.GeneralDate)
      Else
        GridView4[$rData4.Index, Column].Text = $rData4[fld.Name]
      Endif
      Column = Column + 1
    Next
  Next
  GridView4.Row = 0

  With GridView4
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 250 * modBasic.$AppWidthRatio
    .Columns[1].Width = 150 * modBasic.$AppWidthRatio
    .Columns[2].Width = 1
    .Columns[3].Width = 1
    .Columns[0].Text = "Test Name"
    .Columns[1].Text = "DateTime"
  End With

End

Public Sub GridView4_Menu()

  mnutree.Popup

End

Public Sub btnnewexpotree_Click()

  Dim $BillingReport As CReportHTML
  Dim asx As New String[0]
  Dim sql As String
  Dim res As Result
  Dim xcomp As String

  If modBasic.$LabSamplingComp Then
    xcomp = modBasic.$LabSamplingComp
  Else
    xcomp = "%"
  Endif

  Inc Application.Busy
  $BillingReport = New CReportHTML([("Encounter"), ("PatientName"), ("Age/Sex"), ("Particulars"), ("Remarks")], modHelpVariable.$htmlDirectory, " ", "")
  $BillingReport.UserData.Add("TEST REQUESTS", "PARAM1")
  $BillingReport.UserData.Add("Category : " & cmbcategorynew.Text, "PARAM2")

  If cmbcategorynew.Text = "%" Then
    sql = "select distinct(fldencounterval) from tblpatbilling where flditemtype=&1 and fldsample=&2 and fldsave=&3 and fldtarget=&4 and fldordcomp like &5 and flditemqty>fldretqty"
  Else
    sql = "select distinct(fldencounterval) from tblpatbilling where flditemtype=&1 and fldsample=&2 and fldsave=&3 and fldtarget=&4 and fldordcomp like &5 and flditemname in(select fldgroupname from tblgroupradio where fldtestid in(select fldexamid from tblradio where fldcategory like &6)) and flditemqty>fldretqty"
  Endif
  res = modDatabase.$myConn.Exec(sql, "Radio Diagnostics", "Waiting", True, modGeneralMain.compID, xcomp, cmbcategorynew.Text)
  If res.Available Then
    For Each res
      With asx
        .Add(res!fldencounterval)
        .Add(modPatient.GetPatientNameByEnc(res!fldencounterval))
        .Add(modPatient.GetPatientAgeString(res!fldencounterval, Now()) & "/" & modPatient.GetPatientSex(res!fldencounterval))
        .Add(GetTestListForSample(res!fldencounterval).Join("; "))
        .Add("")
      End With
      $BillingReport.Add(asx)
      asx.Clear()
    Next
  Endif

  Dec Application.Busy
  modPrint.OpenHTMLPreview("", $BillingReport.NewHTMLPath(), "ReportSize")

End

Private Sub GetTestListForSample(encid As String) As String[]

  Dim xx As String[]
  Dim sql As String
  Dim res As Result

  If cmbcategorynew.Text = "%" Then
    sql = "select flditemname from tblpatbilling where flditemtype=&1 and fldsample=&2 and fldencounterval=&3 and fldsave=&4 and fldtarget=&5"
  Else
    sql = "select flditemname from tblpatbilling where flditemtype=&1 and fldsample=&2 and fldencounterval=&3 and fldsave=&4 and fldtarget=&5 and flditemname in(select fldgroupname from tblgroupradio where fldtestid in(select fldexamid from tblradio where fldcategory like &6))"
  Endif
  res = modDatabase.$myConn.Exec(sql, "Radio Diagnostics", "Waiting", encid, True, modGeneralMain.compID, cmbcategorynew.Text)
  xx = modFillContainer.GetListFromResult(res)
  Return xx

End

Private Sub AddSampling(plandate As Date)

  Dim res As Result
  Dim res1 As Result
  Dim j As Integer
  Dim res2 As Result

  If GridView4.Rows.Selection.Count > 0 Then
    res2 = modDatabase.$myConn.Exec("select flditemqty,fldretqty,fldbillno,fldrefer,fldreason from tblpatbilling where fldid=&1", GridView4[GridView4.Row, 2].Text)
    res = modDatabase.$myConn.Exec("select fldtestid,fldtesttype,fldactive from tblgroupradio where fldgroupname=&1 and (fldptsex=&2 or fldptsex=&3)", GridView4[GridView4.Row, 0].Text, modPatient.GetPatientSex(GridView4[GridView4.Row, 3].Text), "Both Sex")
    If res.Available = True Then
      If res2!flditemqty > res2!fldretqty Then

        Inc Application.Busy
        modDatabase.$myConn.Begin
        For Each res
          For j = 1 To (res2!flditemqty - res2!fldretqty)
            modRadioTest.InsertRadioTestOrder(GridView4[GridView4.Row, 3].Text, res!fldtestid, res!fldtesttype, res!fldactive, GridView4[GridView4.Row, 2].Text, modGeneral.GetUserFullNamePrint(res2!fldrefer), res2!fldbillno, res2!fldreason, plandate)
          Next
        Next
        res1 = modDatabase.$myConn.Edit("tblpatbilling", "fldid=&1", GridView4[GridView4.Row, 2].Text)
        res1["fldsample"] = "Sampled"
        res1["fldpayto"] = btnpayto.Tag
        res1["xyz"] = False
        res1.Update()
        modDatabase.$myConn.Commit
        Dec Application.Busy
        ShowNewEncounterTests(GridView3[GridView3.Row, 0].Text)
        ShowSampled(Trim(txtencid.Text))

      Endif
    Endif
  Endif

Catch
  modDatabase.$myConn.Rollback
  Dec Application.Busy
  modHelpVariable.CreateErrorReport()

End

Public Sub btnaddin_Click()

  AddSampling("")

End

Public Sub btndelin_Click()

  mnudel_Click()

End

Public Sub mnuadd_Click()

  AddSampling("")

End

Public Sub mnudel_Click()

  Dim res As Result

  If GridView4.Rows.Selection.Count > 0 Then
    If Message.Question(("Are you sure?"), ("No"), ("Yes")) = 2 Then
      Inc Application.Busy
      modDatabase.$myConn.Begin
      res = modDatabase.$myConn.Edit("tblpatbilling", "fldid=&1", GridView4[GridView4.Row, 2].Text)
      If res.Available = True Then
        If modBasic.$BillAutoReturn = "No" Then
        Else
          modBillings.InsertBlankBillItem(res!fldencounterval, res!fldbillingmode, res!flditemtype, res!flditemno, res!flditemname, res!flditemrate, 0 - res!flditemqty, res!fldtaxper, res!flddiscper, "Done", res!fldid, True, False, res!fldtarget, res!fldpayto, res!fldrefer, "AutoReturn", res!fldbillno)              ''
        Endif
        res["fldsample"] = "Removed"
        res["fldretqty"] = res!flditemqty
        res["xyz"] = False
        res.Update()
      Endif
      modDatabase.$myConn.Commit
      Dec Application.Busy
      ShowNewEncounterTests(GridView3[GridView3.Row, 0].Text)
    Endif
  Endif

Catch
  modDatabase.$myConn.Rollback
  Dec Application.Busy
  modHelpVariable.CreateErrorReport()

End

Public Sub mnutransf_Click()

  Dim res As Result
  Dim xx As String

  If GridView4.Rows.Selection.Count > 0 Then
    xx = InputCombo(("Enter Target Location"), ("Transfer"), modBasic.$AllCompList, "", True)
    If xx Then
      res = modDatabase.$myConn.Edit("tblpatbilling", "fldid=&1", GridView4[GridView4.Row, 2].Text)
      res["fldtarget"] = xx
      res["xyz"] = False
      res.Update()
      If xx <> modGeneralMain.compID Then
        ShowNewEncounterTests(GridView3[GridView3.Row, 0].Text)
      Endif
    Endif
  Endif

End

