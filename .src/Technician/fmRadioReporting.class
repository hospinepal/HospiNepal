  Endif

End

Public Sub mnublank_Click()

  Me.Close
  modHelpVariable.AddNewFormToWorkspace(fmRadioReporting)

End

Public Sub mnuaddtest_Click()

  Dim xx As String[]
  Dim xitem As String

  If txtencid.Text Then
    xx = GridListView(("Select requested Tests"), modMedicine.FillRadioTestCombo("%"))
    If xx Then
      modDatabase.$myConn.Begin
      For Each xitem In xx
        modRadioTest.InsertRadioTestOrder(Trim(txtencid.Text), xitem, modFixRadio.GetRadioTestType(xitem), "Regular", 0, "", "", "", "")
      Next
      modDatabase.$myConn.Commit
      ShowSampled(Trim(txtencid.Text))
    Endif
  Endif

End

Public Sub mnuaddgroup_Click()

  Dim xx As String[]
  Dim xitem As String
  Dim res As Result
  Dim xmode As String

  If txtencid.Text Then
    xmode = modBillings.DefaultOpBillingMode(Trim(txtencid.Text), modGeneralMain.compID)
    If xmode Then
      xx = GridListView(("Select requested Test Groups"), modNonMedical.NonStockBillingItemArray("Radio Diagnostics", xmode))
      If xx Then
        modDatabase.$myConn.Begin
        For Each xitem In xx
          res = modDatabase.$myConn.Exec("select fldtestid,fldtesttype,fldactive from tblgroupradio where fldgroupname=&1 and (fldptsex=&2 or fldptsex=&3)", xitem, modPatient.GetPatientSex(Trim(txtencid.Text)), "Both Sex")
          If res.Available = True Then
            For Each res
              modRadioTest.InsertRadioTestOrder(Trim(txtencid.Text), res!fldtestid, res!fldtesttype, res!fldactive, 0, "", "", "", "")
            Next
          Endif
        Next
        modDatabase.$myConn.Commit
        ShowSampled(Trim(txtencid.Text))
      Endif
    Endif
  Endif

End

