''------------------------------------------ patient profile -------------------------------------
Public Sub btnshow_Click()

  If txtencid.Text Then
    btnshow.Enabled = False
    $encid = Trim(txtencid.Text)
    txtpatientname.Text = modPatient.GetPatientNameByEnc($encid)
    txtgender.Text = modPatient.GetPatientAgeString($encid, Now()) & "/" & modPatient.GetPatientSex($encid)
    txtpatientaddress.Text = modPatient.GetPatientAddressByEnc($encid)
    txtpatientcontact.Text = modPatient.GetLocationSetting($encid)
    txtcolor.Background = modPatient.GetPatientColor($encid)
    modGeneralMain.RecordPatientActivity("Patient Data", Me.Name, "EncounterID", $encid)
    If modPatient.AllowEncIDHistory($encid, modDatabase.$myConn) = True Then
      ShowSampled($encid)
      modImage.ShowPhotoSplash("Patient", modPatient.GetPatientNoByEnc(Trim(txtencid.Text)))
      GridView1.SetFocus
    Else
      Me.Enabled = False
    Endif
  Endif

End

Public Sub txtencid_GotFocus()

  btnshow.Enabled = True

End

Public Sub btnwebcam_Click()

  txtencid.Text = modDevice.ChooseBarCodeSource()
  txtencid.SetFocus
  txtencid.Pos = Len(txtencid.Text)

End

'''------------------------------------------ added tests -------------------------------------------
Private Sub ExecuteQuery(encid As String)

  Dim sql As String

  If chkall.Value = False Then
    sql = "select fldid,fldchk,fldtestid,fldreportquali,flvisible,fldmethod,fldreportquanti,fldtest_type,fldsampletype,fldcondition,fldcomment,fldtime_report,fldencounterval,fldstatus,fldabnormal,fldpacstudy from tblpatradiotest where (fldstatus=&1 or fldstatus=&2) and fldencounterval=&3 and fldcomp_report=&4"
    $rData = modDatabase.$myConn.Exec(sql, "Ordered", "Sampled", encid, modGeneralMain.compID)
  Else
    sql = "select fldid,fldchk,fldtestid,fldreportquali,flvisible,fldmethod,fldreportquanti,fldtest_type,fldsampletype,fldcondition,fldcomment,fldtime_report,fldencounterval,fldstatus,fldabnormal,fldpacstudy from tblpatradiotest where (fldstatus=&1 or fldstatus=&2 or fldstatus=&3) and fldencounterval=&4 and fldcomp_report=&5"
    $rData = modDatabase.$myConn.Exec(sql, "Ordered", "Sampled", "Reported", encid, modGeneralMain.compID)
  Endif

End

Private Sub ShowSampled(encid As String)

  Dim Column As Integer
  Dim fld As ResultField

  ExecuteQuery(encid)
  GridView1.Clear
  GridView1.Columns.Count = $rData.Fields.Count
  GridView1.Rows.Count = $rData.Count

  For Each $rData
    Column = 0
    For Each fld In $rData.Fields
      modGeneralMain.GridExplicitDecoration(GridView1, $rData.Index, Column)
      If Column = 3 Then
        GridView1[$rData.Index, Column].RichText = $rData[fld.Name]
      Else If Column = 11 Then
        GridView1[$rData.Index, Column].Text = modReportVar.GetDateTimeReport($rData["fldtime_report"], gb.GeneralDate)
      Else
        GridView1[$rData.Index, Column].Text = $rData[fld.Name]
      Endif
      Column = Column + 1
    Next
  Next
  GridView1.Row = 0

  With GridView1
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 1
    .Columns[1].Width = 1
    .Columns[2].Width = 200 * modBasic.$AppWidthRatio
    .Columns[3].Width = 250 * modBasic.$AppWidthRatio
    .Columns[4].Width = 75 * modBasic.$AppWidthRatio
    .Columns[5].Width = 100 * modBasic.$AppWidthRatio
    .Columns[6].Width = 1
    .Columns[7].Width = 1
    .Columns[8].Width = 125 * modBasic.$AppWidthRatio
    .Columns[9].Width = 1
    .Columns[10].Width = 1
    .Columns[11].Width = 150 * modBasic.$AppWidthRatio
    .Columns[12].Width = 1
    .Columns[13].Width = 1
    .Columns[14].Width = 1
    .Columns[15].Width = 1

    .Columns[2].Text = "Examination"
    .Columns[3].Text = "Observation"     ''5
    .Columns[4].Text = "Visibility" ''4
    .Columns[5].Text = "Method"      ''3
    .Columns[8].Text = "Evaluation"
    .Columns[11].Text = "ReportDate"
  End With
  modGridView.SetLabReportIcon(GridView1, 13, 14, 3)

End

Public Sub GridView1_Click()

  Dim xx As String
  Dim xopt As String[] = ["Visible", "Hidden"]
  Dim res As Result
  Dim xspec As String[]

  If GridView1.Column = 3 Then
    UpdateRadioValue()

  Else If GridView1.Column = 4 Then
    xx = InputCombo("Set Visibility", GridView1[GridView1.Row, 2].Text, xopt, GridView1[GridView1.Row, 4].Text, True)
    If xx Then
      res = modDatabase.$myConn.Edit("tblpatradiotest", "fldid=&1", GridView1[GridView1.Row, 0].Text)
      res["flvisible"] = xx
      res["xyz"] = False
      res.Update
      ShowSampled($encid)
    Endif

  Else If GridView1.Column = 5 Then
    xx = InputCombo(("Select Test Method"), ("Test Method"), modFixLab.GetTestExamEquipments("Radio"), GridView1[GridView1.Row, 5].Text, True)
    If xx Then
      modLabTest.UpdateEquipmenRadiotMethod(GridView1[GridView1.Row, 0].Text, xx)
      ShowSampled($encid)
    Endif

  Else If GridView1.Column = 8 Then
    xx = InputCombo("Set Site of Evaluation", GridView1[GridView1.Row, 2].Text, xspec, GridView1[GridView1.Row, 8].Text, False)
    If xx Then
      res = modDatabase.$myConn.Edit("tblpatradiotest", "fldid=&1", GridView1[GridView1.Row, 0].Text)
      res["fldsampletype"] = xx
      res["xyz"] = False
      res.Update
      ShowSampled($encid)
    Endif

  Endif

End

Public Sub GridView1_KeyRelease()

  If GridView1.Rows.Selection.Count > 0 Then
    If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
      UpdateRadioValue()
    Endif
  Endif

End

Private Sub UpdateRadioValue()

  Dim rs As Result
  Dim xxx As String[]

  Dim yqualival As Variant[]
  Dim xquantival As Variant[]
  Dim hForm3 As FmEnterMultiple
  Dim res As Result
  Dim sql As String
  Dim opid As Long[]
  Dim option As String[]
  Dim opx As String[]
  Dim opt As String[]
  Dim xx As Integer
  Dim xType As String
  Dim xdate As Date

  Dim xmax As Float
  Dim xmin As Float

  xx = GridView1.Row
  If GridView1[GridView1.Row, 7].Text = "Qualitative" Then
    rs = modDatabase.$myConn.Exec("select fldid,fldsubtest from tblpatradiosubtest where fldtestid=&1", GridView1[GridView1.Row, 0].Text)
    If rs.Available = False Then
      If modFixRadio.GetRadioTestOption(GridView1[GridView1.Row, 2].Text) = "Fixed Components" Then
        xxx = modFillContainer.GetListFromResult(modDatabase.$myConn.Exec("select distinct(fldsubexam) as col from tblradioquali where fldexamid=&1", GridView1[GridView1.Row, 2].Text))
        If xxx.Count Then
          modRadioTest.InsertRadioSubTest(GridView1[GridView1.Row, 12].Text, GridView1[GridView1.Row, 0].Text, xxx)
        Endif
      Endif
    Endif

    sql = "select fldid,fldsubtest,fldreport,fldtanswertype from tblpatradiosubtest where fldtestid=&1"
    res = modDatabase.$myConn.Exec(sql, GridView1[GridView1.Row, 0].Text)
    If res.Available = False Then
      xType = modFixRadio.GetRadioTestOption(GridView1[GridView1.Row, 2].Text)
      If xType = "Clinical Scale" Then
        yqualival = modExamOption.GetClinScalePopUp("Radio", GridView1[GridView1.Row, 2].Text)
        If yqualival Then
          ' modRadioTest.UpdateRadioTestReportQuali(GridView1[GridView1.Row, 0].Text, yqualival[0], yqualival[1], yqualival[2])
        Endif
      Else If xType = "Left and Right" Then
        yqualival = CLeftRight(GridView1[GridView1.Row, 2].Text, GridView1[GridView1.Row, 3].RichText)
        If yqualival Then
          modRadioTest.UpdateRadioTestReportQuali(GridView1[GridView1.Row, 0].Text, modString.GetLefRightJSON(yqualival[0], yqualival[1]), yqualival[2], "")
        Endif
      Else If xType = "Date Time" Then
        xdate = GetDateValue(GridView1[GridView1.Row, 2].Text, ("Select Date Time"), CDate(GridView1[GridView1.Row, 3].RichText))
        If xdate Then
          modRadioTest.UpdateRadioTestReportQuali(GridView1[GridView1.Row, 0].Text, CStr(xdate), False, "")
        Endif
      Else
        yqualival = GetQualiValues(GridView1[GridView1.Row, 2].Text, GridView1[GridView1.Row, 3].RichText, "Radio")
        If yqualival Then
          modRadioTest.UpdateRadioTestReportQuali(GridView1[GridView1.Row, 0].Text, yqualival[0], yqualival[1], yqualival[2])
        Endif
      Endif

    Else If res.Available = True Then
      opid = New Long[]
      option = New String[]
      opx = New String[]
      opt = New String[]
      res.MoveFirst
      For Each res
        opid.Add(res!fldid)
        option.Add(res!fldtanswertype)
        opx.Add(res!fldsubtest)
        opt.Add(res!fldreport)
      Next
      opx.Add("Final Impression")
      opt.Add(GridView1[GridView1.Row, 3].RichText)
      opid.Add(0)
      option.Add("No Selection")
      hForm3 = New FmEnterMultiple(GridView1[GridView1.Row, 0].Text, "Radio", GridView1[GridView1.Row, 2].Text, opx, opt, opid, option, "")
      hForm3.ShowModal
    Endif

  Else If GridView1[GridView1.Row, 7].Text = "Quantitative" Then
    xmax = modRadioTest.GetMaxQuantiRadioVal(GridView1[GridView1.Row, 2].Text, $encid)
    xmin = modRadioTest.GetMinQuantiRadioVal(GridView1[GridView1.Row, 2].Text, $encid)
    xquantival = GetQuantiValues("Radio", Trim(txtencid.Text), GridView1[GridView1.Row, 2].Text, xmin, xmax, GridView1[GridView1.Row, 6].Text)
    If xquantival Then
      modRadioTest.UpdateRadioTestReportQuanti(GridView1[GridView1.Row, 0].Text, xquantival[0], xquantival[1])
    Endif

  Endif

  ShowSampled($encid)
  GridView1.Row = xx

End

