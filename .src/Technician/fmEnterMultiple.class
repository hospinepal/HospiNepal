' Gambas class file

''controls
Private aIndexLabel[50] As Label   ''aLab
Private aNameLabel[50] As TextLabel      ''aObj
Private aAbnormCheck[50] As CheckBox      ''aObj2
Private aHTMLText[50] As TextHTML         ''aObj11
Private aLineText[50] As TextBox
Private aUnitText[50] As TextBox
Private aValueBox[50] As ValueBox
Private aNullCheck[50] As CheckBox
Private aClinBox[50] As ValueBox
Private aTextArea[50] As TextArea
Private aDateBox[50] As DateBox
Private aLeftRight[50] As LeftRightTextArea
Private aGridView[50] As GridView          ''aObg11
Private aHelpButton[50] As ButtonBox          ''aObj3
''other variables
Private $frm As String
Private $id As Long
Private $AutoOption As String
''lists
Private $exam As String[]
Private $sValue As String[]
Private $idList As Long[]
Private $optList As String[]

''----------------------------------------- create controls -----------------------------------------
Public Sub _new(id As Long, frm As String, strExam As String, exam As String[], sValue As String[], idList As Long[], OpList As String[], xnote As String)

  Dim i As Integer
  Dim ht As String

  $id = id
  $frm = frm
  lblitem.Text = strExam

  $exam = exam
  $sValue = sValue
  $idList = idList
  $optList = OpList

  If xnote Then
    lblnote.Text = xnote
  Else
    lblnote.Visible = False
    Label1.Visible = False
  Endif

  ht = modSettings.ShowSettingFromFIle("MultipleTextBox/Height")
  If ht Then
    Slider1.Value = CInt(ht)
  Else
    Slider1.Value = 3
  Endif

  For i = 0 To $exam.Count - 1
    aIndexLabel[i] = New Label(Frame1) As "IndexLabel"
    aNameLabel[i] = New TextLabel(Frame1) As "NameLabel"
    aAbnormCheck[i] = New CheckBox(Frame1) As "CheckBoxgroup"
    Select $optList[i]
      Case "Multiple Selection", "Drug Sensitivity", "Text Table", "Dual Columns", "Single Column"
        aGridView[i] = New GridView(Frame1) As "Gridgroup"
      Case "Left and Right"
        aLeftRight[i] = New LeftRightTextArea(Frame1) As "LeftRightGroup"
      Case "Date Time"
        aDateBox[i] = New DateBox(Frame1) As "DateGroup"
      Case "Quantitative", "Percent Sum"
        aValueBox[i] = New ValueBox(Frame1) As "ValueGroup"
        aUnitText[i] = New TextBox(Frame1) As "UnitGroup"
        aNullCheck[i] = New CheckBox(Frame1) As "NullCheckBox"
      Case "Clinical Scale"
        aTextArea[i] = New TextArea(Frame1) As "TextAreaGroup"
        aClinBox[i] = New ValueBox(Frame1) As "ClinGroup"
      Case "Qualitative"
        aLineText[i] = New TextBox(Frame1) As "TextLineGroup"
      Case Else
        aHTMLText[i] = New TextHTML(Frame1) As "TextHTMLgroup"
    End Select
    aHelpButton[i] = New ButtonBox(Frame1) As "ButtonBoxgroup"
  Next
  DIsplayTextForm()

End

Private Sub DIsplayTextForm()

  Dim i As Integer
  Dim asx As String[]
  Dim AppFactor As Float

  AppFactor = modBasic.$AppScaleFactor
  Frame1.Height = ($exam.Count * (25 * Slider1.Value + 20) + 100) * AppFactor
  Frame1.Width = 875 * AppFactor

  For i = 0 To $exam.Count - 1

    ''create index label
    With aIndexLabel[i]
      .X = 5 * AppFactor
      .Y = (i * (25 * Slider1.Value + 20) + 30) * AppFactor
      .Width = 25 * AppFactor
      .Height = 25 * AppFactor
      .Text = i + 1
      .Tag = i
    End With

    ''create Name Label
    With aNameLabel[i]
      .X = (5 + 25) * AppFactor
      .Y = (i * (25 * Slider1.Value + 20) + 30) * AppFactor
      .Width = 197 * AppFactor
      .Height = 25 * AppFactor
      .Text = $exam[i]
      .Tag = i
      If .Text = "Final Impression" Then
        .Font.Bold = True
      Else
        .Font.Bold = False
      Endif
      .Wrap = True
    End With

    ''create abnormal checkbox
    With aAbnormCheck[i]
      .X = (207 + 25) * AppFactor
      .Y = (i * (25 * Slider1.Value + 20) + 30) * AppFactor
      .Width = 100 * AppFactor
      .Height = 25 * AppFactor
      .Text = "Abnormal"
      .Tag = i
    End With

    ''create observation entry
    If $optList[i] = "Multiple Selection" Or If $optList[i] = "Drug Sensitivity" Or If $optList[i] = "Text Table" Or If $optList[i] = "Dual Columns" Or If $optList[i] = "Single Column" Then
      With aGridView[i]
        .X = (312 + 25) * AppFactor
        .Y = (i * (25 * Slider1.Value + 20) + 30) * AppFactor
        .Width = 475 * AppFactor
        .Height = 25 * Slider1.Value * AppFactor
        .Mode = Select.Single
        If $optList[i] = "Dual Columns" Then
          .Header = GridView.Horizontal
        Endif
        .ScrollBar = Scroll.Both
        .AutoResize = True
        .Tag = i
      End With
      LoadSubTable($idList[i], $frm, aGridView[i])
      If $optList[i] = "Dual Columns" Then
        aGridView[i].Columns[0].Width = 1
        aGridView[i].Columns[1].Width = 150 * modBasic.$AppWidthRatio
        aGridView[i].Columns[2].Width = 100 * modBasic.$AppWidthRatio
        aGridView[i].Columns[3].Width = 100 * modBasic.$AppWidthRatio
        aGridView[i].Columns[1].Text = "Parameter"
        aGridView[i].Columns[2].Text = "LEFT"
        aGridView[i].Columns[3].Text = "RIGHT"
      Else
        aGridView[i].Columns[0].Width = 1
        aGridView[i].Columns[1].Width = 150 * modBasic.$AppWidthRatio
      Endif

    Else If $optList[i] = "Left and Right" Then
      With aLeftRight[i]
        .X = (312 + 25) * AppFactor
        .Y = (i * (25 * Slider1.Value + 20) + 30) * AppFactor
        .Width = 475 * AppFactor
        .Height = 25 * Slider1.Value * AppFactor
        .DataText = $sValue[i]
        .Tag = i
      End With

    Else If $optList[i] = "Date Time" Then
      With aDateBox[i]
        .X = (312 + 25) * AppFactor
        .Y = (i * (25 * Slider1.Value + 20) + 30) * AppFactor
        .Width = 200 * AppFactor
        .Height = 25 * AppFactor
        .Mode = DateChooser.DateTime
        .Tag = i
        .Value = CDate($sValue[i])
      End With

    Else If $optList[i] = "Quantitative" Or If $optList[i] = "Percent Sum" Then
      If $sValue[i] Then
        asx = modString.SplitValueText($sValue[i])
      Else
        asx = ["", ""]
      Endif
      With aValueBox[i]
        .X = (312 + 25) * AppFactor
        .Y = (i * (25 * Slider1.Value + 20) + 30) * AppFactor
        .Width = 150 * AppFactor
        .Height = 25 * AppFactor
        .Tag = i
        If asx[0] Then
          .Value = CFloat(asx[0])
        Endif
      End With
      With aUnitText[i]
        .X = (500 + 25) * AppFactor
        .Y = (i * (25 * Slider1.Value + 20) + 30) * AppFactor
        .Width = 100 * AppFactor
        .Height = 25 * AppFactor
        .Tag = i
        .Text = asx[1]
      End With
      With aNullCheck[i]
        .X = (625 + 25) * AppFactor
        .Y = (i * (25 * Slider1.Value + 20) + 30) * AppFactor
        .Width = 50 * AppFactor
        .Height = 25 * AppFactor
        .Tag = i
        .Value = False
        .Text = "Null"
      End With

    Else If $optList[i] = "Clinical Scale" Then
      With aTextArea[i]
        .X = (312 + 25) * AppFactor
        .Y = (i * (25 * Slider1.Value + 20) + 30) * AppFactor
        .Width = 250 * AppFactor
        .Height = 25 * AppFactor
        .Tag = i
      End With
      With aClinBox[i]
        .X = (600 + 25) * AppFactor
        .Y = (i * (25 * Slider1.Value + 20) + 30) * AppFactor
        .Width = 100 * AppFactor
        .Height = 25 * AppFactor
        .Tag = i
      End With

    Else If $optList[i] = "Qualitative" Then
      With aLineText[i]
        .X = (312 + 25) * AppFactor
        .Y = (i * (25 * Slider1.Value + 20) + 30) * AppFactor
        .Width = 475 * AppFactor
        .Height = 25 * AppFactor
        .Text = $sValue[i]
        .Tag = i
      End With

    Else
      With aHTMLText[i]
        .X = (312 + 25) * AppFactor
        .Y = (i * (25 * Slider1.Value + 20) + 30) * AppFactor
        .Width = 475 * AppFactor
        .Height = 25 * Slider1.Value * AppFactor
        .RichText = $sValue[i]
        .DictionaryPath = modBasic.$dictPathList
        .Tag = i
      End With

    Endif

    ''create help button
    With aHelpButton[i]
      .X = (792 + 25) * AppFactor
      .Y = (i * (25 * Slider1.Value + 20) + 30) * AppFactor
      .Width = 25 * AppFactor
      .Height = 25 * AppFactor
      .Text = ""
      .Picture = Picture["icon:/small/info"]
      .Tag = i
    End With

  Next

  If aHTMLText[0] Then
    aHTMLText[0].SetFocus
  Else If aLineText[0] Then
    aLineText[0].SetFocus
  Else If aValueBox[0] Then
    aValueBox[0].SetFocus
  Else If aDateBox[0] Then
    aDateBox[0].SetFocus
  Endif

End

''------------------------ General form
Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me, "False")
  $AutoOption = modSettings.ShowSettingFromFIle("EntrySetting/AutoDisplayOptions")
  If $AutoOption = "Yes" Then
    chkautoption.Value = True
  Else If $AutoOption = "No" Then
    chkautoption.Value = False
  Endif

End

Public Sub Form_Resize()

  If Frame1.Height < $sValue.Count * 45 Then
    Frame1.Height = $sValue.Count * 45
  Endif

End

Public Sub btnexectext_Click()

  Dim j As Integer

  Try j = Application.ActiveControl.Tag
  If aHTMLText[j] Then
    aHTMLText[j].RichText = aHTMLText[j].RichText & modExternal.RunTextHelpScript(aHTMLText[j].Text)
  Endif

End

Public Sub dctexectext_Click()

  Dim xx As String
  Dim j As Integer

  Try j = Application.ActiveControl.Tag
  If aHTMLText[j] Then
    xx = GetRichTextArea(lblitem.Text, aHTMLText[j].RichText)
    If xx Then
      aHTMLText[j].RichText = xx
    Endif
  Endif

End

Public Sub btntempltext_Click()

  Dim j As Integer

  Try j = Application.ActiveControl.Tag
  If aHTMLText[j] Then
    aHTMLText[j].RichText = aHTMLText[j].RichText & DictionaryVIew(modBasic.$dictadvPath)
  Endif

End

Public Sub chkautoption_Click()

  modSettings.EnterCheckSetting(chkautoption, "EntrySetting/AutoDisplayOptions")

End

Public Sub btnrefresh_Click()

  modSettings.SaveSettingsToFile("MultipleTextBox/Height", Slider1.Value)
  DIsplayTextForm()

End

Public Sub btnBrChange_Click()

  modGeneralMain.SaveFormArrangement(Me)
  Me.Close()

End

Public Sub btnBrOK_Click()

  Dim i As Integer
  Dim xval As Float

  xval = 0
  For i = 0 To $exam.Count - 1
    If $optList[i] = "Percent Sum" Then
      xval = xval + aValueBox[i].Value
    Endif
  Next
  If xval = 0 Then
    SaveEntryData()
  Else
    If xval = 100 Then
      SaveEntryData()
    Else
      If Message.Question(("Percent Values Sum not equal to 100. Do you want to proceed?"), ("No"), ("Yes")) = 2 Then
        SaveEntryData()
      Endif
    Endif
  Endif

End

Private Sub SaveEntryData()

  If $frm = "Test" Then
    FillLabTestSubTest()
  Else If $frm = "Exam" Then
    FillExamSubExam()
  Else If $frm = "Radio" Then
    FillRadioTestSubTest()
  Endif
  Balloon.Info(("Information saved"), btnBrOK)
  Balloon.Delay = modBasic.$BalloonDelay

End

''for examination
Private Sub FillExamSubExam()

  Dim i As Integer
  Dim res As Result

  For i = 0 To $exam.Count - 1
    If aNameLabel[i].Text = "Final Impression" Then
      modClinic.UpdateQualiData($id, aHTMLText[i].RichText, aAbnormCheck[i].Value, aHTMLText[i].KeyList.Join(";"))

    Else
      If $optList[i] = "Multiple Selection" Or If $optList[i] = "Drug Sensitivity" Or If $optList[i] = "Text Table" Or If $optList[i] = "Dual Columns" Or If $optList[i] = "Single Column" Then
        res = modDatabase.$myConn.Edit("tblpatientsubexam", "fldsubtexam=&1 and fldheadid=&2", aNameLabel[i].Text, $id)
        res["fldreport"] = ""
        res["fldsave"] = True
        res["fldabnormal"] = aAbnormCheck[i].Value
        res["xyz"] = False
        res.Update()
      Else If $optList[i] = "Left and Right" Then
        If aLeftRight[i].DataText Then
          res = modDatabase.$myConn.Edit("tblpatientsubexam", "fldsubtexam=&1 and fldheadid=&2", aNameLabel[i].Text, $id)
          res["fldreport"] = aLeftRight[i].DataText
          res["fldsave"] = True
          res["fldabnormal"] = aAbnormCheck[i].Value
          res["xyz"] = False
          res.Update()
        Endif
      Else If $optList[i] = "Date Time" Then
        If aDateBox[i].Value Then
          res = modDatabase.$myConn.Edit("tblpatientsubexam", "fldsubtexam=&1 and fldheadid=&2", aNameLabel[i].Text, $id)
          res["fldreport"] = Format(aDateBox[i].Value, gb.GeneralDate)
          res["fldsave"] = True
          res["fldabnormal"] = aAbnormCheck[i].Value
          res["xyz"] = False
          res.Update()
        Endif
      Else If $optList[i] = "Quantitative" Or If $optList[i] = "Percent Sum" Then
        If aValueBox[i].Value Or If aNullCheck[i].Value Then
          res = modDatabase.$myConn.Edit("tblpatientsubexam", "fldsubtexam=&1 and fldheadid=&2", aNameLabel[i].Text, $id)
          res["fldreport"] = CStr(aValueBox[i].Value) & Space(1) & aUnitText[i].Text
          res["fldsave"] = True
          res["fldabnormal"] = aAbnormCheck[i].Value
          res["xyz"] = False
          res.Update()
        Endif
      Else If $optList[i] = "Clinical Scale" Then
        If aTextArea[i].Text Then
          res = modDatabase.$myConn.Edit("tblpatientsubexam", "fldsubtexam=&1 and fldheadid=&2", aNameLabel[i].Text, $id)
          res["fldreport"] = CStr(aClinBox[i].Value)
          res["fldsave"] = True
          res["fldabnormal"] = aAbnormCheck[i].Value
          res["xyz"] = False
          res.Update()
        Endif
      Else If $optList[i] = "Qualitative" Then
        If aLineText[i].Text Then
          res = modDatabase.$myConn.Edit("tblpatientsubexam", "fldsubtexam=&1 and fldheadid=&2", aNameLabel[i].Text, $id)
          res["fldreport"] = aLineText[i].Text
          res["fldsave"] = True
          res["fldabnormal"] = aAbnormCheck[i].Value
          res["xyz"] = False
          res.Update()
        Endif
      Else
        If aHTMLText[i].Text Then
          res = modDatabase.$myConn.Edit("tblpatientsubexam", "fldsubtexam=&1 and fldheadid=&2", aNameLabel[i].Text, $id)
          res["fldreport"] = aHTMLText[i].RichText
          res["fldsave"] = True
          res["fldabnormal"] = aAbnormCheck[i].Value
          res["fldfilepath"] = aHTMLText[i].KeyList.Join(";")
          res["xyz"] = False
          res.Update()
        Endif
      Endif
    Endif
  Next

End

''for lab tests
Private Sub FillLabTestSubTest()

  Dim i As Integer
  Dim res As Result

  For i = 0 To $exam.Count - 1
    If aNameLabel[i].Text = "Final Impression" Then
      modLabTest.UpdateLabTestReportQuali($id, aHTMLText[i].RichText, aAbnormCheck[i].Value, aHTMLText[i].KeyList.Join(";"))

    Else
      If $optList[i] = "Multiple Selection" Or If $optList[i] = "Drug Sensitivity" Or If $optList[i] = "Text Table" Or If $optList[i] = "Dual Columns" Or If $optList[i] = "Single Column" Then
        res = modDatabase.$myConn.Edit("tblpatlabsubtest", "fldsubtest=&1 and fldtestid=&2", aNameLabel[i].Text, $id)
        res["fldreport"] = ""
        res["fldsave"] = True
        res["fldabnormal"] = aAbnormCheck[i].Value
        res["xyz"] = False
        res.Update()
      Else If $optList[i] = "Left and Right" Then
        If aLeftRight[i].DataText Then
          res = modDatabase.$myConn.Edit("tblpatlabsubtest", "fldsubtest=&1 and fldtestid=&2", aNameLabel[i].Text, $id)
          res["fldreport"] = aLeftRight[i].DataText
          res["fldsave"] = True
          res["fldabnormal"] = aAbnormCheck[i].Value
          res["xyz"] = False
          res.Update()
        Endif
      Else If $optList[i] = "Date Time" Then
        If aDateBox[i].Value Then
          res = modDatabase.$myConn.Edit("tblpatlabsubtest", "fldsubtest=&1 and fldtestid=&2", aNameLabel[i].Text, $id)
          res["fldreport"] = Format(aDateBox[i].Value, gb.GeneralDate)
          res["fldsave"] = True
          res["fldabnormal"] = aAbnormCheck[i].Value
          res["xyz"] = False
          res.Update()
        Endif
      Else If $optList[i] = "Quantitative" Or If $optList[i] = "Percent Sum" Then
        If aValueBox[i].Value Or If aNullCheck[i].Value Then
          res = modDatabase.$myConn.Edit("tblpatlabsubtest", "fldsubtest=&1 and fldtestid=&2", aNameLabel[i].Text, $id)
          res["fldreport"] = CStr(aValueBox[i].Value) & Space(1) & aUnitText[i].Text
          res["fldsave"] = True
          res["fldabnormal"] = aAbnormCheck[i].Value
          res["xyz"] = False
          res.Update()
        Endif
      Else If $optList[i] = "Clinical Scale" Then
        If aTextArea[i].Text Then
          res = modDatabase.$myConn.Edit("tblpatlabsubtest", "fldsubtest=&1 and fldtestid=&2", aNameLabel[i].Text, $id)
          res["fldreport"] = CStr(aClinBox[i].Value)
          res["fldsave"] = True
          res["fldabnormal"] = aAbnormCheck[i].Value
          res["xyz"] = False
          res.Update()
        Endif
      Else If $optList[i] = "Qualitative" Then
        If aLineText[i].Text Then
          res = modDatabase.$myConn.Edit("tblpatlabsubtest", "fldsubtest=&1 and fldtestid=&2", aNameLabel[i].Text, $id)
          res["fldreport"] = aLineText[i].Text
          res["fldsave"] = True
          res["fldabnormal"] = aAbnormCheck[i].Value
          res["xyz"] = False
          res.Update()
        Endif
      Else
        If aHTMLText[i].Text Then
          res = modDatabase.$myConn.Edit("tblpatlabsubtest", "fldsubtest=&1 and fldtestid=&2", aNameLabel[i].Text, $id)
          res["fldreport"] = aHTMLText[i].RichText
          res["fldsave"] = True
          res["fldabnormal"] = aAbnormCheck[i].Value
          res["fldfilepath"] = aHTMLText[i].KeyList.Join(";")
          res["xyz"] = False
          res.Update()
        Endif
      Endif
    Endif
  Next

End

