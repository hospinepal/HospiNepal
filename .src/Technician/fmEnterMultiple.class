      If aHTMLText[i - 1] Then
        ScrollView1.EnsureVisible(aHTMLText[i - 1].x, aHTMLText[i - 1].y, aHTMLText[i - 1].Width, aHTMLText[i - 1].Height)
        OpenAutoOptions(i)
        aHTMLText[i - 1].SetFocus
      Endif
    Else If Key.Code = Key.F6 Then
      i = 6
      If aHTMLText[i - 1] Then
        ScrollView1.EnsureVisible(aHTMLText[i - 1].x, aHTMLText[i - 1].y, aHTMLText[i - 1].Width, aHTMLText[i - 1].Height)
        OpenAutoOptions(i)
        aHTMLText[i - 1].SetFocus
      Endif
    Else If Key.Code = Key.F7 Then
      i = 7
      If aHTMLText[i - 1] Then
        ScrollView1.EnsureVisible(aHTMLText[i - 1].x, aHTMLText[i - 1].y, aHTMLText[i - 1].Width, aHTMLText[i - 1].Height)
        OpenAutoOptions(i)
        aHTMLText[i - 1].SetFocus
      Endif
    Else If Key.Code = Key.F8 Then
      i = 8
      If aHTMLText[i - 1] Then
        ScrollView1.EnsureVisible(aHTMLText[i - 1].x, aHTMLText[i - 1].y, aHTMLText[i - 1].Width, aHTMLText[i - 1].Height)
        OpenAutoOptions(i)
        aHTMLText[i - 1].SetFocus
      Endif
    Else If Key.Code = Key.F9 Then
      i = 9
      If aHTMLText[i - 1] Then
        ScrollView1.EnsureVisible(aHTMLText[i - 1].x, aHTMLText[i - 1].y, aHTMLText[i - 1].Width, aHTMLText[i - 1].Height)
        OpenAutoOptions(i)
        aHTMLText[i - 1].SetFocus
      Endif
    Else If Key.Code = Key.F10 Then
      i = 10
      If aHTMLText[i - 1] Then
        ScrollView1.EnsureVisible(aHTMLText[i - 1].x, aHTMLText[i - 1].y, aHTMLText[i - 1].Width, aHTMLText[i - 1].Height)
        OpenAutoOptions(i)
        aHTMLText[i - 1].SetFocus
      Endif
    Else If Key.Code = Key.F11 Then
