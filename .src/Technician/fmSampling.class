Public Sub btnshow_Click()

  BasicInfoPatient()

End

Public Sub BasicInfoPatient()

  $encid = Trim(txtencid.Text)
  txtpatientname.Text = modPatient.GetPatientNameByEnc($encid)
  txtgender.Text = modPatient.GetPatientAgeString($encid, Now()) & "/" & modPatient.GetPatientSex($encid)
  txtpatientaddress.Text = modPatient.GetPatientAddressByEnc($encid)
  txtpatientcontact.Text = modPatient.GetLocationSetting($encid)
  modGeneralMain.RecordPatientActivity("Patient Data", Me.Name, "EncounterID", $encid)
  ShowSampled($encid)
  lsticdisease.List = modPathology.GetProvisionalDiagnosisList(Trim(txtencid.Text))
  btnupdate.Enabled = False
  modImage.ShowPhotoSplash("Patient", modPatient.GetPatientNoByEnc($encid))

End

Public Sub btnwebcam_Click()

  txtencid.Text = modDevice.ChooseBarCodeSource()
  txtencid.SetFocus
  txtencid.Pos = Len(txtencid.Text)

End

Public Sub cmbsamtype_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbsamtype)
  modFillContainer.RestrictComboToContent(cmbsamtype)

End

'''------------------------------------------ added tests -------------------------------------------
Private Sub ShowSampled(encid As String)

  Dim sql As String
  Dim Column As Integer
  Dim fld As ResultField

  If chkall.Value = True Then
    sql = "select fldid,fldchk,fldgroupid,fldtestid,fldtime_sample,fldsampleid,fldsampletype,fldtest_type,fldrefername,fldcomment,fldencounterval,fldtime_start from tblpatlabtest where (fldstatus=&1 or fldstatus=&2) and fldencounterval=&3 and fldcomp_sample=&4"
    $rData = modDatabase.$myConn.Exec(sql, "Ordered", "Sampled", encid, modGeneralMain.compID)
  Else
    sql = "select fldid,fldchk,fldgroupid,fldtestid,fldtime_sample,fldsampleid,fldsampletype,fldtest_type,fldrefername,fldcomment,fldencounterval,fldtime_start from tblpatlabtest where fldstatus=&1 and fldencounterval=&2 and fldcomp_sample=&3"
    $rData = modDatabase.$myConn.Exec(sql, "Ordered", encid, modGeneralMain.compID)
  Endif

  GridView1.Clear
  GridView1.Columns.Count = $rData.Fields.Count
  GridView1.Rows.Count = $rData.Count

  For Each $rData
    Column = 0
    For Each fld In $rData.Fields
      modGeneralMain.GridExplicitDecoration(GridView1, $rData.Index, Column)
      If Column = 1 Then
        GridView1[$rData.Index, Column].Picture = modBasic.$PictureUnchecked
        GridView1[$rData.Index, Column].Text = ""
      Else If Column = 2 Then
        GridView1[$rData.Index, Column].Text = modBillings.GetBillingItemFromID($rData[fld.Name])
      Else If Column = 4 Then
        GridView1[$rData.Index, Column].Text = modReportVar.GetDateTimeReport($rData["fldtime_sample"], gb.GeneralDate)
      Else If Column = 11 Then
        GridView1[$rData.Index, Column].Text = modReportVar.GetDateTimeReport($rData["fldtime_start"], gb.GeneralDate)
      Else
        GridView1[$rData.Index, Column].Text = $rData[fld.Name]
      Endif
      Column = Column + 1
    Next
  Next
  GridView1.Row = 0

  With GridView1
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 1
    .Columns[1].Width = 20
    .Columns[2].Width = 125 * modBasic.$AppWidthRatio
    .Columns[3].Width = 200 * modBasic.$AppWidthRatio
    .Columns[4].Width = 150 * modBasic.$AppWidthRatio
    .Columns[5].Width = 75 * modBasic.$AppWidthRatio
    .Columns[6].Width = 125 * modBasic.$AppWidthRatio
    .Columns[7].Width = 1
    .Columns[8].Width = 120 * modBasic.$AppWidthRatio
    .Columns[9].Width = 1
    .Columns[10].Width = 1
    .Columns[11].Width = 150 * modBasic.$AppWidthRatio

    .Columns[2].Text = "Account"
    .Columns[3].Text = "Test Name"
    .Columns[4].Text = "SampleDate"
    .Columns[5].Text = "SampleID"
    .Columns[6].Text = "Specimen"
    .Columns[8].Text = "Referral"
    .Columns[11].Text = "LoadDate"
  End With

End

Public Sub GridView1_Click()

  Dim xsample As String
  Dim xx As String

  If GridView1.Column = 6 Then
    xx = GetTextArea(("Specimen"), GridView1[GridView1.Row, 6].Text)
    If xx Then
      modLabTest.UpdateSpecimenTest(GridView1[GridView1.Row, 0].Text, xx)
      ShowSampled(Trim(txtencid.Text))
    Endif

  Else
    xsample = GridView1[GridView1.Row, 6].Text
    If Not xsample Then
      xsample = modFixLab.GetTestSpecimen(GridView1[GridView1.Row, 3].Text)
    Endif

    If GridView1[GridView1.Row, 5].Text Then
      txtsamid.Text = GridView1[GridView1.Row, 5].Text
    Endif

    cmbsamtype.Text = xsample
    modGridView.CheckUncheckGridNoDB(GridView1, 1)
    btnupdate.Enabled = True
  Endif

End

Public Sub GridView1_Menu()

  mnuhide.Popup

End

Public Sub btnsampid_Click()

  If Not txtsamid.Text Then
    If cmbsamtype.Text And If GridView1.Rows.Count > 0 Then
      txtsamid.Text = modLabTest.GetAutoIncreasingNo()
    Endif
  Endif

End

