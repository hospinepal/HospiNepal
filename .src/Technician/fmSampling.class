  hForm = New FmAddVariableGrid("fldsampletype", "tblsampletype")
  hForm.ShowModal
  cmbsamtype.List = modMedicine.GetLabSampleTypeList()

End

Public Sub btnclrspec_Click()

  cmbsamtype.Text = ""

End

Public Sub btnupdate_Click()

  Dim Row As Integer
  Dim res As Result
  Dim xxx As String[]
  Dim xallow As Boolean

  If txtsamid.Text And If cmbsamtype.Text Then
    xallow = modLabTest.AllowSampleID($encid, Trim(txtsamid.Text))
    If xallow = True Then

      For Row = 0 To GridView1.Rows.Count - 1
        If GridView1[Row, 1].Picture = modBasic.$PictureChecked Then

          If dtcurr.Value Then
            modLabTest.UpdateLabTestSample(GridView1[Row, 0].Text, Trim(txtsamid.Text), cmbsamtype.Text, "", "", "", "", dtcurr.Value)
          Else
            modLabTest.UpdateLabTestSample(GridView1[Row, 0].Text, Trim(txtsamid.Text), cmbsamtype.Text, "", "", "", "")
          Endif

          res = modDatabase.$myConn.Exec("select fldsubtest from tblpatlabsubtest where fldtestid=&1", GridView1[Row, 0].Text)
          If res.Available = False Then
            If modFixLab.GetLabTestOptionType(GridView1[Row, 3].Text) = "Fixed Components" Then
              xxx = modFixLab.GetSubTestArray(GridView1[Row, 3].Text)     'modFillContainer.GetListFromResult(modDatabase.$myConn.Exec("select distinct(fldsubtest) as col from tbltestquali where fldtestid=&1", GridView1[Row, 3].Text))
              If xxx.Count Then
                modLabTest.InsertLabSubTest(GridView1[Row, 10].Text, GridView1[Row, 0].Text, xxx)
              Endif
            Endif
          Endif

        Endif
      Next

      If rbbar.Value = True Then
        btnbarcode_Click()
      Endif
      If rbwork.Value = True Then
        btnwork_Click()
      Endif
      ShowSampled(Trim(txtencid.Text))
      Balloon.Info(("Information updated"), btnupdate)
      Balloon.Delay = modBasic.$BalloonDelay

    Else
      Message.Warning(("Same Sample ID for different patients not possible"), ("OK"))
    Endif
  Endif

End

