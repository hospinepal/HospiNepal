' Gambas class file

Private $encid As String
Private $rData As Result

Private $rData2 As Result
Private $aMyFields2 As String[]
Private $rData3 As Result

Public Sub Form_Open()

  modGeneralMain.ArrangeEmbedForms(Me, Panel1)
  Panel5.Height = Panel1.Height - (Panel2.Height + 5)
  Panel7.Height = Panel1.Height - (Panel2.Height + 5)
  Panel9.Height = Panel1.Height - (Panel2.Height + 5)
  Me.Icon = Picture[modGeneralMain.$strLogo]
  cmbsamtype.List = modMedicine.GetLabSampleTypeList()
  If modGlobalSetting.ShowSettingFromDB("GeneralSettings/Laboratory_SampleDateLock") = "No" Then
    dtcurr.Enabled = True
    dtcurr.Value = Now()
  Endif
  modSettings.ShowCheckBox(rbwork, "TestSampling/WorkSheet")
  modSettings.ShowCheckBox(rbbar, "TestSampling/BarCode")
  modSettings.ShowCheckBox(chkall, "TestSampling/ShowAll")
  cmbcategory.List = modMedicine.GetPathoCategoryList("Test")
  cmbcategory.Add("%")
  cmbcategory.Text = modSettings.ShowSettingFromFIle("Laboratory/DefaultDepartment")
  txtencid.SetFocus

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub Form_KeyRelease()

  If Key.Code = Key["O"] And If Key.Control Then
    btnwebcam_Click()
  Else If Key.Code = Key["R"] And If Key.Control Then
    btnrefresh_Click()
  Else If Key.Code = Key.F1 Then
    btnsearch_Click()
  Else If Key.Code = Key.F12 Then
    btnbarcode_Click()
  Else If Key.Code = Key["L"] And If Key.Control Then
    btnsampid_Click()
  Else If Key.Code = Key["W"] And If Key.Control Then
    btnwork_Click()
  Else If Key.Code = Key["F"] And If Key.Control Then
    txtencid.Text = GetEncid()
  Else If Key.Code = Key["X"] And If Key.Control Then
    Me.Close()
  Else If Key.Code = Key["B"] And If Key.Control Then
    Me.Close
    Wait
    modHelpVariable.AddNewFormToWorkspace(fmSampling)
  Endif

End

Public Sub Form_Close()

  modSettings.SaveSettingsToFile("Laboratory/DefaultDepartment", cmbcategory.Text)
  modGeneralMain.RecordFormExit(Me)

End

Public Sub btnrefresh_Click()

  Inc Application.Busy
  FillSamplingEncounters()
  ShowEncounterTests("")
  ShowSampled("")
  Dec Application.Busy
  ClearSpecimenVal()
  GridView2.SetFocus

End

''---------------------------- sample grids -------------------------
Public Sub cmbcategory_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbcategory)
  modFillContainer.RestrictComboToContent(cmbcategory)

End

Private Sub FillSamplingEncounters()

  Dim sql As String
  Dim xcomp As String
  Dim xstr As String

  If modBasic.$LabSamplingComp Then
    xcomp = modBasic.$LabSamplingComp
  Else
    xcomp = "%"
  Endif
  If modBasic.$LabSamplingFrom = "Not From" Then
    xstr = "fldordcomp not like &6 ORDER BY fldid ASC"
  Else
    xstr = "fldordcomp like &6 ORDER BY fldid ASC"
  Endif

  If cmbcategory.Text = "%" Then
    sql = "select distinct(fldencounterval) as fldencounterval,fldencounterval,fldencounterval,fldordcomp from tblpatbilling where flditemtype=&1 and fldsample=&2 and fldsave=&3 and fldtarget=&4 and flditemname like &5 and flditemqty>fldretqty and " & xstr                                                  ''
    $rData2 = modDatabase.$myConn.Exec(sql, "Diagnostic Tests", "Waiting", True, modGeneralMain.compID, "%", xcomp)
  Else
    sql = "select distinct(fldencounterval) as fldencounterval,fldencounterval,fldencounterval,fldordcomp from tblpatbilling where flditemtype=&1 and fldsample=&2 and fldsave=&3 and fldtarget=&4 and flditemname in(select fldgroupname from tblgrouptest where fldtestid in(select fldtestid from tbltest where fldcategory like &5)) and flditemqty>fldretqty and " & xstr                                                  ''
    $rData2 = modDatabase.$myConn.Exec(sql, "Diagnostic Tests", "Waiting", True, modGeneralMain.compID, cmbcategory.Text, xcomp)
  Endif
  $aMyFields2 = New String[]
  modGridView.ReadSmallData(GridView2, $rData2, $aMyFields2)
  SHowPatientGrid()

End

Private Sub FillSamplingSelectedEncounter(encid As String)

  Dim sql As String

  If cmbcategory.Text = "%" Then
    sql = "select distinct(fldencounterval) as fldencounterval,fldencounterval,fldencounterval,fldordcomp from tblpatbilling where flditemtype=&1 and fldsample=&2 and fldsave=&3 and fldtarget=&4 and flditemname like &5 and fldencounterval=&6 and flditemqty>fldretqty"                                                                         ''
    $rData2 = modDatabase.$myConn.Exec(sql, "Diagnostic Tests", "Waiting", True, modGeneralMain.compID, "%", encid)
  Else
    sql = "select distinct(fldencounterval) as fldencounterval,fldencounterval,fldencounterval,fldordcomp from tblpatbilling where flditemtype=&1 and fldsample=&2 and fldsave=&3 and fldtarget=&4 and flditemname in(select fldgroupname from tblgrouptest where fldtestid in(select fldtestid from tbltest where fldcategory like &5)) and fldencounterval=&6 and flditemqty>fldretqty"                                                                         ''
    $rData2 = modDatabase.$myConn.Exec(sql, "Diagnostic Tests", "Waiting", True, modGeneralMain.compID, cmbcategory.Text, encid)
  Endif
  $aMyFields2 = New String[]
  modGridView.ReadSmallData(GridView2, $rData2, $aMyFields2)
  SHowPatientGrid()

End

Private Sub SHowPatientGrid()

  With GridView2
    .Columns[0].Width = 75 * modBasic.$AppWidthRatio
    .Columns[1].Width = 10 * modBasic.$AppWidthRatio
    .Columns[2].Width = 150 * modBasic.$AppWidthRatio
    .Columns[0].Text = "EncID"
    .Columns[2].Text = "Name"
    .Columns[3].Text = "Sender"
  End With

End

Public Sub GridView2_Data(Row As Integer, Column As Integer)

  $rData2.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView2, Row)
  If Column = 1 Then
    GridView2.Data.Text = ""
    GridView2.Data.Background = modPatient.GetPatientColor($rData2[$aMyFields2[Column]])
  Else If Column = 2 Then
    GridView2.Data.Text = modPatient.GetPatientNameByEnc($rData2[$aMyFields2[Column]])
  Else
    GridView2.Data.Text = $rData2[$aMyFields2[Column]]
  Endif

End

Public Sub btnsearch_Click()

  Dim enc As String

  If modBasic.$AutoEncPrefix = "Yes" Then
    enc = InputBox(("Encounter ID of Patient"), ("Search Patient"), modBasic.$EncIdPrefix)
  Else
    enc = InputBox(("Encounter ID of Patient"), ("Search Patient"), "")
  Endif
  If enc Then
    FillSamplingSelectedEncounter(Trim(enc))
    ShowEncounterTests(Trim(enc))
    ShowSampled("")
    ClearSpecimenVal()
    GridView3.SetFocus
  Endif

End

Public Sub btnseartext_Click()

  Dim xx As String
  Dim p As Integer

  xx = InputBox("Patient Name to search..", "Search Text", "")
  If xx Then
    p = modGridView.SearchTextinGrid(GridView2, 2, xx)
    Balloon.Info(CStr(p) & (" Text Found"), btnseartext)
    Balloon.Delay = modBasic.$BalloonDelay
  Endif

End

Public Sub GridView2_Click()

  If GridView2.Rows.Selection.Count > 0 Then
    ShowEncounterTests(GridView2[GridView2.Row, 0].Text)
    txtcolor.Background = modPatient.GetPatientColor(GridView2[GridView2.Row, 0].Text)
    ShowSampled("")
    ClearSpecimenVal()
    GridView3.SetFocus
  Endif

End

Public Sub GridView2_KeyRelease()

  If GridView2.Rows.Selection.Count > 0 Then
    If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
      GridView2_Click()
    Endif
  Endif

End

Private Sub ShowEncounterTests(encid As String)

  Dim sql As String
  Dim Column As Integer
  Dim fld As ResultField

  If cmbcategory.Text = "%" Then
    sql = "select flditemname,fldtime,fldid,fldencounterval from tblpatbilling where flditemtype=&1 and fldsample=&2 and fldencounterval=&3 and fldsave=&4 and fldtarget=&5 and flditemqty>fldretqty"
  Else
    sql = "select flditemname,fldtime,fldid,fldencounterval from tblpatbilling where flditemtype=&1 and fldsample=&2 and fldencounterval=&3 and fldsave=&4 and fldtarget=&5 and flditemname in(select fldgroupname from tblgrouptest where fldtestid in(select fldtestid from tbltest where fldcategory like &6)) and flditemqty>fldretqty"
  Endif
  $rData3 = modDatabase.$myConn.Exec(sql, "Diagnostic Tests", "Waiting", encid, True, modGeneralMain.compID, cmbcategory.Text)

  GridView3.Clear
  GridView3.Columns.Count = $rData3.Fields.Count
  GridView3.Rows.Count = $rData3.Count

  For Each $rData3
    Column = 0
    For Each fld In $rData3.Fields
      modGeneralMain.GridExplicitDecoration(GridView3, $rData3.Index, Column)
      If Column = 1 Then
        GridView3[$rData3.Index, Column].Text = modReportVar.GetDateTimeReport($rData3["fldtime"], gb.GeneralDate)
      Else
        GridView3[$rData3.Index, Column].Text = $rData3[fld.Name]
      Endif
      Column = Column + 1
    Next
  Next
  GridView3.Row = 0

  With GridView3
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 250 * modBasic.$AppWidthRatio
    .Columns[1].Width = 150 * modBasic.$AppWidthRatio
    .Columns[2].Width = 1
    .Columns[3].Width = 1
    .Columns[0].Text = "Test Name"
    .Columns[1].Text = "DateTime"
  End With

End

Public Sub GridView3_Menu()

  mnutree.Popup

End

Public Sub btnexpotree_Click()

  Dim $BillingReport As CReportHTML
  Dim asx As New String[0]
  Dim sql As String
  Dim res As Result
  Dim xcomp As String

  If modBasic.$LabSamplingComp Then
    xcomp = modBasic.$LabSamplingComp
  Else
    xcomp = "%"
  Endif

  Inc Application.Busy
  $BillingReport = New CReportHTML([("Encounter"), ("PatientName"), ("Age/Sex"), ("Particulars"), ("Remarks")], modHelpVariable.$htmlDirectory, " ", "")
  $BillingReport.UserData.Add("TEST REQUESTS", "PARAM1")
  $BillingReport.UserData.Add("Category : " & cmbcategory.Text, "PARAM2")

  If cmbcategory.Text = "%" Then
    sql = "select distinct(fldencounterval) from tblpatbilling where flditemtype=&1 and fldsample=&2 and fldsave=&3 and fldtarget=&4 and fldordcomp like &5 and flditemqty>fldretqty"
  Else
    sql = "select distinct(fldencounterval) from tblpatbilling where flditemtype=&1 and fldsample=&2 and fldsave=&3 and fldtarget=&4 and fldordcomp like &5 and flditemname in(select fldgroupname from tblgrouptest where fldtestid in(select fldtestid from tbltest where fldcategory like &6)) and flditemqty>fldretqty"
  Endif
  res = modDatabase.$myConn.Exec(sql, "Diagnostic Tests", "Waiting", True, modGeneralMain.compID, xcomp, cmbcategory.Text)

  If res.Available Then
    For Each res
      With asx
        .Add(res!fldencounterval)
        .Add(modPatient.GetPatientNameByEnc(res!fldencounterval))
        .Add(modPatient.GetPatientAgeString(res!fldencounterval, Now()) & "/" & modPatient.GetPatientSex(res!fldencounterval))
        .Add(GetTestListForSample(res!fldencounterval).Join("; "))
        .Add("")
      End With
      $BillingReport.Add(asx)
      asx.Clear()
    Next
  Endif

  Dec Application.Busy
  modPrint.OpenHTMLPreview("", $BillingReport.NewHTMLPath(), "ReportSize")

End

Private Sub GetTestListForSample(encid As String) As String[]

  Dim xx As String[]
  Dim sql As String
  Dim res As Result

  If cmbcategory.Text = "%" Then
    sql = "select flditemname from tblpatbilling where flditemtype=&1 and fldsample=&2 and fldencounterval=&3 and fldsave=&4 and fldtarget=&5 and flditemqty>fldretqty"
  Else
    sql = "select flditemname from tblpatbilling where flditemtype=&1 and fldsample=&2 and fldencounterval=&3 and fldsave=&4 and fldtarget=&5 and flditemname in(select fldgroupname from tblgrouptest where fldtestid in(select fldtestid from tbltest where fldcategory like &6)) and flditemqty>fldretqty"
  Endif
  res = modDatabase.$myConn.Exec(sql, "Diagnostic Tests", "Waiting", encid, True, modGeneralMain.compID, cmbcategory.Text)
  xx = modFillContainer.GetListFromResult(res)
  Return xx

End

Private Sub AddSampling()

  Dim res As Result
  Dim res1 As Result
  Dim j As Integer
  Dim res2 As Result

  If GridView3.Rows.Selection.Count > 0 Then
    res2 = modDatabase.$myConn.Exec("select flditemqty,fldretqty,fldbillno,fldrefer,fldreason from tblpatbilling where fldid=&1 and flditemqty>&2", GridView3[GridView3.Row, 2].Text, 0)
    res = modDatabase.$myConn.Exec("select fldtestid,fldtesttype,fldactive from tblgrouptest where fldgroupname=&1", GridView3[GridView3.Row, 0].Text)
    If res.Available = True Then
      If res2!flditemqty > res2!fldretqty Then

        Inc Application.Busy
        modDatabase.$myConn.Begin
        For Each res
          For j = 1 To (res2!flditemqty - res2!fldretqty)
            modLabTest.InsertLabTestOrder(GridView3[GridView3.Row, 3].Text, res!fldtestid, res!fldtesttype, res!fldactive, GridView3[GridView3.Row, 2].Text, modGeneral.GetUserFullNamePrint(res2!fldrefer), res2!fldbillno, res2!fldreason)
          Next
        Next
        txtencid.Text = GridView3[GridView3.Row, 3].Text
        res1 = modDatabase.$myConn.Edit("tblpatbilling", "fldid=&1", GridView3[GridView3.Row, 2].Text)
        res1["fldsample"] = "Sampled"
        res1["fldpayto"] = btnpayto.Tag
        res1["xyz"] = False
        res1.Update()
        modDatabase.$myConn.Commit
        Dec Application.Busy

      Endif
      btnshow_Click()
      ShowEncounterTests(GridView2[GridView2.Row, 0].Text)
    Endif
  Endif

Catch
  modDatabase.$myConn.Rollback
  Dec Application.Busy
  modHelpVariable.CreateErrorReport()

End

Public Sub mnuadd_Click()

  AddSampling()

End

Public Sub mnudel_Click()

  Dim res As Result

  If GridView3.Rows.Selection.Count > 0 Then
    If Message.Question(("Are you sure?"), ("No"), ("Yes")) = 2 Then
      Inc Application.Busy
      modDatabase.$myConn.Begin
      res = modDatabase.$myConn.Edit("tblpatbilling", "fldid=&1", GridView3[GridView3.Row, 2].Text)
      If res.Available = True Then
        If modBasic.$BillAutoReturn = "No" Then
        Else
          modBillings.InsertBlankBillItem(res!fldencounterval, res!fldbillingmode, res!flditemtype, res!flditemno, res!flditemname, res!flditemrate, 0 - res!flditemqty, res!fldtaxper, res!flddiscper, "Done", res!fldid, True, False, res!fldtarget, res!fldpayto, res!fldrefer, "AutoReturn", res!fldbillno)              ''
        Endif
        res["fldsample"] = "Removed"
        res["fldretqty"] = res!flditemqty
        res["xyz"] = False
        res.Update()
      Endif
      modDatabase.$myConn.Commit
      Dec Application.Busy
      ShowEncounterTests(GridView2[GridView2.Row, 0].Text)
    Endif
  Endif

Catch
  modDatabase.$myConn.Rollback
  Dec Application.Busy
  modHelpVariable.CreateErrorReport()

End

Public Sub mnutransf_Click()

  Dim res As Result
  Dim xx As String

  If GridView3.Rows.Selection.Count > 0 Then
    xx = InputCombo(("Enter Target Location"), ("Transfer"), modBasic.$AllCompList, "", True)
    If xx Then
      res = modDatabase.$myConn.Edit("tblpatbilling", "fldid=&1", GridView3[GridView3.Row, 2].Text)
      res["fldtarget"] = xx
      res["xyz"] = False
      res.Update()
      If xx <> modGeneralMain.compID Then
        ShowEncounterTests(GridView2[GridView2.Row, 0].Text)
      Endif
    Endif
  Endif

End

Public Sub btnpayto_Click()

  btnpayto.Tag = MedicalSelectedUser(("Select Payable User"), modBasic.$PayUserList)
  btnpayto.Text = modGeneral.GetUserFullName(btnpayto.Tag)

End

