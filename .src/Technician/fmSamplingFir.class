Public Sub btnupdate_Click()

  Dim Row As Integer
  Dim res As Result
  Dim xxx As String[]
  Dim xallow As Boolean

  If txtsamid.Text And If cmbsamtype.Text Then
    xallow = modLabTest.AllowSampleID(Trim(txtencid.Text), Trim(txtsamid.Text))
    If xallow = True Then

      For Row = 0 To GridView1.Rows.Count - 1
        If GridView1[Row, 1].Picture = modBasic.$PictureChecked Then
          If dtcurr.Value Then
            modLabTest.UpdateLabTestSample(GridView1[Row, 0].Text, Trim(txtsamid.Text), cmbsamtype.Text, txtrefer.Text, txtcondition.Text, txtcomment.Text, txtbillno.Text, dtcurr.Value)
          Else
            modLabTest.UpdateLabTestSample(GridView1[Row, 0].Text, Trim(txtsamid.Text), cmbsamtype.Text, txtrefer.Text, txtcondition.Text, txtcomment.Text, txtbillno.Text)
          Endif

          res = modDatabase.$myConn.Exec("select fldsubtest from tblpatlabsubtest where fldtestid=&1", GridView1[Row, 0].Text)
          If res.Available = False Then
            If modFixLab.GetLabTestOptionType(GridView1[Row, 2].Text) = "Fixed Components" Then
              xxx = modFixLab.GetSubTestArray(GridView1[Row, 2].Text)      'modFillContainer.GetListFromResult(modDatabase.$myConn.Exec("select distinct(fldsubtest) as col from tbltestquali where fldtestid=&1", GridView1[Row, 2].Text))
              If xxx.Count Then
                modLabTest.InsertLabSubTest(GridView1[Row, 10].Text, GridView1[Row, 0].Text, xxx)
              Endif
            Endif
          Endif

        Endif
      Next

      If rbbar.Value = True Then
        btnbarcode_Click()
      Endif
      If rbwork.Value = True Then
        btnwork_Click()
      Endif
      ShowSampled()
      Balloon.Info(("Information updated"), btnupdate)
      Balloon.Delay = modBasic.$BalloonDelay

    Else
      Message.Warning(("Same Sample ID for different patients not possible"), ("OK"))
    Endif
  Endif

End

Public Sub dtnepcal_Click()

  Dim xx As String

  xx = BSDateFormat(("Enter BS Date in yyyy/mm/dd format"), ("Date Converter"), modDate.ConvertToLocaldate(dtcurr.Value))
  If xx Then
    dtcurr.Value = modDate.ConvertToEnglishdate(xx)
  Endif

End

Public Sub btnbarcode_Click()

  Dim i As Integer
  Dim xval As String[]
  Dim xsect As String

  Dim xx As String

  If txtsamid.Text And If txtencid.Text Then
    If GridView1.Rows.Count Then

      xval = New String[]
      For i = 0 To GridView1.Rows.Count - 1
        If GridView1[i, 1].Picture = modBasic.$PictureChecked Then

          If modBasic.$LabBarPrint = "Section" Then
            xsect = modFixLab.GetLabTestCategory(GridView1[i, 2].Text)
          Else If modBasic.$LabBarPrint = "TestName" Then
            xsect = GridView1[i, 2].Text
          Else
            xsect = ""
          Endif

          If xsect Then
            If xval.Count = 0 Then
              xval.Add(xsect)
            Else
              If xval.Exist(xsect) = False Then
                xval.Add(xsect)
              Endif
            Endif
          Endif

        Endif
      Next

      If xval.Count Then
        For Each xx In xval
          modLabTest.PrintBarCodeSampling(Trim(txtencid.Text), Trim(txtsamid.Text), cmbsamtype.Text, xx)
        Next
      Else
        modLabTest.PrintBarCodeSampling(Trim(txtencid.Text), Trim(txtsamid.Text), cmbsamtype.Text, "")
      Endif

    Endif
  Endif

End

