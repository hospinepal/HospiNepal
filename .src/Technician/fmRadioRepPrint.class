' Gambas class file

Private $rData As Result
Private $rData1 As Result
Private $encid As String
Private $TestID As Long
Private $CategList As String[]

Public Sub _new(encid As String)

  txtencid.Text = encid

End

Public Sub Form_Open()

  modGeneralMain.ArrangeEmbedForms(Me, Panel1, "Vertical")
  Me.Icon = Picture[modGeneralMain.$strLogo]
  cmbcategory.List = modMedicine.GetPathoCategoryList("Radio")
  cmbcategory.Add("%")
  cmbcategory.Text = modSettings.ShowSettingFromFIle("Radiology/DefaultDepartment")

  DefaultTestReportFormat(rbform1, rbform2, rbform3)
  modSettings.ShowCheckBox(chknew, "RadioReportFormat/NewItems")
  modSettings.ShowCheckBox(chkprinted, "RadioReportFormat/PrintedItems")
  modSettings.ShowCheckBox(chkmark, "RadioReportFormat/MarkPrinted")
  modMisc.LockReportOutput(rbreported, rbverified, Panel3)

  rbtext.Value = True
  dtfrom.Value = modDate.StartSqlDate(Now())
  dtto.Value = modDate.EndSqlDate(Now())
  DateSelectionSett()
  txtencid.SetFocus

End

Public Sub Form_Activate()

  If Not txtencid.Text Then
    txtencid.SetFocus
  Endif

End

Public Sub Form_Close()

  modSettings.SaveSettingsToFile("Radiology/DefaultDepartment", cmbcategory.Text)
  modGeneralMain.RecordFormExit(Me)

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub Form_KeyRelease()

  If Key.Code = Key["F"] And If Key.Control Then
    txtencid.Text = GetEncid()
  Else If Key.Code = Key["X"] And If Key.Control Then
    Me.Close()
  Endif

End

Public Sub chknew_Click()

  modSettings.EnterCheckSetting(chknew, "RadioReportFormat/NewItems")

End

Public Sub chkprinted_Click()

  modSettings.EnterCheckSetting(chkprinted, "RadioReportFormat/PrintedItems")

End

Public Sub chkmark_Click()

  modSettings.EnterCheckSetting(chkmark, "RadioReportFormat/MarkPrinted")

End

Private Sub DefaultTestReportFormat(rbformA As Radiobutton, rbformB As Radiobutton, rbformC As RadioButton)

  Dim def As String

  def = modSettings.ShowSettingFromFIle("RadioReportFormat/Format")
  If def Then
    If def = "A" Then
      rbformA.Value = True
    Else If def = "B" Then
      rbformB.Value = True
    Else If def = "C" Then
      rbformC.Value = True
    Endif
  Else
    rbformB.Value = True
  Endif

End

Private Sub EnableButton(sval As Boolean)

  If sval = True Then
    btnrecord.Enabled = True
    btnftp.Enabled = True
    btnreport.Enabled = True
  Else If sval = False Then
    btnrecord.Enabled = False
    btnftp.Enabled = False
    btnreport.Enabled = False
  Endif

End

Private Sub EnableSelected()

  Dim sval As Integer
  Dim i As Integer

  sval = 0
  For i = 0 To GridView1.Rows.Count - 1
    If GridView1[i, 1].Picture = modBasic.$PictureChecked Then
      sval = sval + 1
    Endif
  Next
  If sval Then
    EnableButton(True)
  Else
    EnableButton(False)
  Endif

End

Public Sub rbform1_Click()

  modSettings.SaveSettingsToFile("RadioReportFormat/Format", "A")

End

Public Sub rbform2_Click()

  modSettings.SaveSettingsToFile("RadioReportFormat/Format", "B")

End

Public Sub rbform3_Click()

  modSettings.SaveSettingsToFile("RadioReportFormat/Format", "C")

End

Public Sub btnshow_Click()

  If txtencid.Text And If cmbcategory.Text Then
    $encid = Trim(txtencid.Text)
    txtpatientname.Text = modPatient.GetPatientNameByEnc($encid)
    txtgender.Text = modPatient.GetPatientAgeString($encid, Now()) & "/" & modPatient.GetPatientSex($encid)
    txtpatientcontact.Text = modPatient.GetLocationSetting($encid)
    modGeneralMain.RecordPatientActivity("Patient Data", Me.Name, "EncounterID", $encid)
    $CategList = New String[]
    If modPatient.AllowEncIDHistory($encid, modDatabase.$myConn) = True Then
      FillLabtable()
      txtcomment.Text = ""
      GridView1.SetFocus
    Else
      Me.Enabled = False
    Endif
  Endif

End

Private Function GetReportOrder(sType As String) As String

  Dim xx As String

  If modSettings.ShowSettingFromFIle("Laboratory/Report_Order") Then
    If modSettings.ShowSettingFromFIle("Laboratory/Report_Order") = "ASC" Then
      If sType = "Test" Then
        xx = " ORDER BY fldtestid ASC"
      Else If sType = "SubTest" Then
        xx = " ORDER BY fldsubtest ASC"
      Endif
    Else If modSettings.ShowSettingFromFIle("Laboratory/Report_Order") = "DESC" Then
      If sType = "Test" Then
        xx = " ORDER BY fldtestid DESC"
      Else If sType = "SubTest" Then
        xx = " ORDER BY fldsubtest DESC"
      Endif
    Else If modSettings.ShowSettingFromFIle("Laboratory/Report_Order") = "Manual" Then
      If sType = "Test" Then
        xx = " ORDER BY fldorder ASC"
      Else If sType = "SubTest" Then
        xx = " ORDER BY fldorder ASC"
      Endif
    Else
      If sType = "Test" Then
        xx = ""
      Else If sType = "SubTest" Then
        xx = ""
      Endif
    Endif
  Else
    If sType = "Test" Then
      xx = ""
    Else If sType = "SubTest" Then
      xx = ""
    Endif
  Endif

  Return xx

End

Private Sub DateSelectionSett()

  If chkdate.Value = True Then
    Panel7.Enabled = True
  Else
    Panel7.Enabled = False
  Endif

End

Public Sub chkdate_Click()

  DateSelectionSett()

End

Private Sub FillLabtable()

  Dim reprt As String
  Dim vrfd As String
  Dim sprt As Boolean
  Dim testList As String[]

  Dim Column As Integer
  Dim fld As ResultField

  If rbreported.Value = True Then
    vrfd = "Verified"
    reprt = "Reported"
  Else If rbverified.Value = True Then
    vrfd = "Verified"
    reprt = "Verified"
  Endif

  If chkdate.Value = True Then
    If chknew.Value And If chkprinted.Value Then
      If cmbcategory.Text = "%" Then
        $rData = modDatabase.$myConn.Exec("select fldid,fldchk,fldsave_report,fldtest_type,fldtestid,fldmethod,fldtime_report,fldabnormal,fldid,fldid,fldstatus,flduserid_report,flduserid_verify,fldsampletype,fldcondition,fldtime_report,fldprint,fldorder,fldtestid from tblpatradiotest where fldsave_report=&1 and fldencounterval=&2 and (fldstatus=&3 or fldstatus=&4) and flvisible=&5 and fldtime_report>=&6 and fldtime_report<=&7" & GetReportOrder("Test"), True, Trim(txtencid.Text), reprt, vrfd, "Visible", dtfrom.Value, dtto.Value)
      Else
        $rData = modDatabase.$myConn.Exec("select fldid,fldchk,fldsave_report,fldtest_type,fldtestid,fldmethod,fldtime_report,fldabnormal,fldid,fldid,fldstatus,flduserid_report,flduserid_verify,fldsampletype,fldcondition,fldtime_report,fldprint,fldorder,fldtestid from tblpatradiotest where fldsave_report=&1 and fldencounterval=&2 and (fldstatus=&3 or fldstatus=&4) and flvisible=&5 and fldtestid in(select fldexamid from tblradio where fldcategory like &6) and fldtime_report>=&6 and fldtime_report>=&7 and fldtime_report<=&8 and fldtime_report<=&7" & GetReportOrder("Test"), True, Trim(txtencid.Text), reprt, vrfd, "Visible", cmbcategory.Text, dtfrom.Value, dtto.Value)                                                   ''
      Endif
    Else
      If chknew.Value Then
        sprt = False
      Else If chkprinted.Value Then
        sprt = True
      Endif
      If cmbcategory.Text = "%" Then
        $rData = modDatabase.$myConn.Exec("select fldid,fldchk,fldsave_report,fldtest_type,fldtestid,fldmethod,fldtime_report,fldabnormal,fldid,fldid,fldstatus,flduserid_report,flduserid_verify,fldsampletype,fldcondition,fldtime_report,fldprint,fldorder,fldtestid from tblpatradiotest where fldsave_report=&1 and fldencounterval=&2 and (fldstatus=&3 or fldstatus=&4) and fldprint=&5 and flvisible=&6 and fldtime_report>=&7 and fldtime_report<=&8" & GetReportOrder("Test"), True, Trim(txtencid.Text), reprt, vrfd, sprt, "Visible", dtfrom.Value, dtto.Value)
      Else
        $rData = modDatabase.$myConn.Exec("select fldid,fldchk,fldsave_report,fldtest_type,fldtestid,fldmethod,fldtime_report,fldabnormal,fldid,fldid,fldstatus,flduserid_report,flduserid_verify,fldsampletype,fldcondition,fldtime_report,fldprint,fldorder,fldtestid from tblpatradiotest where fldsave_report=&1 and fldencounterval=&2 and (fldstatus=&3 or fldstatus=&4) and fldprint=&5 and flvisible=&6 and fldtestid in(select fldexamid from tblradio where fldcategory like &7) and fldtime_report>=&8 and fldtime_report<=&9" & GetReportOrder("Test"), True, Trim(txtencid.Text), reprt, vrfd, sprt, "Visible", cmbcategory.Text, dtfrom.Value, dtto.Value)                                                   ''
      Endif
    Endif

  Else
    If chknew.Value And If chkprinted.Value Then
      If cmbcategory.Text = "%" Then
        $rData = modDatabase.$myConn.Exec("select fldid,fldchk,fldsave_report,fldtest_type,fldtestid,fldmethod,fldtime_report,fldabnormal,fldid,fldid,fldstatus,flduserid_report,flduserid_verify,fldsampletype,fldcondition,fldtime_report,fldprint,fldorder,fldtestid from tblpatradiotest where fldsave_report=&1 and fldencounterval=&2 and (fldstatus=&3 or fldstatus=&4) and flvisible=&5" & GetReportOrder("Test"), True, Trim(txtencid.Text), reprt, vrfd, "Visible")
      Else
        $rData = modDatabase.$myConn.Exec("select fldid,fldchk,fldsave_report,fldtest_type,fldtestid,fldmethod,fldtime_report,fldabnormal,fldid,fldid,fldstatus,flduserid_report,flduserid_verify,fldsampletype,fldcondition,fldtime_report,fldprint,fldorder,fldtestid from tblpatradiotest where fldsave_report=&1 and fldencounterval=&2 and (fldstatus=&3 or fldstatus=&4) and flvisible=&5 and fldtestid in(select fldexamid from tblradio where fldcategory like &6)" & GetReportOrder("Test"), True, Trim(txtencid.Text), reprt, vrfd, "Visible", cmbcategory.Text)                                                   ''
      Endif
    Else
      If chknew.Value Then
        sprt = False
      Else If chkprinted.Value Then
        sprt = True
      Endif
      If cmbcategory.Text = "%" Then
        $rData = modDatabase.$myConn.Exec("select fldid,fldchk,fldsave_report,fldtest_type,fldtestid,fldmethod,fldtime_report,fldabnormal,fldid,fldid,fldstatus,flduserid_report,flduserid_verify,fldsampletype,fldcondition,fldtime_report,fldprint,fldorder,fldtestid from tblpatradiotest where fldsave_report=&1 and fldencounterval=&2 and (fldstatus=&3 or fldstatus=&4) and fldprint=&5 and flvisible=&6" & GetReportOrder("Test"), True, Trim(txtencid.Text), reprt, vrfd, sprt, "Visible")
      Else
        $rData = modDatabase.$myConn.Exec("select fldid,fldchk,fldsave_report,fldtest_type,fldtestid,fldmethod,fldtime_report,fldabnormal,fldid,fldid,fldstatus,flduserid_report,flduserid_verify,fldsampletype,fldcondition,fldtime_report,fldprint,fldorder,fldtestid from tblpatradiotest where fldsave_report=&1 and fldencounterval=&2 and (fldstatus=&3 or fldstatus=&4) and fldprint=&5 and flvisible=&6 and fldtestid in(select fldexamid from tblradio where fldcategory like &7)" & GetReportOrder("Test"), True, Trim(txtencid.Text), reprt, vrfd, sprt, "Visible", cmbcategory.Text)                                                   ''
      Endif
    Endif

  Endif
  GridView1.Clear
  GridView1.Columns.Count = $rData.Fields.Count
  GridView1.Rows.Count = $rData.Count
  testList = New String[]

  For Each $rData
    Column = 0
    testList.Add($rData!fldtestid)
    For Each fld In $rData.Fields
      modGeneralMain.GridExplicitDecoration(GridView1, $rData.Index, Column)
      If Column = 1 Then
        GridView1[$rData.Index, Column].Picture = modBasic.$PictureUnchecked
        GridView1[$rData.Index, Column].Text = ""
      Else If Column = 2 Then
        GridView1[$rData.Index, Column].Picture = modBasic.$PictureUnchecked
        GridView1[$rData.Index, Column].Text = ""
      Else If Column = 6 Then
        GridView1[$rData.Index, Column].Text = modReportVar.GetDateTimeReport($rData["fldtime_report"], gb.GeneralDate)
      Else If Column = 7 Then
        GridView1[$rData.Index, Column].Picture = Picture[modGridView.GetGridIcon($rData["fldabnormal"])]
        GridView1[$rData.Index, Column].Text = ""
      Else If Column = 8 Then
        GridView1[$rData.Index, Column].RichText = modRadioTest.GetRadioTestValueGridString($rData["fldid"], False)
      Else If Column = 9 Then
        GridView1[$rData.Index, Column].Text = modRadioTest.GetRadioTestLimitSrting($rData["fldid"])
      Else If Column = 16 Then
        GridView1[$rData.Index, Column].Picture = Picture[modGridView.SetGridCheckIcon($rData["fldprint"])]
        GridView1[$rData.Index, Column].Text = ""
      Else If Column = 18 Then
        GridView1[$rData.Index, Column].Text = modFixRadio.GetRadioTestCategory($rData["fldtestid"])
      Else
        GridView1[$rData.Index, Column].Text = $rData[fld.Name]
      Endif
      Column = Column + 1
    Next
  Next
  GridView1.Row = 0
  cmbfootest.List = testList

  With GridView1
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[4].Text = "Test Name"
    .Columns[5].Text = "Method"
    .Columns[6].Text = "ReportDate"
    .Columns[8].Text = "Observation"
    .Columns[9].Text = "Reference"

    .Columns[0].Width = 50 * modBasic.$AppWidthRatio
    .Columns[1].Width = 20
    .Columns[2].Width = 20
    .Columns[3].Width = 1
    .Columns[4].Width = 175 * modBasic.$AppWidthRatio
    .Columns[5].Width = 85 * modBasic.$AppWidthRatio
    .Columns[6].Width = 180 * modBasic.$AppWidthRatio
    .Columns[7].Width = 20
    .Columns[8].Width = 225 * modBasic.$AppWidthRatio
    .Columns[9].Width = 200 * modBasic.$AppWidthRatio

    .Columns[10].Width = 1  'status
    .Columns[11].Width = 1  'reported by
    .Columns[12].Width = 1  'verified by
    .Columns[13].Width = 1  'specimen name
    .Columns[14].Width = 1  'refer dept
    .Columns[15].Width = 1  'reporting time
    .Columns[16].Width = 20
    .Columns[17].Width = 30 * modBasic.$AppWidthRatio
    .Columns[18].Width = 1
  End With
  EnableButton(False)
  SHowQualiSUbTest(0) ''false grid to make grid empty

End

Public Sub GridView1_Click()

  Dim xx As String
  Dim col As Integer
  Dim row As Integer

  col = GridView1.Column
  row = GridView1.Row
  SHowQualiSUbTest(0) ''false grid to make grid empty
  $TestID = GridView1[GridView1.Row, 0].Text
  If GridView1.Column = 1 Then
    modGridView.CheckUncheckGridNoDB(GridView1, 1)
    EnableSelected()
  Else If GridView1.Column = 2 Then
    If GridView1[GridView1.Row, 3].Text = "Qualitative" Then
      SHowQualiSUbTest(GridView1[GridView1.Row, 0].Text)
      modGridView.CheckUncheckGridNoDB(GridView1, 2)
      ManipulateSecondGrid(GridView1.Row, GridView1[GridView1.Row, 0].Text)
    Endif
  Else If GridView1.Column = 17 Then
    xx = InputBox(("Enter Order Number"), ("Test Order"), GridView1[GridView1.Row, 22].Text)
    If xx Then
      modRadioTest.UpdateRadioTestOrder(GridView1[GridView1.Row, 0].Text, CInt(xx))
      FillLabtable()
    Endif
  Else If GridView1.Column > 2 Then
    If GridView1[GridView1.Row, 3].Text = "Qualitative" Then
      SHowQualiSUbTest(GridView1[GridView1.Row, 0].Text)
    Endif
  Endif
  GridView1.Column = col
  GridView1.Row = row

End

Private Sub ManipulateSecondGrid(Row As Integer, testid As Long)

  Dim res As Result
  Dim i As Integer

  res = modDatabase.$myConn.Edit("tblpatradiosubtest", "fldtestid=&1 and fldsave=&2", testid, True)
  If GridView1[Row, 2].Picture = modBasic.$PictureChecked Then
    For Each res
      res["fldchk"] = True
      res["xyz"] = False
      res.Update
    Next
    For i = 0 To GridView2.Rows.Count - 1
      GridView2[i, 1].Picture = modBasic.$PictureChecked
    Next

  Else If GridView1[Row, 2].Picture = modBasic.$PictureUnchecked Then
    For Each res
      res["fldchk"] = False
      res["xyz"] = False
      res.Update
    Next
    For i = 0 To GridView2.Rows.Count - 1
      GridView2[i, 1].Picture = modBasic.$PictureUnchecked
    Next

  Endif

End

Private Sub SHowQualiSUbTest(serial As Long)

  Dim sql As String
  Dim Column As Integer
  Dim fld As ResultField

  GridView2.Clear
  sql = "select fldid,fldchk,fldsubtest,fldabnormal,fldreport,fldorder from tblpatradiosubtest where fldtestid=&1 and fldsave=&2" & GetReportOrder("SubTest")
  $rData1 = modDatabase.$myConn.Exec(sql, serial, True)

  GridView2.Columns.Count = $rData1.Fields.Count
  GridView2.Rows.Count = $rData1.Count

  For Each $rData1
    Column = 0
    For Each fld In $rData1.Fields
      modGeneralMain.GridExplicitDecoration(GridView2, $rData1.Index, Column)
      If Column = 1 Then
        GridView2[$rData1.Index, Column].Picture = Picture[modGridView.SetGridCheckIcon($rData1["fldchk"])]
        GridView2[$rData1.Index, Column].Text = ""
      Else If Column = 3 Then
        GridView2[$rData1.Index, Column].Picture = Picture[modGridView.GetGridIcon($rData1["fldabnormal"])]
        GridView2[$rData1.Index, Column].Text = ""
      Else If Column = 4 Then
        GridView2[$rData1.Index, Column].RichText = $rData1[fld.Name]
      Else
        GridView2[$rData1.Index, Column].Text = $rData1[fld.Name]
      Endif
      Column = Column + 1
    Next
  Next
  GridView2.Row = 0

  With GridView2
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 50 * modBasic.$AppWidthRatio
    .Columns[1].Width = 20
    .Columns[2].Width = 175 * modBasic.$AppWidthRatio
    .Columns[3].Width = 20
    .Columns[4].Width = 400 * modBasic.$AppWidthRatio
    .Columns[5].Width = 30 * modBasic.$AppWidthRatio
    .Columns[2].Text = "SubTest"
    .Columns[4].Text = "Observation"
  End With

End

Public Sub GridView2_Click()

  Dim xx As String

  If GridView2.Column = 5 Then
    xx = InputBox(("Enter Order Number"), ("Test Order"), GridView2[GridView2.Row, 5].Text)
    If xx Then
      modRadioTest.UpdateRadioSubTestOrder(GridView2[GridView2.Row, 0].Text, CInt(xx))
      SHowQualiSUbTest($TestID)
    Endif
  Else
    modGridView.CheckUncheckGrid(modDatabase.$myConn, GridView2, 1, "fldchk", "fldid", "tblpatradiosubtest", GridView2[GridView2.Row, 0].Text)
  Endif

End

Private Sub ShowPatLaboratoryReport(sType As String)

  Dim $BillingReport As CReportHTML
  Dim res As Result
  Dim asx As New String[0]
  Dim i As Integer

  Dim categ As String[]
  Dim newCateg As String[]
  Dim xx As String
  Dim dtcont As String
  Dim xval As String
  Dim xsection As String

  Dim repor As String
  Dim verif As String

  Dim xfontcol1 As String
  Dim xfontcol2 As String
  Dim xfontbod As String
  Dim col1Font As String
  Dim col2Font As String
  Dim xintrp As String
  Dim xexlabel As String

  Dim aa As String
  Dim bb As String
  Dim cc As String
  Dim xquali As String
  Dim xrefstr As String
  Dim yrefstr As String

  Dim $reportedBy As String[]
  Dim $verifiedBy As String[]
  Dim $specName As String[]
  Dim $condiName As String[]
  Dim $ReportDate As String[]

  Inc Application.Busy

  xfontbod = modSettings.ShowSettingFromFIle("ReportFormat/ReportBody_ContentFont")
  xfontcol1 = modSettings.ShowSettingFromFIle("ReportFormat/ReportBody_Font_Column1")
  xfontcol2 = modSettings.ShowSettingFromFIle("ReportFormat/ReportBody_Font_Column2")
  xintrp = modSettings.ShowSettingFromFIle("Laboratory/Intrepretation_Report")

  If xfontcol1 Then
    col1Font = xfontcol1
  Else
    If xfontbod Then
      col1Font = xfontbod
    Else
      col1Font = "Bold"
    Endif
  Endif

  If xfontcol2 Then
    col2Font = xfontcol2
  Else
    If xfontbod Then
      col2Font = xfontbod
    Else
      col2Font = ""
    Endif
  Endif

  If $CategList.Count Then
    newCateg = $CategList
  Else
    categ = New String[]
    For i = 0 To GridView1.Rows.Count - 1
      If GridView1[i, 1].Picture = modBasic.$PictureChecked Then
        xval = GridView1[i, 18].Text

        If categ.Count = 0 Then
          categ.Add(xval)
        Else
          If categ.Exist(xval) = False Then
            categ.Add(xval)
          Endif
        Endif

      Endif
    Next

    newCateg = categ
  Endif

  xsection = modSettings.ShowSettingFromFIle("Laboratory/ReportSections")
  If xsection = "Separate" Then
    ''=========== For separate Report ============
    For Each xx In newCateg
      If rbimage.Value = True Then
        $BillingReport = New CReportHTML([("Examination"), ("Observation"), ("Images")], modHelpVariable.$htmlDirectory, "LaboratoryReport", $encid)
      Else
        If rbform1.Value = True Then
          $BillingReport = New CReportHTML([("Examination"), ("Observation")], modHelpVariable.$htmlDirectory, "LaboratoryReport", $encid)
        Else If rbform3.Value = True Then
          $BillingReport = New CReportHTML([("Examination")], modHelpVariable.$htmlDirectory, "LaboratoryReport", $encid)
        Else
          $BillingReport = New CReportHTML([("Examination"), ("Observation"), ("Reference Range")], modHelpVariable.$htmlDirectory, "LaboratoryReport", $encid)
        Endif
      Endif
      $BillingReport.UserData.Add("SECTION", "Report")
      $BillingReport.UserData.Add(xx, "PARAM1")
      $BillingReport.UserData.Add(txtcomment.RichText, "FooterSummary")

      $reportedBy = New String[]
      $verifiedBy = New String[]
      $specName = New String[]
      $condiName = New String[]
      $ReportDate = New String[]

      dtcont = modSettings.ShowSettingFromFIle("Laboratory/DateContent")
      For i = 0 To GridView1.Rows.Count - 1
        If GridView1[i, 1].Picture = modBasic.$PictureChecked And If GridView1[i, 18].Text = xx Then
          $reportedBy.Add(GridView1[i, 11].Text)
          $verifiedBy.Add(GridView1[i, 12].Text)
          $specName.Add(GridView1[i, 13].Text)
          $condiName.Add(GridView1[i, 14].Text)
          If dtcont = "DateTime" Then
            $ReportDate.Add(modReportVar.GetDateTimeReport(GridView1[i, 15].Text, gb.GeneralDate))
          Else
            $ReportDate.Add(modReportVar.GetDateTimeReport(GridView1[i, 15].Text, gb.MediumDate))
          Endif

          With asx
            If rbimage.Value = True Then
              aa = modRadioTest.GetRadionameFromTestID(GridView1[i, 0].Text)
              If GridView1[i, 3].Text = "Quantitative" Then
                xrefstr = modRadioTest.RadioTestInterpretByTestID(GridView1[i, 0].Text)
                If xintrp = "Yes" And If xrefstr Then
                  bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True) & " [" & modRadioTest.GetRadioTestLimitSrting(GridView1[i, 0].Text) & "]" & gb.NewLine & "RESULT :" & xrefstr
                Else
                  bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True) & " [" & modRadioTest.GetRadioTestLimitSrting(GridView1[i, 0].Text) & "]"
                Endif
              Else If GridView1[i, 3].Text = "Qualitative" Then
                xrefstr = modRadioTest.GetRadioTestLimitSrting(GridView1[i, 0].Text)
                If xrefstr Then
                  bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True) & " [" & xrefstr & "]"
                Else
                  bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True)
                Endif
              Endif
              .Add(aa)
              .Add(bb)
              .Add(modString.GetImageListForHTML(modImage.ShowTestExamImagePathList("Radio", GridView1[i, 0].Text, $encid)))

            Else
              If rbform1.Value = True Then
                aa = modRadioTest.GetRadionameFromTestID(GridView1[i, 0].Text)
                If GridView1[i, 3].Text = "Quantitative" Then
                  xrefstr = modRadioTest.RadioTestInterpretByTestID(GridView1[i, 0].Text)
                  If xintrp = "Yes" And If xrefstr Then
                    bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True) & " [" & modRadioTest.GetRadioTestLimitSrting(GridView1[i, 0].Text) & "]" & gb.NewLine & "RESULT :" & xrefstr
                  Else
                    bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True) & " [" & modRadioTest.GetRadioTestLimitSrting(GridView1[i, 0].Text) & "]"
                  Endif
                Else If GridView1[i, 3].Text = "Qualitative" Then
                  xrefstr = modRadioTest.GetRadioTestLimitSrting(GridView1[i, 0].Text)
                  If xrefstr Then
                    bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True) & " [" & xrefstr & "]"
                  Else
                    bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True)
                  Endif
                Endif
                .Add(aa)
                .Add(bb)

              Else If rbform3.Value = True Then
                aa = modRadioTest.GetRadionameFromTestID(GridView1[i, 0].Text)
                If GridView1[i, 3].Text = "Quantitative" Then
                  xrefstr = modRadioTest.RadioTestInterpretByTestID(GridView1[i, 0].Text)
                  If xintrp = "Yes" And If xrefstr Then
                    bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True) & " [" & modRadioTest.GetRadioTestLimitSrting(GridView1[i, 0].Text) & "]" & gb.NewLine & "RESULT :" & xrefstr
                  Else
                    bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True) & " [" & modRadioTest.GetRadioTestLimitSrting(GridView1[i, 0].Text) & "]"
                  Endif
                Else If GridView1[i, 3].Text = "Qualitative" Then
                  xrefstr = modRadioTest.GetRadioTestLimitSrting(GridView1[i, 0].Text)
                  If xrefstr Then
                    bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True) & " [" & xrefstr & "]"
                  Else
                    bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True)
                  Endif
                Endif
                .Add(modString.GetFormatTextFontString(aa, col1Font) & "<br>" & modString.GetFormatTextFontString(bb, col2Font))

              Else
                aa = modRadioTest.GetRadionameFromTestID(GridView1[i, 0].Text)
                If GridView1[i, 3].Text = "Quantitative" Then
                  xrefstr = modRadioTest.RadioTestInterpretByTestID(GridView1[i, 0].Text)
                  If xintrp = "Yes" And If xrefstr Then
                    bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True) & gb.NewLine & "RESULT :" & xrefstr
                  Else
                    bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True)
                  Endif
                  cc = modRadioTest.GetRadioTestLimitSrting(GridView1[i, 0].Text)
                Else If GridView1[i, 3].Text = "Qualitative" Then
                  bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True)
                  cc = modRadioTest.GetRadioTestLimitSrting(GridView1[i, 0].Text)
                Endif
                .Add(aa)
                .Add(bb)
                .Add(cc)

              Endif
            Endif
          End With
          $BillingReport.Add(asx)
          asx.Clear()

          If GridView1[i, 3].Text = "Qualitative" Then
            res = modDatabase.$myConn.Exec("select fldsubtest,fldreport,fldid,fldtestid,fldtanswertype from tblpatradiosubtest where fldtestid=&1 and fldchk=&2 and fldsave=&3" & GetReportOrder("SubTest"), GridView1[i, 0].Text, True, True)
            If res.Available = True Then
              For Each res
                If res!fldtanswertype = "Multiple Selection" Then
                  xquali = modRadioTest.GetSubRadioTableReportString(res!fldtestid, res!fldid, True)
                Else If res!fldtanswertype = "Text Table" Then
                  xquali = modRadioTest.GetSubRadioTableReportString(res!fldtestid, res!fldid, True)
                Else If res!fldtanswertype = "Dual Columns" Then
                  xquali = modRadioTest.GetSubRadioDualTableString(res!fldtestid, res!fldid, True)
                Else If res!fldtanswertype = "Single Column" Then
                  xquali = modRadioTest.GetSubRadioTableReportString(res!fldtestid, res!fldid, True)
                Else
                  xquali = res!fldreport
                Endif

                If xquali Then
                  With asx
                    If rbform1.Value = True Then
                      aa = modString.HTMLBlankSpace(4) & res!fldsubtest
                      yrefstr = modFixRadio.GetSubRadioTestQualiReference(modRadioTest.GetRadionameFromTestID(GridView1[i, 0].Text), res!fldsubtest)
                      If yrefstr Then
                        bb = res!fldreport & " [" & yrefstr & " ]"
                      Else
                        bb = xquali
                      Endif
                      .Add(aa)
                      .Add(bb)

                    Else If rbform3.Value = True Then
                      aa = res!fldsubtest
                      yrefstr = modFixRadio.GetSubRadioTestQualiReference(modRadioTest.GetRadionameFromTestID(GridView1[i, 0].Text), res!fldsubtest)
                      If yrefstr Then
                        bb = res!fldreport & " [" & yrefstr & " ]"
                      Else
                        bb = xquali
                      Endif
                      .Add(modString.GetFormatTextFontString(aa, col1Font) & "<br>" & modString.GetFormatTextFontString(bb, col2Font))

                    Else
                      aa = modString.HTMLBlankSpace(4) & res!fldsubtest
                      bb = xquali
                      cc = modFixRadio.GetSubRadioTestQualiReference(modRadioTest.GetRadionameFromTestID(GridView1[i, 0].Text), res!fldsubtest)
                      .Add(aa)
                      .Add(bb)
                      .Add(cc)

                    Endif
                  End With
                  $BillingReport.Add(asx)
                  asx.Clear()
                Endif
              Next
            Endif
          Endif

        Endif
      Next

      ''default footer
      repor = modSettings.ShowSettingFromFIle("Laboratory/Footer_ReportedBy")
      verif = modSettings.ShowSettingFromFIle("Laboratory/Footer_VerifiedBy")

      modReportVar.$FoottUser1 = ""
      modReportVar.$FoottUser2 = ""
      modReportVar.$FoottUser3 = ""

      If repor = "Column1" Then
        modReportVar.$FoottUser1 = modString.GetDistinctStringArray($reportedBy).Join(",")
      Else If repor = "Column2" Then
        modReportVar.$FoottUser2 = modString.GetDistinctStringArray($reportedBy).Join(",")
      Else If repor = "Column3" Then
        modReportVar.$FoottUser3 = modString.GetDistinctStringArray($reportedBy).Join(",")
      Endif

      If verif = "Column1" Then
        modReportVar.$FoottUser1 = modString.GetDistinctStringArray($verifiedBy).Join(",")
      Else If verif = "Column2" Then
        modReportVar.$FoottUser2 = modString.GetDistinctStringArray($verifiedBy).Join(",")
      Else If verif = "Column3" Then
        modReportVar.$FoottUser3 = modString.GetDistinctStringArray($verifiedBy).Join(",")
      Endif

      ''header
      $BillingReport.UserData.Add("", "EXTRA1")
      $BillingReport.UserData.Add("", "EXTRA2")
      $BillingReport.UserData.Add("", "EXTRA3")
      $BillingReport.UserData.Add("", "EXTRA4")
      $BillingReport.UserData.Add("", "EXTRA5")
      $BillingReport.UserData.Add("", "EXTRA6")

      xexlabel = modSettings.ShowSettingFromFIle("Laboratory/Show_ExtraLabel")
      If xexlabel = "Yes" Then
        If modRadioTest.GetColumnName("ReportDate") Then
          $BillingReport.UserData.Add("Reporting Date: " & modString.GetDistinctStringArray($ReportDate).Join(","), modLabTest.GetColumnName("ReportDate"))
        Endif
        If modLabTest.GetColumnName("Specimen") Then
          $BillingReport.UserData.Add("Location: " & modString.GetDistinctStringArray($specName).Join(","), modLabTest.GetColumnName("ReferBy"))
        Endif
        If modLabTest.GetColumnName("Condition") Then
          $BillingReport.UserData.Add("Clinical Note: " & modString.GetDistinctStringArray($condiName).Join(","), modLabTest.GetColumnName("Condition"))
        Endif

      Else
        If modLabTest.GetColumnName("ReportDate") Then
          $BillingReport.UserData.Add(modString.GetDistinctStringArray($ReportDate).Join(","), modLabTest.GetColumnName("ReportDate"))
        Endif
        If modLabTest.GetColumnName("Specimen") Then
          $BillingReport.UserData.Add(modString.GetDistinctStringArray($specName).Join(","), modLabTest.GetColumnName("ReferBy"))
        Endif
        If modLabTest.GetColumnName("Condition") Then
          $BillingReport.UserData.Add(modString.GetDistinctStringArray($condiName).Join(","), modLabTest.GetColumnName("Condition"))
        Endif

      Endif
      Dec Application.Busy

      ''final print
      If sType = "Report" Then
        modPrint.OpenHTMLPreview($encid, $BillingReport.NewHTMLPath(), "ReportSize")
      Else If sType = "FTP" Then
        SendFTPSMS($BillingReport.NewHTMLPath())
      Else If sType = "Save" Then
        SaveReportAsHTML($BillingReport.NewHTMLPath())
      Endif
    Next

  Else
    ''=========== For combined Report ============
    If rbimage.Value = True Then
      $BillingReport = New CReportHTML([("Examination"), ("Observation"), ("Images")], modHelpVariable.$htmlDirectory, "LaboratoryReport", $encid)
    Else
      If rbform1.Value = True Then
        $BillingReport = New CReportHTML([("Examination"), ("Observation")], modHelpVariable.$htmlDirectory, "LaboratoryReport", $encid)
      Else If rbform3.Value = True Then
        $BillingReport = New CReportHTML([("Examination")], modHelpVariable.$htmlDirectory, "LaboratoryReport", $encid)
      Else
        $BillingReport = New CReportHTML([("Examination"), ("Observation"), ("Reference Range")], modHelpVariable.$htmlDirectory, "LaboratoryReport", $encid)
      Endif
    Endif
    $BillingReport.UserData.Add("SECTION", "Report")
    $BillingReport.UserData.Add(newCateg.Join(";"), "PARAM1")
    $BillingReport.UserData.Add(txtcomment.RichText, "FooterSummary")

    $reportedBy = New String[]
    $verifiedBy = New String[]
    $specName = New String[]
    $condiName = New String[]
    $ReportDate = New String[]

    dtcont = modSettings.ShowSettingFromFIle("Laboratory/DateContent")
    For Each xx In newCateg
      $BillingReport.AddSection(xx, True)

      For i = 0 To GridView1.Rows.Count - 1
        If GridView1[i, 1].Picture = modBasic.$PictureChecked And If GridView1[i, 18].Text = xx Then
          $reportedBy.Add(GridView1[i, 11].Text)
          $verifiedBy.Add(GridView1[i, 12].Text)
          $specName.Add(GridView1[i, 13].Text)
          $condiName.Add(GridView1[i, 14].Text)
          If dtcont = "DateTime" Then
            $ReportDate.Add(modReportVar.GetDateTimeReport(GridView1[i, 15].Text, gb.GeneralDate))
          Else
            $ReportDate.Add(modReportVar.GetDateTimeReport(GridView1[i, 15].Text, gb.MediumDate))
          Endif

          With asx
            If rbimage.Value = True Then
              aa = modRadioTest.GetRadionameFromTestID(GridView1[i, 0].Text)
              If GridView1[i, 3].Text = "Quantitative" Then
                xrefstr = modRadioTest.RadioTestInterpretByTestID(GridView1[i, 0].Text)
                If xintrp = "Yes" And If xrefstr Then
                  bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True) & " [" & modRadioTest.GetRadioTestLimitSrting(GridView1[i, 0].Text) & "]" & gb.NewLine & "RESULT :" & xrefstr
                Else
                  bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True) & " [" & modRadioTest.GetRadioTestLimitSrting(GridView1[i, 0].Text) & "]"
                Endif
              Else If GridView1[i, 3].Text = "Qualitative" Then
                xrefstr = modRadioTest.GetRadioTestLimitSrting(GridView1[i, 0].Text)
                If xrefstr Then
                  bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True) & " [" & xrefstr & "]"
                Else
                  bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True)
                Endif
              Endif
              .Add(aa)
              .Add(bb)
              .Add(modString.GetImageListForHTML(modImage.ShowTestExamImagePathList("Radio", GridView1[i, 0].Text, $encid)))

            Else
              If rbform1.Value = True Then
                aa = modRadioTest.GetRadionameFromTestID(GridView1[i, 0].Text)
                If GridView1[i, 3].Text = "Quantitative" Then
                  xrefstr = modRadioTest.RadioTestInterpretByTestID(GridView1[i, 0].Text)
                  If xintrp = "Yes" And If xrefstr Then
                    bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True) & " [" & modRadioTest.GetRadioTestLimitSrting(GridView1[i, 0].Text) & "]" & gb.NewLine & "RESULT :" & xrefstr
                  Else
                    bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True) & " [" & modRadioTest.GetRadioTestLimitSrting(GridView1[i, 0].Text) & "]"
                  Endif
                Else If GridView1[i, 3].Text = "Qualitative" Then
                  xrefstr = modRadioTest.GetRadioTestLimitSrting(GridView1[i, 0].Text)
                  If xrefstr Then
                    bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True) & " [" & xrefstr & "]"
                  Else
                    bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True)
                  Endif
                Endif
                .Add(aa)
                .Add(bb)

              Else If rbform3.Value = True Then
                aa = modRadioTest.GetRadionameFromTestID(GridView1[i, 0].Text)
                If GridView1[i, 3].Text = "Quantitative" Then
                  xrefstr = modRadioTest.RadioTestInterpretByTestID(GridView1[i, 0].Text)
                  If xintrp = "Yes" And If xrefstr Then
                    bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True) & " [" & modRadioTest.GetRadioTestLimitSrting(GridView1[i, 0].Text) & "]" & gb.NewLine & "RESULT :" & xrefstr
                  Else
                    bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True) & " [" & modRadioTest.GetRadioTestLimitSrting(GridView1[i, 0].Text) & "]"
                  Endif
                Else If GridView1[i, 3].Text = "Qualitative" Then
                  xrefstr = modRadioTest.GetRadioTestLimitSrting(GridView1[i, 0].Text)
                  If xrefstr Then
                    bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True) & " [" & xrefstr & "]"
                  Else
                    bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True)
                  Endif
                Endif
                .Add(modString.GetFormatTextFontString(aa, col1Font) & "<br>" & modString.GetFormatTextFontString(bb, col2Font))

              Else
                aa = modRadioTest.GetRadionameFromTestID(GridView1[i, 0].Text)
                If GridView1[i, 3].Text = "Quantitative" Then
                  xrefstr = modRadioTest.RadioTestInterpretByTestID(GridView1[i, 0].Text)
                  If xintrp = "Yes" And If xrefstr Then
                    bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True) & gb.NewLine & "RESULT :" & xrefstr
                  Else
                    bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True)
                  Endif
                  cc = modRadioTest.GetRadioTestLimitSrting(GridView1[i, 0].Text)
                Else If GridView1[i, 3].Text = "Qualitative" Then
                  bb = modRadioTest.GetRadioTestValueGridString(GridView1[i, 0].Text, True)
                  cc = modRadioTest.GetRadioTestLimitSrting(GridView1[i, 0].Text)
                Endif
                .Add(aa)
                .Add(bb)
                .Add(cc)

              Endif
            Endif
          End With
          $BillingReport.Add(asx)
          asx.Clear()

          If GridView1[i, 3].Text = "Qualitative" Then
            res = modDatabase.$myConn.Exec("select fldsubtest,fldreport,fldid,fldtestid,fldtanswertype from tblpatradiosubtest where fldtestid=&1 and fldchk=&2 and fldsave=&3" & GetReportOrder("SubTest"), GridView1[i, 0].Text, True, True)
            If res.Available = True Then
              For Each res
                If res!fldtanswertype = "Multiple Selection" Then
                  xquali = modRadioTest.GetSubRadioTableReportString(res!fldtestid, res!fldid, True)
                Else If res!fldtanswertype = "Text Table" Then
                  xquali = modRadioTest.GetSubRadioTableReportString(res!fldtestid, res!fldid, True)
                Else If res!fldtanswertype = "Dual Columns" Then
                  xquali = modRadioTest.GetSubRadioDualTableString(res!fldtestid, res!fldid, True)
                Else If res!fldtanswertype = "Single Column" Then
                  xquali = modRadioTest.GetSubRadioTableReportString(res!fldtestid, res!fldid, True)
                Else
                  xquali = res!fldreport
                Endif

                If xquali Then
                  With asx
                    If rbform1.Value = True Then
                      aa = modString.HTMLBlankSpace(4) & res!fldsubtest
                      yrefstr = modFixRadio.GetSubRadioTestQualiReference(modRadioTest.GetRadionameFromTestID(GridView1[i, 0].Text), res!fldsubtest)
                      If yrefstr Then
                        bb = res!fldreport & " [" & yrefstr & " ]"
                      Else
                        bb = xquali
                      Endif
                      .Add(aa)
                      .Add(bb)

                    Else If rbform3.Value = True Then
                      aa = res!fldsubtest
                      yrefstr = modFixRadio.GetSubRadioTestQualiReference(modRadioTest.GetRadionameFromTestID(GridView1[i, 0].Text), res!fldsubtest)
                      If yrefstr Then
                        bb = res!fldreport & " [" & yrefstr & " ]"
                      Else
                        bb = xquali
                      Endif
                      .Add(modString.GetFormatTextFontString(aa, col1Font) & "<br>" & modString.GetFormatTextFontString(bb, col2Font))

                    Else
                      aa = modString.HTMLBlankSpace(4) & res!fldsubtest
                      bb = xquali
                      cc = modFixRadio.GetSubRadioTestQualiReference(modRadioTest.GetRadionameFromTestID(GridView1[i, 0].Text), res!fldsubtest)
                      .Add(aa)
                      .Add(bb)
                      .Add(cc)

                    Endif
                  End With
                  $BillingReport.Add(asx)
                  asx.Clear()
                Endif
              Next
            Endif
          Endif

        Endif
      Next

    Next

    ''default footer
    repor = modSettings.ShowSettingFromFIle("Laboratory/Footer_ReportedBy")
    verif = modSettings.ShowSettingFromFIle("Laboratory/Footer_VerifiedBy")

    modReportVar.$FoottUser1 = ""
    modReportVar.$FoottUser2 = ""
    modReportVar.$FoottUser3 = ""

    If repor = "Column1" Then
      modReportVar.$FoottUser1 = modString.GetDistinctStringArray($reportedBy).Join(",")
    Else If repor = "Column2" Then
      modReportVar.$FoottUser2 = modString.GetDistinctStringArray($reportedBy).Join(",")
    Else If repor = "Column3" Then
      modReportVar.$FoottUser3 = modString.GetDistinctStringArray($reportedBy).Join(",")
    Endif

    If verif = "Column1" Then
      modReportVar.$FoottUser1 = modString.GetDistinctStringArray($verifiedBy).Join(",")
    Else If verif = "Column2" Then
      modReportVar.$FoottUser2 = modString.GetDistinctStringArray($verifiedBy).Join(",")
    Else If verif = "Column3" Then
      modReportVar.$FoottUser3 = modString.GetDistinctStringArray($verifiedBy).Join(",")
    Endif

    ''header
    $BillingReport.UserData.Add("", "EXTRA1")
    $BillingReport.UserData.Add("", "EXTRA2")
    $BillingReport.UserData.Add("", "EXTRA3")
    $BillingReport.UserData.Add("", "EXTRA4")
    $BillingReport.UserData.Add("", "EXTRA5")
    $BillingReport.UserData.Add("", "EXTRA6")

    xexlabel = modSettings.ShowSettingFromFIle("Laboratory/Show_ExtraLabel")
    If xexlabel = "Yes" Then
      If modRadioTest.GetColumnName("ReportDate") Then
        $BillingReport.UserData.Add("Reporting Date: " & modString.GetDistinctStringArray($ReportDate).Join(","), modLabTest.GetColumnName("ReportDate"))
      Endif
      If modLabTest.GetColumnName("Specimen") Then
        $BillingReport.UserData.Add("Location: " & modString.GetDistinctStringArray($specName).Join(","), modLabTest.GetColumnName("ReferBy"))
      Endif
      If modLabTest.GetColumnName("Condition") Then
        $BillingReport.UserData.Add("Clinical Note: " & modString.GetDistinctStringArray($condiName).Join(","), modLabTest.GetColumnName("Condition"))
      Endif

    Else
      If modLabTest.GetColumnName("ReportDate") Then
        $BillingReport.UserData.Add(modString.GetDistinctStringArray($ReportDate).Join(","), modLabTest.GetColumnName("ReportDate"))
      Endif
      If modLabTest.GetColumnName("Specimen") Then
        $BillingReport.UserData.Add(modString.GetDistinctStringArray($specName).Join(","), modLabTest.GetColumnName("ReferBy"))
      Endif
      If modLabTest.GetColumnName("Condition") Then
        $BillingReport.UserData.Add(modString.GetDistinctStringArray($condiName).Join(","), modLabTest.GetColumnName("Condition"))
      Endif

    Endif
    Dec Application.Busy

    ''final print
    If sType = "Report" Then
      modPrint.OpenHTMLPreview($encid, $BillingReport.NewHTMLPath(), "ReportSize")
    Else If sType = "FTP" Then
      SendFTPSMS($BillingReport.NewHTMLPath())
    Else If sType = "Save" Then
      SaveReportAsHTML($BillingReport.NewHTMLPath())
    Endif

  Endif

End

Private Sub SendSMSPatient(sInt As String)

  Dim sText As String
  Dim phno As String

  If modSettings.ShowSettingFromFIle("Laboratory/Patient_EnableSMS") = "Yes" Then
    sText = modSettings.ShowSettingFromFIle("Laboratory/Patient_SMSText") & " Report No: " & sInt
    phno = modPatient.GetPatientContactByEnc($encid)
    If phno Then
      If sText Then

        sText = modReportVar.GetReportVarPatient($encid, sText)
        sText = modReportVar.GetReportVarEncounter($encid, sText)
        modGeneralMain.SaveSMSEntry(phno, sText)

      Endif
    Endif
  Endif

End

Private Sub SendFTPSMS(sHTML As String)

  Dim sPath As String
  Dim sInt As String

  If Desktop.NetworkAvailable = True Then

    sInt = modString.GetNowString()
    sPath = modPrint.ConvertHTMLToPDFString(sHTML, "ReportSize", sInt)

    Inc Application.Busy
    modDevice.SendFileToRemoteFTP(sPath)
    SendSMSPatient(sInt)
    If modBasic.$ReportLogFTP = "Yes" Then
      modImage.SaveReportLog("FTP", sPath)
    Endif
    Dec Application.Busy

  Endif

End

Private Sub SaveReportAsHTML(sHTML As String)

  Dim xx As String
  Dim sType As String
  Dim sPath As String
  Dim sInt As String

  sInt = modString.GetNowString()
  sPath = modPrint.ConvertHTMLToPDFString(sHTML, "ReportSize", sInt)
  sType = "Radio Diagnostics"
  xx = InputBox(("Title of Report"), sType, cmbcategory.Text)
  modImage.SavePatientDataForGeneral($encid, sType, xx, sPath)
  SendSMSPatient("")

End

Public Sub btnreport_Click()

  If txtencid.Text Then
    If modNonMedical.AllowEntryWithDeposit($encid, "Radio") = True Then
      MarkPrintedSelected()
      ShowPatLaboratoryReport("Report")
      FillLabtable()
    Endif
  Endif

End

Public Sub btnrecord_Click()

  If txtencid.Text Then
    If modNonMedical.AllowEntryWithDeposit($encid, "Radio") = True Then
      MarkPrintedSelected()
      ShowPatLaboratoryReport("Save")
      FillLabtable()
    Endif
  Endif

End

Public Sub btnftp_Click()

  If txtencid.Text Then
    If modNonMedical.AllowEntryWithDeposit($encid, "Radio") = True Then
      MarkPrintedSelected()
      ShowPatLaboratoryReport("FTP")
      FillLabtable()
    Endif
  Endif

End

Private Sub MarkPrintedSelected()

  Dim i As Integer
  Dim res As Result

  If chkmark.Value = True Then
    For i = 0 To GridView1.Rows.Count - 1
      If GridView1[i, 1].Picture = modBasic.$PictureChecked Then
        res = modDatabase.$myConn.Edit("tblpatradiotest", "fldid=&1", GridView1[i, 0].Text)
        res["fldprint"] = True
        res["xyz"] = False
        res.Update
      Endif
    Next
  Endif

End

Public Sub GridView1_Menu()

  mnuhide.Popup

End

Public Sub mnuselall_Click()

  Dim i As Integer
  Dim res As Result

  Inc Application.Busy
  SHowQualiSUbTest(0) ''false grid to make grid empty
  For i = 0 To GridView1.Rows.Count - 1
    GridView1[i, 1].Picture = modBasic.$PictureChecked
    res = modDatabase.$myConn.Edit("tblpatradiosubtest", "fldtestid=&1", GridView1[i, 0].Text)
    If res.Available = True Then
      GridView1[i, 2].Picture = modBasic.$PictureChecked
      For Each res
        res["fldchk"] = True
        res["xyz"] = False
        res.Update
      Next
    Endif
  Next
  EnableButton(True)
  Dec Application.Busy

End

Public Sub mnudselal_Click()

  Dim i As Integer
  Dim res As Result

  Inc Application.Busy
  SHowQualiSUbTest(0) ''false grid to make grid empty
  For i = 0 To GridView1.Rows.Count - 1
    GridView1[i, 1].Picture = modBasic.$PictureUnchecked
    res = modDatabase.$myConn.Edit("tblpatradiosubtest", "fldtestid=&1", GridView1[i, 0].Text)
    If res.Available = True Then
      GridView1[i, 2].Picture = modBasic.$PictureUnchecked
      For Each res
        res["fldchk"] = False
        res["xyz"] = False
        res.Update
      Next
    Endif
  Next
  EnableButton(False)
  Dec Application.Busy

End

Public Sub btnsearch_Click()

  txtencid.Text = PatSearch("Encounter")

End

Public Sub btnorder_Click()

  Dim categ As String[]
  Dim i As Integer

  categ = New String[]
  For i = 0 To GridView1.Rows.Count - 1
    If GridView1[i, 1].Picture = modBasic.$PictureChecked Then
      categ.Add(GridView1[i, 18].Text)
    Endif
  Next

  $CategList = ListOrder(("Reorder Items"), modString.GetDistinctStringArray(categ))

End

Public Sub btnfootlist_Click()

  Dim xlst As String[]
  Dim i As Integer
  Dim xx As String
  Dim xlink As String
  Dim sText As String[]

  xlst = SelectListView(("Select Foot Notes"), modLabTest.ListFooterNoteList(), False)
  If xlst Then
    sText = New String[]
    For i = 1 To 50
      xx = modSettings.ShowSettingFromFIle("FooterNote/Name_" & CStr(i))
      If xlst.Exist(xx) Then
        xlink = modSettings.ShowSettingFromFIle("FooterNote/Link_" & CStr(i))
        If Exist(xlink) Then
          sText.Add(File.Load(xlink))
        Endif
      Endif
    Next
    txtcomment.RichText = sText.Join(gb.NewLine & "<br>")
  Endif

End

Public Sub cmbfootest_Click()

  If cmbfootest.Text Then
    If txtcomment.Text Then
      txtcomment.Text = txtcomment.Text & gb.NewLine & modFixRadio.GetRadioToolTip(cmbfootest.Text)
    Else
      txtcomment.Text = modFixRadio.GetRadioToolTip(cmbfootest.Text)
    Endif
  Endif

End

Public Sub txtencid_KeyPress()

  If Key.Code = Key.Down Then
    If modBasic.$AutoEncSuffix = "Yes" Then
      txtencid.Text = txtencid.Text & modBasic.$HospCode
    Endif
  Else
    modGeneralMain.InputUpCaseOnly()
  Endif

End
