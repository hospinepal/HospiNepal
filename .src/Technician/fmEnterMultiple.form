# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,110,65)
  Text = ("Enter Components")
  Resizable = False
  { Label2 Label
    MoveScaled(1,1,7,3)
    Text = ("Name:")
    Border = Border.Plain
  }
  { lblitem Label
    MoveScaled(9,1,51,3)
    Border = Border.Plain
  }
  { btnBrOK Button
    MoveScaled(84,61,12,3.5333)
    Text = Shortcut(("Save"), "S")
    Picture = Picture["icon:/small/apply"]
  }
  { btnBrChange Button
    MoveScaled(97,61,12,3.5333)
    Text = Shortcut(("Close"), "C")
    Picture = Picture["icon:/small/close"]
    Cancel = True
  }
  { ScrollView1 ScrollView
    MoveScaled(1,5,108,55)
    { Frame1 Frame
      MoveScaled(0,0,107,54)
      Expand = True
      Text = ("Components")
    }
  }
  { Slider1 Slider
    MoveScaled(84,1,20,3)
    MinValue = 2
    MaxValue = 15
  }
  { btnrefresh ToolButton
    MoveScaled(105,1,3,3)
    Picture = Picture["icon:/small/refresh"]
  }
  { chkautoption CheckBox
    MoveScaled(62,1,17,3)
    Text = ("Display Options")
  }
  { Label1 Label
    MoveScaled(1,61,7,3)
    Text = ("Note:")
    Border = Border.Plain
  }
  { lblnote Label
    MoveScaled(9,61,51,3)
    Border = Border.Plain
  }
  { btnexectext ToolButton
    MoveScaled(68,61,3,3)
    Picture = Picture["icon:/small/exec"]
  }
  { dctexectext ToolButton
    MoveScaled(64,61,3,3)
    Picture = Picture["icon:/small/edit"]
  }
  { btntempltext ToolButton
    MoveScaled(72,61,3,3)
    Picture = Picture["icon:/small/attach"]
  }
}
