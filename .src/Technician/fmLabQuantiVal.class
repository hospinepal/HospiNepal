' Gambas class file

Private $xMAC As String
Private $id As Long
Private $encid As String

Public Sub _new(id As Long, strExam As String, strValue As Float, defUnt As String, xspecimen As String, xMAC As String)

  lblitem.Text = strExam
  $id = id
  $xMAC = xMAC
  txtreport.Value = strValue
  txtspecimen.Text = xspecimen

  If defUnt = "Metric" Then
    rbmetric.Value = True
  Else If defUnt = "SI" Then
    rbsi.Value = True
  Endif

End

Public Sub Form_Open()

  Dim hForm As FmQuantiEntry

  modGeneralMain.ArrangeFormCentre(Me, "False")
  hForm = New FmQuantiEntry(txtreport, pnlquanti)
  modSettings.ShowCheckBox(chkoutlier, "Laboratory/WarnOutliers")
  $encid = modLabTest.GetEncIDFromLabID($id)
  ShowTestLImit()

End

Public Sub chkoutlier_Click()

  modSettings.EnterCheckSetting(chkoutlier, "Laboratory/WarnOutliers")

End

Private Sub ShowTestLImit()

  Dim strUnit As String
  Dim xlimit As Float[]
  Dim xlimunit As String

  If rbsi.Value = True Then
    strUnit = "SI"
  Else
    strUnit = "Metric"
  Endif

  xlimit = modLabTest.GetTestBothLimits($id, strUnit)
  txtlower.Value = xlimit[0]
  txtupper.Value = xlimit[1]

  xlimunit = modLabTest.GetTestLabUnit($encid, $id, strUnit)
  lblunit1.Text = xlimunit
  lblunit2.Text = xlimunit

End

Public Sub rbsi_Click()

  ShowTestLImit()

End

Public Sub rbmetric_Click()

  ShowTestLImit()

End

Private Sub GetOutlierRange()

  Dim xcrit As Float

  If txtlower.Value <> txtupper.Value Then
    xcrit = modFixLab.GetCritValueTest(lblitem.Text)
    If xcrit Then
      txtcritlow.Value = txtlower.Value - xcrit * (txtupper.Value - txtlower.Value)
      txtcrithigh.Value = txtupper.Value + xcrit * (txtupper.Value - txtlower.Value)
    Endif
  Endif

End

Private Sub GetAbnormal()

  If txtlower.Value <> txtupper.Value Then
    If txtreport.Value < txtlower.Value Or txtreport.Value > txtupper.Value Then
      chkabnormal.Value = True
    Else
      chkabnormal.Value = False
    Endif
  Endif

End

Public Sub btnBrChange_Click()

  Me.Close

End

Public Sub txtreport_GotFocus()

  chkabnormal.Value = False

End

Public Sub btncalc_Click()

  Dim xsyscon As String
  Dim xval As Float

  If rbsi.Value = True Then
    rbmetric.Value = True
    ShowTestLImit()
  Endif

  xsyscon = modFixLab.GetTestSysName(lblitem.Text)
  If xsyscon Then
    If rbmetric.Value = True Then
      xval = modSysCons.GetConstantValue(xsyscon, modPatient.GetPatientEncFromID("tblpatlabtest", $id))
      If xval Then
        txtreport.Value = xval
      Endif
    Endif
  Endif

End

Public Sub btnBrOK_Click()

  GetAbnormal()

  If chkoutlier.Value = True Then

    GetOutlierRange()
    If txtcritlow.Value Or If txtcrithigh.Value Then
      If txtreport.Value < txtcritlow.Value Or If txtreport.Value > txtcrithigh.Value Then

        If Message.Question(("Are you sure ?"), ("No"), ("Yes")) = 2 Then
          SaveLabData()
          If modSettings.ShowSettingFromFIle("Laboratory/AbnormalVal_AutoSMS") = "Auto" Then
            modDevice.SendSMSLabConsultant(modLabTest.GetEncIDFromLabID($id), lblitem.Text, modLabTest.GetLabTestValueString($encid, $id, modLabTest.GetTestUnitFromButton(rbsi, rbmetric), False))                                 ''
          Endif
        Endif

      Else
        SaveLabData()
      Endif
    Else
      SaveLabData()
    Endif

  Else
    SaveLabData()
  Endif

End

Private Sub SaveLabData()

  modLabTest.UpdateLabTestReportQuanti($id, txtreport.Value, chkabnormal.Value, modLabTest.GetTestUnitFromButton(rbsi, rbmetric))
  SocketMessage()
  Balloon.Info(("Information saved"), btnBrOK)
  Balloon.Delay = modBasic.$BalloonDelay

End

Private Sub SocketMessage()

  Dim xline As String
  Dim encid As String
  Dim xuser As String

  If $xMAC Then
    Inc Application.Busy
    encid = modLabTest.GetEncIDFromLabID($id)
    xuser = modGeneral.GetCurrentUseronMac($xMAC)
    xline = "UserNotice: [" & modPatient.GetPatientNameByEnc(encid, modDatabase.$myConn) & "]" & lblitem.Text & Space(1) & CStr(txtreport.Value) & "@"
    modDevice.TransferTextSocket(modGeneral.GetCurrentIPonMac($xMAC), modHelpVariable.GetTransferPort(xuser), xline)
    Dec Application.Busy
  Endif

Catch
  Dec Application.Busy
  Message.Warning(Error.Text, ("OK"))

End
