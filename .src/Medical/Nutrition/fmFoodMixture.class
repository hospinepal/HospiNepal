' Gambas class file

Private $rData As Result

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me)
  cmbgroup.List = modFillContainer.GetListFromResult(modDatabase.$medConn.Exec("select distinct(fldgroup) as col from tblfoodgroup"))
  cmbtype.List = modFillContainer.GetListFromResult(modDatabase.$medConn.Exec("select distinct(fldfoodtype) as col from tblfoodtype"))

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.Esc Then
    Me.Close
  Else
    modGeneralmain.GoToNextControlTab()
  Endif

End

Public Sub btnlist_Click()

  Dim xPath As String

  xPath = modMedicalReport.ShowFoodGroupListHTML()
  modPrint.OpenHTMLPreview("", xPath, "ReportSize")

End

Private Sub ShowGridData()

  Dim sql As String
  Dim Column As Integer
  Dim fld As ResultField

  If cmbgroup.Text Then
    sql = "select fldid,flditemname,flditemamt from tblfoodgroup where fldgroup=&1 ORDER BY flditemname ASC"
    $rData = modDatabase.$medConn.Exec(sql, cmbgroup.Text)

    GridView1.Clear
    GridView1.Columns.Count = $rData.Fields.Count
    GridView1.Rows.Count = $rData.Count

    For Each $rData
      Column = 0
      For Each fld In $rData.Fields
        modGeneralMain.GridExplicitDecoration(GridView1, $rData.Index, Column)
        GridView1[$rData.Index, Column].Text = $rData[fld.Name]
        Column = Column + 1
      Next
    Next
    GridView1.Row = 0

    With GridView1
      .Rows.Height = 25 * modBasic.$AppHeightRatio
      .Columns[0].Width = 1
      .Columns[1].Width = 450 * modBasic.$AppWidthRatio
      .Columns[2].Width = 150 * modBasic.$AppWidthRatio

      .Columns[1].Text = "Particulars"
      .Columns[2].Text = "Amount (gm)"
    End With

  Endif

End

Public Sub btnrefresh_Click()

  ShowGridData()

End

Public Sub mnudel_Click()

  If GridView1.Rows.Selection.Count > 0 Then
    If Message.Question(("Are you sure?"), ("No"), ("Yes")) = 2 Then
      modDatabase.$medConn.Delete("tblfoodgroup", "fldid=&1", GridView1[GridView1.Row, 0].Text)
      ShowGridData()
      Message.Delete(("Information deleted"), ("OK"))
    Endif
  Endif

End

Public Sub GridView1_Menu()

  mnuhide.Popup

End

Public Sub cmbtype_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbtype)
  modFillContainer.RestrictComboToContent(cmbtype)

End

Public Sub cmbitem_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbitem)
  modFillContainer.RestrictComboToContent(cmbitem)

End

Public Sub cmbtype_Click()

  cmbitem.List = modMedicine.GetFoodSelectedType(cmbtype.Text)

End

Public Sub btnadd_Click()

  Dim res As Result

  If cmbtype.Text And If cmbitem.Text And If txtdose.Value Then
    res = modDatabase.$medConn.Create("tblfoodgroup")
    res["fldgroup"] = cmbgroup.Text
    res["flditemname"] = cmbitem.Text
    res["flditemamt"] = txtdose.Value
    res["fldprep"] = txtmethod.Text
    res.Update
    ShowGridData()
    cmbitem.Text = ""
    txtdose.Value = 0
    cmbtype.SetFocus
  Endif

End

Public Sub btnadd_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    btnadd_Click()
  Endif

End
