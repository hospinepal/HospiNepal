# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,76,64)
  Text = ("Food Mixtures")
  Resizable = False
  { mnuhide Menu
    Visible = False
    { mnudel Menu
      Text = ("Delete")
      Shortcut = "Ctrl+D"
    }
  }
  { Label2 Label
    MoveScaled(1,1,13,3.25)
    Text = ("Mixture Name")
    Border = Border.Plain
  }
  { cmbgroup ComboBox
    MoveScaled(15,1,28,3)
    Sorted = True
  }
  { btnrefresh Button
    MoveScaled(43,1,3,3)
    Picture = Picture["icon:/small/refresh"]
  }
  { btnlist Button
    MoveScaled(62,1,11.25,3)
    Text = ("List")
    Picture = Picture["icon:/small/file"]
  }
  { GridView1 GridView
    MoveScaled(1,16,73,47)
    Mode = Select.Single
    Header = GridView.Both
    AutoResize = False
  }
  { cmbtype ComboBox
    MoveScaled(1,5,13,3)
  }
  { cmbitem ComboBox
    MoveScaled(15,5,40,3)
    Sorted = True
  }
  { txtdose ValueBox
    MoveScaled(56,5,6,3)
  }
  { txtunit Label
    MoveScaled(63,5,6,3)
    Text = ("Gram")
    Border = Border.Plain
  }
  { btnadd Button
    MoveScaled(70,5,3,3)
    Picture = Picture["icon:/small/add"]
  }
  { txtmethod TextArea
    MoveScaled(1,9,73,6)
    Wrap = True
    ScrollBar = Scroll.Vertical
  }
}
