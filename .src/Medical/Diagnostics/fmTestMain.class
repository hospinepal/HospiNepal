' Gambas class file

Private $TestOption As String[]

Private Sub BlankALL()

  cmbconstant.Text = ""
  cmbtype.Text = ""
  cmbcategory.Text = ""
  cmboption.Text = ""
  txtcollection.Text = ""
  txtspecimen.Text = ""
  txtmethod.Text = ""
  txttestname.Text = ""
  txtcomment.Text = ""
  txtsensitivity.Value = 0
  txtspecificity.Value = 0
  txtcritical.Value = 0

End

Public Sub Form_Open()

  modGeneralMain.ArrangeEmbedForms(Me, Panel1, "Column")
  Me.Icon = Picture[modGeneralMain.$strLogo]

  cmbtype.List = ["Qualitative", "Quantitative"]
  cmbconstant.List = modSysCons.SysLabTestList()
  cmbcategory.List = modMedicine.GetPathoCategoryList("Test")
  txtspecimen.List = modMedicine.GetLabSampleTypeList()
  $TestOption = modMedicine.FillCLinicalLessOptionCombo()
  FillTestListbox()
  txtfind.SetFocus

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

Public Sub Form_KeyRelease()

  modGeneralmain.GoToNextControlTab()

End

Public Sub txttestname_KeyPress()

  modGeneralMain.InputTextKeyOnly()

End

Private Sub FillTestListbox()

  Dim sql As String
  Dim res As Result

  sql = "select fldtestid as col from tbltest where lower(fldtestid) like &1"
  res = modDatabase.$medConn.Exec(sql, LCase(txtfind.Text) & "%")
  modFillContainer.FillListBox(lsttestname, res, False)

End

Public Sub lsttestname_Click()

  Dim sql As String
  Dim res As Result

  sql = "select fldtestid,fldcategory,fldsysconst,fldspecimen,fldcollection,flddetail,fldtype,fldcomment,fldoption,fldsensitivity,fldspecificity,fldcritical from tbltest where fldtestid=&1"
  res = modDatabase.$medConn.Exec(sql, lsttestname.Text)
  If res.Available Then
    cmbconstant.Text = res["fldsysconst"]
    cmbtype.Text = res["fldtype"]
    cmboption.Text = res["fldoption"]
    cmbcategory.Text = res["fldcategory"]
    txtcollection.Text = res["fldcollection"]
    txtspecimen.Text = res["fldspecimen"]
    txtmethod.Text = res["flddetail"]
    txttestname.Text = res["fldtestid"]
    txtcomment.Text = res["fldcomment"]
    txtsensitivity.Value = res["fldsensitivity"]
    txtspecificity.Value = res["fldspecificity"]
    txtcritical.Value = res["fldcritical"]
    btnBrOK.Text = "&Add"
  Endif

End

Public Sub tlbtnadd_Click()

  Dim hForm As FmAddVariable1

  hForm = New FmAddVariable1("flclass", "fldcategory", "Test", "tblpathocategory")
  hForm.ShowModal
  cmbcategory.List = modMedicine.GetPathoCategoryList("Test")

End

Public Sub btnspecadd_Click()

  Dim hForm As FmAddVariableGrid

  hForm = New FmAddVariableGrid("fldsampletype", "tblsampletype")
  hForm.ShowModal
  txtspecimen.List = modMedicine.GetLabSampleTypeList()

End

Public Sub cmbtype_Click()

  If cmbtype.Text Then
    If cmbtype.Text = "Quantitative" Then
      cmboption.Clear
      cmboption.Add("No Selection")
    Else If cmbtype.Text = "Qualitative" Then
      cmboption.List = $TestOption
    Endif
  Endif

End

Public Sub txtspecimen_KeyRelease()

  modFillContainer.AutoFillComboBox(txtspecimen)
  modFillContainer.RestrictComboToContent(txtspecimen)

End

Public Sub cmboption_KeyRelease()

  modFillContainer.AutoFillComboBox(cmboption)
  modFillContainer.RestrictComboToContent(cmboption)

End

Public Sub cmbcategory_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbcategory)
  modFillContainer.RestrictComboToContent(cmbcategory)

End

Public Sub cmbconstant_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbconstant)
  modFillContainer.RestrictComboToContent(cmbconstant)

End

Public Sub cmbtype_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbtype)
  modFillContainer.RestrictComboToContent(cmbtype)

End

Public Sub btnBrOK_Click()

  Dim res As Result

  If btnBrOK.Text = "&Add" And If btnBrChange.Text = "&Edit" Then
    btnBrOK.Text = "&Save"
    BlankALL()

  Else If btnBrOK.Text = "&Save" And If btnBrChange.Text = "&Edit" Then
    If txttestname.Text And If cmbcategory.Text And If cmbtype.Text Then
      res = modDatabase.$medConn.Create("tbltest")
      res["fldtestid"] = Trim(txttestname.Text)
      res["fldcategory"] = Trim(cmbcategory.Text)
      res["fldsysconst"] = cmbconstant.Text
      res["fldspecimen"] = Trim(txtspecimen.Text)
      res["fldcollection"] = Trim(txtcollection.Text)
      res["flddetail"] = txtmethod.Text
      res["fldtype"] = cmbtype.Text
      res["fldsensitivity"] = txtsensitivity.Value
      res["fldspecificity"] = txtspecificity.Value
      res["fldoption"] = cmboption.Text
      res["fldcomment"] = txtcomment.text
      res["fldcritical"] = txtcritical.Value
      res.Update()
      btnBrOK.Text = "&Add"
      FillTestListbox()
      lsttestname.Index = modFillContainer.GetItemIndexListBox(lsttestname, Trim(txttestname.Text))
      Balloon.Info(("Information saved"), btnBrOK)
      Balloon.Delay = modBasic.$BalloonDelay
    Endif

  Endif

End

Public Sub btnBrChange_Click()

  Dim res As Result
  Dim res1 As Result
  Dim res2 As Result

  If btnBrChange.Text = "&Edit" And If btnBrOK.Text = "&Add" Then
    btnBrChange.Text = "&Update"

  Else If btnBrChange.Text = "&Update" And If btnBrOK.Text = "&Add" Then
    If txttestname.Text And If cmbcategory.Text And If cmbtype.Text Then
      res = modDatabase.$medConn.Edit("tbltest", "fldtestid=&1", Trim(txttestname.Text))
      res["fldcategory"] = Trim(cmbcategory.Text)
      res["fldsysconst"] = cmbconstant.Text
      res["fldspecimen"] = Trim(txtspecimen.Text)
      res["fldcollection"] = Trim(txtcollection.Text)
      res["flddetail"] = txtmethod.Text
      res["fldtype"] = cmbtype.Text
      res["fldoption"] = cmboption.Text
      res["fldsensitivity"] = txtsensitivity.Value
      res["fldspecificity"] = txtspecificity.Value
      res["fldcomment"] = txtcomment.text
      res["fldcritical"] = txtcritical.Value
      res.Update()
      btnBrChange.Text = "&Edit"

      res1 = modDatabase.$medConn.Edit("tbltestoption", "fldtestid=&1", txttestname.Text)
      If res1.Available Then
        For Each res1
          res1["fldanswertype"] = cmboption.Text
          res1.Update
        Next
      Endif
      res2 = modDatabase.$medConn.Edit("tbltestquali", "fldtestid=&1", txttestname.Text)
      If res2.Available Then
        For Each res2
          res2["fldtanswertype"] = cmboption.Text
          res2.Update
        Next
      Endif
      Balloon.Info(("Information updated"), btnBrChange)
      Balloon.Delay = modBasic.$BalloonDelay
    Endif
  Endif

End

Public Sub btnBrCancel_Click()

  Dim res As Result

  If Message.Question(("Are you sure?"), ("No"), ("Yes")) = 2 Then
    res = modDatabase.$medConn.Exec("select COUNT(fldid) as cnt from tblpatlabtest where fldtestid=&1", Trim(txttestname.Text))
    If res!cnt = 0 Then
      modDatabase.$medConn.Delete("tbltest", "fldtestid=&1", Trim(txttestname.Text))
      BlankALL()
      FillTestListbox()
      Balloon.Delete(("Information deleted"), btnBrCancel)
    Else
      Balloon.Delete(("Deletion not permitted"), btnBrCancel)
    Endif
    Balloon.Delay = modBasic.$BalloonDelay
  Endif

End

Public Sub btnoption_Click()

  Dim hForm As FmSubQuali
  Dim hForm1 As FmVisualInput
  Dim hForm2 As FmSubScale
  Dim hQuali As FmTestQuali
  Dim hQuanti As FmTestQuanti
  Dim hForm3 As FmSubQualiText

  If cmbtype.Text = "Quantitative" Then
    hQuanti = New FmTestQuanti(txttestname.Text)
    hQuanti.ShowModal
  Else

    If cmboption.Text Then
      If cmboption.Text = "No Selection" Then
      Else If cmboption.Text = "Clinical Scale" Then
        hForm2 = New FmSubScale("Diagnostic Tests", txttestname.Text, "")
        hForm2.ShowModal
      Else If cmboption.Text = "Visual Input" Then
        hForm1 = New FmVisualInput("Diagnostic Tests", txttestname.Text, "", cmboption.Text)
        hForm1.ShowModal
      Else If cmboption.Text = "Custom Components" Or If cmboption.Text = "Fixed Components" Then
        hQuali = New FmTestQuali(txttestname.Text)
        hQuali.ShowModal
      Else If cmboption.Text = "Text Addition" Then
        hForm3 = New FmSubQualiText("Diagnostic Tests", txttestname.Text, "", cmboption.Text)
        hForm3.ShowModal
      Else
        hForm = New FmSubQuali("Diagnostic Tests", txttestname.Text, "", cmboption.Text)
        hForm.ShowModal
      Endif
    Endif
  Endif

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub txttestname_LostFocus()

  txttestname.Text = String.UCaseFirst(txttestname.Text)

End

Public Sub txtfind_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
  Else
    FillTestListbox()
  Endif

End

Public Sub btnsysconst_Click()

  Dim hForm As FmAddVariable1

  hForm = New FmAddVariable1("fldsysconst", "fldcategory", "Test", "tblsysconst")
  hForm.ShowModal
  modBasic.$sysTestList = modSysCons.GetSysconstList("Test")
  cmbconstant.List = modSysCons.SysLabTestList()

End

Public Sub txtfind_KeyPress()

  modGeneralMain.InputTextKeyOnly()

End

Public Sub ToolButton1_Click()

End

Public Sub btnamedit_Click()

  Dim xval As String
  Dim res As Result
  Dim rsn As Result
  Dim res1 As Result
  Dim res2 As Result
  Dim res3 As Result
  Dim res4 As Result
  Dim res5 As Result

  Dim res6 As Result
  Dim res7 As Result
  Dim res8 As Result
  Dim res9 As Result

  If Message.Question(("This process will affect multiple tables. Are you sure?"), ("No"), ("Yes")) = 2 Then
    xval = InputBox(("New Name for ") & txttestname.Text, "Diagnostic Tests", txttestname.Text)
    If xval And xval <> txttestname.Text Then
      Inc Application.Busy

      res1 = modDatabase.$medConn.Edit("tbltestcomment", "fldtestid=&1", txttestname.Text)
      If res1.Available Then
        For Each res1
          res1["fldtestid"] = xval
          res1.Update
        Next
      Endif

      res2 = modDatabase.$medConn.Edit("tbltestlimit", "fldtestid=&1", txttestname.Text)
      If res2.Available Then
        For Each res2
          res2["fldtestid"] = xval
          res2.Update
        Next
      Endif

      res3 = modDatabase.$medConn.Edit("tbltestquali", "fldtestid=&1", txttestname.Text)
      If res3.Available Then
        For Each res3
          res3["fldtestid"] = xval
          res3.Update
        Next
      Endif

      res4 = modDatabase.$medConn.Edit("tblsubtestquali", "fldtestid=&1", txttestname.Text)
      If res4.Available Then
        For Each res4
          res4["fldtestid"] = xval
          res4.Update
        Next
      Endif

      res5 = modDatabase.$medConn.Edit("tbltestoption", "fldtestid=&1", txttestname.Text)
      If res5.Available Then
        For Each res5
          res5["fldtestid"] = xval
          res5.Update
        Next
      Endif

      res6 = modDatabase.$medConn.Edit("tblcodehypo", "fldparent=&1", txttestname.Text)
      If res6.Available Then
        For Each res6
          res6["fldparent"] = xval
          res6.Update
        Next
      Endif

      res7 = modDatabase.$medConn.Edit("tblcodehyper", "fldparent=&1", txttestname.Text)
      If res7.Available Then
        For Each res7
          res7["fldparent"] = xval
          res7.Update
        Next
      Endif

      res8 = modDatabase.$medConn.Edit("tblsyndrohypo", "fldparent=&1", txttestname.Text)
      If res8.Available Then
        For Each res8
          res8["fldparent"] = xval
          res8.Update
        Next
      Endif

      res9 = modDatabase.$medConn.Edit("tblsyndrohyper", "fldparent=&1", txttestname.Text)
      If res9.Available Then
        For Each res9
          res9["fldparent"] = xval
          res9.Update
        Next
      Endif

      res = modDatabase.$medConn.Edit("tbltest", "fldtestid=&1", txttestname.Text)
      If res.Available Then
        res["fldtestid"] = xval
        res.Update
      Endif

      rsn = modDatabase.$medConn.Edit("tblgrouptest", "fldtestid=&1", txttestname.Text)
      If rsn.Available Then
        For Each rsn
          rsn["fldtestid"] = xval
          rsn.Update
        Next
      Endif

      Dec Application.Busy
      FillTestListbox()
    Endif
  Endif

End
