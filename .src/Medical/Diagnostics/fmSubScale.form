# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,63,60)
  Text = ("Clinical Scale Parameters")
  Resizable = False
  { cmbgroup ComboBox
    MoveScaled(13,9,49,3)
    Sorted = True
  }
  { txtoption TextBox
    MoveScaled(13,13,49,3)
  }
  { txtscale ValueBox
    MoveScaled(13,17,11,3)
  }
  { btnBrOK Button
    MoveScaled(37,17,12,3.5333)
    Text = Shortcut(("Add"), "A")
    Picture = Picture["icon:/small/add"]
  }
  { btndel Button
    MoveScaled(50,17,12,3.5333)
    Text = ("Delete")
    Picture = Picture["icon:/small/cancel"]
  }
  { Label1 Label
    MoveScaled(1,1,11,3)
    Text = ("Test")
    Border = Border.Plain
  }
  { lbltest Label
    MoveScaled(13,1,49,3)
    Border = Border.Plain
  }
  { Label2 Label
    MoveScaled(1,5,11,3)
    Text = ("Sub Test")
    Border = Border.Plain
  }
  { lblsubtest Label
    MoveScaled(13,5,49,3)
    Border = Border.Plain
  }
  { GridView1 GridView
    MoveScaled(1,21,61,38)
    Mode = Select.Single
    Header = GridView.Vertical
    AutoResize = False
  }
  { Label4 Label
    MoveScaled(1,17,11,3)
    Text = ("Value")
    Border = Border.Plain
  }
  { Label7 Label
    MoveScaled(1,13,11,3)
    Text = ("Parameter")
    Border = Border.Plain
  }
  { Label5 Label
    MoveScaled(1,9,11,3)
    Text = ("Group")
    Border = Border.Plain
  }
  { btnup ToolButton
    MoveScaled(25,17,3,3)
    Picture = Picture["icon:/small/up"]
  }
  { btndown ToolButton
    MoveScaled(28,17,3,3)
    Picture = Picture["icon:/small/down"]
  }
  { btnqueall ToolButton
    MoveScaled(31,17,3,3)
    Picture = Picture["icon:/small/script"]
  }
}
