' Gambas class file

Private $strDrug As String

Public Sub _new(strDrug As String, xEditable As Boolean)

  $strDrug = strDrug
  txtinjid.Text = $strDrug
  If xEditable = False Then
    tlbdelcompatdrug.Visible = False
    tlbtnadcompatdrug.Visible = False
    tlbdelincompatdrug.Visible = False
    tlbtnadincompatdrug.Visible = False
    tlbdelcompatfluid.Visible = False
    tlbtnadcompatfluid.Visible = False
    tlbdelincompatfluid.Visible = False
    tlbtnadincompatfluid.Visible = False
  Endif

End

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me)

  FillCompatFluid()
  FillIncompatFluid()
  FillComaptDrug()
  FillIncompatDrug()

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

''ZZZZZZZZZZZZZZZZZZZZZZZZZZz
Public Sub tlbtnadcompatfluid_Click()

  Dim hForm As FmRefTextEntry

  hForm = New FmRefTextEntry("Select Compatible Fluids", "Compatible Fluids", txtinjid.Text)
  hForm.ShowModal
  FillCompatFluid()

End

Public Sub tlbtnadincompatfluid_Click()

  Dim hForm As FmRefTextEntry

  hForm = New FmRefTextEntry("Select Incompatible Fluids", "Incompatible Fluids", txtinjid.Text)
  hForm.ShowModal
  FillIncompatFluid()

End

''ZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZZz
''
Public Sub tlbtnadcompatdrug_Click()

  Dim hForm As FmRefTextEntry

  hForm = New FmRefTextEntry("Select Compatible Drugs", "Compatible Drugs", txtinjid.Text)
  hForm.ShowModal
  FillComaptDrug()

End

Public Sub tlbtnadincompatdrug_Click()

  Dim hForm As FmRefTextEntry

  hForm = New FmRefTextEntry("Select Incompatible Drugs", "Incompatible Drugs", txtinjid.Text)
  hForm.ShowModal
  FillIncompatDrug()

End

Public Sub FillCompatFluid()

  Dim sql As String
  Dim tbl As String
  Dim res As Result

  tbl = "tblcompatfluid"
  sql = "select fldchild as col from " & tbl & " where fldparent=&1"
  res = modDatabase.$medConn.Exec(sql, txtinjid.Text)
  modFillContainer.FillListBox(lstcomfl, res, False)

End

Public Sub FillIncompatFluid()

  Dim sql As String
  Dim tbl As String
  Dim res As Result

  tbl = "tblincompatfluid"
  sql = "select fldchild as col from " & tbl & " where fldparent=&1"
  res = modDatabase.$medConn.Exec(sql, txtinjid.Text)
  modFillContainer.FillListBox(lstincomfl, res, False)

End

Public Sub FillComaptDrug()

  Dim sql As String
  Dim tbl As String
  Dim res As Result

  tbl = "tblcompatdrug"
  sql = "select fldchild as col from " & tbl & " where fldparent=&1"
  res = modDatabase.$medConn.Exec(sql, txtinjid.Text)
  modFillContainer.FillListBox(lstcomdrug, res, False)

End

Public Sub FillIncompatDrug()

  Dim sql As String
  Dim tbl As String
  Dim res As Result

  tbl = "tblincompatdrug"
  sql = "select fldchild as col from " & tbl & " where fldparent=&1"
  res = modDatabase.$medConn.Exec(sql, txtinjid.Text)
  modFillContainer.FillListBox(lstincompdrug, res, False)

End

Public Sub tlbdelcompatdrug_Click()

  Dim tbl As String

  If lstcomdrug.Text Then
    tbl = "tblcompatdrug"
    modDatabase.$medConn.Delete(tbl, "fldchild=&1", lstcomdrug.Text)
    FillComaptDrug()
    Balloon.Delete(("Information deleted"), tlbdelcompatdrug)
    Balloon.Delay = modBasic.$BalloonDelay
  Endif

End

Public Sub tlbdelincompatdrug_Click()

  Dim tbl As String

  If lstincompdrug.Text Then
    tbl = "tblincompatdrug"
    modDatabase.$medConn.Delete(tbl, "fldchild=&1", lstincompdrug.Text)
    FillIncompatDrug()
    Balloon.Delete(("Information deleted"), tlbdelincompatdrug)
    Balloon.Delay = modBasic.$BalloonDelay
  Endif

End

