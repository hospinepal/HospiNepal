Public Sub TreeView1_Menu()

  If TreeView1.Selection.Count Then
    If TreeView1.Current.Picture = Picture["icons/coll1.png"] Then
      mnuhide.Popup
    Endif
  Endif

End

Public Sub btnserach_Click()

  Dim xx As String

  xx = InputBox(("Search Generic Names starting with .."), ("Generic List"), "")
  If xx Then
    modMedicine.CompleteGenericTree(TreeView1, 100 * SpinBox1.Value, xx)
    lbltotal.Text = ""
  Endif

End

Public Sub btnmenu_Click()

  If TreeView1.Selection.Count Then
    If TreeView1.Current.Picture = Picture["icons/coll1.png"] Then
      btnmenu.Menu = "mnuhide"
    Endif
  Endif

End

