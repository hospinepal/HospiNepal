' Gambas class file

Private $rData As Result
Private $aMyFields As String[]
Private $sType As String

Public Sub _new(sType As String)

  $sType = sType
  Me.Text = $sType

End

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me)
  GetSelList()

End

Public Sub GetSelList()

  If $sType = "Ethnic Groups" Then
    cmbgroup.List = modFillContainer.GetListFromResult(modDatabase.$medConn.Exec("select distinct(fldgroupname) as col from tblethnicgroup"))
  Else If $sType = "Diagnosis Groups" Then
    cmbgroup.List = modFillContainer.GetListFromResult(modDatabase.$medConn.Exec("select distinct(fldgroupname) as col from tbldiagnogroup"))
  Endif

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

Public Sub btnadd_Click()

  Dim xxx As String[]
  Dim xList As String[]
  Dim xval As String
  Dim res As Result

  If $sType = "Ethnic Groups" Then
    xList = modFillContainer.GetListFromResult(modDatabase.$medConn.Exec("select distinct(fldptnamelast) as col from tblpatientinfo"))
    xxx = GridListView("Select SurNames", xList.Sort())
    If xxx Then
      For Each xval In xxx
        res = modDatabase.$medConn.Create("tblethnicgroup")
        res["fldgroupname"] = cmbgroup.Text
        res["flditemname"] = xval
        res.Update
      Next
    Endif

  Else If $sType = "Diagnosis Groups" Then
    xList = modICD.ICDGroupNCodeList(modPathology.ICDCodePath())
    xxx = GridDualView("Select Diseases", xList.Sort())
    If xxx Then
      For Each xval In xxx
        res = modDatabase.$medConn.Create("tbldiagnogroup")
        res["fldgroupname"] = cmbgroup.Text
        res["flditemname"] = xval
        res["fldcodeid"] = modPathology.GetDiagnosisValue(xval)
        res.Update
      Next
    Endif

  Endif
  ShowGridData()
  GetSelList()

End

Private Sub ShowGridData()

  Dim sql As String

  If cmbgroup.Text Then
    If $sType = "Ethnic Groups" Then
      sql = "select fldid,fldgroupname,flditemname from tblethnicgroup where fldgroupname=&1 ORDER BY flditemname ASC"
    Else If $sType = "Diagnosis Groups" Then
      sql = "select fldid,fldcodeid,flditemname from tbldiagnogroup where fldgroupname=&1 ORDER BY flditemname ASC"
    Endif
    $rData = modDatabase.$medConn.Exec(sql, cmbgroup.Text)
    $aMyFields = New String[]
    modGridView.ReadSmallData(GridView1, $rData, $aMyFields)

    With GridView1
      .Columns[0].Width = 1
      .Columns[1].Width = 75 * modBasic.$AppWidthRatio
      .Columns[2].Width = 450 * modBasic.$AppWidthRatio

      .Columns[1].Text = "Code"
      .Columns[2].Text = "Particulars"
    End With

  Endif

End

Public Sub GridView1_Data(Row As Integer, Column As Integer)

  $rData.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView1, Row)
  GridView1.Data.Text = $rData[$aMyFields[Column]]

End

Public Sub btnrefresh_Click()

  ShowGridData()

End

Public Sub mnudel_Click()

  If GridView1.Rows.Selection.Count > 0 Then
    If Message.Question(("Are you sure?"), ("No"), ("Yes")) = 2 Then
      If $sType = "Ethnic Groups" Then
        modDatabase.$medConn.Delete("tblethnicgroup", "fldid=&1", GridView1[GridView1.Row, 0].Text)
      Else If $sType = "Diagnosis Groups" Then
        modDatabase.$medConn.Delete("tbldiagnogroup", "fldid=&1", GridView1[GridView1.Row, 0].Text)
      Endif
      ShowGridData()
    Endif
  Endif

End

Public Sub GridView1_Menu()

  mnuhide.Popup

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.Esc Then
    Me.Close
  Else
    modGeneralmain.GoToNextControlTab()
  Endif

End

Public Sub btnduplicate_Click()

  Dim hForm As FRequest
  Dim res As Result

  If $sType = "Ethnic Groups" Then
    res = modDatabase.$syConn.Exec("select flditemname,count(flditemname) FROM tblethnicgroup GROUP BY flditemname HAVING count(flditemname)>1")                          ''
    hForm = New FRequest(res, "Items Duplicate in Grouping List", "Ethnic Groups:Duplicates", False)
    hForm.ShowModal
  Else If $sType = "Diagnosis Groups" Then
    res = modDatabase.$syConn.Exec("select flditemname,count(flditemname) FROM tbldiagnogroup GROUP BY flditemname HAVING count(flditemname)>1")                          ''
    hForm = New FRequest(res, "Items Duplicate in Grouping List", "Diagnosis Groups:Duplicates", False)
    hForm.ShowModal
  Endif

End

Public Sub btnmissed_Click()

  Dim hForm As FRequest
  Dim res As Result

  If $sType = "Ethnic Groups" Then
    res = modDatabase.$syConn.Exec("select distinct(fldptnamelast) as SurName FROM tblpatientinfo where fldptnamelast NOT IN(select flditemname from tblethnicgroup) ORDER BY fldptnamelast ASC")                          ''
    hForm = New FRequest(res, "Items Missing from Grouping List", "Ethnic Groups:Missing", False)
    hForm.ShowModal
  Else If $sType = "Diagnosis Groups" Then
  Endif

End
