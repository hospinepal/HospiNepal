# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,73,64)
  Text = ("Medical Grouping")
  Resizable = False
  { mnuhide Menu
    Visible = False
    { mnudel Menu
      Text = ("Delete")
      Shortcut = "Ctrl+D"
    }
  }
  { cmbgroup ComboBox
    MoveScaled(14,1,37,3.2667)
    Sorted = True
  }
  { btnrefresh Button
    MoveScaled(51,1,3,3)
    Picture = Picture["icon:/small/refresh"]
  }
  { GridView1 GridView
    MoveScaled(1,6,71,53)
    Mode = Select.Single
    Header = GridView.Both
    AutoResize = False
  }
  { Label2 Label
    MoveScaled(1,1,12,3.5333)
    Text = ("Group Name")
    Border = Border.Plain
  }
  { btnadd Button
    MoveScaled(68,1,3,3)
    Picture = Picture["icon:/small/add"]
  }
  { btnduplicate Button
    MoveScaled(1,60,19,3)
    Text = ("Duplicates")
    Picture = Picture["icon:/small/file"]
  }
  { btnmissed Button
    MoveScaled(53,60,19,3)
    Text = ("Missing")
    Picture = Picture["icon:/small/file"]
  }
}
