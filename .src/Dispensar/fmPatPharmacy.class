Public Sub mnucost_Click()

  Dim xx As String
  Dim cstamt As Float
  Dim discper As Float
  Dim taxper As Float

  If GridView1.Rows.Selection.Count > 0 Then
    cstamt = modStock.GetToDispenseCostOneComp(GridView1[GridView1.Row, 3].Text, modGeneralMain.compID, CFloat(GridView1[GridView1.Row, 6].Text), CFloat(GridView1[GridView1.Row, 7].Text))
    taxper = GridView1[GridView1.Row, 11].Text
    discper = GridView1[GridView1.Row, 10].Text

    xx = "<b>" & GridView1[GridView1.Row, 3].Text & "</b>" & "<br>"
    xx = xx & "Item Cost: " & modReportVar.GetLocaleNumberFormat(cstamt, gb.Currency) & "<br>"
    xx = xx & "Tax: " & modReportVar.GetLocaleNumberFormat(cstamt * taxper / 100, gb.Currency) & "<br>"
    xx = xx & "Disc: " & modReportVar.GetLocaleNumberFormat(cstamt * discper / 100, gb.Currency) & "<br>"
    xx = xx & "Total: " & modReportVar.GetLocaleNumberFormat(cstamt * (1 - discper / 100) * (1 + taxper / 100), gb.Currency)
    Message.Info(xx, ("OK"))
  Endif

End

