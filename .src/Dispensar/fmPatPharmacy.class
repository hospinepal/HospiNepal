Public Sub mnuhelp_Click()

  Dim res As Result
  Dim xx As String

  If GridView1.Rows.Selection.Count > 0 Then
    res = modDatabase.$myConn.Exec("select fldbatch,fldexpiry,fldqty,fldsellpr from tblentry where fldstockid=&1 and fldstatus=&2", GridView1[GridView1.Row, 3].Text, 1)
    If res.Available = True Then
      xx = "<b>" & GridView1[GridView1.Row, 3].Text & "</b>" & "<br>" & "<b>BATCH:</b> " & res!fldbatch & "<br>" & "<b>EXPIRY:</b> " & modReportVar.GetDateTimeReport(res!fldexpiry, gb.MediumDate) & "<br>" & "<b>RATE:</b> " & modReportVar.GetLocaleNumberFormat(res!fldsellpr, gb.Currency) & "<br>" & "<b>QTY:</b> " & res!fldqty                                             ''
      Message.Info(xx, ("OK"))
    Endif
  Endif

End

