Public Sub mnuexpiry_Click()

  Dim xPath As String

  Dialog.Title = "Select Expiry Date"
  Dialog.Date = DateAdd(Date(), gb.Month, 3)
  If Dialog.SelectDate() Then Return
  xPath = modHTMLStock.ShowTotalExpiry(Dialog.Date)
  modPrint.OpenHTMLPreview("", xPath, "ReportSize")

End

Public Sub mnunderstock_Click()

  Dim xPath As String

  xPath = modHTMLStock.ShowUnderStockItemReport()
  modPrint.OpenHTMLPreview("", xPath, "ReportSize")

End

Public Sub mnuipreturn_Click()

  Dim xPath As String
  Dim xx As Date[]

  xx = DoubleDates(("Select Purchase Invoice Dates"), "Inpatient Medicine Returns", [Date(), Date()])
  If xx Then
    xPath = modHTMLStock.PatientMedicationForReturn(xx[0], xx[1])
    modPrint.OpenHTMLPreview("", xPath, "ReportSize")
  Endif

End

'''---------------------- transfer server -------------------------------------------------------
Public Sub ServerSocket2_Connection(RemoteHostIP As String)

  Dim Myket As Socket

  Myket = ServerSocket2.Accept()
  Myket.Blocking = False
  Print RemoteHostIP

End

Public Sub Socket_Read()

  Dim sCad As String

  If Last.Status <> Net.Connected Then Return
  Read #Last, sCad, Lof(Last)
  modControl.ShowTransferFile(Last.RemoteHost, sCad)

End

Public Sub Workspace1_Menu()

  If Workspace1.Windows.Count = 0 Then
    mnufile.Popup
  Endif

End

Public Sub mnubackground_Click()

  Dialog.Filter = ["*.jpg;*.jpeg;*.png;*.bmp", "Picture files"]
  If Dialog.OpenFile() Then Return
  modSettings.SaveSettingsToVar("AppSetting_DeskPicture/" & modGeneralMain.$lbluser, Dialog.Path)
  modHelpVariable.SetWorkSpaceImage()

End

