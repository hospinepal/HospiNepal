' Gambas class file

Private $rData As Result
Private $aMyFields As String[]

Private dt1 As Date
Private dt2 As Date

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me)

  cmbcomp.List = modBasic.$AllCompList
  rbmed.Value = True
  cmbcomp.SetFocus

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

Public Sub cmbcomp_Click()

  lblcomp.Text = modGeneral.GetCompNameFromCompID(cmbcomp.Text)

End

Public Sub btnfill_Click()

  If cmbcomp.Text Then
    ShowStockGrid()
    dt1 = DateAdd(Now(), gb.Date, 0 - CInt(txtprev.Value))
    dt2 = Now()
  Endif

End

Private Function GetStockType() As String

  Dim xx As String

  If rbmed.Value = True Then
    xx = "Medicines"
  Else If rbsurg.Value = True Then
    xx = "Surgicals"
  Else If rbextra.Value = True Then
    xx = "Extra Items"
  Endif

  Return xx

End

Private Sub ShowStockGrid()

  $rData = modDatabase.$myConn.Exec("select distinct(fldstockid) as fldstockid,fldstockid,fldstockid,fldstockid,fldstockid,fldstockid from tblentry  where fldcategory=&1 and fldcomp=&2", GetStockType(), cmbcomp.Text)                          ''

  $aMyFields = New String[]
  modGridView.ReadSmallData(GridView1, $rData, $aMyFields)
  With GridView1
    .Columns[0].Width = 315 * modBasic.$AppWidthRatio
    .Columns[1].Width = 75 * modBasic.$AppWidthRatio
    .Columns[2].Width = 75 * modBasic.$AppWidthRatio
    .Columns[3].Width = 75 * modBasic.$AppWidthRatio
    .Columns[4].Width = 75 * modBasic.$AppWidthRatio
    .Columns[5].Width = 75 * modBasic.$AppWidthRatio
    .Columns[0].Text = "Particulars"
    .Columns[1].Text = "MinStock"
    .Columns[2].Text = "MaxStock"
    .Columns[3].Text = "SalesQTY"
    .Columns[4].Text = "CurrQTY"
    .Columns[5].Text = "OrderQTY"
  End With

End

Public Sub GridView1_Data(Row As Integer, Column As Integer)

  $rData.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView1, Row)
  If Column = 1 Then
    GridView1.Data.Text = modStock.GetMinimumStock($rData[$aMyFields[Column]], GetStockType())
  Else If Column = 2 Then
    GridView1.Data.Text = modStock.GetMaximumStock($rData[$aMyFields[Column]], GetStockType())
  Else If Column = 3 Then
    GridView1.Data.Text = modStock.GetConsumptionQTY(GetStockType(), $rData[$aMyFields[Column]], dt1, dt2, cmbcomp.Text)
  Else If Column = 4 Then
    GridView1.Data.Text = modStock.GetCurrentStockOneComp($rData[$aMyFields[Column]], cmbcomp.Text)
  Else If Column = 5 Then
    GridView1.Data.Text = GetOrderQty($rData[$aMyFields[Column]], GetStockType())
  Else
    GridView1.Data.Text = $rData[$aMyFields[Column]]
  Endif

End

Private Function GetOrderQty(strItem As String, strType As String) As Integer

  Dim xx As Float

  xx = modStock.GetConsumptionQTY(strType, strItem, dt1, dt2, cmbcomp.Text) * (txtlater.Value / txtprev.Value) - modStock.GetCurrentStockOneComp(strItem, cmbcomp.Text)
  If xx < 0 Then
    xx = 0
  Endif
  Return Round(xx, 0)

End

Public Sub btnreqs_Click()

  If cmbcomp.Text Then
    modCHTMLReport.ExportGridToHTML(GridView1, "PURCHASE REQUEST : " & cmbcomp.Text, modReportVar.GetDateTimeReport(Now(), gb.GeneralDate))
  Endif

End
