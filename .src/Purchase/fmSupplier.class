' Gambas class file

Private $rData As Result
Private $aMyFields As String[]

Public Sub Form_Open()

  modGeneralMain.ArrangeEmbedForms(Me, Panel1, "Vertical")
  Me.Icon = Picture[modGeneralMain.$strLogo]
  cmbstatus.List = ["Active", "Inactive"]
  cmbpaymode.List = ["Cash Payment", "Credit Payment"]
  dtstart.Value = Now()
  BlankAll()
  FillGridSupplier()
  txtsupname.SetFocus

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

Private Sub BlankAll()

  txtconphone.Text = ""
  txtcontname.Text = ""
  txtcreday.Value = 0
  txtsupadd.Text = ""
  txtsuphone.Text = ""
  txtsupname.Text = ""
  dtstart.Value = Date()
  cmbpaymode.Text = ""
  cmbstatus.Text = ""

End

Public Sub Form_KeyRelease()

  modGeneralmain.GoToNextControlTab()

End

Public Sub dtnepstart_Click()

  Dim xx As String

  xx = BSDateFormat(("Enter BS Date in yyyy/mm/dd format"), ("Date Converter"), modDate.ConvertToLocaldate(dtstart.Value))
  If xx Then
    dtnepstart.Value = modDate.ConvertToEnglishdate(xx)
  Endif

End

Public Sub txtsupname_KeyPress()

  modGeneralMain.InputTextKeyOnly()

End

Public Sub cmbpaymode_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbpaymode)
  modFillContainer.RestrictComboToContent(cmbpaymode)

End

Public Sub cmbstatus_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbstatus)
  modFillContainer.RestrictComboToContent(cmbstatus)

End

Public Sub txtsupname_LostFocus()

  txtsupname.Text = UCase(txtsupname.Text)

End

Public Sub txtsupadd_LostFocus()

  txtsupadd.text = String.UCaseFirst(txtsupadd.text)

End

Public Sub txtcontname_LostFocus()

  txtcontname.text = String.UCaseFirst(txtcontname.text)

End

Public Sub btnfullrep_Click()

  Dim sAmt As String[]

  sAmt = New String[]
  sAmt.Add("All")
  sAmt.Add("")
  sAmt.Add("")
  sAmt.Add(modReportVar.GetLocaleNumberFormat(txttotdebit.Value, gb.Currency))
  sAmt.Add(modReportVar.GetLocaleNumberFormat(txttotcredit.Value, gb.Currency))
  sAmt.Add(modReportVar.GetLocaleNumberFormat(txttotcredit.Value - txttotdebit.Value, gb.Currency))
  modCHTMLReport.ExportGridToHTML(GridView1, "SUPPLIERS", modReportVar.GetDateTimeReport(Now(), gb.GeneralDate), sAmt)

End

Public Sub btnadd_Click()

  Dim res As Result

  If txtsupname.Text And If cmbstatus.Text Then
    res = modDatabase.$myConn.Create("tblsupplier")
    res["fldsuppname"] = Trim(txtsupname.Text)
    res["fldsuppaddress"] = Trim(txtsupadd.Text)
    res["fldsuppphone"] = txtsuphone.Text
    res["fldcontactname"] = txtcontname.Text
    res["fldcontactphone"] = txtconphone.Text
    res["fldstartdate"] = dtstart.Value
    res["fldpaymentmode"] = cmbpaymode.Text
    res["fldcreditday"] = txtcreday.Value
    res["fldactive"] = cmbstatus.Text
    res["fldpaiddebit"] = 0
    res["fldleftcredit"] = 0
    res.Update()
    BlankAll()
    FillGridSupplier()
    Balloon.Info(("Information saved"), btnadd)
    Balloon.Delay = modBasic.$BalloonDelay
  Endif

End

Public Sub btnedit_Click()

  Dim res As Result

  If Message.Question(("Are you sure?"), ("No"), ("Yes")) = 2 Then
    If GridView1.Rows.Selection.Count > 0 Then
      res = modDatabase.$myConn.Edit("tblsupplier", "fldsuppname=&1", GridView1[GridView1.Row, 0].Text)
      res["fldsuppaddress"] = Trim(txtsupadd.Text)
      res["fldsuppphone"] = txtsuphone.Text
      res["fldcontactname"] = txtcontname.Text
      res["fldcontactphone"] = txtconphone.Text
      res["fldstartdate"] = dtstart.Value
      res["fldpaymentmode"] = cmbpaymode.Text
      res["fldcreditday"] = txtcreday.Value
      res["fldactive"] = cmbstatus.Text
      res["fldpaiddebit"] = 0
      res["fldleftcredit"] = 0
      res["xyz"] = False
      res.Update()
      Balloon.Info(("Information updated"), btnedit)
      Balloon.Delay = modBasic.$BalloonDelay
    Endif
  Endif

End

Private Sub FillGridSupplier()

  Dim sql As String
  Dim debit As Float
  Dim credit As Float
  Dim btot As Float

  sql = "select fldsuppname,fldsuppaddress,fldactive,fldpaiddebit,fldleftcredit,(fldleftcredit-fldpaiddebit) as tot from tblsupplier"
  $rData = modDatabase.$myConn.Exec(sql)
  $aMyFields = New String[]
  modGridView.ReadSmallData(GridView1, $rData, $aMyFields)
  With GridView1
    .Columns[0].Width = 250 * modBasic.$AppWidthRatio
    .Columns[1].Width = 150 * modBasic.$AppWidthRatio
    .Columns[2].Width = 60 * modBasic.$AppWidthRatio
    .Columns[3].Width = 125 * modBasic.$AppWidthRatio
    .Columns[4].Width = 125 * modBasic.$AppWidthRatio
    .Columns[5].Width = 125 * modBasic.$AppWidthRatio

    .Columns[0].Text = "Supplier"
    .Columns[1].Text = "Address"
    .Columns[2].Text = "Status"
    .Columns[3].Text = "TOTAL PAID"
    .Columns[4].Text = "TOTAL TOPAY"
    .Columns[5].Text = "NET TOPAY"
  End With

  debit = 0
  credit = 0
  btot = 0
  For Each $rData
    debit = debit + $rData!fldpaiddebit
    credit = credit + $rData!fldleftcredit
    btot = btot + $rData!tot
  Next
  txttotdebit.Value = Round(debit, -2)
  txttotcredit.Value = Round(credit, -2)
  txtbalance.Value = Round(btot, -2)

End

Public Sub GridView1_Data(Row As Integer, Column As Integer)

  $rData.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView1, Row)
  If Column = 3 Then
    GridView1.Data.Text = modReportVar.GetLocaleNumberFormat($rData[$aMyFields[Column]], gb.Currency)
  Else If Column = 4 Then
    GridView1.Data.Text = modReportVar.GetLocaleNumberFormat($rData[$aMyFields[Column]], gb.Currency)
  Else If Column = 5 Then
    GridView1.Data.Text = modReportVar.GetLocaleNumberFormat($rData[$aMyFields[Column]], gb.Currency)
  Else
    GridView1.Data.Text = $rData[$aMyFields[Column]]
  Endif

End

Public Sub GridView1_Click()

  Dim sql As String
  Dim res As Result

  sql = "select fldsuppname,fldsuppaddress,fldsuppphone,fldcontactname,fldcontactphone,fldstartdate,fldpaymentmode,fldcreditday,fldactive from tblsupplier where fldsuppname=&1"
  res = modDatabase.$myConn.Exec(sql, GridView1[GridView1.Row, 0].Text)
  If res.Available Then
    txtsupadd.Text = res["fldsuppaddress"]
    txtsuphone.Text = res["fldsuppphone"]
    txtsupname.Text = res["fldsuppname"]
    dtstart.Value = res["fldstartdate"]
    cmbpaymode.Text = res["fldpaymentmode"]
    txtconphone.Text = res["fldcontactphone"]
    txtcontname.Text = res["fldcontactname"]
    txtcreday.Value = res["fldcreditday"]
    cmbstatus.Text = res["fldactive"]
  Endif

End

Public Sub GridView1_Menu()

  mnuhide.Popup

End

Public Sub btndetail_Click()

  Dim sql As String
  Dim hForm As FRequest
  Dim res As Result

  If GridView1.Rows.Selection.Count > 0 Then
    sql = "select fldid,fldreference,fldpurtype,fldpurdate,fldbillno,fldcategory,flddebit,fldcredit from tblpurchasebill where fldsuppname=&1"
    res = modDatabase.$myConn.Exec(sql, GridView1[GridView1.Row, 0].Text)
    If res.Available Then
      hForm = New FRequest(res, GridView1[GridView1.Row, 0].Text, "Supplier", False)
      hForm.ShowModal
    Endif
  Endif

End

Public Sub btninvoice_Click()

  Dim xx As Date[]
  Dim xPath As String

  If GridView1.Rows.Selection.Count > 0 Then
    xx = DoubleDates(("Select Purchase Invoice Dates"), GridView1[GridView1.Row, 0].Text, [Date(), Date()])
    If xx Then
      xPath = modHTMLStock.ShowSupplierInnvoices(GridView1[GridView1.Row, 0].Text, xx[0], xx[1])
      modPrint.OpenHTMLPreview("", xPath, "ReportSize")
    Endif
  Endif

End

Public Sub btnitems_Click()

  Dim xx As Date[]
  Dim xPath As String

  If GridView1.Rows.Selection.Count > 0 Then
    xx = DoubleDates(("Select Purchase Invoice Dates"), GridView1[GridView1.Row, 0].Text, [Date(), Date()])
    If xx Then
      xPath = modHTMLStock.ShowSupplierItemList(GridView1[GridView1.Row, 0].Text, xx[0], xx[1])
      modPrint.OpenHTMLPreview("", xPath, "ReportSize")
    Endif
  Endif

End

Public Sub btnpayment_Click()

  Dim xPath As String

  If GridView1.Rows.Selection.Count > 0 Then
    xPath = modHTMLStock.ShowTotalPaymentSupplier(GridView1[GridView1.Row, 0].Text)
    modPrint.OpenHTMLPreview("", xPath, "ReportSize")
  Endif

End

Public Sub mnudel_Click()

  If GridView1.Rows.Selection.Count > 0 Then
    If Message.Question(("Are you sure?"), ("No"), ("Yes")) = 2 Then
      modDatabase.$myConn.Delete("tblsupplier", "fldsuppname=&1 and fldpaiddebit=&2 and fldleftcredit=&3", GridView1[GridView1.Row, 0].Text, 0, 0)
      FillGridSupplier()
      BlankAll()
      Message.Delete(("Information deleted"), ("OK"))
    Endif
  Endif

End
