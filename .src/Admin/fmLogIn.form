# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,69,29)
  Drop = True
  Text = ("Log In")
  Resizable = False
  Margin = True
  { cmbusname ComboBox
    MoveScaled(29,6,39,4)
    NoTabFocus = True
    Drop = True
    Sorted = True
  }
  { txtuser TextBox
    MoveScaled(29,10,39,4)
  }
  { txtpass TextBox
    MoveScaled(29,14,39,4)
    Password = True
  }
  { btnOK Button
    MoveScaled(29,21,13,4)
    Tag = "Auto"
    Text = Shortcut(("OK"), "O")
    Picture = Picture["icon:/small/apply"]
  }
  { btnChange Button
    MoveScaled(42,21,13,4)
    Text = ("Change")
    Picture = Picture["icon:/small/edit"]
  }
  { btnCancel Button
    MoveScaled(55,21,13,4)
    Text = ("Cancel")
    Picture = Picture["icon:/small/cancel"]
    Cancel = True
  }
  { ToolButton1 ToolButton
    MoveScaled(33,25,31,3)
    Enabled = False
    Font = Font["Underline"]
    Foreground = &H0000FF&
    Mouse = Mouse.Pointing
    Text = ("Project Homepage")
  }
  { tlbtnadd ToolButton
    MoveScaled(65,25,3,3)
    Picture = Picture["icon:/small/pen"]
  }
  { Panel1 Panel
    MoveScaled(29,18,35,3)
    { rblocal RadioButton
      MoveScaled(0,0,12,3)
      Text = ("Local DB")
    }
    { rbremote RadioButton
      MoveScaled(21,0,14,3)
      Text = ("Remote DB")
    }
  }
  { tlbtnadd2 ToolButton
    MoveScaled(64,18,3,3)
    Picture = Picture["icon:/small/server"]
  }
  { btnexec ToolButton
    MoveScaled(29,25,3,3)
    Picture = Picture["icon:/small/keyboard"]
  }
  { PictureBox1 PictureBox
    MoveScaled(1,1,27,27)
    Border = Border.Plain
  }
  { Frame1 Panel
    MoveScaled(29,0,39,6)
    NoTabFocus = True
    { optadmin RadioButton
      MoveScaled(0,0,12.5333,3)
      Text = ("Admin")
    }
    { optlab RadioButton
      MoveScaled(0,3,12.5333,3)
      Text = ("Labs")
    }
    { optcash RadioButton
      MoveScaled(13,0,12.5333,3)
      Text = ("Cash")
    }
    { optclinic RadioButton
      MoveScaled(26,0,12.5333,3)
      Text = ("Clinic")
    }
    { optphm RadioButton
      MoveScaled(13,3,12.5333,3)
      Text = ("Pharm")
    }
    { optstore RadioButton
      MoveScaled(26,3,12.5333,3)
      Text = ("Store")
    }
  }
}
