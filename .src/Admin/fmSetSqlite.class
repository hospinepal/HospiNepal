Private Function ShowSysSettingFromFIleNew(strSetting As String) As String

  Dim strVal As String

  strVal = modSettings.ShowSettingValue(modHelpVariable.AppDirectory &/ modHelpVariable.AppName & ".conf", strSetting)
  Return strVal

End

Public Sub btnshow_Click()

  Dim xfile As String
  Dim xssl As String
  Dim xird As String

  xfile = modGeneralMain.GetConfigSettingFIle()

