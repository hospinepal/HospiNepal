    Endif

    cmbtype.Text = modSettings.ShowSettingValue(xfile, "System/Service")
    txtserver.Text = modSettings.ShowSettingValue(xfile, "System/Host")
    txtuser.Text = modSettings.ShowSettingValue(xfile, "System/User")
    txtpass.Text = modPassword.DecryptDBPass(modSettings.ShowSettingValue(xfile, "System/Password"), chkssl.Value)
    txtport.Text = modSettings.ShowSettingValue(xfile, "System/Port")

    cmbtype2.Text = modSettings.ShowSettingValue(xfile, "SystemExtra/Service")
    txtserver2.Text = modSettings.ShowSettingValue(xfile, "SystemExtra/Host")
    txtuser2.Text = modSettings.ShowSettingValue(xfile, "SystemExtra/User")
    txtpass2.Text = modPassword.DecryptDBPass(modSettings.ShowSettingValue(xfile, "SystemExtra/Password"), chkssl.Value)
    txtport2.Text = modSettings.ShowSettingValue(xfile, "SystemExtra/Port")

    cmbtype3.Text = modSettings.ShowSettingValue(xfile, "SystemFallback/Service")
    txtserver3.Text = modSettings.ShowSettingValue(xfile, "SystemFallback/Host")
    txtuser3.Text = modSettings.ShowSettingValue(xfile, "SystemFallback/User")
    txtpass3.Text = modPassword.DecryptDBPass(modSettings.ShowSettingValue(xfile, "SystemFallback/Password"), chkssl.Value)
