Public Sub btnadmin_Click()

  Dim rs As Result
  Dim res As Result
  Dim res1 As Result
  Dim res2 As Result

  If txtaduser.Text And If txtadpass.Text And If txtadroot.Text Then
    rs = modDatabase.$myConn.Exec("select flduserid from tbluser")
    If rs.Available = False Then
      res = modDatabase.$myConn.Create("tbluser")
      res["flduserid"] = txtaduser.Text
      res["fldusername"] = "System"
      res["fldpass"] = modPassword.EncryptSimple(Trim(txtadpass.Text))
      res["fldroot"] = Base64(Trim(txtadroot.Text))
      res["fldcategory"] = ""
      res["fldcode"] = 1
      res["fldfromdate"] = Date()
      res["fldtodate"] = Date()
      res["fldstatus"] = "Active"
      res["fldfaculty"] = False
      res["fldpayable"] = False
      res["fldreferral"] = False
      res["fldopconsult"] = False
      res["fldipconsult"] = False
      res["fldsigna"] = False
      res["fldreport"] = False
      res.Update()

      res1 = modDatabase.$myConn.Create("tbluseraccess")
      res1["flduserid"] = txtaduser.Text
      res1["fldaccess"] = Base64(chkadmin.Text)
      res1.Update()

      res2 = modDatabase.$myConn.Create("tblcompaccess")
      res2["flduserid"] = txtaduser.Text
      res2["fldcomp"] = txtcomp.Text
      res2.Update()

      Balloon.Info(("Information Updated"), btnadmin)
      Balloon.Delay = modBasic.$BalloonDelay
    Endif
  Endif

End

Public Sub cmdaccess_Click()

  Dim res As Result
  Dim rs As Result

  rs = modDatabase.$myConn.Exec("select fldhostmac from tblmacaccess where fldhostmac=&1", txtmac.Text)
  If rs.Available = False Then
    res = modDatabase.$myConn.Create("tblmacaccess")
    res["fldhostmac"] = txtmac.Text
    res["fldhostuser"] = txtcompname.Text
    res["fldhostpass"] = Base64(modPassword.$HostLoginPassword)
    res["fldhostip"] = txtip.Text
    res["fldhostname"] = txthost.text
    res["fldcomp"] = txtcomp.Text
    If rs.Available = False Then
      res["fldcompname"] = modGeneralMain.$Department
      res["fldaccess"] = "Active"
    Else If rs.Available = True Then
      res["fldcompname"] = "Empty"
      res["fldaccess"] = "Inactive"
    Endif
    res["fldiptype"] = ""
    res["fldcode"] = modGeneral.GetMaxMacAddCode()
    res.Update()
    Balloon.Info(("Access granted/requested"), cmdaccess)
    Balloon.Delay = modBasic.$BalloonDelay
  Endif

End

Public Sub txtaduser_KeyPress()

  modGeneralMain.InputTextKeyOnly()

End
