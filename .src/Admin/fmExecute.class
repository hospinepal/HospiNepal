' Gambas class file

Public Sub Form_Open()

  txthost.Text = System.Host
  txtip.Text = modApplication.GetLocalIP()
  txtmac.Text = modApplication.GetMACAddress()
  txtcompname.Text = System.User.Name
  txtcomp.Text = modGeneralMain.compID
  Me.Center

End

Public Sub Form_Close()

  modDatabase.CloseDatabase()

End

Public Sub btnpat_Click()

  Dim res As Result
  Dim rer As Result
  Dim res1 As Result

  rer = modDatabase.$myConn.Exec("select fldtype,fldvalue from tblautoid")
  If rer.Available = False Then
    res = modDatabase.$myConn.Create("tblautoid")
    res["fldtype"] = "PatientNo"
    res["fldvalue"] = txtpatno.Value
    res.Update

    res = modDatabase.$myConn.Create("tblautoid")
    res["fldtype"] = "EncounterID"
    res["fldvalue"] = txtencid.Value
    res.Update

    res = modDatabase.$myConn.Create("tblautoid")
    res["fldtype"] = "InvoiceNo"
    res["fldvalue"] = txtinvno.Value
    res.Update

    res = modDatabase.$myConn.Create("tblautoid")
    res["fldtype"] = "AdmitFileNo"
    res["fldvalue"] = txtfileno.Value
    res.Update

    res = modDatabase.$myConn.Create("tblautoid")
    res["fldtype"] = "BookingNo"
    res["fldvalue"] = 1
    res.Update

    res = modDatabase.$myConn.Create("tblautoid")
    res["fldtype"] = "StockNo"
    res["fldvalue"] = 1
    res.Update

    res = modDatabase.$myConn.Create("tblautoid")
    res["fldtype"] = "ReferenceNo"
    res["fldvalue"] = 1
    res.Update

    res = modDatabase.$myConn.Create("tblautoid")
    res["fldtype"] = "JournalNo"
    res["fldvalue"] = 1
    res.Update

    res = modDatabase.$myConn.Create("tblautoid")
    res["fldtype"] = "VoucherNo"
    res["fldvalue"] = 1
    res.Update

    res = modDatabase.$myConn.Create("tblautoid")
    res["fldtype"] = "LabSampleNo"
    res["fldvalue"] = 1
    res.Update

    res = modDatabase.$myConn.Create("tblautoid")
    res["fldtype"] = "PurchaseRefNo"
    res["fldvalue"] = 1
    res.Update

  Endif

  res1 = modDatabase.$myConn.Create("tblpatsubs")
  res1["fldhospcode"] = txthospcode.Text
  res1.Update

  Balloon.Info(("Information inserted"), btnpat)
  Balloon.Delay = modBasic.$BalloonDelay

End

