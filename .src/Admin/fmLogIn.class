' Gambas class file

Public Sub Form_Open()

  Me.Center
  ToolButton1.Text = Application.Title & " Homepage"
  PictureBox1.Picture = Image.Load("logo.png").Stretch(PictureBox1.Width, PictureBox1.Height).Picture
  If Not Exist(modGeneralMain.$SysConfigPath) Then
    modHelpVariable.$FIrstTimeSetting = True
    fmSetSqlite.Show
    fmLogIn.Close
  Else
    If Desktop.NetworkAvailable = True Then
      ToolButton1.Enabled = True
      ToolButton1.Tag = modSettings.ShowSettingValue(modHelpVariable.$appWebconfFile, "Remote/HomaPage")
    Endif

    modExternal.ExecStartUpScript()
    LoadCategor()
    cmbusname.Text = ""
    GetConnType()
    cmbusname.SetFocus
  Endif

End

Private Sub DefaultLog()

  Dim def As String

  def = modSettings.ShowLogValues("LogIn/Default")
  If def = optadmin.Text Then
    optadmin.Value = True
  Else If def = optcash.Text Then
    optcash.Value = True
  Else If def = optclinic.Text Then
    optclinic.Value = True
  Else If def = optlab.Text Then
    optlab.Value = True
  Else If def = optphm.Text Then
    optphm.Value = True
  Else If def = optstore.Text Then
    optstore.Value = True
  Endif

End

Private Sub LoadCategor()

  cmbusname.Text = ""
  cmbusname.Clear

  If optadmin.Value = True Then
    modHelpVariable.$LogInGroup = optadmin.Text
    cmbusname.add("Medical")
    cmbusname.add("Record")
    'cmbusname.add ("Admin")

  Else If optcash.Value = True Then
    modHelpVariable.$LogInGroup = optcash.text
    cmbusname.add("Account")
    cmbusname.add("Cashier")

  Else If optlab.Value = True Then
    modHelpVariable.$LogInGroup = optlab.text
    cmbusname.add("Technologist")
    cmbusname.add("Technician")

  Else If optclinic.Value = True Then
    modHelpVariable.$LogInGroup = optclinic.text
    cmbusname.add("Consultant")
    cmbusname.add("Clinician")

  Else If optstore.Value = True Then
    modHelpVariable.$LogInGroup = optstore.text
    cmbusname.add("Purchase")
    cmbusname.add("Store")

  Else If optphm.Value = True Then
    modHelpVariable.$LogInGroup = optphm.text
    cmbusname.add("Pharmacist")
    cmbusname.add("Dispensar")
  Endif

  DefaultLog()

End

