' Gambas class file

Private $rData As Result
Private $aMyFields As String[]

Public Sub Form_Open()

  modGeneralMain.ArrangeEmbedForms(Me, Panel1, "Vertical")
  Me.Icon = Picture[modGeneralMain.$strLogo]

  cmbcategory.List = ["%", "Diagnostic Tests", "General Services", "Procedures", "Equipment", "Radio Diagnostics", "Other Items", "Medicines", "Surgicals", "Extra Items"]                              ''
  cmbcategory.Text = "%"
  cmbcomp.List = modBasic.$AllCompList
  cmbcomp.Text = "%"
  dtfir.Value = Now()
  dtlast.Value = Now()

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

Public Sub dtnepfir_Click()

  Dim xx As String

  xx = BSDateFormat(("Enter BS Date in yyyy/mm/dd format"), ("Date Converter"), modDate.ConvertToLocaldate(dtfir.Value))
  If xx Then
    dtfir.Value = modDate.ConvertToEnglishdate(xx)
  Endif

End

Public Sub dtneplast_Click()

  Dim xx As String

  xx = BSDateFormat(("Enter BS Date in yyyy/mm/dd format"), ("Date Converter"), modDate.ConvertToLocaldate(dtlast.Value))
  If xx Then
    dtlast.Value = modDate.ConvertToEnglishdate(xx)
  Endif

End

Private Sub ExecuteQuery()

  Dim sql As String
  Dim encid As String

  If txtencid.Text Then
    encid = Trim(txtencid.Text)
  Else
    encid = "%"
  Endif

  If txtinvoice.Text Then
    sql = "select fldencounterval,fldencounterval,flditemname,flditemrate,flditemqty,fldtaxper,flddiscper,fldditemamt as tot,fldtime,fldbillno,fldid,flditemtype,fldsample,fldpayto,fldrefer" & modMisc.HospField() & " from tblpatbilling where fldsave=&1 and fldtime>=&2 and fldtime<=&3 and flditemtype like &4 and fldcomp like &5 and fldencounterval like &6 and fldbillno like &7"                                                   ''
  Else
    sql = "select fldencounterval,fldencounterval,flditemname,flditemrate,flditemqty,fldtaxper,flddiscper,fldditemamt as tot,fldtime,fldbillno,fldid,flditemtype,fldsample,fldpayto,fldrefer" & modMisc.HospField() & " from tblpatbilling where fldsave=&1 and fldtime>=&2 and fldtime<=&3 and flditemtype like &4 and fldcomp like &5 and fldencounterval like &6"
  Endif
  $rData = modDatabase.$syConn.Exec(sql, True, modDate.StartSqlDate(dtfir.value), modDate.EndSqlDate(dtlast.value), cmbcategory.Text, cmbcomp.Text, encid, Trim(txtinvoice.Text))
  ShowSaleData()

End

Private Sub ShowSaleData()

  $aMyFields = New String[]
  modGridView.ReadSmallData(GridView1, $rData, $aMyFields)
  With GridView1
    .Columns[0].Width = 75 * modBasic.$AppWidthRatio
    .Columns[1].Width = 150 * modBasic.$AppWidthRatio
    .Columns[2].Width = 300 * modBasic.$AppWidthRatio
    .Columns[3].Width = 100 * modBasic.$AppWidthRatio
    .Columns[4].Width = 50 * modBasic.$AppWidthRatio
    .Columns[5].Width = 50 * modBasic.$AppWidthRatio
    .Columns[6].Width = 50 * modBasic.$AppWidthRatio
    .Columns[7].Width = 120 * modBasic.$AppWidthRatio
    .Columns[8].Width = 180 * modBasic.$AppWidthRatio
    .Columns[9].Width = 100 * modBasic.$AppWidthRatio
    .Columns[10].Width = 1
    .Columns[11].Width = 1
    .Columns[12].Width = 75 * modBasic.$AppWidthRatio
    .Columns[13].Width = 150 * modBasic.$AppWidthRatio
    .Columns[14].Width = 150 * modBasic.$AppWidthRatio

    .Columns[0].Text = "Encounter"
    .Columns[1].Text = "Patient Name"
    .Columns[2].Text = "Particulars"
    .Columns[3].Text = "Rate"
    .Columns[4].Text = "QTY"
    .Columns[5].Text = "Tax%"
    .Columns[6].Text = "Disc%"
    .Columns[7].Text = "Total"
    .Columns[8].Text = "EntryDate"
    .Columns[9].Text = "Invoice"
    .Columns[12].Text = "Status"
    .Columns[13].Text = "Payable"
    .Columns[14].Text = "Referral"
  End With

End

Public Sub btnrefresh_Click()

  ExecuteQuery()

End

Public Sub GridView1_Data(Row As Integer, Column As Integer)

  $rData.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView1, Row)
  If Column = 1 Then
    GridView1.Data.Text = modPatient.GetPatientNameByEnc($rData["fldencounterval"])
  Else If Column = 3 Then
    GridView1.Data.Text = modReportVar.GetLocaleNumberFormat($rData[$aMyFields[Column]], gb.Currency)
  Else If Column = 4 Then
    GridView1.Data.Text = modReportVar.GetLocaleNumberFormat($rData[$aMyFields[Column]], -2)
  Else If Column = 5 Then
    GridView1.Data.Text = modReportVar.GetLocaleNumberFormat($rData[$aMyFields[Column]], -2)
  Else If Column = 6 Then
    GridView1.Data.Text = modReportVar.GetLocaleNumberFormat($rData[$aMyFields[Column]], -2)
  Else If Column = 7 Then
    GridView1.Data.Text = modReportVar.GetLocaleNumberFormat($rData[$aMyFields[Column]], gb.Currency)
  Else If Column = 8 Then
    GridView1.Data.Text = modReportVar.GetDateTimeReport($rData["fldtime"], gb.GeneralDate)
  Else If Column = 13 Then
    GridView1.Data.Text = modGeneral.GetUserFullName($rData[$aMyFields[Column]])
  Else If Column = 14 Then
    GridView1.Data.Text = modGeneral.GetUserFullName($rData[$aMyFields[Column]])
  Else
    GridView1.Data.Text = $rData[$aMyFields[Column]]
  Endif

End

Public Sub btnexpo_Click()

  Dim dtstr As String

  dtstr = modReportVar.GetDateTimeReport(modDate.StartSqlDate(dtfir.value), gb.MediumDate) & " TO " & modReportVar.GetDateTimeReport(modDate.EndSqlDate(dtlast.value), gb.MediumDate)
  modCHTMLReport.$EncColumn = 0
  modCHTMLReport.ExportReportGridToHTML(GridView1, dtstr, cmbcategory.Text & "," & cmbcomp.Text & "," & txtencid.Text & "," & txtinvoice.Text)

End

Public Sub GridView1_KeyRelease()

  Dim xtype As String

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    xtype = GridView1[GridView1.Row, 11].Text
    If xtype Then
      If xtype = "Diagnostic Tests" Then
        DiagnoGrid(GridView1[GridView1.Row, 10].Text)

      Endif
    Endif
  Endif

End

Private Sub DiagnoGrid(sid As Long)

  Dim res As Result
  Dim sql As String

  Dim Column As Integer
  Dim fld As ResultField

  sql = "select fldid,fldtestid,fldsampleid,fldsampletype,fldstatus,fldtime_sample,flduserid_sample,fldtime_report,flduserid_report,fldtime_verify,flduserid_verify from tblpatlabtest where fldgroupid=&1"
  res = modDatabase.$syConn.Exec(sql, sid)

  GridView2.Clear
  GridView2.Columns.Count = res.Fields.Count
  GridView2.Rows.Count = res.Count

  For Each res
    Column = 0
    For Each fld In res.Fields
      modGeneralMain.GridExplicitDecoration(GridView2, res.Index, Column)
      GridView2[res.Index, Column].Text = res[fld.Name]
      Column = Column + 1
    Next
  Next
  GridView2.Row = 0

  With GridView2
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 1
    .Columns[1].Width = 250 * modBasic.$AppWidthRatio
    .Columns[2].Width = 100 * modBasic.$AppWidthRatio
    .Columns[3].Width = 120 * modBasic.$AppWidthRatio
    .Columns[4].Width = 70 * modBasic.$AppWidthRatio
    .Columns[5].Width = 150 * modBasic.$AppWidthRatio
    .Columns[6].Width = 70 * modBasic.$AppWidthRatio
    .Columns[7].Width = 150 * modBasic.$AppWidthRatio
    .Columns[8].Width = 70 * modBasic.$AppWidthRatio
    .Columns[9].Width = 150 * modBasic.$AppWidthRatio
    .Columns[10].Width = 70 * modBasic.$AppWidthRatio

    .Columns[1].Text = "TestName"
    .Columns[2].Text = "SampID"
    .Columns[3].Text = "Specimen"
    .Columns[4].Text = "Status"
    .Columns[5].Text = "SampleDate"
    .Columns[6].Text = "SampledBy"
    .Columns[7].Text = "ReportDate"
    .Columns[8].Text = "ReportedBy"
    .Columns[9].Text = "VerifyDate"
    .Columns[10].Text = "VerifiedBy"
  End With

End

Public Sub GridView1_Menu()

  mnuhide.Popup

End

Public Sub mnureferal_Click()

  Dim xx As String
  Dim res1 As Result
  Dim Row As Integer

  If GridView1.Rows.Selection.Count > 0 Then
    Row = GridView1.Row
    xx = MedicalSelectedUser(("Select Referral User"), modBasic.$ReferUserList)
    If xx Then
      If Message.Question(("Are you sure?"), ("No"), ("Yes")) = 2 Then
        res1 = modDatabase.$myConn.Edit("tblpatbilling", "fldid=&1", GridView1[GridView1.Row, 10].Text)
        res1["fldrefer"] = xx
        res1["xyz"] = False
        res1.Update
        ExecuteQuery()
      Endif
    Endif
    GridView1.Row = Row
  Endif

End

Public Sub mnupayble_Click()

  Dim xx As String
  Dim res1 As Result
  Dim Row As Integer

  If GridView1.Rows.Selection.Count > 0 Then
    Row = GridView1.Row
    xx = MedicalSelectedUser(("Select Payable User"), modBasic.$PayUserList)
    If xx Then
      If Message.Question(("Are you sure?"), ("No"), ("Yes")) = 2 Then
        res1 = modDatabase.$myConn.Edit("tblpatbilling", "fldid=&1", GridView1[GridView1.Row, 10].Text)
        res1["fldpayto"] = xx
        res1["xyz"] = False
        res1.Update
        ExecuteQuery()
      Endif
    Endif
    GridView1.Row = Row
  Endif

End

Public Sub mnucancel_Click()

  Dim xtype As String
  Dim Row As Integer

  xtype = GridView1[GridView1.Row, 11].Text
  If xtype Then
    If Message.Question(("Are you sure?"), ("No"), ("Yes")) = 2 Then
      Row = GridView1.Row
      If xtype = "Diagnostic Tests" Then
        DeleteDiagno(GridView1[GridView1.Row, 10].Text)
        DiagnoGrid(GridView1[GridView1.Row, 10].Text)

      Endif
      ExecuteQuery()
      GridView1.Row = Row
    Endif
  Endif

End

Private Sub DeleteDiagno(sid As Long)

  Dim res As Result
  Dim res1 As Result

  Inc Application.Busy
  modDatabase.$myConn.Begin
  res = modDatabase.$myConn.Edit("tblpatbilling", "fldid=&1 and fldsample=&2", sid, "Sampled")
  If res.Available = True Then
    modBillings.InsertBlankBillItem(res!fldencounterval, res!fldbillingmode, res!flditemtype, res!flditemno, res!flditemname, res!flditemrate, 0 - res!flditemqty, res!fldtaxper, res!flddiscper, "Done", res!fldid, True, False, res!fldtarget, res!fldpayto, res!fldrefer, "AutoReturn", res!fldbillno)              ''
    res["fldsample"] = "Removed"
    res["fldretqty"] = res!flditemqty
    res["xyz"] = False
    res.Update()

    res1 = modDatabase.$myConn.Edit("tblpatlabtest", "fldgroupid=&1 and (fldstatus=&2 or fldstatus=&3)", sid, "Ordered", "Sampled")
    If res1.Available Then
      For Each res1
        res1["fldstatus"] = "Cancelled"
        res1["xyz"] = False
        res1.Update
      Next
    Endif

  Endif
  modDatabase.$myConn.Commit
  Dec Application.Busy

Catch
  modDatabase.$myConn.Rollback
  Dec Application.Busy
  modHelpVariable.CreateErrorReport()

End

Public Sub txtencid_KeyPress()

  If Key.Code = Key.Down Then
    If modBasic.$AutoEncSuffix = "Yes" Then
      txtencid.Text = txtencid.Text & modBasic.$HospCode
    Endif
  Else
    modGeneralMain.InputUpCaseOnly()
  Endif

End

Public Sub txtinvoice_KeyPress()

  If Key.Code = Key.Down Then
    If modBasic.$AutoEncSuffix = "Yes" Then
      txtinvoice.Text = txtinvoice.Text & modBasic.$HospCode
    Endif
  Else
    modGeneralMain.InputUpCaseOnly()
  Endif

End
