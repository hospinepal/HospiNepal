' Gambas class file

Private $rData As Result
Private $aMyFields As String[]

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me)
  cmbcomp.List = modBasic.$AllCompList
  If modGlobalSetting.ShowSettingFromDB("GeneralSettings/RestrictToOwnBilling") = "Yes" Then
    txtuser.Text = modGeneralMain.$lbluser
    txtuser.Enabled = False
  Endif
  cmbcomp.Add("%")
  dtfir.Value = Now()
  dtlast.Value = Now()

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.Esc Then
    Me.Close
  Endif

End

Public Sub dtnepfir_Click()

  Dim xx As String

  xx = BSDateFormat(("Enter BS Date in yyyy/mm/dd format"), ("Date Converter"), modDate.ConvertToLocaldate(dtfir.Value))
  If xx Then
    dtfir.Value = modDate.ConvertToEnglishdate(xx)
  Endif

End

Public Sub dtneplast_Click()

  Dim xx As String

  xx = BSDateFormat(("Enter BS Date in yyyy/mm/dd format"), ("Date Converter"), modDate.ConvertToLocaldate(dtlast.Value))
  If xx Then
    dtlast.Value = modDate.ConvertToEnglishdate(xx)
  Endif

End

Public Sub btnrefresh_Click()

  If txtuser.Text Then
    lbluser.Text = modGeneral.GetUserFullName(Trim(txtuser.Text))
    ShowCOllection()
  Endif

End

Private Sub ShowCOllection()

  $rData = modDatabase.$syConn.Exec("select fldid,fldfrominvoice,fldtoinvoice,fldbillamt,fldretinvoice,fldretamt,fldrecvamt from tblusercollection where fldcashier=&1", Trim(txtuser.Text))                                                       ''
  $aMyFields = New String[]
  modGridView.ReadSmallData(GridView1, $rData, $aMyFields)
  With GridView1
    .Columns[0].Width = 1
    .Columns[1].Width = 120 * modBasic.$AppWidthRatio
    .Columns[2].Width = 120 * modBasic.$AppWidthRatio
    .Columns[3].Width = 100 * modBasic.$AppWidthRatio
    .Columns[4].Width = 150 * modBasic.$AppWidthRatio
    .Columns[5].Width = 100 * modBasic.$AppWidthRatio
    .Columns[6].Width = 100 * modBasic.$AppWidthRatio

    .Columns[1].Text = "From Inv"
    .Columns[2].Text = "To Inv"
    .Columns[3].Text = "Inv AMT"
    .Columns[4].Text = "Returns"
    .Columns[5].Text = "Ret AMT"
    .Columns[6].Text = "Paid AMT"
  End With

End

Public Sub GridView1_Data(Row As Integer, Column As Integer)

  $rData.MoveTo(Row)
  GridView1.Data.Text = $rData[$aMyFields[Column]]

End

Public Sub btnprint_Click()

  Dim xPath As String

  If GridView1.Rows.Selection.Count > 0 Then
    xPath = modReportBilling.ShowUserCollection(GridView1[GridView1.Row, 0].Text)
    modPrint.OpenHTMLPreview("", xPath, "ReportSize")
  Endif

End

Public Sub btnbillshow_Click()

  Dim res As Result

  res = modDatabase.$syConn.Exec("select fldbillno from tblpatbilldetail where fldtime>=&1 and fldtime<=&2", modDate.StartSqlDate(dtfir.value), modDate.EndSqlDate(dtlast.value))
  If res.Available Then
    res.MoveFirst
    txtfrombill.Text = res!fldbillno
    res.MoveLast
    txttobill.Text = res!fldbillno
  Endif

End

Public Sub btncollcash_Click()

  If txtfrombill.Text And If txttobill.Text And If txtuser.Text And If cmbcomp.Text Then
    txtbillamt.Value = modBillings.GetInvoiceAmountBetweenBills(txtuser.Text, txtfrombill.Text, txttobill.Text, cmbcomp.Text)
  Endif

End

Public Sub btnitemwise_Click()

  Dim xPath As String

  If txtfrombill.Text And If txttobill.Text And If txtuser.Text Then
    xPath = modCHTMLInvoice.GetSummaryInvoiceContentBetweenUser(modDatabase.$syConn, Trim(txtfrombill.Text), Trim(txttobill.Text), Trim(txtuser.Text))
    modPrint.OpenHTMLPreview("", xPath, "ReportSize")
  Endif

End

Public Sub btngroupwise_Click()

  Dim xPath As String

  If txtfrombill.Text And If txttobill.Text And If txtuser.Text Then
    xPath = modCHTMLInvoice.GetSummaryInvoiceContentBetweenGroupUser(modDatabase.$syConn, Trim(txtfrombill.Text), Trim(txttobill.Text), Trim(txtuser.Text))
    modPrint.OpenHTMLPreview("", xPath, "ReportSize")
  Endif

End

Public Sub btnsummary_Click()

  Dim xPath As String

  If txtfrombill.Text And If txttobill.Text And If txtuser.Text Then
    xPath = modCHTMLInvoice.SummaryReceiveBillingSIngleUser(modDatabase.$syConn, Trim(txtfrombill.Text), Trim(txttobill.Text), Trim(txtuser.Text))
    modPrint.OpenHTMLPreview("", xPath, "ReportSize")
  Endif

End

''--------------------------------------- SUMMARY -----------------------------
Public Sub btnsummrefresh_Click()

  Dim res1 As Result
  Dim res2 As Result
  Dim res3 As Result
  Dim xrecv As Float
  Dim xpaid As Float
  Dim xwait As Float
  Dim xnoninv As Float

  If txtuser.Text Then
    res1 = modDatabase.$syConn.Exec("select SUM(fldreceivedamt) as totrecv from tblpatbilldetail where flduserid=&1", Trim(txtuser.Text))
    If res1.Available Then
      If res1!totrecv Then
        xrecv = res1!totrecv
      Else
        xrecv = 0
      Endif
    Else
      xrecv = 0
    Endif

    res2 = modDatabase.$syConn.Exec("select SUM(fldrecvamt) as paidtot from tblusercollection where fldcashier=&1", Trim(txtuser.Text))
    If res2.Available Then
      If res2!paidtot Then
        xpaid = res2!paidtot
      Else
        xpaid = 0
      Endif
    Else
      xpaid = 0
    Endif

    xwait = xrecv - xpaid

    res3 = modDatabase.$syConn.Exec("select SUM(fldditemamt) as noninvamt from tblpatbilling where fldprint=&1 and fldsave=&2 and flduserid=&3", False, True, Trim(txtuser.Text))
    If res3.Available Then
      If res3!noninvamt Then
        xnoninv = res3!noninvamt
      Else
        xnoninv = 0
      Endif
    Else
      xnoninv = 0
    Endif
  Endif

  txtsummrecv.Value = xrecv
  txtsummpaid.Value = xpaid
  txtsummpend.Value = xwait
  txtnotinvoi.Value = xnoninv

End

Public Sub txtuser_KeyPress()

  modGeneralMain.InputTextKeyOnly()

End

Public Sub txtfrombill_KeyPress()

  modGeneralMain.InputUpCaseOnly()

End

Public Sub txttobill_KeyPress()

  modGeneralMain.InputUpCaseOnly()

End
