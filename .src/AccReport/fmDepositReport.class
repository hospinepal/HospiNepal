' Gambas class file

Private $rData As Result
Private $aMyFields As String[]

Public Sub Form_Open()

  modGeneralMain.ArrangeEmbedForms(Me, Panel1, "Vertical")
  Me.Icon = Picture[modGeneralMain.$strLogo]
  cmbstatus.List = ["Admitted", "Discharged", "LAMA", "Refer", "Death", "Absconder"]
  cmbstatus.Text = "Admitted"
  cmbdeposit.List = ["All", "Positive", "Negative"]
  cmbdeposit.Text = "All"
  dtfir.Value = Now()
  dtlast.Value = Now()

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

Public Sub dtnepfir_Click()

  Dim xx As String

  xx = BSDateFormat(("Enter BS Date in yyyy/mm/dd format"), ("Date Converter"), modDate.ConvertToLocaldate(dtfir.Value))
  If xx Then
    dtfir.Value = modDate.ConvertToEnglishdate(xx)
  Endif

End

Public Sub dtneplast_Click()

  Dim xx As String

  xx = BSDateFormat(("Enter BS Date in yyyy/mm/dd format"), ("Date Converter"), modDate.ConvertToLocaldate(dtlast.Value))
  If xx Then
    dtlast.Value = modDate.ConvertToEnglishdate(xx)
  Endif

End

Public Sub btnrefresh_Click()

  If cmbstatus.Text Then
    Inc Application.Busy

    FillInvoiceGrid(modDatabase.$syConn)

    Dec Application.Busy
  Endif

End

Private Sub FillInvoiceGrid(sCon As Connection)

  Dim xfld As String

  If cmbstatus.Text = "Admitted" Then
    xfld = "flddoa"
  Else
    xfld = "flddod"
  Endif

  If chkalldate.Value = True Then
    If cmbdeposit.Text = "Positive" Then
      $rData = sCon.Exec("select fldencounterval,fldencounterval,fldencounterval,fldregdate,fldcurrlocat,fldencounterval,fldcashdeposit,fldencounterval,fldencounterval" & modMisc.HospField() & " from tblencounter where fldadmission like &1 and fldcashdeposit>&2", cmbstatus.Text, 0)
    Else If cmbdeposit.Text = "Negative" Then
      $rData = sCon.Exec("select fldencounterval,fldencounterval,fldencounterval,fldregdate,fldcurrlocat,fldencounterval,fldcashdeposit,fldencounterval,fldencounterval" & modMisc.HospField() & " from tblencounter where fldadmission like &1 and fldcashdeposit<&2", cmbstatus.Text, 0)
    Else
      $rData = sCon.Exec("select fldencounterval,fldencounterval,fldencounterval,fldregdate,fldcurrlocat,fldencounterval,fldcashdeposit,fldencounterval,fldencounterval" & modMisc.HospField() & " from tblencounter where fldadmission like &1", cmbstatus.Text)                                              ''   ''
    Endif

  Else
    If cmbdeposit.Text = "Positive" Then
      $rData = sCon.Exec("select fldencounterval,fldencounterval,fldencounterval,fldregdate,fldcurrlocat,fldencounterval,fldencounterval,fldencounterval,fldencounterval" & modMisc.HospField() & " from tblencounter where " & xfld & ">=&1 and " & xfld & "<=&2 and fldadmission like &3 and fldcashdeposit>&4", modDate.StartSqlDate(dtfir.value), modDate.EndSqlDate(dtlast.value), cmbstatus.Text, 0)
    Else If cmbdeposit.Text = "Negative" Then
      $rData = sCon.Exec("select fldencounterval,fldencounterval,fldencounterval,fldregdate,fldcurrlocat,fldencounterval,fldencounterval,fldencounterval,fldencounterval" & modMisc.HospField() & " from tblencounter where " & xfld & ">=&1 and " & xfld & "<=&2 and fldadmission like &3 and fldcashdeposit<&4", modDate.StartSqlDate(dtfir.value), modDate.EndSqlDate(dtlast.value), cmbstatus.Text, 0)
    Else
      $rData = sCon.Exec("select fldencounterval,fldencounterval,fldencounterval,fldregdate,fldcurrlocat,fldencounterval,fldencounterval,fldencounterval,fldencounterval" & modMisc.HospField() & " from tblencounter where " & xfld & ">=&1 and " & xfld & "<=&2 and fldadmission like &3", modDate.StartSqlDate(dtfir.value), modDate.EndSqlDate(dtlast.value), cmbstatus.Text)                                              ''   ''
    Endif

  Endif
  $aMyFields = New String[]
  modGridView.ReadSmallData(GridView1, $rData, $aMyFields)

  With GridView1
    .Columns[0].Width = 75 * modBasic.$AppWidthRatio
    .Columns[1].Width = 175 * modBasic.$AppWidthRatio
    .Columns[2].Width = 120 * modBasic.$AppWidthRatio
    .Columns[3].Width = 1
    .Columns[4].Width = 75 * modBasic.$AppWidthRatio
    .Columns[5].Width = 75 * modBasic.$AppWidthRatio
    .Columns[6].Width = 115 * modBasic.$AppWidthRatio
    .Columns[7].Width = 115 * modBasic.$AppWidthRatio
    .Columns[8].Width = 115 * modBasic.$AppWidthRatio

    .Columns[0].Text = "EncID"
    .Columns[1].Text = "Name"
    .Columns[2].Text = "Age/Sex"
    .Columns[4].Text = "Location"
    .Columns[5].Text = "Credit"
    .Columns[6].Text = "Deposit"
    .Columns[7].Text = "Pending"
    .Columns[8].Text = "Surplus"

  End With

End

Public Sub GridView1_Data(Row As Integer, Column As Integer)

  $rData.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView1, Row)
  If Column = 1 Then
    Try GridView1.Data.Text = modPatient.GetPatientNameByEnc($rData["fldencounterval"], modDatabase.$syConn)
  Else If Column = 2 Then
    Try GridView1.Data.Text = modPatient.GetPatientAgeString($rData["fldencounterval"], Now()) & "/" & modPatient.GetPatientSex($rData["fldencounterval"], modDatabase.$syConn)
  Else If Column = 5 Then
    GridView1.Data.Text = modReportVar.GetLocaleNumberFormat(modNonMedical.ShowCreditVAlEnc($rData["fldencounterval"]), gb.Currency)
  Else If Column = 6 Then
    If chkexpen.Value = True Then
      GridView1.Data.Text = modReportVar.GetLocaleNumberFormat(modNonMedical.GetPatientDeposit($rData["fldencounterval"]), gb.Currency)
    Endif
  Else If Column = 7 Then
    If chkexpen.Value = True Then
      GridView1.Data.Text = modReportVar.GetLocaleNumberFormat(modNonMedical.TotalUnpaidAmountyPatient(modDatabase.$syConn, $rData["fldencounterval"]), gb.Currency)
    Endif
  Else If Column = 8 Then
    If chkexpen.Value = True Then
      GridView1.Data.Text = modReportVar.GetLocaleNumberFormat(modNonMedical.GetPatientDeposit($rData["fldencounterval"]) - modNonMedical.TotalUnpaidAmountyPatient(modDatabase.$syConn, $rData["fldencounterval"]), gb.Currency)
    Endif
  Else
    GridView1.Data.Text = $rData[$aMyFields[Column]]
  Endif

End

Public Sub btnexpo_Click()

  modCHTMLReport.$EncColumn = 0
  modCHTMLReport.ExportReportGridToHTML(GridView1, "DEPOSIT REPORT", modReportVar.GetDateTimeReport(Now(), gb.GeneralDate))

End

Public Sub GridView1_Menu()

  mnuhide.Popup

End

Public Sub mnubill_Click()

  Dim xPath As String

  If GridView1.Rows.Selection.Count > 0 Then
    xPath = modCHTMLInvoice.ShowTotalInvoicebyPatient(GridView1[GridView1.Row, 0].Text)
    modPrint.OpenHTMLPreview(GridView1[GridView1.Row, 0].Text, xPath, "ReportSize")
  Endif

End

Public Sub mnuexpense_Click()

  Dim xPath As String

  If GridView1.Rows.Selection.Count > 0 Then
    xPath = modCHTMLInvoice.ShowTotalExpensebyPatient(modDatabase.$syConn, GridView1[GridView1.Row, 0].Text)
    modPrint.OpenHTMLPreview(GridView1[GridView1.Row, 0].Text, xPath, "ReportSize")
  Endif

End

Public Sub mnunoninvoiced_Click()

  Dim xPath As String

  If GridView1.Rows.Selection.Count > 0 Then
    xPath = modCHTMLInvoice.ShowPendingExpensebyPatient(modDatabase.$syConn, GridView1[GridView1.Row, 0].Text)
    modPrint.OpenHTMLPreview(GridView1[GridView1.Row, 0].Text, xPath, "ReportSize")
  Endif

End

