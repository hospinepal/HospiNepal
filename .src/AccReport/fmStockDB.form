# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,91,64)
  Text = ("Inventory Database")
  Resizable = False
  { Panel1 Panel
    MoveScaled(1,5,23,3)
    { rbgeneric RadioButton
      MoveScaled(0,0,11,3)
      Text = ("Generic")
    }
    { rbbrand RadioButton
      MoveScaled(12,0,11,3)
      Text = ("Brand")
    }
  }
  { Panel2 Panel
    MoveScaled(1,1,42,3)
    { rbmed RadioButton
      MoveScaled(0,0,13,3)
      Text = ("Medicines")
    }
    { rbsurg RadioButton
      MoveScaled(14,0,12,3)
      Text = ("Surgicals")
    }
    { rbextra RadioButton
      MoveScaled(28,0,14,3)
      Text = ("Extra Items")
    }
  }
  { txtname TextBox
    MoveScaled(25,5,18,3)
  }
  { GridView1 GridView
    MoveScaled(1,9,89,54)
    Mode = Select.Single
    Header = GridView.Both
    AutoResize = False
  }
  { btnfullrep Button
    MoveScaled(76,5,14,3.5333)
    Text = Shortcut(("Export"), "E")
    Picture = Picture["icon:/small/html"]
  }
  { btninvent Button
    MoveScaled(76,1,14,3.5333)
    Text = ("Inventory")
    Picture = Picture["icon:/small/book"]
  }
  { chkall CheckBox
    MoveScaled(45,1,12,3)
    Text = ("All Depart")
  }
  { btnrefresh Button
    MoveScaled(44,5,13,3.2667)
    Text = ("Refresh")
    Picture = Picture["icon:/small/refresh"]
  }
}
