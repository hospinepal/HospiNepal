' Gambas class file

Private $rData As Result
Private $aMyFields As String[]
Private $strType As String

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me)
  rbgeneric.Value = True
  rbmed.Value = True
  txtname.SetFocus

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Private Function GetCompID() As String

  Dim xcomp As String

  If chkall.Value = True Then
    xcomp = "%"
  Else
    xcomp = modGeneralMain.compID
  Endif
  Return xcomp

End

'NOTE:TWO CON
Private Sub ShowStockGrid()

  If rbmed.Value = True Then
    If rbgeneric.Value = True Then
      $rData = modDatabase.$syConn.Exec("select fldbrandid,fldbrand,fldbrandid,fldbrandid as qty from tblmedbrand where lower(fldbrandid) like &1 and fldbrandid in(select fldstockid from tblentry where fldqty>&2 and fldcomp like &3) order by fldbrandid ASC", LCase(txtname.Text) & "%", 0, GetCompID())                                   ''
    Else If rbbrand.Value = True Then
      $rData = modDatabase.$syConn.Exec("select fldbrandid,fldbrand,fldbrandid,fldbrandid as qty from tblmedbrand where lower(fldbrand) like &1 and fldbrandid in(select fldstockid from tblentry where fldqty>&2 and fldcomp like &3) order by fldbrand ASC", LCase(txtname.Text) & "%", 0, GetCompID())
    Endif
  Else If rbsurg.Value = True Then
    $rData = modDatabase.$syConn.Exec("select fldbrandid,fldbrand,fldbrandid,fldbrandid as qty from tblsurgbrand where lower(fldbrandid) like &1 and fldbrandid in(select fldstockid from tblentry where fldqty>&2 and fldcomp like &3) order by fldbrandid ASC", LCase(txtname.Text) & "%", 0, GetCompID())
  Else If rbextra.Value = True Then
    $rData = modDatabase.$syConn.Exec("select fldbrandid,fldbrand,fldbrandid,fldbrandid as qty from tblextrabrand where lower(fldbrandid) like &1 and fldbrandid in(select fldstockid from tblentry where fldqty>&2 and fldcomp like &3) order by fldbrandid ASC", LCase(txtname.Text) & "%", 0, GetCompID())
  Endif

  $aMyFields = New String[]
  modGridView.ReadSmallData(GridView1, $rData, $aMyFields)
  With GridView1
    .Columns[0].Width = 325 * modBasic.$AppWidthRatio
    .Columns[1].Width = 175 * modBasic.$AppWidthRatio
    .Columns[2].Width = 75 * modBasic.$AppWidthRatio
    .Columns[3].Width = 50 * modBasic.$AppWidthRatio
    .Columns[0].Text = "Generic Name"
    .Columns[1].Text = "Brand Name"
    .Columns[2].Text = "Type"
    .Columns[3].Text = "QTY"
  End With

End

Public Sub GridView1_Data(Row As Integer, Column As Integer)

  $rData.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView1, Row)
  If Column = 3 Then
    GridView1.Data.Text = modStock.TotalQTYbyBrand($rData["qty"], GetCompID())
  Else If Column = 2 Then
    GridView1.Data.Text = modMedicine.GetRouteFromItem($rData[$aMyFields[Column]], $strType)
  Else
    GridView1.Data.Text = $rData[$aMyFields[Column]]
  Endif

End

Public Sub rbmed_Click()

  $strType = "Medicines"

End

Public Sub rbsurg_Click()

  $strType = "Surgicals"

End

Public Sub rbextra_Click()

  $strType = "Extra Items"

End

Public Sub btnrefresh_Click()

  ShowStockGrid()

End

Public Sub txtname_KeyRelease()

  ShowStockGrid()

End

Public Sub GridView1_Click()

  Dim hForm As FRequest
  Dim sql As String
  Dim res As Result

  sql = "select fldstockno,fldstockid,fldbatch,fldexpiry,fldqty,fldsellpr,fldstatus,fldcomp from tblentry where fldstockid=&1 and fldqty>&2 and fldcomp like &3"
  res = modDatabase.$syConn.Exec(sql, GridView1[GridView1.Row, 0].Text, 0, GetCompID())
  If res.Available Then
    hForm = New FRequest(res, GridView1[GridView1.Row, 0].Text, "StockDB", False)
    hForm.ShowModal
  Endif

End

Public Sub btnfullrep_Click()

  modCHTMLReport.ExportGridToHTML(GridView1, $strType, "Total Quantity")

End

Public Sub btninvent_Click()

  Dim xPath As String

  xPath = modHTMLStock.ShowTotalInventory($strType)
  modPrint.OpenHTMLPreview("", xPath, "ReportSize")

End

Public Sub txtname_KeyPress()

  modGeneralMain.InputTextKeyOnly()

End
