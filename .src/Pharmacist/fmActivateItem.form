# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,92,60)
  Tag = "Product Activation"
  Text = ("Product Activation")
  Resizable = False
  { mnuhide Menu
    Visible = False
    { mnuactivate Menu
      Text = ("Activate")
      Shortcut = "Ctrl+A"
    }
    { mnudeactiv Menu
      Text = ("Deactivate")
      Shortcut = "Ctrl+D"
    }
    { mnudelete Menu
      Text = ("Delete Brand")
    }
  }
  { mnualllist Menu
    Visible = False
    { btnactone Menu
      Text = ("Enable One")
    }
    { btnactive Menu
      Text = ("Enable All")
    }
    { btndeact Menu
      Text = ("Disable All")
    }
  }
  { Panel2 Panel
    MoveScaled(1,1,42,3)
    { rbmed RadioButton
      MoveScaled(0,0,13,3)
      Text = ("Medicines")
    }
    { rbsurg RadioButton
      MoveScaled(14,0,12,3)
      Text = ("Surgicals")
    }
    { rbextra RadioButton
      MoveScaled(28,0,13,3)
      Text = ("Extra")
    }
  }
  { GridView1 GridView
    MoveScaled(1,9,90,50)
    Mode = Select.Single
    Header = GridView.Both
    AutoResize = False
  }
  { txtname TextBox
    MoveScaled(1,5,42,3)
  }
  { Panel1 Panel
    MoveScaled(52,5,23,3)
    { rbgeneric RadioButton
      MoveScaled(0,0,11,3)
      Text = ("Generic")
    }
    { rbbrand RadioButton
      MoveScaled(12,0,11,3)
      Text = ("Brand")
    }
  }
  { MenuButton1 MenuButton
    MoveScaled(76,5,15,3)
    Text = ("Status")
  }
  { Label1 Label
    MoveScaled(67,1,8,3)
    Text = ("Route")
    Border = Border.Plain
  }
  { cmbroute ComboBox
    MoveScaled(76,1,15,3)
  }
  { btnexport ToolButton
    MoveScaled(43,5,4,3)
    Picture = Picture["icon:/small/html"]
  }
}
