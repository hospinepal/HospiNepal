Public Sub mnubackup_Click()

  If Dialog.SelectDirectory() Then Return
  If modGeneralMain.$IRDLevel = "Yes" Then
    modGeneralMain.RecordIRDActivity(modDatabase.$myConn, "Database Backup", Me.Name, "BACKUP", "")
  Endif
  modDatabase.BackUpCurrentDB(Dialog.Path)

End

