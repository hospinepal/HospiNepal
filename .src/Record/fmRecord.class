Public Sub mnuinsert_Click()

  Dim hForm As FmDoubleEntry
  Dim tbl As String
  Dim res As Result

  If Application.Version Like "0.3." & "*" Then
    tbl = "tblkey"
  Else If Application.Version Like "1.3." & "*" Then
    tbl = "tblkey"
  Else
    tbl = "tblnewkey"
  Endif
  res = modDatabase.$myConn.Exec(Subst("select key1,key2 from &1", tbl))
  If res.Available = False Then
    hForm = New FmDoubleEntry("Key Authorization")
    hForm.ShowModal
  Else
    Message.Warning(("Keys already present in database"), ("OK"))
  Endif

End
