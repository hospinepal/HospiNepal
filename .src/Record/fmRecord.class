Public Sub mnudbsetting_Click()

  Dim xx As String
  Dim xPath As String

  xx = InputCombo(("Group Global Settings Values by "), "DB Settings", ["Location", "Setting"], "", True)
  If xx Then
    xPath = modGENReport.ShowDBSettingsList(xx)
    modPrint.OpenHTMLPreview("", xPath, "ReportSize")
  Endif

End

