' Gambas class file

Private $sFIle As String
Private $encid As String

Public Sub _new(sPath As String, encid As String)

  $sFIle = sPath
  $encid = encid
  If Not $encid Then
    rbarchive.Enabled = False
  Endif

End

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me, "False")
  btnfile.Text = File.Name($sFIle)
  rbpersonal.Value = True
  txtdetail.SetFocus

End

Public Sub btnfile_Click()

  Desktop.Open($sFIle)

End

Public Sub btnsend_Click()

  If rbpersonal.Value = True Then
    SaveToPersonal()
  Else If rbarchive.Value = True Then
    SaveToArchive()
  Endif

End

Private Sub SaveToPersonal()

  Dim res As Result
  Dim fixFile As String
  Dim pic As Picture

  If txtdetail.Text Then
    fixFile = Temp() & ".png"
    pic = Desktop.GetFileIcon($sFIle, modImage.ThumbSize - 5)
    pic.Save(fixFile)

    Inc Application.Busy
    res = modDatabase.$myConn.Create("tblpersonal")
    res!fldcateg = "Document"
    If modMisc.BlobTarget("Personal") = "FTP" Then
      res!fldblob = ""
      res!fldlink = modDevice.SendBlobToFTP($sFIle, modGeneralMain.$lbluser, "Personal")
    Else
      res!fldblob = File.Load($sFIle)
      res!fldlink = ""
    Endif
    res!fldthumb = File.Load(fixFile)
    res!flddetail = txtdetail.Text
    res!fldextension = File.Ext($sFIle)
    res!flduserid = modGeneralMain.$lbluser
    res!fldtime = Now()
    res!fldcomp = modGeneralMain.compID
    res!fldsave = True
    res.Update()
    Dec Application.Busy
    Me.Close
  Endif

End

Private Sub SaveToArchive()

  Inc Application.Busy
  modImage.SavePatientDataForGeneral($encid, "General Reports", txtdetail.Text, $sFIle)
  Dec Application.Busy
  Me.Close

End
