' Gambas class file

Private $rData As Result
Private $aMyFields As String[]
Private $totalrec As Long

Public Sub Form_Open()

  modGeneralMain.ArrangeEmbedForms(Me, Panel1, "Column")
  Me.Icon = Picture[modGeneralMain.$strLogo]

  cmbcategory.List = ["Audio File", "Document", "Image File", "Public File", "Video File"]
  cmbcategory.Text = "Document"
  rbpersonal.Value = True
  ButtonSetting()
  SpinBox1.Value = 0
  BlankAll()
  cmbcategory.SetFocus

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

Private Sub BlankAll()

  txtdetail.Text = ""
  cmbcategory.Text = ""

End

Public Sub cmbcategory_Click()

  If cmbcategory.Text = "Image File" Then
    Frame3.Enabled = False
    Frame1.Enabled = True

  Else
    txtmedia.Text = ""
    Frame3.Enabled = True
    Frame1.Enabled = False

  Endif

End

Public Sub cmbcategory_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbcategory)
  modFillContainer.RestrictComboToContent(cmbcategory)

End

Public Sub btnrefresh_Click()

  Dim rtot As Result

  If rbpersonal.Value = True Then
    rtot = modDatabase.$syConn.Exec("select perid from tblpersonal where flduserid=&1 and fldcateg=&2", modGeneralMain.$lbluser, cmbcategory.Text)
  Else If rbshared.Value = True Then
    rtot = modDatabase.$syConn.Exec("select perid from tblpersonal where fldcateg=&1 and perid in(select fldperid from tblfileshare where fldshared=&2 and fldstatus=&3) UNION ALL select perid from tblpersonal where fldcateg=&4", cmbcategory.Text, modGeneralMain.$lbluser, "Shared", "Public File")                       ''
  Endif
  $totalrec = rtot.Count
  SpinBox1.MaxValue = CInt(Floor($totalrec / 50))
  SHowGridData()

End

Private Sub SHowGridData()

  Dim sql As String
  Dim stint As Integer

  stint = SpinBox1.Value * 50
  If rbpersonal.Value = True Then
    sql = "select perid,fldtime,fldcateg,fldthumb,flddetail,fldextension,fldlink,flduserid from tblpersonal where flduserid=&1 and fldcateg=&2 ORDER by perid DESC LIMIT 50 OFFSET &3"   '$
    $rData = modDatabase.$syConn.Exec(sql, modGeneralMain.$lbluser, cmbcategory.Text, stint)
  Else If rbshared.Value = True Then
    sql = "select perid,fldtime,fldcateg,fldthumb,flddetail,fldextension,fldlink,flduserid from tblpersonal where fldcateg=&1 and perid in(select fldperid from tblfileshare where fldshared=&2 and fldstatus=&3) UNION ALL select perid,fldtime,fldcateg,fldthumb,flddetail,fldextension,fldlink,flduserid from tblpersonal where fldcateg=&4 ORDER by perid DESC LIMIT 50 OFFSET &5"   '$
    $rData = modDatabase.$syConn.Exec(sql, cmbcategory.Text, modGeneralMain.$lbluser, "Shared", "Public File", stint)
  Endif
  lbltotal.Text = modMisc.RecordNumberLabel(SpinBox1.Value * 50, 50, $totalrec)
  FillPersonalGridImage()

End

Public Sub btntxtsearch_Click()

  Dim sql As String
  Dim xx As String

  xx = InputBox("Enter File Extension", cmbcategory.Text, "")
  If xx Then
    If cmbcategory.Text Then
      If rbpersonal.Value = True Then
        sql = "select perid,fldtime,fldcateg,fldthumb,flddetail,fldextension,fldlink,flduserid from tblpersonal where flduserid=&1 and fldcateg=&2 and fldextension like &3 ORDER by perid"   '$
        $rData = modDatabase.$syConn.Exec(sql, modGeneralMain.$lbluser, cmbcategory.Text, xx)
      Else If rbshared.Value = True Then
        sql = "select perid,fldtime,fldcateg,fldthumb,flddetail,fldextension,fldlink,flduserid from tblpersonal where fldcateg=&1 and perid in(select fldperid from tblfileshare where fldshared=&2 and fldstatus=&3) and fldextension like &4 UINON ALL select perid,fldtime,fldcateg,fldthumb,flddetail,fldextension,fldlink,flduserid from tblpersonal where fldcateg=&5 and fldextension like &4 ORDER by perid DESC"   '$
        $rData = modDatabase.$syConn.Exec(sql, cmbcategory.Text, modGeneralMain.$lbluser, "Shared", xx, "Public File")
      Endif
      lbltotal.Text = ""
    Endif
    FillPersonalGridImage()

  Endif

End

Private Sub FillPersonalGridImage()

  $aMyFields = New String[]
  modGridView.ReadSmallData(GridView1, $rData, $aMyFields)
  GridView1.Rows.Height = modImage.ThumbSize
  With GridView1
    .Rows.Height = 40 * modBasic.$AppHeightRatio
    .Columns[0].Width = 1
    .Columns[1].Width = 150 * modBasic.$AppWidthRatio
    .Columns[2].Width = 1
    .Columns[3].Width = 1.2 * modImage.ThumbSize
    .Columns[4].Width = 325 * modBasic.$AppWidthRatio
    .Columns[5].Width = 50 * modBasic.$AppWidthRatio
    .Columns[6].Width = 1
    .Columns[7].Width = 75 * modBasic.$AppWidthRatio

    .Columns[1].Text = "DateTime"
    .Columns[4].Text = "Description"
    .Columns[5].Text = "Ext"
    .Columns[7].Text = "Owner"
  End With

End

Public Sub GridView1_Data(Row As Integer, Column As Integer)

  Dim tempFile As String
  Dim hFile As Blob

  $rData.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView1, Row)
  If Column = 1 Then
    Try GridView1.Data.Text = modReportVar.GetDateTimeReport($rData["fldtime"], gb.GeneralDate)
  Else If Column = 3 Then
    hFile = $rData["fldthumb"]
    If hFile.Length Then
      tempFile = Temp() & ".png"
      File.Save(tempFile, hFile.Data)
    Endif
    GridView1.Data.Picture = Picture.Load(tempFile)
    If Exist(tempFile) Then Kill tempFile
  Else
    GridView1.Data.Text = $rData[$aMyFields[Column]]
    GridView1.Data.WordWrap = True
  Endif

End

Public Sub GridView1_Click()

  If GridView1.Column = 3 Then
    OpenMediaGrid()
  Else
    txtdetail.Text = GridView1[GridView1.Row, 4].Text
  Endif

End

Public Sub btnOK_Click()

  Dim res As Result
  Dim tempFile As String
  Dim hFile As String
  Dim fixFile As String
  Dim saveOk As Boolean
  Dim pic As Picture
  Dim xauto As String

  Dim xtempdf As String

  xauto = modBasic.$UploadMaxSize
  If cmbcategory.Text = "Audio File" Or cmbcategory.text = "Video File" Then
    If xauto Then
      If txtsize.Value < CFloat(xauto) * 1024 Then
        saveOk = True
      Else
        saveOk = False
      Endif
    Else
      saveOk = True
    Endif
  Else
    saveOk = True
  Endif

  If saveOk = True Then

    If cmbcategory.text = "Image File" Then
      hFile = modImage.GetPNGImage(PictureBox1.Tag)
      fixFile = modImage.GetThumbNailImage(hFile)
    Else
      hFile = txtmedia.Text
      fixFile = Temp() & ".png"
      pic = Desktop.GetFileIcon(hFile, modImage.ThumbSize - 5)
      pic.Save(fixFile)

      If txtpass.Text Then
        If LCase(File.Ext(hFile)) = "pdf" Then
          xtempdf = Temp() & ".pdf"
          modDevice.GetEncryptPDF(hFile, xtempdf, txtpass.Text)
          hFile = xtempdf
        Endif
      Endif

    Endif

    Inc Application.Busy
    res = modDatabase.$myConn.Create("tblpersonal")
    res["fldcateg"] = cmbcategory.Text
    If modMisc.BlobTarget("Personal") = "FTP" Then
      res["fldblob"] = ""
      res["fldlink"] = modDevice.SendBlobToFTP(hFile, modGeneralMain.$lbluser, "Personal")
    Else
      res["fldblob"] = File.Load(hFile)
      res["fldlink"] = ""
    Endif
    res["fldthumb"] = File.Load(fixFile)
    res["flddetail"] = txtdetail.Text
    res["fldextension"] = File.Ext(hFile)
    res["flduserid"] = modGeneralMain.$lbluser
    res["fldtime"] = Now()
    res["fldcomp"] = modGeneralMain.compID
    res["fldsave"] = True
    res.Update()
    Dec Application.Busy
    SHowGridData()
    Balloon.Info(("Data saved"), btnOK)
    Balloon.Delay = modBasic.$BalloonDelay
    If Exist(tempFile) Then Kill tempFile

  Else
    If xauto Then
      Message.Warning(("File larger than ") & CStr(CFloat(xauto) * 1024) & " KB", ("OK"))
    Endif
  Endif

End

Public Sub btnChange_Click()

  Dim res As Result

  If GridView1.Rows.Selection.Count > 0 Then
    res = modDatabase.$myConn.Edit("tblpersonal", "perid=&1", GridView1[GridView1.Row, 0].Text)
    res["flddetail"] = txtdetail.Text
    res.Update()
    SHowGridData()
    Balloon.Info(("Information updated"), btnChange)
    Balloon.Delay = modBasic.$BalloonDelay
  Endif

End

'''''----------------------------------------  file types ----------------------------------
Public Sub btnopenmedia_Click()

  txtdetail.Text = ""
  If cmbcategory.Text = "Audio File" Then
    Dialog.Filter = ["*.ogg;*.mp3", "Audio files"]
    If Dialog.OpenFile() Then Return
    txtmedia.Text = Dialog.Path

  Else If cmbcategory.Text = "Video File" Then
    Dialog.Filter = ["*", "Video File"]
    If Dialog.OpenFile() Then Return
    txtmedia.Text = Dialog.Path

  Else If cmbcategory.Text = "Document" Or If cmbcategory.Text = "Public File" Then
    Dialog.Filter = ["*.odt;*.doc;*.docx;*.odp;*.ppt;*.pptx;*.pps;*.ods;*.xls;*.xlsx;*.pdf;*.djvu;*.html;*.txt", "Document File"]
    If Dialog.OpenFile() Then Return
    txtmedia.Text = Dialog.Path

  Endif
  txtsize.Value = Round(Stat(txtmedia.Text).Size / 1024, -3)

End

Public Sub chkshow_Click()

  If chkshow.Value = True Then
    txtpass.Password = False
  Else If chkshow.Value = False Then
    txtpass.Password = True
  Endif

End

Public Sub btnPlaymedia_Click()

  If txtmedia.Text Then
    Desktop.Open(txtmedia.Text)
  Endif

End

Public Sub btnclearmedia_Click()

  txtmedia.Text = ""

End

Public Sub btnwebvideo_Click()

  Dim yy As Integer
  Dim sTemp As String

  If cmbcategory.Text = "Video File" Then
    txtdetail.Text = ""
    yy = InputValue(("Enter Webcam Video duration in seconds"), ("Webcam"), "10")
    If yy Then
      Inc Application.Busy
      sTemp = modDevice.GetWebCamVideo(yy)
      Dec Application.Busy
      If Exist(sTemp) Then
        txtmedia.Text = sTemp
        txtsize.Value = Round(Stat(sTemp).Size / 1024, -3)
      Endif
    Endif
  Endif

End

Public Sub btnOpen_Click()

  txtdetail.Text = ""
  Dialog.Filter = ["*.jpg;*.jpeg;*.png;*.bmp", "Picture files"]
  If Dialog.OpenFile() Then Return
  PictureBox1.Tag = Dialog.Path
  PictureBox1.Image = Image.Load(Dialog.Path)

End

Public Sub btnwebcam_Click()

  txtdetail.Text = ""
  PictureBox1.Tag = modImage.GetWebCamValue(modDevice.WebCamDevice())
  If PictureBox1.Tag Then
    PictureBox1.Image = Image.Load(PictureBox1.Tag)
  Endif

End

Public Sub btnimgedit_Click()

  If PictureBox1.Tag Then
    Desktop.Open(PictureBox1.Tag)
  Endif

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub btnback_Click()

  SpinBox1.Value = SpinBox1.Value - 1
  SHowGridData()

End

Public Sub btnforward_Click()

  SpinBox1.Value = SpinBox1.Value + 1
  SHowGridData()

End

Private Sub ButtonSetting()

  If rbpersonal.Value = True Then
    btnsharenew.Enabled = True
    btnpersonew.Enabled = True
    btndeletenew.Enabled = True
  Else If rbshared.Value = True Then
    btnsharenew.Enabled = False
    btnpersonew.Enabled = False
    btndeletenew.Enabled = False
  Endif

End

Private Sub OpenMediaGrid()

  Dim xPath As String

  If GridView1.Rows.Selection.Count > 0 Then
    xPath = GetPersonalFile(GridView1[GridView1.Row, 0].Text)
    If modBasic.$MultiMediaFormat = "Embedded" Then
      fmMediaPlay.MediaView1.URL = Dialog.Path
      fmMediaPlay.Enabled = True
    Else
      Desktop.Open(xPath)
    Endif
  Endif

End

Private Function GetPersonalFile(serial As Long) As String

  Dim res As Result
  Dim sql As String
  Dim tempFile As String
  Dim hFile As Blob

  If modGeneralMain.$ApplKey < 2 Then
    sql = "select fldcateg,fldblob,fldthumb,flddetail,fldextension,fldlink from tblpersonal where perid=&1"
    res = modDatabase.$myConn.Exec(sql, serial)
    If res["fldlink"] Then
      Inc Application.Busy
      tempFile = modDevice.GetFileFromLocalFTP(res["fldlink"])
      Dec Application.Busy
    Else
      hFile = res["fldblob"]
      If hFile.Length Then
        tempFile = Temp() & "." & res["fldextension"]
        File.Save(tempFile, hFile.Data)
      Endif
    Endif
    Return tempFile
  Else
    Message.Warning(("File extraction disabled. Please insert validation key"), ("OK"))
  Endif

End

Public Sub btnclear_Click()

  If PictureBox1.Tag Then
    PictureBox1.Image.Clear()
    PictureBox1.Refresh()
    Wait
  Endif

End

Public Sub Slider1_Change()

  PictureBox1.Zoom = Slider1.Value / 100

End

Public Sub btnexport_Click()

  modCHTMLReport.ExportGridToHTML(GridView1, modGeneralMain.$lbluser, cmbcategory.Text)

End

Public Sub btnemailnew_Click()

  Dim hForm As FmRemoteMail
  Dim xx As String[]

  If GridView1.Rows.Selection.Count > 0 Then
    If Desktop.NetworkAvailable = True Then
      xx = New String[]
      hForm = New FmRemoteMail(xx, GetPersonalFile(GridView1[GridView1.Row, 0].Text), "Personal File")
      hForm.ShowModal()
    Endif
  Endif

End

Public Sub btnsharenew_Click()

  Dim hForm As FmSelectList

  If GridView1.Rows.Selection.Count > 0 Then
    If rbpersonal.Value = True Then
      hForm = New FmSelectList("Select Users to share", "Sharing Rules", GridView1[GridView1.Row, 0].Text)
      hForm.ShowModal()
    Endif
  Endif

End

Public Sub btnpersonew_Click()

  If GridView1.Rows.Selection.Count > 0 Then
    If rbpersonal.Value = True Then
      modDatabase.$myConn.Delete("tblfileshare", "flduserid=&1 and fldperid=&2", modGeneralMain.$lbluser, GridView1[GridView1.Row, 0].Text)
      Message.Info(("File personalized"), ("OK"))
    Endif
  Endif

End

Public Sub btndeletenew_Click()

  Dim sLink As String

  If GridView1.Rows.Selection.Count > 0 Then
    If Message.Question(("Are you sure?"), ("No"), ("Yes")) = 2 Then
      sLink = GridView1[GridView1.Row, 6].Text
      If sLink Then
        modDevice.DeleteBlobFIleFTP(sLink)
      Endif
      modDatabase.$myConn.Delete("tblpersonal", "perid=&1 and flduserid=&2", GridView1[GridView1.Row, 0].Text, modGeneralMain.$lbluser)
      SHowGridData()
    Endif
  Endif

End

Public Sub rbpersonal_Click()

  ButtonSetting()

End

Public Sub rbshared_Click()

  ButtonSetting()

End

Public Sub btnopennew_Click()

  OpenMediaGrid()

End
