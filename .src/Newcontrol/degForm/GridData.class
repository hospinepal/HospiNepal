' Gambas class file

''' This class is the data importer and data container for DegComboBox and DegTableView

Inherits Variant[]
Property Read ColumnCount As Integer
Property Read DBResult As Result
Private $Res As Result

'' Containes the Gambas types of all columns
Property Read Types As Integer[]
Private $Types As New Integer[]

Public Sub _new()

  Reset

End

Public Sub SetData(Data As Variant, Optional Fieldnames As String[])

  Dim grid As New Variant[][]
  Dim row As New Variant[]
  Dim orm As Object 'degorm is not defined here
  Dim i As Integer

  '' Test incoming Data
  If Data Then
    If Data Is Result Then
      ' ------------------------------------------------- Data from Result
      $res = Data
      GetTypesFromRes()
      SetDataFromResult(Fieldnames)
    Else If Data Is Variant[]
      ' ------------------------------------------------- Data from Array
      'test if data is array or array in array
      If TypeOf(Data[0]) = gb.Object And If Data[0] Is Array Then
        'array in array, purrfact
        GetTypesFromVariant(Data[0])
        Me.Insert(Data)
      Else
        ' Data is monodimensional array, has to be packed in
        ' a 2-dim array
        grid = New Variant[][]
        For i = 0 To Data.count - 1
          row.Add(Data[i], 0)
          grid.Add(row.Copy(), i)
          row.clear
        Next
        ' Not perfect, but a try
        GetTypesFromVariant(grid[0])
        Me.Insert(grid)
      Endif
    Else If Object.Type(Data) = "DegOrm" Then
      ' ------------------------------------------------- Data from Orm
      orm = Data
      $Types = orm.Types
      SetDataFromDegOrm(orm, Fieldnames)
    Endif
  Endif

End

'' Unfortunately DegOrm is not documented here
Private Sub SetDataFromDegOrm(Data As Variant, Fieldnames As String[])

  Dim grid As Variant[][]
  Dim row As Variant[]
  Dim OrmRow As Object
  Dim Fname As String

  grid = New Variant[][]
  For Each OrmRow In Data.Rows
    row = New Variant[]
    For Each Fname In Fieldnames
      row.Add(Object.GetProperty(OrmRow, Fname))
    Next
    grid.Add(row)
  Next
  Me.Insert(grid)

End

Private Sub SetDataFromResult(Optional Fieldnames As String[])

  '' Fills Grid with a DB result
  '' No sorting available
  Dim c As Integer
  Dim row As Variant[]
  Dim Fname As String

  'Todo: Test schreiben für SetDataFromResult
  If $res.Count > 0 Then
    For Each $res
      row = []
      If Fieldnames And If Fieldnames.Count > 0 Then
        For Each Fname In Fieldnames
          row.Add($Res[Fname])
        Next
      Else
        For c = 0 To $Res.Fields.Count - 1
          row.Add($Res[c])
        Next
      Endif
      Me.Add(row)
    Next
  Else
    Me.Clear
  Endif

End

Private Function ColumnCount_Read() As Integer
  ' returns the number of columns

  Return Me[0].count

End

Private Function DBResult_Read() As Result

  Return $Res

End

Private Sub Reset()

  $Res = Null
  Me.Clear

End

Private Function Types_Read() As Integer[]

  Return $Types

End

Sub GetTypesFromRes()

  Dim F As ResultField

  For Each F In $res.Fields
    $Types.Add(F.Type)
  Next

End

Sub GetTypesFromVariant(row As Variant[])

  Dim col As Variant

  For Each col In row
    $Types.Add(TypeOf(col))
  Next

End
