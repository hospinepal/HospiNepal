# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,91,60)
  Text = ("Data List with Code")
  Resizable = False
  { txtname ButtonBox
    MoveScaled(4,1,39,3)
    ToolTip = ("Write few alphabets of disease name for quick sorting")
    Picture = Picture["icon:/small/cancel"]
  }
  { txtcode TextBox
    MoveScaled(70,1,15,3)
  }
  { GridView1 GridView
    MoveScaled(1,5,84,54)
    Mode = Select.Single
    Header = GridView.Horizontal
  }
  { btnok Button
    MoveScaled(57,1,11,3)
    Text = ("Save")
    Picture = Picture["icon:/small/save"]
  }
  { lstletter ListBox
    MoveScaled(86,5,4,54)
    Sorted = True
  }
  { chkleftmain CheckBox
    MoveScaled(1,1,3,3)
  }
  { btninsert Button
    MoveScaled(45,1,11,3)
    Text = ("Select")
    Picture = Picture["icon:/small/apply"]
  }
}
