' Gambas class file

Private $sValue As Date[]

Public Sub Run(Prompt As String, Optional Title As String, sTime As Date[]) As Date[]

  lblitem.Text = Prompt
  If Title Then
    Me.Text = Title
  Else
    Me.Text = Application.ActiveWindow.Title
  Endif
  dtfirst.Value = sTime[0]
  dtlast.Value = sTime[1]

  If Me.ShowModal() Then Return $sValue

End

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me, "False")
  dtfirst.SetFocus

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.Esc Then
    Me.Close
  Else
    modGeneralmain.GoToNextControlTab()
  Endif

End

Public Sub dtnepfir_Click()

  Dim xx As String

  xx = BSDateFormat(("Enter BS Date in yyyy/mm/dd format"), ("Date Converter"), modDate.ConvertToLocaldate(dtfirst.Value))
  If xx Then
    dtfirst.Value = modDate.ConvertToEnglishdate(xx)
  Endif

End

Public Sub dtneplast_Click()

  Dim xx As String

  xx = BSDateFormat(("Enter BS Date in yyyy/mm/dd format"), ("Date Converter"), modDate.ConvertToLocaldate(dtlast.Value))
  If xx Then
    dtlast.Value = modDate.ConvertToEnglishdate(xx)
  Endif

End

Public Sub btnclear_Click()

  dtfirst.Value = ""
  dtlast.Value = ""

End

Public Sub btnsave_Click()

  Dim xx As Date[]

  If dtfirst.Value And If dtlast.Value Then
    xx = New Date[]
    xx.Add(dtfirst.Value)
    xx.Add(dtlast.Value)
    $sValue = xx
    Me.Close(True)
  Endif

End
