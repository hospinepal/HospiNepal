# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,69,9)
  Resizable = False
  { dtdate DateBox
    MoveScaled(1,5,17,3)
  }
  { dttime DateBox
    MoveScaled(27,5,15,3)
    Mode = DateChooser.TimeOnly
  }
  { btnBrOK Button
    MoveScaled(56,5,12,3.5)
    Tag = "Auto"
    Text = Shortcut(("Save"), "S")
    Picture = Picture["icon:/small/apply"]
  }
  { lblitem Label
    MoveScaled(1,1,67,3)
    Border = Border.Plain
  }
  { dtnepdate ToolButton
    MoveScaled(18,5,3,3.25)
    Picture = Picture["icon:/small/calendar"]
  }
}
