' Gambas class file

Private $sValue As Variant[]

Public Sub Run(strExam As String, strValue As String) As Variant[]

  Dim xx As Variant[]

  lblitem.Text = strExam
  If strValue Then
    xx = modString.GetLeftRightValue(strValue)
    LeftRightTextArea1.LeftText = CStr(xx[0])
    LeftRightTextArea1.RightText = CStr(xx[1])
  Endif

  If Me.ShowModal() Then Return $sValue

End

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me, "False")
  LeftRightTextArea1.SetFocus

End

Public Sub btnBrOK_Click()

  Dim xx As Variant[]

  xx = New Variant[]
  xx.Add(Trim(LeftRightTextArea1.LeftText))
  xx.Add(Trim(LeftRightTextArea1.RightText))
  xx.Add(chkabnormal.Value)
  $sValue = xx
  Me.Close(True)

End

Public Sub Form_KeyRelease()

  If Key.Code = Key["A"] And If Key.Control Then
    If chkabnormal.Value = False Then
      chkabnormal.Value = True
    Else If chkabnormal.Value = True Then
      chkabnormal.Value = False
    Endif
  Else If Key.Code = Key.Esc Then
    Me.Close
  Endif

End
