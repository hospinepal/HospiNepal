' Gambas class file

Private $hPlayer As MediaPlayer
Private hSink As MediaControl
Private $sDevice As String
Private $sValue As String

Public Sub Run(sDevice As String) As String

  If sDevice Then
    $sDevice = sDevice
  Else
    $sDevice = "/dev/video0"
  Endif
  If Me.ShowModal() Then Return $sValue

End

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me, "False")
  ReadyForImage()
  Timer1.Enabled = True

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.Esc Then
    Me.Close
  Endif

End

Private Sub ReadyForImage()

  $hPlayer = New Mediaplayer As "NewMediaPlayer"
  $hPlayer.url = "v4l2://" & $sDevice
  hSink = New MediaControl($hPlayer, "xvimagesink")
  $hPlayer.video.output = hsink

  hsink.SetWindow(dwgVideo)
  $hPlayer.play

End

Public Sub Timer1_Timer()

  If hSink.GetLastImage() Then
    BtnTakeShot.Enabled = True
    Timer1.Enabled = False
  Endif

End

Public Sub BtnTakeShot_Click()

  Dim sPath As String

  Object.Lock(dwgVideo)
  sPath = Temp() & ".png"
  hSink.GetLastImage().Save(sPath)
  Object.Unlock(dwgVideo)

  $sValue = sPath
  Me.Close(True)

End

Public Sub Form_Close()

  $hPlayer.Close()

End
