# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,63,60)
  Text = ("Item Grid")
  Resizable = False
  { txtname ButtonBox
    MoveScaled(4,1,30.6667,3)
    ToolTip = ("Write few alphabets of disease name for quick sorting")
    Picture = Picture["icon:/small/cancel"]
  }
  { GridView1 GridView
    MoveScaled(1,5,56,51)
    Mode = Select.Single
  }
  { chkall CheckBox
    MoveScaled(45,56,12,3)
    Text = ("Select All")
  }
  { chksort CheckBox
    MoveScaled(6,56,12,3)
    Text = ("Sorted")
  }
  { lstletter ListBox
    MoveScaled(58,5,4,54)
    Sorted = True
  }
  { btninsert Button
    MoveScaled(36,1,13,3)
    Text = ("Select")
    Picture = Picture["icon:/small/apply"]
  }
  { btnok Button
    MoveScaled(50,1,12,3)
    Text = ("Save")
    Picture = Picture["icon:/small/save"]
  }
  { chkleftmain CheckBox
    MoveScaled(1,1,3,3)
  }
}
