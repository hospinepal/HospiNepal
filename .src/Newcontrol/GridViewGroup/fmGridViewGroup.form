# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,78,60)
  Text = ("Item Grid")
  Resizable = False
  { txtname ButtonBox
    MoveScaled(26,1,36,3)
    ToolTip = ("Write few alphabets of disease name for quick sorting")
    Picture = Picture["icon:/small/cancel"]
  }
  { GridView1 GridView
    MoveScaled(23,5,49,54)
    Mode = Select.Single
  }
  { lstletter ListBox
    MoveScaled(73,5,4,54)
    Sorted = True
  }
  { btnok Button
    MoveScaled(64,1,13,3)
    Text = ("Save")
    Picture = Picture["icon:/small/save"]
  }
  { ListBox1 ListBox
    MoveScaled(1,5,21,54)
    Sorted = True
  }
  { chkallcateg Button
    MoveScaled(1,1,21,3)
    Text = ("All Categories")
    Picture = Picture["icon:/small/bookmark"]
  }
  { chkleftmain CheckBox
    MoveScaled(23,1,3,3)
  }
}
