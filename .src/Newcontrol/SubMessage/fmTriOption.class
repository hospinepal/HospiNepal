' Gambas class file

Public Sub _new(sOption1 As String, sOption2 As String, sOption3 As String)

  rbopt1.Text = sOption1
  rbopt2.Text = sOption2
  rbopt3.Text = sOption3
  Me.Tag = ""

End

Public Sub rbopt1_Click()

  Me.Tag = rbopt1.Text

End

Public Sub rbopt2_Click()

  Me.Tag = rbopt2.Text

End

Public Sub rbopt3_Click()

  Me.Tag = rbopt3.Text

End
