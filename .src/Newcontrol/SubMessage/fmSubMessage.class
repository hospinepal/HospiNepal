' Gambas class file

Private AppWidth As Float
Private AppHeight As Float

Private $sValue As String[]
Private $MessageList As String[]

Private aObjPanel[50] As Panel
Private aObjLabel[50] As TextLabel
Private aObjSelect[50] As FmTriOption

Public Sub Run(sTitle As String, sMessage As String[]) As String[]

  Me.Text = sTitle
  $MessageList = sMessage
  If Me.ShowModal() Then Return $sValue

End

Public Sub Form_Open()

  Dim i As Integer

  modGeneralMain.ArrangeFormCentre(Me, "False")
  AppWidth = modBasic.$AppWidthRatio
  AppHeight = modBasic.$AppHeightRatio

  For i = 0 To $MessageList.Count - 1
    aObjPanel[i] = New Panel(Frame1) As "PanelGroup"
    With aObjPanel[i]
      .Arrangement = Arrange.Horizontal
      .Border = Border.Plain
      .AutoResize = True
      .Width = 715 * AppWidth
      .Padding = 10
    End With

    aObjSelect[i] = New FmTriOption("Useful", "Neutral", "Useless", aObjPanel[i]) As "SelectionGroup"
    With aObjSelect[i]
      .Width = 200 * AppWidth
    End With
    aObjLabel[i] = New TextLabel(aObjPanel[i]) As "LabelGroup"
    With aObjLabel[i]
      .AutoResize = True
      .Wrap = True
      .Width = 525 * AppWidth
      .Text = $MessageList[i]
    End With

  Next

End

Public Sub btnBrOK_Click()

  Dim i As Integer
  Dim xx As String[]

  xx = New String[]
  For i = 0 To $MessageList.Count - 1
    If aObjSelect[i].Tag Then
      xx.Add(aObjSelect[i].Tag)
    Endif
  Next
  If xx.Count = $MessageList.Count Then
    $sValue = xx
    Me.Close(True)
  Endif

End

Public Sub btnBrOK_KeyRelease()

  If Key.Code = Key.Esc Then
    Me.Close()
  Endif

End
