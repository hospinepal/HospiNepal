# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,63,60)
  Text = ("Item Grid")
  Resizable = False
  { txtname ButtonBox
    MoveScaled(4,1,42,3)
    ToolTip = ("Write few alphabets of disease name for quick sorting")
    Picture = Picture["icon:/small/cancel"]
  }
  { lstletter ListBox
    MoveScaled(58,5,4,50)
    Sorted = True
  }
  { btnok Button
    MoveScaled(48,1,13,3)
    Text = ("Save")
    Picture = Picture["icon:/small/save"]
  }
  { pnlcustom Panel
    MoveScaled(1,56,61,3)
    Enabled = False
    { Label1 Label
      MoveScaled(0,0,8,3)
      Text = ("Custom:")
      Border = Border.Plain
    }
    { txtcustom TextBox
      MoveScaled(9,0,38,3)
    }
    { btncustsave Button
      MoveScaled(48,0,12,3)
      Text = ("Save")
      Picture = Picture["icon:/small/save"]
    }
  }
  { chkleftmain CheckBox
    MoveScaled(1,1,3,3)
  }
  { GridView1 GridView
    MoveScaled(1,5,56,50)
    Mode = Select.Single
  }
}
