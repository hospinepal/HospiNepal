# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,53,24)
  Arrangement = Arrange.Vertical
  { mnufile Menu
    Visible = False
    { mnudictword Menu
      Text = ("Add To List")
    }
    { mnukeywords Menu
      Text = ("Key Words")
    }
    { mnusimilar Menu
      Text = ("Suggestions")
    }
    { Menu1 Menu
      Text = ("- - Edit - -")
      Enabled = False
    }
    { mnuclear Menu
      Text = ("Clear Select")
    }
    { mnusentcase Menu
      Text = ("First UCase")
    }
    { mnuuptext Menu
      Text = ("Upper Case")
    }
    { mnulowtext Menu
      Text = ("Lower Case")
    }
    { mnureplace Menu
      Text = ("Find+Replace")
    }
    { mnuclearall Menu
      Text = ("Erase All")
    }
  }
  { HBox1 HBox
    MoveScaled(0,0,53.3333,2.3333)
    { HBox2 HBox
      MoveScaled(0,0,9,2.3333)
      Enabled = False
      { btnBold ToolButton
        MoveScaled(0,0,2,2.3333)
        ToolTip = ("Bold")
        Picture = Picture["icon:/tiny/text-bold"]
        Toggle = True
      }
      { btnItalic ToolButton
        MoveScaled(2,0,2,2.3333)
        ToolTip = ("Italic")
        Picture = Picture["icon:/tiny/text-italic"]
        Toggle = True
      }
      { btnUnderline ToolButton
        MoveScaled(4,0,2,2.3333)
        ToolTip = ("Underline")
        Picture = Picture["icon:/tiny/text-underline"]
        Toggle = True
      }
      { btnStrikeOut ToolButton
        MoveScaled(6,0,2,2.3333)
        ToolTip = ("StrikeOut")
        Picture = Picture["icon:/tiny/text-strike"]
        Toggle = True
      }
    }
    { HBox3 HBox
      MoveScaled(9,0,11,2.3333)
      Enabled = False
      AutoResize = True
      { btnAlignLeft ToolButton
        MoveScaled(0,0,2.3333,2.3333)
        ToolTip = ("Align Left")
        Picture = Picture["icon:/tiny/text-left"]
        Radio = True
        Toggle = True
      }
      { btnAlignCenter ToolButton
        MoveScaled(2.3333,0,2,2.3333)
        ToolTip = ("Align Center")
        Picture = Picture["icon:/tiny/text-center"]
        Radio = True
        Toggle = True
      }
      { btnAlignRight ToolButton
        MoveScaled(5,0,2.3333,2.3333)
        ToolTip = ("Align Right")
        Picture = Picture["icon:/tiny/text-right"]
        Radio = True
        Toggle = True
      }
      { btnAlignJustify ToolButton
        MoveScaled(8,0,2.3333,2.3333)
        ToolTip = ("Align Justify")
        Picture = Picture["icon:/tiny/text-fill"]
        Radio = True
        Toggle = True
      }
    }
    { HBox4 HBox
      MoveScaled(20,0,24,2.3333)
      Enabled = False
      { ComboBox1 ComboBox
        MoveScaled(0,0,15,1)
        Font = Font["-2"]
        ToolTip = ("Set font face")
      }
      { SpinBox1 SpinBox
        MoveScaled(15,0,4.3333,2.3333)
        Font = Font["-1"]
        ToolTip = ("Set font size")
      }
      { ColorButton1 ColorButton
        MoveScaled(19,0,2.3333,2.3333)
        ToolTip = ("Set font color")
      }
      { ColorButton2 ColorButton
        MoveScaled(21.3333,0,2.3333,2.3333)
        ToolTip = ("Set background color")
      }
    }
    { HBox5 HBox
      MoveScaled(44,0,9,2.3333)
      { CheckBox1 CheckBox
        MoveScaled(0,0,2.3333,2.3333)
        ToolTip = ("Enable Rich Text Format")
      }
      { btnkey ToolButton
        MoveScaled(3,0,2.3333,2.3333)
        ToolTip = ("Insert selected text to KeyList")
        Picture = Picture["icon:/tiny/flag"]
      }
      { btnmenu MenuButton
        MoveScaled(6.3333,0,2.3333,2.3333)
        Picture = Picture["icon:/tiny/indent"]
      }
    }
  }
  { Panel1 Panel
    MoveScaled(0,2.3333,53.3333,22)
    Expand = True
    Arrangement = Arrange.Column
    { !TextEdit1 TextEdit
      MoveScaled(0,0,49,22)
      #Public = True
      Expand = True
      Wrap = True
    }
    { ListBox1 ListBox
      MoveScaled(49,0,4,22)
      Expand = True
      Sorted = True
    }
  }
}
