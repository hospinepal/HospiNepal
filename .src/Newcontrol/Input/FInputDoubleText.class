' Gambas class file

Private $sPrompt As String
Private $LabelList As String[]
Private $sList As String[]
Private $sValue As String[]

Public Sub Run(Prompt As String, LabelList As String[], Optional {Default} As String[], Optional sList As String[]) As String[]

  $sPrompt = Prompt
  $LabelList = LabelList
  $sValue = {Default}
  If sList Then
    $sList = sList
  Else
    $sList = New String[]
  Endif

  If Me.ShowModal() Then Return $sValue

End

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me, "False")
  TextLabel1.Text = $sPrompt
  txtvalue2.List = $sList
  If $LabelList Then
    If $LabelList.Count = 2 Then
      txtlabel1.Text = $LabelList[0]
      txtlabel2.Text = $LabelList[1]
    Endif
  Endif

  If $sValue Then
    If $sValue.Count = 2 Then
      txtvalue1.Text = $sValue[0]
      txtvalue2.Text = $sValue[0]
    Endif
  Endif

End

Public Sub btnCancel_Click()

  Me.Close

End

Public Sub btnOK_Click()

  Dim sval As String[]

  If txtvalue1.Text And If txtvalue2.Text Then
    sval = New String[]
    sval.Add(Trim(txtvalue1.Text))
    sval.Add(Trim(txtvalue2.Text))
    $sValue = sval
    Me.Close(True)
  Endif

End
