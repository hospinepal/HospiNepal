' Gambas class file

''controls
Private aRadioBox[100] As RadioButton         ''aObj
Private aCheckBox[100] As CheckBox       ''aObj1
Private aNaleLabel[100] As TextLabel             ''aObj2
Private aClinCombo[100] As DegComboBox           ''aObj3
Private aValueBox[100] As ValueBox             ''aObj4
Private aSensiForm[100] As FmSensitivity           ''aObj5
Private aDualTextForm[100] As FmDualText
Private aTextBox[100] As TextBox        ''aObj6
''other
Private AppWidth As Float
Private AppHeight As Float
Private $opt As String[]
Private $strType As String
Private $sValue As String[]

''------------------------------- create controls -------------------------------
Public Sub Run(opt As String[], strType As String, strExam As String) As String[]

  $opt = opt
  $strType = strType
  lblitem.Text = strExam
  If Me.ShowModal() Then Return $sValue

End

Public Sub Form_Open()

  Dim i As Integer
  Dim srt As String

  modGeneralMain.ArrangeFormCentre(Me, "False")
  AppWidth = modBasic.$AppScaleFactor
  AppHeight = modBasic.$AppScaleFactor

  If $strType = "Clinical Scale" Then
    Frame1.Height = (ClinScaleList().Count * 40 + 20) * AppHeight
  Else
    Frame1.Height = ($opt.Count * 25 + 20) * AppHeight
  Endif
  Frame1.Width = 650 * AppWidth

  Me.Text = $strType
  If $strType = "Single Selection" Or If $strType = "Dichotomous" Then
    i = 1
    For Each srt In $opt
      aRadioBox[i] = New RadioButton(Frame1) As "Buttongroup"
      With aRadioBox[i]
        .X = 5 * AppWidth
        .Y = ((i - 1) * 25 + 5) * AppHeight
        .Width = 550 * AppWidth
        .Height = 25 * AppHeight
        .Text = srt
        .Tag = i
      End With
      i = i + 1
    Next

  Else If $strType = "Multiple Selection" Then
    i = 1
    For Each srt In $opt
      aCheckBox[i] = New CheckBox(Frame1) As "Buttongroup"
      With aCheckBox[i]
        .X = 5 * AppWidth
        .Y = ((i - 1) * 25 + 5) * AppHeight
        .Width = 550 * AppWidth
        .Height = 25 * AppHeight
        .Text = srt
        .Tag = i
      End With
      i = i + 1
    Next

  Else If $strType = "Text Table" Then
    i = 1
    For Each srt In $opt
      aNaleLabel[i] = New TextLabel(Frame1) As "LabelGroup"
      aTextBox[i] = New TextBox(Frame1) As "Textugroup"
      With aNaleLabel[i]
        .X = 5 * AppWidth
        .Y = ((i - 1) * 25 + 5) * AppHeight
        .Width = 200 * AppWidth
        .Height = 25 * AppHeight
        ' .Border = Border.Plain
        .Wrap = True
        .Text = srt
        .Tag = i
      End With
      With aTextBox[i]
        .X = (5 + 225) * AppWidth
        .Y = ((i - 1) * 25 + 5) * AppHeight
        .Width = 400 * AppWidth
        .Height = 25 * AppHeight
        .Text = ""
        .Tag = i
      End With
      i = i + 1
    Next

  Else If $strType = "Drug Sensitivity" Then
    i = 1
    For Each srt In $opt
      aCheckBox[i] = New CheckBox(Frame1) As "Buttongroup"
      With aCheckBox[i]
        .X = 5 * AppWidth
        .Y = ((i - 1) * 25 + 5) * AppHeight
        .Width = 250 * AppWidth
        .Height = 25 * AppHeight
        .Text = srt
        .Tag = i
      End With
      aSensiForm[i] = New FmSensitivity(Frame1) As "sensitivity"
      With aSensiForm[i]
        .X = 265 * AppWidth
        .Y = ((i - 1) * 25 + 5) * AppHeight
        .Width = 350 * AppWidth
        .Height = 25 * AppHeight
      End With
      i = i + 1
    Next

  Else If $strType = "Single Column" Then
    i = 1
    For Each srt In $opt
      aNaleLabel[i] = New TextLabel(Frame1) As "LabelGroup"
      aTextBox[i] = New TextBox(Frame1) As "Textugroup"
      With aNaleLabel[i]
        .X = 5 * AppWidth
        .Y = ((i - 1) * 25 + 5) * AppHeight
        .Width = 200 * AppWidth
        .Height = 25 * AppHeight
        ' .Border = Border.Plain
        .Wrap = True
        .Text = srt
        .Tag = i
      End With
      With aTextBox[i]
        .X = (5 + 225) * AppWidth
        .Y = ((i - 1) * 25 + 5) * AppHeight
        .Width = 400 * AppWidth
        .Height = 25 * AppHeight
        .Text = ""
        .Tag = i
      End With
      i = i + 1
    Next

  Else If $strType = "Dual Columns" Then
    i = 1
    For Each srt In $opt
      aCheckBox[i] = New CheckBox(Frame1) As "Buttongroup"
      With aCheckBox[i]
        .X = 5 * AppWidth
        .Y = ((i - 1) * 25 + 5) * AppHeight
        .Width = 250 * AppWidth
        .Height = 25 * AppHeight
        .Text = srt
        .Tag = i
      End With
      aDualTextForm[i] = New FmDualText(Frame1) As "DualText"
      With aDualTextForm[i]
        .X = 265 * AppWidth
        .Y = ((i - 1) * 25 + 5) * AppHeight
        .Width = 350 * AppWidth
        .Height = 25 * AppHeight
      End With
      i = i + 1
    Next

  Else If $strType = "Clinical Scale" Then
    i = 1
    For Each srt In ClinScaleList()
      aNaleLabel[i] = New TextLabel(Frame1) As "LabelGroup"
      aClinCombo[i] = New DegComboBox(Frame1) As "DgComboGroup"
      aValueBox[i] = New ValueBox(Frame1) As "Valugroup"
      With aNaleLabel[i]
        .X = 5 * AppWidth
        .Y = ((i - 1) * 40 + 5) * AppHeight
        .Width = 300 * AppWidth
        .Height = 40 * AppHeight
        ' .Border = Border.Plain
        .Wrap = True
        .Text = srt
      End With
      With aClinCombo[i]
        .X = (5 + 325) * AppWidth
        .Y = ((i - 1) * 40 + 5) * AppHeight
        .Width = 225 * AppWidth
        .Height = 25 * AppHeight
        .Tag = i
      End With
      With aValueBox[i]
        .X = (5 + 575) * AppWidth
        .Y = ((i - 1) * 40 + 5) * AppHeight
        .Width = 50 * AppWidth
        .Height = 25 * AppHeight
        .Value = 0
      End With
      FillDegComboData(srt, aClinCombo[i])
      i = i + 1
    Next

  Endif

  If aRadioBox[1] Then
    aRadioBox[1].SetFocus
  Else If aCheckBox[1] Then
    aCheckBox[1].SetFocus
  Endif

End

''------------------------------ form procedures ------------------------------
Public Sub Form_Resize()

  Dim xht As Integer

  If $strType = "Clinical Scale" Then
    xht = (ClinScaleList().Count * 40 + 20) * AppHeight
  Else
    xht = ($opt.Count * 25 + 20) * AppHeight
  Endif
  If Frame1.Height < xht Then
    Frame1.Height = xht
  Endif

End

Public Sub Buttongroup_Click()

  Dim i As Integer

  i = Last.Tag
  If $strType = "Drug Sensitivity" Then
    If aCheckBox[i].Value = True Then
      aSensiForm[i].Enabled = True
    Else If aCheckBox[i].Value = False Then
      aSensiForm[i].Enabled = False
    Endif
  Else If $strType = "Dual Columns" Then
    If aCheckBox[i].Value = True Then
      aDualTextForm[i].Enabled = True
    Else If aCheckBox[i].Value = False Then
      aDualTextForm[i].Enabled = False
    Endif
  Endif

End

Public Sub btnBrOK_Click()

  Dim i As Integer
  Dim xx As String[]
  Dim yy As Float
  Dim aLst As String[]
  Dim aColl As JSONCollection

  xx = New String[]
  Inc Application.Busy
  If $strType = "Single Selection" Or If $strType = "Dichotomous" Then
    For i = 1 To $opt.Count
      If aRadioBox[i].Value = True Then
        xx.Add(aRadioBox[i].Text)
      Endif
    Next

  Else If $strType = "Multiple Selection" Then
    For i = 1 To $opt.Count
      If aCheckBox[i].Value = True Then
        xx.Add(aCheckBox[i].Text)
      Endif
    Next

  Else If $strType = "Drug Sensitivity" Then
    For i = 1 To $opt.Count
      If aCheckBox[i].Value = True Then
        xx.Add(aCheckBox[i].Text & ";" & aSensiForm[i].Tag)
      Endif
    Next

  Else If $strType = "Single Column" Then
    For i = 1 To $opt.Count
      If aTextBox[i].Text Then
        xx.Add(aNaleLabel[i].Text & ";" & aTextBox[i].Text)
      Endif
    Next

  Else If $strType = "Dual Columns" Then
    For i = 1 To $opt.Count
      If aCheckBox[i].Value = True Then
        xx.Add(aCheckBox[i].Text & ";" & aDualTextForm[i].Tag)
      Endif
    Next

  Else If $strType = "Text Table" Then
    aLst = New String[]
    For i = 1 To $opt.Count
      If aTextBox[i].Text Then
        aLst.Add(aTextBox[i].Text)
      Endif
    Next
    xx.Add(aLst.Join(";"))

  Else If $strType = "Clinical Scale" Then
    yy = 0
    aColl = New JSONCollection
    For i = 1 To ClinScaleList().Count
      yy = yy + aValueBox[i].Value
      aColl.Add(aValueBox[i].Value, aNaleLabel[i].Text)
    Next
    xx.Add(CStr(yy))
    xx.Add(JSON.Encode(aColl))

  Endif

  $sValue = xx
  Dec Application.Busy
  Me.Close(True)

End

''------------------------------ short cut keys -----------------------------
Public Sub Form_KeyRelease()

  Dim i As Integer

  If Key.Code = Key.Esc Then
    Me.Close
  Else
    For i = 1 To $opt.Count
      If Key.Code = Key[i] And If Key.Control Then
        If aCheckBox[i] Then
          aCheckBox[i].Value = True
          ScrollView1.EnsureVisible(aCheckBox[i].X, aCheckBox[i].Y, aCheckBox[i].Width, aCheckBox[i].Height)
          Break
        Endif
        If aRadioBox[i] Then
          aRadioBox[i].Value = True
          ScrollView1.EnsureVisible(aRadioBox[i].X, aRadioBox[i].Y, aRadioBox[i].Width, aRadioBox[i].Height)
          Break
        Endif
      Endif
    Next
  Endif

End

''------------------------- clinical scale ------------------------------------------------
Private Function ClinScaleList() As String[]

  Dim clin As String[]
  Dim clinList As String[]
  Dim aSize As String[]
  Dim xx As String

  clin = New String[]
  For Each xx In $opt
    aSize = Split(xx, "@")
    If aSize.Count = 3 Then
      If aSize[2] Then

        If clin.Count = 0 Then
          clin.Add(aSize[2])
        Else
          If clin.Exist(aSize[2]) = False Then
            clin.Add(aSize[2])
          Endif
        Endif

      Endif
    Endif
  Next

  ' clin.Sort()
  clinList = clin
  Return clinList

End

Private Sub FillDegComboData(sCaption As String, dgCombo As DegComboBox)

  Dim xx As String
  Dim aSize As String[]
  Dim clin As String[]
  Dim dgdata As Variant[]

  dgdata = New Variant[]
  For Each xx In $opt
    aSize = Split(xx, "@")
    If aSize.Count = 3 Then
      If aSize[2] = sCaption Then
        clin = New String[]
        clin.Add(aSize[1])
        clin.Add(aSize[0])
        dgdata.Add(clin)
      Endif
    Endif
  Next
  dgCombo.SetListData(dgdata)
  dgCombo.DefineColumnWidths([20 * AppHeight, 500 * AppWidth])
  dgCombo.ColumnSearch = 1
  dgCombo.ColumnBound = 0
  dgCombo.show

End

Public Sub DgComboGroup_Save(Text As String, Index As Variant)

  Dim j As Integer

  j = Last.Tag
  aValueBox[j].Value = Index
  Print Text

End
