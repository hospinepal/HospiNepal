' Gambas class file

Private $GridDataList As String[]
Private $GridWorkList As String[]
Private $SelDataList As String[]
Private $SubListView As String[]
Private $CodePath As String
Private $sType As String
Private $sValue As String[]

Public Sub Run(CodePath As String, sType As String) As String[]

  $CodePath = CodePath
  $sType = sType
  If Me.ShowModal() Then Return $sValue

End

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me, "False")
  $sValue = New String[]
  If $sType = "Disease" Then
    cmbchapter.List = modFillContainer.GetListFromResult(modDatabase.$myConn.Exec("select distinct(fldgroupname) as col from tbldiagnogroup"))                              ''
  Else If $sType = "Procedure" Then
  Endif
  $GridDataList = modICD.GetICDCodeTreeList($CodePath)

  If $sType = "Disease" Then
    If modBasic.$DefaultDiagnoGroup Then
      cmbchapter.Text = modBasic.$DefaultDiagnoGroup
      btncharefresh_Click()
    Else
      $GridWorkList = $GridDataList
      lstletter.List = modString.GetFirstLetterArray($GridWorkList)
    Endif
  Else If $sType = "Procedure" Then
    $GridWorkList = $GridDataList
    lstletter.List = modString.GetFirstLetterArray($GridWorkList)
  Endif

  $GridWorkList.Sort()
  chkleftmain.Value = modBasic.$SearchBothSide
  chkleftsub.Value = modBasic.$SearchBothSide
  FillICDGrid()
  txtgrid.SetFocus

End

Public Sub chkleftmain_Click()

  modBasic.$SearchBothSide = chkleftmain.Value

End

Public Sub chkleftsub_Click()

  modBasic.$SearchBothSide = chkleftsub.Value

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.Esc Then
    Me.Close
  Else If Key.Code = Key["S"] And If Key.Control Then
    btnadd_Click()
  Endif

End

Public Sub cmbchapter_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbchapter)
  modFillContainer.RestrictComboToContent(cmbchapter)

End

Public Sub txtgrid_KeyPress()

  modGeneralMain.InputTextSearchKeyOnly()

End

Public Sub txtlist_KeyPress()

  modGeneralMain.InputTextSearchKeyOnly()

End

Public Sub txtcodesearch_KeyPress()

  modGeneralMain.InputTextSearchKeyOnly()

End

Public Sub txtgrid_Click()

  txtgrid.Text = ""
  If Not cmbchapter.Text Then
    $GridWorkList = $GridDataList
  Else
    $GridWorkList = $SelDataList
  Endif
  FillICDGrid()

End

Public Sub btnclear_Click()

  cmbchapter.Text = ""
  $GridWorkList = $GridDataList
  lstletter.List = modString.GetFirstLetterArray($GridWorkList)
  FillICDGrid()

End

''------------------------ Grid view -----------------------------
Public Sub btncharefresh_Click()

  Dim res As Result
  Dim xxx As String[]

  If cmbchapter.Text Then
    txtgrid.Text = ""
    txtlist.Text = ""
    xxx = New String[]
    If $sType = "Disease" Then
      res = modDatabase.$myConn.Exec("select flditemname,fldcodeid from tbldiagnogroup where fldgroupname=&1", cmbchapter.Text)
      If res.Available Then
        For Each res
          If res!flditemname And If res!fldcodeid Then
            If res!flditemname = "Obstetrics" Then
            Else
              xxx.Add(res!flditemname & "@" & res!fldcodeid)
            Endif
          Endif
        Next

      Else
        xxx = modICD.GetICDItemBlockList($CodePath, modPathology.ICDBlockPath(), cmbchapter.Text)
      Endif
      $SelDataList = xxx
    Else If $sType = "Procedure" Then
    Endif

    If $SelDataList Then
      $GridWorkList = $SelDataList.Sort()
      lstletter.List = modString.GetFirstLetterArray($GridWorkList)
      FillICDGrid()
    Endif

  Endif

End

Private Sub SortSelectedRows()

  Dim xx As String
  Dim asx As String[]
  Dim xfinal As String[]
  Dim xdata As String[]

  If Not cmbchapter.Text Then
    xdata = $GridDataList
  Else
    xdata = $SelDataList
  Endif

  xfinal = New String[]
  If xdata Then
    For Each xx In xdata
      asx = Split(xx, "@")

      If txtgrid.Text Then
        If chkleftmain.Value Then
          If LCase(asx[0]) Like "*" & LCase(txtgrid.Text) & "*" Then
            xfinal.Add(asx[0] & "@" & asx[1])
          Endif
        Else
          If LCase(asx[0]) Like LCase(txtgrid.Text) & "*" Then
            xfinal.Add(asx[0] & "@" & asx[1])
          Endif
        Endif
      Endif

    Next
  Endif
  $GridWorkList = xfinal.Sort()
  FillICDGrid()

End

Public Sub txtgrid_KeyRelease()

  If Key.Code = Key.Down Then
    GridView1.SetFocus
  Else
    If txtgrid.Text Then
      SortSelectedRows()
    Else
      If Not cmbchapter.Text Then
        $GridWorkList = $GridDataList
      Else
        $GridWorkList = $SelDataList
      Endif
      FillICDGrid()
    Endif
  Endif

End

Private Sub SortCodeSelectedRows()

  Dim xx As String
  Dim asx As String[]
  Dim xfinal As String[]
  Dim xdata As String[]

  If Not cmbchapter.Text Then
    xdata = $GridDataList
  Else
    xdata = $SelDataList
  Endif

  xfinal = New String[]
  If xdata Then
    For Each xx In xdata
      asx = Split(xx, "@")

      If txtcodesearch.Text Then
        If LCase(asx[1]) Like LCase(txtcodesearch.Text) & "*" Then
          xfinal.Add(asx[0] & "@" & asx[1])
        Endif
      Endif

    Next
  Endif
  $GridWorkList = xfinal.Sort()
  FillICDGrid()

End

Public Sub txtcodesearch_KeyRelease()

  If Key.Code = Key.Down Then
    GridView1.SetFocus
  Else
    If txtcodesearch.Text Then
      SortCodeSelectedRows()
    Else
      If Not cmbchapter.Text Then
        $GridWorkList = $GridDataList
      Else
        $GridWorkList = $SelDataList
      Endif
      FillICDGrid()
    Endif
  Endif

End

Public Sub lstletter_Click()

  txtgrid.Text = lstletter.Text
  SortSelectedRows()

End

Public Sub FillICDGrid()

  GridView1.Clear()
  GridView1.Columns.Count = 2
  GridView1.Rows.Count = $GridWorkList.Count

  With GridView1
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 50 * modBasic.$AppWidthRatio
    .Columns[1].Width = 500 * modBasic.$AppWidthRatio
    .Columns[0].Text = "Code"
    .Columns[1].Text = "Category"
  End With
  GridView1.Row = 0
  ListView1.Clear()

End

Public Sub GridView1_Data(Row As Integer, Column As Integer)

  Dim sLip As String[]

  sLip = Split($GridWorkList[Row], "@")
  If Column = 0 Then
    GridView1.Data.Text = sLip[1]
  Else If Column = 1 Then
    GridView1.Data.Text = sLip[0]
  Endif

End

Public Sub GridView1_Click()

  txtlist.Text = ""
  txtcode.Text = ""
  txtname.Text = ""
  If $SubListView Then
    $SubListView.Clear()
  Endif

  If GridView1.Rows.Selection.Count Then
    txtcode.Text = GridView1[GridView1.Row, 0].Text
    $SubListView = modICD.GetICDItemTreeList($CodePath, GridView1[GridView1.Row, 0].Text, GridView1[GridView1.Row, 1].Text)
    If Not $SubListView.Count Then
      txtname.Text = GridView1[GridView1.Row, 1].Text
    Endif
    FillListView()
  Endif

End

Public Sub GridView1_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    GridView1_Click()
  Else If Key.Code = Key.Right Then
    ListView1.SetFocus
  Endif

End

''================================== Individual Diagnosis =====================================
Private Sub FillListView()

  Dim xx As String
  Dim asx As String[]

  ListView1.Clear()
  For Each xx In $SubListView
    asx = Split(xx, "@")
    ListView1.Add(asx[1], asx[0])
  Next

End

Public Sub txtlist_KeyRelease()

  Dim xlst As String[]
  Dim xx As String
  Dim xlsfinal As String[]

  If Key.Code = Key.Down Then
    ListView1.SetFocus
  Else
    If txtlist.Text Then
      xlst = modICD.GetICDItemTreeList($CodePath, GridView1[GridView1.Row, 0].Text, GridView1[GridView1.Row, 1].Text)
      xlsfinal = New String[]
      For Each xx In xlst
        If chkleftsub.Value Then
          If LCase(xx) Like "*" & LCase(txtlist.Text) & "*" Then
            xlsfinal.Add(xx)
          Endif
        Else
          If LCase(xx) Like LCase(txtlist.Text) & "*" Then
            xlsfinal.Add(xx)
          Endif
        Endif
      Next
      $SubListView = xlsfinal.Sort()
      FillListView()

    Else
      $SubListView = modICD.GetICDItemTreeList($CodePath, GridView1[GridView1.Row, 0].Text, GridView1[GridView1.Row, 1].Text)
      FillListView()
    Endif
  Endif

End

Public Sub ListView1_Click()

  txtname.Text = ListView1.Current.Text

End

Public Sub ListView1_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    ListView1_Click()
  Endif

End

Public Sub btnadd_Click()

  Dim xx As String[]

  If txtcode.Text And If txtname.Text Then
    xx = New String[]
    xx.Add(txtcode.Text)
    xx.Add(Trim(txtname.Text))
    $sValue = xx
    Me.Close(True)
  Endif

End

Public Sub bticdroup_Click()

  Dim xlist As String[]

  xlist = modBasic.$ClinDiagnoChapterGrouped
  If xlist.Count Then
    cmbchapter.Text = GridViewGroupNew("Select Diagnosis Block", xlist)
    Wait
    If cmbchapter.Text Then
      btncharefresh_Click()
    Endif
  Endif

End
