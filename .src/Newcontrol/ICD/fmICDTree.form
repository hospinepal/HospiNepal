# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,116,58)
  Text = ("ICD10 Database")
  Resizable = False
  Arrangement = Arrange.Vertical
  AutoResize = True
  { Panel2 Panel
    MoveScaled(0,0,115,57)
    { txtgrid ButtonBox
      MoveScaled(12,5,39,3)
      Picture = Picture["icon:/small/cancel"]
    }
    { GridView1 GridView
      MoveScaled(1,9,50,47)
      Mode = Select.Single
    }
    { txtlist TextBox
      MoveScaled(59,1,35,3)
    }
    { ListView1 ListView
      MoveScaled(57,5,57,43)
    }
    { Label1 Label
      MoveScaled(57,49,6,3)
      Text = ("Code")
      Border = Border.Plain
    }
    { Label2 Label
      MoveScaled(57,53,6,3)
      Text = ("Text")
      Border = Border.Plain
    }
    { txtcode TextBox
      MoveScaled(64,49,21,3)
      ReadOnly = True
    }
    { txtname TextBox
      MoveScaled(64,53,50,3)
    }
    { btnadd Button
      MoveScaled(99,49,15,3)
      Text = Shortcut(("Save"), "S")
      Picture = Picture["icon:/small/apply"]
    }
    { lstletter ListBox
      MoveScaled(52,5,4,51)
      Sorted = True
    }
    { cmbchapter ComboBox
      MoveScaled(12,1,31,3)
    }
    { Label3 Label
      MoveScaled(1,1,7,3)
      Text = ("Group")
      Border = Border.Plain
    }
    { btncharefresh ToolButton
      MoveScaled(44,1,3,3)
      Picture = Picture["icon:/small/refresh"]
    }
    { btnclear ToolButton
      MoveScaled(48,1,3,3)
      Picture = Picture["icon:/small/cancel"]
    }
    { chkleftmain CheckBox
      MoveScaled(9,5,3,3)
    }
    { chkleftsub CheckBox
      MoveScaled(56,1,3,3)
    }
    { txtcodesearch TextBox
      MoveScaled(1,5,7,3)
    }
    { bticdroup ToolButton
      MoveScaled(8,1,3,3)
      Picture = Picture["icon:/small/book"]
    }
  }
}
