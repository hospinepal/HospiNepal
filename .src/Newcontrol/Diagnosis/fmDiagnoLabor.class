' Gambas class file

Private $encid As String
Private $sValue As String[]

Public Sub Run(encid As String) As String[]

  $encid = encid
  If Me.ShowModal() Then Return $sValue

End

Public Sub Form_Open()

  Dim xval As String

  modGeneralMain.ArrangeFormCentre(Me, "False")
  txtpatientname.Text = modPatient.GetPatientNameByEnc($encid)
  cmbpresent.List = ["Cephalic", "Breech", "Face", "Cord", "Shoulder"]
  cmbstatus.List = ["Latent phase", "Active phase", "Second stage", "None"]
  xval = modSettings.ShowSettingFromFIle("ClinicalRule/EDD_LMP_DayDifference")
  If xval Then
    txtexday.Value = CInt(xval)
  Else
    txtexday.Value = 277
  Endif
  ObsFormat()
  ShowLastValues()
  txtgravida.SetFocus

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.Esc Then
    Me.Close
  Else
    modGeneralmain.GoToNextControlTab()
  Endif

End

Public Sub cmbpresent_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbpresent)
  modFillContainer.RestrictComboToContent(cmbpresent)

End

Public Sub cmbstatus_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbstatus)
  modFillContainer.RestrictComboToContent(cmbstatus)

End

Public Sub dtlmp_Click()

  txtlmp.Text = modDate.ConvertToLocaldate(dtlmp.Value)
  GetEDDValue()

End

Public Sub txtlmp_LostFocus()

  dtlmp.Value = modDate.ConvertToEnglishdate(txtlmp.Text)
  GetEDDValue()

End

Public Sub dtedd_Click()

  txtedd.Text = modDate.ConvertToLocaldate(dtedd.Value)

End

Public Sub txtedd_LostFocus()

  dtedd.Value = modDate.ConvertToEnglishdate(txtedd.Text)

End

Private Sub GetEDDValue()

  Dim xday As Float

  dtedd.Value = DateAdd(dtlmp.Value, gb.Day, CInt(txtexday.Value))
  txtedd.Text = modDate.ConvertToLocaldate(dtedd.Value)
  xday = DateDiff(dtlmp.Value, Now(), gb.Day) / 7
  txtgesweek.Value = Fix(xday)
  txtgesdays.Value = Round(Frac(xday) * 7)

End

Private Function GetDiagnosisText() As String

  Dim xpresent As String
  Dim xstatus As String
  Dim xday As String
  Dim xpast As String
  Dim xx As String

  If txtgesdays.Value Then
    If rbformB.Value = True Then
      xday = CStr(txtgesweek.Value) & " + " & CStr(txtgesdays.Value) & " WOG"
    Else
      xday = CStr(txtgesweek.Value) & " weeks & " & CStr(txtgesdays.Value) & " days"
    Endif
  Else
    If rbformB.Value = True Then
      xday = CStr(txtgesweek.Value) & " WOG"
    Else
      xday = CStr(txtgesweek.Value) & " weeks"
    Endif
  Endif

  If cmbpresent.Text Then
    If cmbpresent.Text = "Cephalic" Then
    Else
      xpresent = " with " & cmbpresent.Text & " Presentation"
    Endif
  Endif

  If cmbstatus.Text Then
    If cmbstatus.Text = "None" Then
      xstatus = " Not in labor"
    Else
      xstatus = " in " & cmbstatus.Text & " of labor"
    Endif
  Endif

  If txtpast.Text Then
    xpast = " with " & txtpast.Text
  Else
    xpast = ""
  Endif

  If rbformB.Value = True Then
    xx = "G" & CStr(txtgravida.Value) & " P" & CStr(txtparity.Value) & " + " & CStr(txtabortion.Value) & " L" & CStr(txtliving.Value) & " AT " & xday & xpresent & Space(1) & xstatus & xpast
  Else
    xx = "G" & CStr(txtgravida.Value) & " P" & CStr(txtparity.Value) & " + " & CStr(txtabortion.Value) & " L" & CStr(txtliving.Value) & " with " & xday & " of pregnancy" & xpresent & Space(1) & xstatus & xpast                                                                ''
  Endif
  Return xx

End

Public Sub xdiagno_LostFocus()

  txtdiagno.Text = GetDiagnosisText()

End

Public Sub cmbpresent_LostFocus()

  txtdiagno.Text = GetDiagnosisText()

End

Public Sub cmbstatus_LostFocus()

  txtdiagno.Text = GetDiagnosisText()

End

Private Sub ShowLastValues()

  Dim xlmp As String
  Dim xedd As String
  Dim xday As Integer

  xday = modPatientGeneral.GetQuantiObstetricValue($encid, "Gestation")
  txtgesweek.Value = Floor(xday / 7)
  txtgesdays.Value = Round(Frac(xday / 7) * 7)

  txtgravida.Value = modPatientGeneral.GetQuantiObstetricValue($encid, "Gravida")
  txtparity.Value = modPatientGeneral.GetQuantiObstetricValue($encid, "Parity")
  txtabortion.Value = modPatientGeneral.GetQuantiObstetricValue($encid, "Abortion")
  txtliving.Value = modPatientGeneral.GetQuantiObstetricValue($encid, "Living")
  cmbpresent.Text = modPatientGeneral.GetQualiiObstetricValue($encid, "Presentation")
  cmbstatus.Text = modPatientGeneral.GetQualiiObstetricValue($encid, "Labor Status")
  txtpast.Text = modPatientGeneral.GetQualiiObstetricValue($encid, "Past Pregnancy")

  xlmp = modPatientGeneral.GetQualiiObstetricValue($encid, "Last Menstrual Period")
  If xlmp Then
    dtlmp.Value = Val(xlmp)
  Else
    dtlmp.Value = DateAdd(Now(), gb.Day, 0 - CInt(txtexday.Value))
  Endif
  txtlmp.Text = modDate.ConvertToLocaldate(dtlmp.Value)
  xedd = modPatientGeneral.GetQualiiObstetricValue($encid, "Expected Delivery Date")
  If xedd Then
    dtedd.Value = Val(xedd)
    txtedd.Text = modDate.ConvertToLocaldate(dtedd.Value)
  Endif

  txtdiagno.Text = GetDiagnosisText()

End

Private Function ObstetricSUmmary() As String

  Dim xlist As String[]

  xlist = New String[]
  xlist.Add("Gravida: " & CStr(txtgravida.Value))
  If txtparity.Value Then
    xlist.Add("Parity: " & CStr(txtparity.Value))
  Endif
  If txtabortion.Value Then
    xlist.Add("Abortion: " & CStr(txtabortion.Value))
  Endif
  If txtliving.Value Then
    xlist.Add("Living: " & CStr(txtliving.Value))
  Endif
  xlist.Add("Last Menstrual Period: " & modReportVar.GetDateTimeReport(dtlmp.Value, gb.MediumDate))
  xlist.Add("Expected Delivery Date: " & modReportVar.GetDateTimeReport(dtedd.Value, gb.MediumDate))
  xlist.Add("Gestation: " & CStr(txtgesweek.Value) & " Weeks " & CStr(txtgesdays.Value) & " Days")
  If cmbpresent.Text Then
    xlist.Add("Presentation: " & cmbpresent.Text)
  Endif
  If cmbstatus.Text Then
    xlist.Add("Labor Status: " & cmbstatus.Text)
  Endif

  Return xlist.Join(gb.NewLine)

End

Public Sub btnsave_Click()

  Dim xday As Integer
  Dim xx As String[]

  Inc Application.Busy
  If txtgesweek.Value Then
    xx = New String[]
    xx.Add("Obstetrics")
    xx.Add(Trim(txtdiagno.Text))
    xx.Add(ObstetricSUmmary())
    $sValue = xx

    xday = 7 * txtgesweek.Value + txtgesdays.Value
    modClinic.AddGeneralParametersQuali($encid, "Pregnancy Status", GetTrimesterLabel(xday))
    modPatientGeneral.AddExamGeneralQuantiData($encid, "Obstetrics", "Gravida", txtgravida.Value, "", True)
    modPatientGeneral.AddExamGeneralQuantiData($encid, "Obstetrics", "Parity", txtparity.Value, "", True)
    modPatientGeneral.AddExamGeneralQuantiData($encid, "Obstetrics", "Abortion", txtabortion.Value, "", True)
    modPatientGeneral.AddExamGeneralQuantiData($encid, "Obstetrics", "Living", txtliving.Value, "", True)
    modPatientGeneral.AddExamGeneralQualiData($encid, "Obstetrics", "Last Menstrual Period", Format(dtlmp.Value, gb.ShortDate), "", True)
    modPatientGeneral.AddExamGeneralQualiData($encid, "Obstetrics", "Expected Delivery Date", Format(dtedd.Value, gb.ShortDate), "", True)
    modPatientGeneral.AddExamGeneralQuantiData($encid, "Obstetrics", "Gestation", xday, "", True)
    modPatientGeneral.AddExamGeneralQualiData($encid, "Obstetrics", "Presentation", cmbpresent.Text, "", True)
    modPatientGeneral.AddExamGeneralQualiData($encid, "Obstetrics", "Labor Status", cmbstatus.Text, "", True)
    If txtpast.Text Then
      modPatientGeneral.AddExamGeneralQualiData($encid, "Obstetrics", "Past Pregnancy", txtpast.Text, "", True)
    Endif
  Endif
  Dec Application.Busy
  Me.Close(True)

End

Public Sub btnsave_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    btnsave_Click()
  Endif

End

Public Sub rbformA_Click()

  modSettings.SaveSettingsToFile("Obstetrics/Format", "A")
  txtdiagno.Text = GetDiagnosisText()

End

Public Sub rbformB_Click()

  modSettings.SaveSettingsToFile("Obstetrics/Format", "B")
  txtdiagno.Text = GetDiagnosisText()

End

Private Sub ObsFormat()

  Dim xval As String

  xval = modSettings.ShowSettingFromFIle("Obstetrics/Format")
  If xval = "B" Then
    rbformB.Value = True
  Else
    rbformA.Value = True
  Endif

End

Private Function GetTrimesterLabel(sDay As Integer) As String

  Dim xx As String

  If sDay < 84 Then
    xx = "1st trimester"
  Else If sDay >= 84 And If sDay < 189 Then
    xx = "2nd trimester"
  Else If sDay >= 189 Then
    xx = "3rd trimester"
  Endif
  Return xx

End
