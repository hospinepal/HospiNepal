' Gambas class file

Private $ValMax As Integer
Private $ValMin As Integer

Public Sub Form_Open()

  ValueBox1.SetFocus

End

Public Sub Form_Resize()

  Panel1.Width = Me.Width
  Panel1.Height = Me.Height
  btnhigh.Width = CInt(Panel1.Width / 3)
  btnlow.Width = CInt(Panel1.Width / 3)
  ValueBox1.Width = CInt(Panel1.Width / 3)
  btnhigh.Height = Panel1.Height
  btnlow.Height = Panel1.Height
  ValueBox1.Height = Panel1.Height

End

Public Sub btnlow_Click()

  If ValueBox1.Value > $ValMin Then
    ValueBox1.Value = ValueBox1.Value - 1
  Endif

End

Public Sub btnhigh_Click()

  If ValueBox1.Value < $ValMax Then
    ValueBox1.Value = ValueBox1.Value + 1
  Endif

End

''------------------
Public Sub SetMaxValue(sValue As Integer)

  $ValMax = sValue

End

Public Sub SetMinValue(sValue As Integer)

  $ValMin = sValue

End

Public Function GetValue() As Integer

  Return ValueBox1.Value

End

Public Sub SetValue(sValue As Integer)

  ValueBox1.Value = sValue

End

Public Function GetTagValue() As Variant

  Return ValueBox1.Tag

End

Public Sub SetTagValue(sValue As Variant)

  ValueBox1.Tag = sValue

End

Public Function GetToolTip() As String

  Return ValueBox1.Tooltip

End

Public Sub SetToolTip(sValue As String)

  ValueBox1.Tooltip = sValue

End
