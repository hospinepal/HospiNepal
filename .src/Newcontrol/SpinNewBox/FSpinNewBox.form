# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,9,3)
  Expand = True
  Border = False
  { Panel1 Panel
    MoveScaled(0,0,8,3)
    Expand = True
    Arrangement = Arrange.Horizontal
    { ValueBox1 ValueBox
      MoveScaled(0,0,4,3)
      Expand = True
      Alignment = Align.Right
      ReadOnly = True
    }
    { Panel2 Panel
      MoveScaled(4,0,4,3)
      Expand = True
      Arrangement = Arrange.Horizontal
      { btnlow ToolButton
        MoveScaled(0,0,2,3)
        Expand = True
        Picture = Picture["icon:/small/down"]
      }
      { btnhigh ToolButton
        MoveScaled(2,0,2,3)
        Expand = True
        Picture = Picture["icon:/small/up"]
      }
    }
  }
}
