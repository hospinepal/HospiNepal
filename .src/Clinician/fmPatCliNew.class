' Gambas class file

Private hPatient As FmPatientProfile
Private $NumForm As FmQuantiEntry
Private $Status As String
Private $UserRestrict As String[]
Private $dateReg As Date
Private $examGrpList As String[]
Private $ExamLst As String[]

Public Sub Form_Open()

  Dim hFmQuan1 As FmQuantiEntry
  Dim hFmQuan2 As FmQuantiEntry

  modGeneralMain.ArrangeEmbedForms(Me, Panel1, "Vertical")
  Me.Icon = Picture[modGeneralMain.$strLogo]

  hPatient = New FmPatientProfile(Me.Name, Frame1)
  hFmQuan1 = New FmQuantiEntry(txtsympval, pnlquantisyn)
  hFmQuan2 = New FmQuantiEntry(txtfinval, pnlquantiexam)
  modLabTest.DisplayDefaultTestUnit(rbsi, rbmetric)
  $ExamLst = modMedicine.FillClinicalSubClass("OutPatient")

  FillCustomFormMenu()
  FillCustomMenu()
  FillExamMenu()

  cmbmode.List = modBasic.$BillBillingMode
  cmbsympunit.List = ["Hours", "Days", "Weeks", "Months", "Years"]
  cmbsymdura.List = ["Left Side", "Right Side", "Both Side", "Episodes", "On/Off", "Present"]
  If modBasic.$ItemListFormat = "GridView" Then
  Else
    cmbfinding.List = modBasic.$ClinFindingComp
    cmbsymptom.List = modBasic.$ClinComplaintComp
  Endif
  $UserRestrict = modBasic.$ClinicDisableCompo
  $examGrpList = modFillContainer.GetListFromResult(modDatabase.$myConn.Exec("select distinct(fldgroupname) as col from tblgroupexam"))

  txthistory.DictionaryPath = modBasic.$dictPathList
  txtplan.DictionaryPath = modBasic.$dictPathList

End

Public Sub Form_Activate()

  If hPatient.txtencid.Text = "" Then
    hPatient.txtencid.SetFocus
  Endif

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub Form_Close()

  hPatient.Close
  modGeneralMain.RecordFormExit(Me)

End

Public Sub rbsi_Click()

  modSettings.SaveSettingsToFile("TestUnit/Default", "SI")

End

Public Sub rbmetric_Click()

  modSettings.SaveSettingsToFile("TestUnit/Default", "Metric")

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.F11 Then
    mnulab_Click()
  Else If Key.Code = Key.F12 Then
    mnupharm_Click()

  Else If Key.Code = Key.F1 Then
    If txtencid.Text Then
      cmbsymptom.SetFocus
    Endif
  Else If Key.Code = Key.F2 Then
    If txtencid.Text Then
      cmbfinding.SetFocus
    Endif
  Else If Key.Code = Key.F3 And If Key.Control Then
    TabPanel1.Index = 0
    Wait
    dcthelphistory_Click()
  Else If Key.Code = Key.F3 Then
    TabPanel1.Index = 0
    txthistory.RichText = modPatientGeneral.ShowSelectedHistory(Trim(txtencid.Text), "History of Illness")
    txthistory.SetFocus
  Else If Key.Code = Key.F4 Then
    txtpulse.SetFocus
  Else If Key.Code = Key.F5 Then
    btnallergy_Click()
  Else If Key.Code = Key.F6 Then
    tbndisease_Click()
  Else If Key.Code = Key.F7 Then
    TabPanel1.Index = 1
    ShowMedFluids()
    Wait
    grdfluid.Row = 0
  Else If Key.Code = Key.F8 Then
    TabPanel1.Index = 2
    txtplan.RichText = modPatientGeneral.ShowSelectedNotes(Trim(txtencid.Text), "Initial Planning")
    txtplan.SetFocus
  Else If Key.Code = Key.F8 And If Key.Control Then
    TabPanel1.Index = 2
    Wait
    dcthelpplan_Click()
  Else If Key.Code = Key["X"] And If Key.Control Then
    Me.Close()
  Else
    modGeneralmain.GoToNextControlTab()
  Endif

End

Public Sub TabPanel1_Click()

  If TabPanel1.Index = 0 Then
    txthistory.RichText = modPatientGeneral.ShowSelectedHistory(Trim(txtencid.Text), "History of Illness")
    txthistory.SetFocus
  Else If TabPanel1.Index = 1 Then
    ShowMedFluids()
    grdfluid.Row = 0
  Else If TabPanel1.Index = 2 Then
    txtplan.RichText = modPatientGeneral.ShowSelectedNotes(Trim(txtencid.Text), "Initial Planning")
    txtplan.SetFocus
  Endif

End

Public Sub BasicInfoPatient()

  txtencid.Text = hPatient.$PatientEncounter

  If txtencid.Text Then
    $Status = modPatient.CurrentAdmissionStatus(Trim(txtencid.Text))
    modGeneralMain.RecordPatientActivity("Patient Data", Me.Name, "EncounterID", Trim(txtencid.Text))
    ButtonControl()
    $dateReg = modPatient.GetRecordDate(Trim(txtencid.Text))
    Timer1.Enabled = True
    modBillings.GetBillingComboDefaultMode(cmbmode, Trim(txtencid.Text), modGeneralMain.compID)
    txthistory.RichText = modPatientGeneral.ShowSelectedHistory(Trim(txtencid.Text), "History of Illness")
    lsticdisease.List = modPathology.GetProvisionalDiagnosisList(Trim(txtencid.Text))
    lstallergy.List = modPathology.GetAllergyMedicineList(Trim(txtencid.Text), chkallergy.Value)
    ShowSymptomData()
    ShowEssentialExam()
    FillExamtable()
    modPatient.PopUpPatientForm(Trim(txtencid.Text), Me.Tag)
    txthistory.SetFocus
  Endif

End

Public Sub mnupatsearch_Click()

  hPatient.txtencid.Text = PatSearch("Encounter")

End

Private Sub ButtonControl()

  Dim xx As Boolean
  Dim xval As String

  xx = modPatient.EnableClinicForm($Status)
  ''complaints
  btnsympadd.Enabled = xx
  grdchiefsymptom.Enabled = xx
  ''history
  btnhistory.Enabled = xx
  btnplan.Enabled = xx
  ''iv fluids
  grdfluid.Enabled = xx
  grdfluiddata.Enabled = xx
  ''findings
  btnfinadd.Enabled = xx
  GridView1.Enabled = xx
  btnaddexamlist.Enabled = xx
  ''diagnosis
  tlbtndeldises.Enabled = xx
  btndismanual.Enabled = xx
  tbnsyndro.Enabled = xx
  tbndisease.Enabled = xx
  ''alergy
  tlbtndelallergy.Enabled = xx
  btnallergy.Enabled = xx
  ''lab
  mnulab.Enabled = xx
  ''radio
  mnuradioreq.Enabled = xx
  ''pharmacy
  mnupharm.Enabled = xx
  ''med product
  mnumedproduct.Enabled = xx
  ''demographics
  mnudemo.Enabled = xx
  ''images
  btnaddchart.Enabled = xx
  ''triage
  mnutriage.Enabled = xx
  ''vitals
  mnuvital.Enabled = xx
  Frame2.Enabled = xx
  ''minor procedure
  mnuminorproc.Enabled = xx
  ''equipments
  mnuequip.Enabled = xx
  ''vaccines
  mnuvaccine.Enabled = xx
  ''dosing
  mnupatdosing.Enabled = xx
  ''consultation
  mnuconsultplan.Enabled = xx
  ''major procedure
  mnumajor.Enabled = xx
  ''extra procedure
  mnuextprocedure.Enabled = xx
  ''monitoring
  mnumonitor.Enabled = xx
  ''outcome
  mnuoutcome.Enabled = xx

  xval = modBasic.$LockDiagnosisList
  If xval = "No" Then
  Else
    btndismanual.Enabled = False
  Endif

  If $UserRestrict Then
    RestrictUserAccess()
  Endif

End

Public Sub mnuwaitconsult_Click()

  hPatient.GetF2Code()

End

Public Sub mnulastEncID_Click()

  hPatient.txtencid.Text = modSettings.ShowLogValues("LastValue/Encounter")

End

Public Sub mnupatlock_Click()

  If txtencid.Text Then
    modGeneralMain.LockPatientActivity(Me.Name, Trim(txtencid.Text))
  Endif

End

Public Sub Timer1_Timer()

  Dim xdely As Integer

  xdely = DateDiff($dateReg, Now(), gb.Second)
  LCDLabel1.Text = modDate.GetSecondToTimeForm(xdely)

End

''--------------------------------------------- icd disease --------------------------------------------------
Public Sub tlbtndeldises_Click()

  Dim res As Result

  If txtencid.Text Then
    If lsticdisease.Text Then
      If Message.Question(("Are you sure?"), ("No"), ("Yes")) = 2 Then
        res = modDatabase.$myConn.Edit("tblpatfindings", "fldcode=&1 and fldencounterval=&2 and fldtype=&3 and fldsave=&4", lsticdisease.Text, Trim(txtencid.Text), "Provisional Diagnosis", True)
        res["fldsave"] = False
        res["xyz"] = False
        res.Update
        lsticdisease.List = modPathology.GetProvisionalDiagnosisList(Trim(txtencid.Text))
        Balloon.Delete(("Information deleted"), tlbtndeldises)
        Balloon.Delay = modBasic.$BalloonDelay
      Endif
    Endif
  Endif

End

Public Sub tbndisease_Click()

  Dim sName As String[]

  If txtencid.Text Then
    sName = ICDTree(modPathology.ICDCodePath(), "Disease")
    If sName Then
      If sName[1] And If sName[0] Then
        modPatientGeneral.AddPatientFindings("Provisional Diagnosis", Trim(txtencid.Text), sName[1], sName[0])
        lsticdisease.List = modPathology.GetProvisionalDiagnosisList(Trim(txtencid.Text))
      Endif
    Endif
  Endif

End

Public Sub tbnsyndro_Click()

  Dim xx As String[]

  If txtencid.Text Then
    xx = modPathology.DiagnosisRule("Provisional Diagnosis", Trim(txtencid.Text))
    If xx Then
      If xx[1] And If xx[0] Then
        modPatientGeneral.AddPatientFindings("Provisional Diagnosis", Trim(txtencid.Text), xx[1], xx[0])
        If modSettings.ShowSettingFromFIle("ClinicalRule/DiagnosisParam_History") = "Yes" Then
          txthistory.Text = txthistory.Text & gb.NewLine & xx[2]
        Endif
        lsticdisease.List = modPathology.GetProvisionalDiagnosisList(Trim(txtencid.Text))
      Endif
    Endif
  Endif

End

Public Sub btndismanual_Click()

  Dim xx As String

  If txtencid.Text Then
    xx = InputBox(("Enter custom Provisional Diagnosis"), ("Provisional Diagnosis"), "")
    If xx Then
      modPatientGeneral.AddPatientFindings("Provisional Diagnosis", Trim(txtencid.Text), xx, "Other")
      lsticdisease.List = modPathology.GetProvisionalDiagnosisList(Trim(txtencid.Text))
    Endif
  Endif

End

Public Sub btnregimen_Click()

  Dim hForm As FmDrugDose

  If lsticdisease.Text Then
    hForm = New FmDrugDose(Trim(txtencid.Text), lsticdisease.Text)
    hForm.ShowModal
  Endif

End

