Public Sub mnucomptest_Click()

  Dim res As Result
  Dim xx As String[]
  Dim yy As String[]
  Dim hForm As FmMultiChart

  If txtencid.Text Then
    yy = New String[]

    res = modDatabase.$myConn.Exec("select distinct(fldtestid) as col from tblpatlabtest where fldencounterval=&1 and fldtest_type=&2 and (fldstatus=&3 or fldstatus=&4)", Trim(txtencid.Text), "Quantitative", "Reported", "Verified")
    xx = modFillContainer.GetListFromResult(res)
    If xx.Count Then
      xx.Sort()
      hForm = New FmMultiChart(Trim(txtencid.Text), yy, xx, modLabTest.GetTestUnitFromButton(rbsi, rbmetric))
      modHelpVariable.AddNewFormToWorkspace(hForm)
    Endif
  Endif

End

Public Sub mnulablocal_Click()

  Dim xPath As String
  Dim xpatno As String

  If txtencid.Text Then
    xpatno = modPatient.GetPatientNoByEnc(Trim(txtencid.Text))
    If modPatient.GetPatPassCheck(modDatabase.$myConn, xpatno) = True Then
