Public Sub btnfinadd_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    btnfinadd_Click()
    cmbfinding.SetFocus
  Endif

End

Public Sub btnaddexamlist_Click()

  Dim hForm As FmEnterMultiExam
  Dim res As Result
  Dim asx As String[]
  Dim xval As String

  If txtencid.Text Then
    xval = InputListView(("Select Examination Group"), "Examination", $examGrpList)
    If xval Then
      asx = New String[]
      res = modDatabase.$myConn.Exec("select fldexamid from tblgroupexam where fldgroupname=&1", xval)
      If res.Available Then
        For Each res
          asx.Add(res["fldexamid"])
        Next
        hForm = New FmEnterMultiExam(xval, Trim(txtencid.Text), "OPD Examination", asx)
        hForm.ShowModal
        FillExamtable()
        ShowEssentialExam()
      Endif
    Endif
  Endif

End

Public Sub btnfinadd_Click()

  Dim sType As String
  Dim abn As Boolean
  Dim xsys As String

  If txtencid.Text Then
    If cmbfinding.Text Then
      sType = modFixClinic.GetExaminationType(cmbfinding.Text)
      xsys = modFixClinic.SysConstFromGetExamID(cmbfinding.Text)
      If sType = "Quantitative" Then
        pnlquantiexam.Visible = False
        If txtfindmin.Value > txtfinval.Value Or If txtfindmax.Value < txtfinval.Value Then
          abn = True
        Else
          abn = False
        Endif
        modClinic.AddQuantiData(Trim(txtencid.Text), "", cmbfinding.Text, txtfinval.Value, abn, "OPD Examination", xsys)
      Else
        modClinic.AddClinicExam(Trim(txtencid.Text), "", cmbfinding.Text, txtfinding.Text, txtfinval.Value, False, "OPD Examination", xsys, "Regular")
      Endif
      FillExamtable()
      ShowEssentialExam()
      cmbfinding.Text = ""
      txtfinding.Text = ""
      txtfinding.Clear()
      txtfinval.Value = 0
      txtfinval.Tag = ""
    Endif
  Endif

End

Public Sub FillExamtable()

  Dim Column As Integer
  Dim fld As ResultField
  Dim res As Result

  res = modDatabase.$myConn.Exec("select fldid,fldtype,fldhead,fldabnormal,fldid,fldid,fldtime,fldsave,fldencounterval from tblpatientexam where fldencounterval=&1 and fldinput=&2 and fldsave=&3", Trim(txtencid.Text), "OPD Examination", True)
  GridView1.Clear
  GridView1.Columns.Count = res.Fields.Count
  GridView1.Rows.Count = res.Count

  For Each res
    Column = 0
    For Each fld In res.Fields
      modGeneralMain.GridExplicitDecoration(GridView1, res.Index, Column)
      If Column = 3 Then
        GridView1[res.Index, Column].Picture = Picture[modGridView.GetGridIcon(res[fld.Name])]
        GridView1[res.Index, Column].Text = ""
      Else If Column = 4 Then
        GridView1[res.Index, Column].RichText = modClinic.GetExamValueString(Trim(txtencid.Text), res["fldid"], False)
      Else If Column = 5 Then
        GridView1[res.Index, Column].Picture = Picture["icon:/small/cancel"]
        GridView1[res.Index, Column].Text = ""
      Else If Column = 6 Then
        GridView1[res.Index, Column].Text = modReportVar.GetDateTimeReport(res["fldtime"], gb.GeneralDate)
      Else
        GridView1[res.Index, Column].Text = res[fld.Name]
      Endif
      Column = Column + 1
    Next
  Next
  GridView1.Row = 0

  With GridView1
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 1
    .Columns[1].Width = 1
    .Columns[2].Width = 150 * modBasic.$AppWidthRatio
    .Columns[3].Width = 20
    .Columns[4].Width = 200 * modBasic.$AppWidthRatio
    .Columns[5].Width = 25 * modBasic.$AppWidthRatio
    .Columns[6].Width = 150 * modBasic.$AppWidthRatio
    .Columns[7].Width = 1
    .Columns[8].Width = 1
    .Columns[2].Text = "Examination"
    .Columns[4].Text = "Observation"
    .Columns[6].Text = "ReportTime"
  End With

End

Public Sub GridView1_Click()

  Dim hForm2 As FmEnterMultiple
  Dim res As Result
  Dim opid As Long[]
  Dim option As String[]
  Dim opx As String[]
  Dim opt As String[]
  Dim Row As Integer
  Dim yyy As String[]
  Dim xx As String

  Dim xquantival As Variant[]
  Dim yqualival As Variant[]
  Dim xlimit As Float[]
  Dim xType As String
  Dim xdate As Date

  pnlquantiexam.Visible = False
  Row = GridView1.Row
  If GridView1.Column = 4 Then
    If GridView1[GridView1.Row, 1].Text = "Qualitative" Then
      xType = modFixClinic.GetExamtOptionType(GridView1[GridView1.Row, 2].Text)
      If modClinic.GetSubExamBool(GridView1[GridView1.Row, 0].Text) = False Then
        If xType = "Fixed Components" Then
          yyy = modFixClinic.GetSubExamArray(GridView1[GridView1.Row, 2].Text)     'modFillContainer.GetListFromResult(modDatabase.$myConn.Exec("select fldsubexam as col from tblexamquali where fldexamid=&1", GridView1[GridView1.Row, 2].Text))
          If yyy.Count Then
            modClinic.InsertExamSubExam(GridView1[GridView1.Row, 8].Text, GridView1[GridView1.Row, 0].Text, yyy)
          Endif
        Endif
      Endif

      res = modDatabase.$myConn.Exec("select fldid,fldsubtexam,fldreport,fldtanswertype from tblpatientsubexam where fldheadid=&1", GridView1[GridView1.Row, 0].Text)
      If res.Available = False Then
        If xType = "Clinical Scale" Then
          yqualival = modExamOption.GetClinScalePopUp("Exam", GridView1[GridView1.Row, 2].Text)
          If yqualival Then
            modClinic.UpdateQualiQuantiData(GridView1[GridView1.Row, 0].Text, yqualival[1], CFloat(yqualival[0]), False)
          Endif
        Else If xType = "Left and Right" Then
          yqualival = CLeftRight(GridView1[GridView1.Row, 2].Text, GridView1[GridView1.Row, 4].RichText)
          If yqualival Then
            modClinic.UpdateClinicQualiData(GridView1[GridView1.Row, 0].Text, modString.GetLefRightJSON(yqualival[0], yqualival[1]), yqualival[2], "")
          Endif
        Else If xType = "Date Time" Then
          xdate = GetDateValue(GridView1[GridView1.Row, 2].Text, ("Select Date Time"), CDate(GridView1[GridView1.Row, 4].RichText))
          If xdate Then
            modClinic.UpdateClinicQualiData(GridView1[GridView1.Row, 0].Text, CStr(xdate), False, "")
          Endif
        Else
          yqualival = GetQualiValues(GridView1[GridView1.Row, 2].Text, GridView1[GridView1.Row, 4].RichText, "Exam")
          If yqualival Then
            modClinic.UpdateClinicQualiData(GridView1[GridView1.Row, 0].Text, yqualival[0], yqualival[1], yqualival[2])
          Endif
        Endif

      Else If res.Available = True Then
        opid = New Long[]
        option = New String[]
        opx = New String[]
        opt = New String[]
        For Each res
          opid.Add(res!fldid)
          option.Add(res!fldtanswertype)
          opx.Add(res!fldsubtexam)
          opt.Add(res!fldreport)
        Next
        opx.Add("Final Impression")
        opt.Add(GridView1[GridView1.Row, 4].RichText)
        opid.Add(0)
        option.Add("No Selection")
        hForm2 = New FmEnterMultiple(GridView1[GridView1.Row, 0].Text, "Exam", GridView1[GridView1.Row, 2].Text, opx, opt, opid, option, "")
        hForm2.ShowModal
      Endif

    Else If GridView1[GridView1.Row, 1].Text = "Quantitative" Then
      xlimit = modClinic.GetBothQuantiExamVal(GridView1[GridView1.Row, 2].Text, GridView1[GridView1.Row, 8].Text)
      xquantival = GetQuantiValues("Exam", Trim(txtencid.Text), GridView1[GridView1.Row, 2].Text, xlimit[0], xlimit[1], modClinic.GetExamValueByID(GridView1[GridView1.Row, 0].Text))                                       '
      If xquantival Then
        modClinic.UpdateClinicQuantiData(GridView1[GridView1.Row, 0].Text, xquantival[0], xquantival[1])
      Endif

    Endif
    FillExamtable()

  Else If GridView1.Column = 3 Then
    xx = InputCombo("Select Flag for the observation", "Change Flag", ["Normal", "Abnormal"], modGridView.GetIconValue(GridView1[GridView1.Row, 3].Picture), True)
    If xx Then
      modClinic.UpdateExamFlag(GridView1[GridView1.Row, 0].Text, xx)
      FillExamtable()
    Endif

  Else If GridView1.Column = 5 Then
    If Message.Question(("Are you sure?"), ("No"), ("Yes")) = 2 Then
      res = modDatabase.$myConn.Edit("tblpatientexam", "fldid=&1", GridView1[GridView1.Row, 0].Text)
      If modGeneral.AllowClinicalEdit(res["flduserid"]) = True Then
        res["fldsave"] = False
        res["flduserid"] = modGeneralMain.$lbluser
        res.Update
        FillExamtable()
      Else
        Message.Warning("Authorization with " & res["flduserid"], ("OK"))
      Endif
    Endif

  Endif
  GridView1.Row = Row

End

''------------------------------------- chief symptom ------------------------------------------------------
Public Sub cmbsymptom_GotFocus()

  Dim xlist As String[]

  txtsympval.Value = 0
  txtsympval.Tag = ""
  If modBasic.$ItemListFormat = "GridView" Then
    If modSettings.ShowSettingFromFIle("ClinicForms/CategoryGridView") = "Yes" Then
      xlist = modBasic.$ClinComplaintCompGrouped
      If xlist.Count Then
        cmbsymptom.Enabled = False
        cmbsymptom.Text = GridViewGroup("Select Presenting Complaints", xlist)
        cmbsymptom.Enabled = True
        txtsympval.SetFocus
      Endif
    Else
      xlist = modBasic.$ClinComplaintComp
      If xlist.Count Then
        cmbsymptom.Enabled = False
        cmbsymptom.Text = GridViewNew("Select Presenting Complaints", xlist, modMisc.LockBoolean(modBasic.$LockSymptomList))
        cmbsymptom.Enabled = True
        txtsympval.SetFocus
      Endif
    Endif
  Endif

End

