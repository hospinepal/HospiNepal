    yy = Split(modSettings.ShowSettingForReport(mnucustform9.Tag & "/" & "Form_Test"), ";")
    hForm = New FmMultiChart(Trim(txtencid.Text), xx, yy, modLabTest.GetTestUnitFromButton(rbsi, rbmetric))
    modHelpVariable.AddNewFormToWorkspace(hForm)
  Endif

End

