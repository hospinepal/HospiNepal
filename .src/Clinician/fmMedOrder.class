' Gambas class file

Private $encid As String
Private $status As String
Private $sBillMode As String
Private $Dept As String
Private $rData As Result
Private $aMyFields As String[]
Private $NumForm As FmQuantiEntry

Private $sType As String
Private $HideErr As Boolean
Private $HideDos As Boolean

Public Sub _new(encid As String, sStatus As String, sBillMode As String, sDept As String)

  $encid = encid
  $status = sStatus
  $sBillMode = sBillMode
  $Dept = sDept

End

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me, "False")

  cmbroute.List = modMedicine.InpatientRoute()
  cmbroute.Add("Group")
  cmbfreq.List = modMedicine.FrequencyCombo()
  modStock.DisplayDefaultDispensingMode(rbrand, rbgeneric)
  modSettings.ShowCheckBox(chkeypad, "Pharmacy/DisplayKeyPad")

  txtpatientname.Text = modPatient.GetPatientNameByEnc($encid)
  txtgender.Text = modPatient.GetPatientSex($encid)
  txtpatientaddress.Text = modPatient.GetPatientAddressByEnc($encid)
  txtpatientcontact.Text = modPatient.GetLocationSetting($encid)
  cmbdiagnosis.List = modFillContainer.GetListFromResult(modDatabase.$myConn.Exec("select distinct(fldcode) as col from tblpatfindings where fldencounterval=&1 and (fldtype=&2 or fldtype=&3) and fldsave=&4", $encid, "Final Diagnosis", "Provisional Diagnosis", True))
  ButtonControl()
  rbvalue.Value = True
  rbin.Value = True
  rbsurg.Value = True
  ShowRunningMedicine()

End

Private Sub ButtonControl()

  Dim xx As Boolean

  xx = modPatient.EnableClinicForm($Status)
  GridView3.Enabled = xx
  GridView4.Enabled = xx

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.Esc Then
    Me.Close
  Else If Key.Code = Key.F1 Then
    TabPanel1.Index = 0
    ShowRunningMedicine()
  Else If Key.Code = Key.F2 Then
    TabPanel1.Index = 1
  Else If Key.Code = Key.F3 Then
    TabPanel1.Index = 2
    ShwDefaultMode()
    FillDosingGrid()
    BlankDosingBox()
    cmbroute.SetFocus
  Else If Key.Code = Key.F4 Then
    TabPanel1.Index = 3
    ShowCurrStockGrid()
    ShowUsedGridViewList()
    txtname.SetFocus
  Else
    modGeneralmain.GoToNextControlTab()
  Endif

End

Public Sub TabPanel1_Click()

  If TabPanel1.Index = 0 Then
    ShowRunningMedicine()
  Else If TabPanel1.Index = 1 Then
  Else If TabPanel1.Index = 2 Then
    ShwDefaultMode()
    FillDosingGrid()
    BlankDosingBox()
    cmbroute.SetFocus
  Else If TabPanel1.Index = 3 Then
    ShowCurrStockGrid()
    ShowUsedGridViewList()
    txtname.SetFocus
  Endif

End

Private Sub BlankDosingBox()

  cmbroute.Text = ""
  cmbmedicine.Text = ""
  cmbfreq.Text = ""
  txtdose.Value = 0
  txtday.Value = 0
  txtday.Tag = ""
  txtqty.Value = 0
  txtqty.Tag = ""
  $HideErr = False
  $HideDos = False

End

Public Sub chkeypad_Click()

  modSettings.EnterCheckSetting(chkeypad, "Pharmacy/DisplayKeyPad")
  ShowKeyPad()

End

Private Sub ShowKeyPad()

  If chkeypad.Value = True Then
    pnlquanti.Visible = True
  Else If chkeypad.Value = False Then
    pnlquanti.Visible = False
  Endif

End

''------------------------------ Request ---------------------------------
Public Sub rbgeneric_Click()

  modSettings.SaveSettingsToFile("BrandOrGeneric/Dispensing", "Generic")

End

Public Sub rbrand_Click()

  modSettings.SaveSettingsToFile("BrandOrGeneric/Dispensing", "Brand")

End

Private Sub ShwDefaultMode()

  Dim xval As String

  xval = modSettings.ShowSettingFromFIle("ClinicForms/RestrictToHospitalInventory")
  If xval = "Yes" Then
    $sType = "Restict"
  Else
    $sType = "Free"
  Endif

End

Private Function GetBrandGenerricType() As String

  Dim brandOrGeneric As String

  If rbrand.Value = True Then
    brandOrGeneric = "Brand"
  Else
    brandOrGeneric = "Generic"
  Endif
  Return brandOrGeneric

End

Public Sub cmbroute_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbroute)
  modFillContainer.RestrictComboToContent(cmbroute)

End

Public Sub cmbroute_Click()

  cmbmedicine.Clear
  cmbmedicine.Text = ""
  txtdose.Enabled = True
  cmbfreq.Enabled = True
  txtday.Enabled = True

End

Public Sub cmbmedicine_GotFocus()

  Dim res As Result
  Dim xlist1 As String[]
  Dim xlist As String[]

  If Not cmbroute.Text Then
    cmbroute.SetFocus

  Else If cmbroute.Text Then
    If cmbroute.Text = "Group" Then
    Else
      If Not cmbmedicine.Text Then

        If modBasic.$ItemListFormat = "GridView" Then
          txtdose.Tag = "Auto"
          txtdose.Parent.Tag = "Auto"

          If cmbroute.Text = "suture" Or If cmbroute.Text = "msurg" Or If cmbroute.Text = "ortho" Or If cmbroute.Text = "extra" Then
            res = modStock.ItemListForPurchaseResult(cmbroute.Text, GetBrandGenerricType(), "")
            cmbmedicine.Enabled = False
            cmbmedicine.Text = GridViewNew("Select Particulars", modFillContainer.GetListFromResult(res), False)
            cmbmedicine.Enabled = True
          Else
            If $sType = "Free" Then
              res = modStock.ItemListForPurchaseResult(cmbroute.Text, GetBrandGenerricType(), "")
            Else If $sType = "Restict" Then
              res = modStock.FillMedicinesPrescribingComboResult(cmbroute.Text, GetBrandGenerricType(), "")
            Endif
            If modSettings.ShowSettingFromFIle("ClinicForms/CategoryGridView") = "Yes" Then
              xlist1 = modFillContainer.GetListFromResult(res)
              If xlist1 Then
                xlist = modMedConstant.GetStockIDWithCategory(xlist1)
                If xlist Then
                  cmbmedicine.Enabled = False
                  cmbmedicine.Text = GridViewGroup("Select Medicine", xlist)
                  cmbmedicine.Enabled = True
                Endif
              Endif
            Else
              cmbmedicine.Enabled = False
              cmbmedicine.Text = GridViewNew("Select Particulars", modFillContainer.GetListFromResult(res), False)
              cmbmedicine.Enabled = True
            Endif
          Endif

          If Not cmbmedicine.Text Then
            txtdose.SetFocus
          Endif

        Endif

      Endif
    Endif

  Endif

End

Public Sub cmbmedicine_KeyRelease()

  If cmbroute.Text = "suture" Or If cmbroute.Text = "msurg" Or If cmbroute.Text = "ortho" Or If cmbroute.Text = "extra" Then
    modStock.ItemListForPurchase(cmbroute.Text, cmbmedicine, "Generic")
  Else If cmbroute.Text = "Group" Then
    modStock.MedicineGroupItem(cmbmedicine)
  Else
    If $sType = "Free" Then
      modStock.ItemListForPurchase(cmbroute.Text, cmbmedicine, GetBrandGenerricType())
    Else If $sType = "Restict" Then
      modStock.FillMedicinesPrescribingCombo(cmbroute.Text, cmbmedicine, GetBrandGenerricType())
    Endif
  Endif

End

Public Sub txtdose_GotFocus()

  Dim hForm As FmDiseaseDose

  If cmbmedicine.Text Then
    If modStock.GetComboControl(cmbroute.Text, cmbmedicine.Text, rbgeneric, rbrand, modDatabase.$medConn) = False Then
      cmbmedicine.Text = ""
      Balloon.Warning(("Item not listed"), cmbmedicine)
      Balloon.Delay = modBasic.$BalloonDelay
      cmbroute.SetFocus
    Else

      If cmbroute.Text = "suture" Or If cmbroute.Text = "msurg" Or If cmbroute.Text = "ortho" Or If cmbroute.Text = "extra" Or If cmbroute.Text = "Group" Then
        txtdose.Enabled = False
        cmbfreq.Enabled = False
        txtday.Enabled = False
        txtqty.SetFocus

      Else
        If rbrand.Value = True Then
          cmbmedicine.Text = modMedConstant.ConvertBrandToGeneric(cmbroute.Text, cmbmedicine.Text)
        Endif
        txtdose.Enabled = True
        cmbfreq.Enabled = True
        txtday.Enabled = True

        If modBasic.$MedDoseRecommend = "Yes" Then
          txtdose.Value = modMedDosing.RecommendedDoseDrug($encid, cmbmedicine.Text)
          cmbfreq.Text = modMedDosing.RecommendedFrequencyDrug($encid, cmbmedicine.Text)
        Endif

        If $HideDos = False Then
          If modBasic.$MedDiseaseDose = "Yes" Then
            $HideDos = True
            hForm = New FmDiseaseDose($encid, cmbroute.Text, cmbmedicine.Text, txtdose, cmbfreq, txtday)
            hForm.ShowModal
          Endif
        Endif

        ClearNumPad()
        ShowKeyPad()
        $NumForm = New FmQuantiEntry(txtdose, pnlquanti)

      Endif

    Endif
  Endif

End

Public Sub txtdose_KeyRelease()

  Dim xx As String
  Dim brandOrGeneric As String

  txtdose.Tag = ""
  txtdose.Parent.Tag = ""

  If Key.Code = Key.Right Then
    If cmbroute.Text And If cmbmedicine.Text Then
      If cmbroute.Text = "suture" Or If cmbroute.Text = "msurg" Or If cmbroute.Text = "ortho" Or If cmbroute.Text = "extra" Then
      Else
        If rbrand.Value = True Then
          brandOrGeneric = "Brand"
        Else
          brandOrGeneric = "Generic"
        Endif
        xx = CAlternative(cmbroute.Text, cmbmedicine.Text, brandOrGeneric)
        If xx Then
          cmbmedicine.Text = xx
        Endif

      Endif
    Endif
  Endif

End

Public Sub cmbfreq_GotFocus()

  If modBasic.$ItemListFormat = "GridView" Then
    If Not cmbfreq.Text Then
      cmbfreq.Popup
    Endif
  Endif

End

Public Sub cmbfreq_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbfreq)
  modFillContainer.RestrictComboToContent(cmbfreq)
  If Key.Code = Key.Down Then
    $HideErr = True
  Endif

End

Public Sub cmbfreq_Click()

  $HideErr = False

End

Public Sub txtday_GotFocus()

  ClearNumPad()
  ShowKeyPad()
  $NumForm = New FmQuantiEntry(txtday, pnlquanti)

End

Public Sub txtday_LostFocus()

  If txtdose.Value And If cmbfreq.Text And If txtday.Value Then
    txtqty.Value = Ceil(modMedConstant.GetQuantityDosing(cmbmedicine.Text, txtdose.Value, cmbfreq.Text, txtday.Value))
  Endif

End

Public Sub txtqty_GotFocus()

  ClearNumPad()
  ShowKeyPad()
  $NumForm = New FmQuantiEntry(txtqty, pnlquanti)

  If txtdose.Value And If cmbfreq.Text Then
    If Not txtday.Value Then
      txtday.SetFocus
    Endif
  Endif

End

Public Sub chksave_Click()

  If cmbroute.Text And If cmbmedicine.Text And If txtqty.Value Then
    EnterDosingRecord()
    ClearNumPad()
    pnlquanti.Visible = False
    cmbroute.SetFocus
  Endif '

End

Public Sub chksave_GotFocus()

  chksave_Click()

End

Public Sub chksave_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    chksave_Click()
  Endif

End

Private Sub EnterDosingRecord()

  Dim txprescriber As String
  Dim txpresno As String
  Dim res As Result
  Dim xdose As Float
  Dim xtax As Float
  Dim xdisc As Float
  Dim itemtype As String

  If cmbroute.Text And If cmbmedicine.Text Then

    If cmbroute.Text = "suture" Or If cmbroute.Text = "msurg" Or If cmbroute.Text = "ortho" Or If cmbroute.Text = "extra" Then
      itemtype = modNonMedical.GetBillItemCategoryFromCombo(cmbroute.Text)
      xtax = modNonMedical.ShowTaxValues(itemtype, cmbmedicine.Text)
      xdisc = modNonMedical.DiscPercentForItem($encid, itemtype, cmbmedicine.Text)
      modPharmacy.InsertNonMedDosingEntry($encid, cmbroute.Text, cmbmedicine.Text, txtqty.Value, $status, 0, xtax, xdisc, "Request", $Dept)

    Else If cmbroute.Text = "Group" Then
      res = modDatabase.$myConn.Exec("select fldroute,flditem,flddose,flddoseunit,fldfreq,fldday,fldqty,fldstart from tblproductgroup where fldmedgroup=&1", cmbmedicine.Text)
      If res.Available Then
        For Each res

          itemtype = modNonMedical.GetBillItemCategoryFromCombo(res!fldroute)
          xtax = modNonMedical.ShowTaxValues(itemtype, res!flditem)
          xdisc = modNonMedical.DiscPercentForItem($encid, itemtype, res!flditem)
          If res!fldroute = "suture" Or If res!fldroute = "msurg" Or If res!fldroute = "ortho" Or If res!fldroute = "extra" Then
            modPharmacy.InsertNonMedDosingEntry($encid, res!fldroute, res!flditem, res!fldqty * txtqty.Value, $status, res!fldstart, xtax, xdisc, "Request", $Dept)
          Else
            xdose = modMedDosing.GetDoseInMg(res!flddose, res!flddoseunit, $encid)
            If xdose Then
              If modMedConstant.GetNarcoticType(res!flditem) = "Yes" Then
                txprescriber = MedicalSelectedUser(("Select Narcotic Prescriber"), modBasic.$IPConsultUserList)
                If txprescriber Then
                  txpresno = modGeneral.GetPrescriberCodeFromName(txprescriber)
                Endif
              Else
                txprescriber = ""
                txpresno = ""
              Endif
              modPharmacy.InsertDosingEntry($encid, res!fldroute, res!flditem, xdose, res!fldfreq, res!fldday, res!fldqty * txtqty.Value, $status, txprescriber, txpresno, res!fldstart, xtax, xdisc, "Request", $Dept)
            Endif
          Endif

        Next
      Endif

    Else
      If modMedConstant.GetNarcoticType(cmbmedicine.Text) = "Yes" Then
        txprescriber = MedicalSelectedUser(("Select Narcotic Prescriber"), modBasic.$IPConsultUserList)
        If txprescriber Then
          txpresno = modGeneral.GetPrescriberCodeFromName(txprescriber)
        Endif
      Else
        txprescriber = ""
        txpresno = ""
      Endif
      itemtype = modNonMedical.GetBillItemCategoryFromCombo(cmbroute.Text)
      xtax = modNonMedical.ShowTaxValues(itemtype, cmbmedicine.Text)
      xdisc = modNonMedical.DiscPercentForItem($encid, itemtype, cmbmedicine.Text)
      modPharmacy.InsertDosingEntry($encid, cmbroute.Text, cmbmedicine.Text, txtdose.Value, cmbfreq.Text, txtday.Value, txtqty.Value, $status, txprescriber, txpresno, 0, xtax, xdisc, "Request", $Dept)                     '
    Endif

  Endif
  BlankDosingBox()
  FillDosingGrid()

End

Private Sub FillDosingGrid()

  Dim sql As String
  Dim Column As Integer
  Dim fld As ResultField
  Dim res As Result

  sql = "select fldid,fldstarttime,fldroute,flditem,flddose,fldfreq,flddays,fldqtydisp,flduserid_order,fldid,fldid,fldstarttime from tblpatdosing where fldencounterval=&1 and fldsave_order=&2 and fldstatus=&3 and fldorder=&4 and fldcurval=&5"                                                   ''
  res = modDatabase.$myConn.Exec(sql, $encid, False, $status, "Request", "Continue")

  GridView1.Clear
  GridView1.Columns.Count = res.Fields.Count
  GridView1.Rows.Count = res.Count

  For Each res
    Column = 0
    For Each fld In res.Fields
      modGeneralMain.GridExplicitDecoration(GridView1, res.Index, Column)
      If Column = 1 Then
        GridView1[res.Index, Column].Text = modReportVar.GetDateTimeReport(res["fldstarttime"], gb.GeneralDate)
      Else If Column = 9 Then
        GridView1[res.Index, Column].Picture = Picture["icon:/small/cancel"]
        GridView1[res.Index, Column].Text = ""
      Else If Column = 10 Then
        GridView1[res.Index, Column].Picture = Picture["icon:/small/print"]
        GridView1[res.Index, Column].Text = ""
      Else
        GridView1[res.Index, Column].Text = res[fld.Name]
      Endif
      Column = Column + 1
    Next
  Next
  GridView1.Row = 0

  With GridView1
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 1
    .Columns[1].Width = 150 * modBasic.$AppWidthRatio
    .Columns[2].Width = 75 * modBasic.$AppWidthRatio
    .Columns[3].Width = 275 * modBasic.$AppWidthRatio
    .Columns[4].Width = 50 * modBasic.$AppWidthRatio
    .Columns[5].Width = 50 * modBasic.$AppWidthRatio
    .Columns[6].Width = 40 * modBasic.$AppWidthRatio
    .Columns[7].Width = 40 * modBasic.$AppWidthRatio
    .Columns[8].Width = 1
    .Columns[9].Width = 25 * modBasic.$AppWidthRatio
    .Columns[10].Width = 25 * modBasic.$AppWidthRatio
    .Columns[11].Width = 1

    .Columns[1].Text = "StartDate"
    .Columns[2].Text = "Route"
    .Columns[3].Text = "Particulars"
    .Columns[4].Text = "Dose"
    .Columns[5].Text = "Freq"
    .Columns[6].Text = "Day"
    .Columns[7].Text = "QTY"
  End With

End

Public Sub GridView1_Click()

  Dim xval As Float
  Dim yval As String
  Dim Column As Integer
  Dim Row As Integer
  Dim res As Result
  Dim xdate As Date
  Dim hClabel As CLabelSize

  Row = GridView1.Row
  Column = GridView1.Column
  If GridView1.Column = 1 Then
    If modGeneral.AllowClinicalEdit(GridView1[GridView1.Row, 8].Text) = True Then
      xdate = GetDateValue(("Select Start Date for this medicine"), GridView1[GridView1.Row, 3].Text, GridView1[GridView1.Row, 11].Text)
      If xdate Then
        modPharmacy.UpdateStartBefDispensing(GridView1[GridView1.Row, 0].Text, xdate)
        FillDosingGrid()
      Endif
    Endif

  Else If GridView1.Column = 4 Then
    If modGeneral.AllowClinicalEdit(GridView1[GridView1.Row, 8].Text) = True Then
      xval = InputValue(GridView1[GridView1.Row, 3].Text, ("Change Value"), GridView1[GridView1.Row, 4].Text)
      If xval Then
        modPharmacy.UpdateDoseBefDispensing(GridView1[GridView1.Row, 0].Text, xval)
        FillDosingGrid()
      Endif
    Endif

  Else If GridView1.Column = 5 Then
    If modGeneral.AllowClinicalEdit(GridView1[GridView1.Row, 8].Text) = True Then
      yval = InputCombo(GridView1[GridView1.Row, 3].Text, ("Change Value"), modMedicine.FrequencyCombo(), GridView1[GridView1.Row, 5].Text, True)
      If yval Then
        modPharmacy.UpdateFreqBefDispensing(GridView1[GridView1.Row, 0].Text, yval)
        FillDosingGrid()
      Endif
    Endif

  Else If GridView1.Column = 6 Then
    If modGeneral.AllowClinicalEdit(GridView1[GridView1.Row, 8].Text) = True Then
      xval = InputValue(GridView1[GridView1.Row, 3].Text, ("Change Value"), GridView1[GridView1.Row, 6].Text)
      If xval Then
        modPharmacy.UpdateDaysBefDispensing(GridView1[GridView1.Row, 0].Text, xval)
        FillDosingGrid()
      Endif
    Endif

  Else If GridView1.Column = 7 Then
    xval = InputValue(GridView1[GridView1.Row, 3].Text, ("Change Value"), GridView1[GridView1.Row, 7].Text)
    modPharmacy.UpdateQTYBefDispensing(GridView1[GridView1.Row, 0].Text, xval)
    FillDosingGrid()

  Else If GridView1.Column = 9 Then
    If Message.Question(("Are you sure?"), ("No"), ("Yes")) = 2 Then
      res = modDatabase.$myConn.Edit("tblpatdosing", "fldid=&1 and fldsave_order=&2", GridView1[GridView1.Row, 0].Text, False)
      If modGeneral.AllowClinicalEdit(res["flduserid_order"]) = True Then
        modDatabase.$myConn.Delete("tblpatdosing", "fldid=&1 and fldsave_order=&2", GridView1[GridView1.Row, 0].Text, False)
      Else
        res["fldcurval"] = "Cancelled"
        res["flduserid_order"] = modGeneralMain.$lbluser
        res["xyz"] = False
        res.Update
      Endif
      FillDosingGrid()
    Endif

  Else If GridView1.Column = 10 Then
    hClabel = New CLabelSize(GridView1[GridView1.Row, 0].Text, GetLabelMode())
    modPrint.PrintPopUp(CStr(GridView1[GridView1.Row, 0].Text), hClabel.LabelPath(), "LabelSize")

  Else
    modGridView.CheckUncheckGrid(modDatabase.$myConn, GridView1, 8, "fldlabel", "fldid", "tblpatdosing", GridView1[GridView1.Row, 0].Text)
  Endif
  GridView1.Row = Row
  GridView1.Column = Column

End

Private Function GetLabelMode() As String

  Dim xx As String

  If rbout.Value = True Then
    xx = "Outpatient"
  Else If rbin.Value = True Then
    xx = "Inpatient"
  Else If rbasep.Value = True Then
    xx = "Aseptic"
  Endif

  Return xx

End

Private Sub ClearNumPad()

  txtdose.Tag = ""
  txtday.Tag = ""
  txtqty.Tag = ""
  Try $NumForm.Close

End

