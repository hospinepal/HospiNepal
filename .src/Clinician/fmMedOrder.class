End

Public Sub mnusave_Click()

  If GridView1.Rows.Selection.Count > 0 Then
    If Message.Question(("Do you want to start dosing without pharmacy supply ?"), ("No"), ("Yes")) = 2 Then
      modPharmacy.UpdateDispensing(GridView1[GridView1.Row, 0].Text, True)
    Endif
    FillDosingGrid()
  Endif

End

Public Sub mnuonline_Click()

  Dim Row As Integer

  If GridView1.Rows.Selection.Count > 0 Then
    Row = GridView1.Row
    modPharmacy.DisableDispOnline(GridView1[GridView1.Row, 0].Text)
    FillDosingGrid()
    GridView1.Row = Row
    Message.Info(("Request sent"), ("OK"))
  Endif

End

