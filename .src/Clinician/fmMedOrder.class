Private Function DoseFormRoutine() As String

  Dim xx As String

  If rblabel.Value = True Then
    xx = "Label"
  Else
    xx = "Value"
  Endif
  Return xx

End

Private Sub ShowRunningMedicine()

  Dim sql As String
  Dim Column As Integer
  Dim fld As ResultField
  Dim res As Result

  sql = "select fldid,fldstarttime,fldroute,flditem,fldid,fldfreq,flddays,fldcurval,fldid,fldstarttime,fldstatus from tblpatdosing where fldencounterval=&1 and fldsave_order=&2 and fldstarttime<=&3 and flditemtype=&4 and flddispmode=&5 ORDER BY fldid DESC"                    ''
  res = modDatabase.$myConn.Exec(sql, $encid, True, modDate.EndSqlDate(Now()), "Medicines", "IPD")

  grdmedicine.Clear
  grdmedicine.Columns.Count = res.Fields.Count
  grdmedicine.Rows.Count = res.Count

  For Each res
    Column = 0
    For Each fld In res.Fields
      modGeneralMain.GridExplicitDecoration(grdmedicine, res.Index, Column)
      If Column = 1 Then
        grdmedicine[res.Index, Column].Text = modReportVar.GetDateTimeReport(res["fldstarttime"], gb.GeneralDate)
      Else If Column = 4 Then
        grdmedicine[res.Index, Column].Text = modPharmacy.GetMedicineDoseInFormat(res["fldid"], DoseFormRoutine())
      Else If Column = 8 Then
        grdmedicine[res.Index, Column].Text = modPharmacy.TotalDoseNumner(res["fldid"])
      Else
        grdmedicine[res.Index, Column].Text = res[fld.Name]
      Endif
      Column = Column + 1
    Next
  Next
  grdmedicine.Row = 0

  With grdmedicine
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 1
    .Columns[1].Width = 150 * modBasic.$AppWidthRatio
    .Columns[2].Width = 75 * modBasic.$AppWidthRatio
    .Columns[3].Width = 250 * modBasic.$AppWidthRatio
    .Columns[4].Width = 75 * modBasic.$AppWidthRatio
    .Columns[5].Width = 50 * modBasic.$AppWidthRatio
    .Columns[6].Width = 40 * modBasic.$AppWidthRatio
    .Columns[7].Width = 75 * modBasic.$AppWidthRatio
    .Columns[8].Width = 40 * modBasic.$AppWidthRatio
    .Columns[9].Width = 1
    .Columns[10].Width = 1

    .Columns[1].Text = "StartDate"
    .Columns[2].Text = "Route"
    .Columns[3].Text = "Medicine"
    .Columns[4].Text = "Dose"
    .Columns[5].Text = "Freq"
    .Columns[6].Text = "Days"
    .Columns[7].Text = "Status"
    .Columns[8].Text = "N"
  End With

End

''================================SELECTION ===============================
Private Sub ShowStockGrid()

  Dim sql As String
  Dim Column As Integer
  Dim fld As ResultField
  Dim res As Result

  sql = "select fldid,fldcodename,flddosetype,flddose,flddoseunit,fldfreq,fldday,fldid,fldid,fldid from tblregimen where flddisease=&1 and (fldgender=&2 or fldgender=&3) and (fldagegroup=&4 or fldagegroup=&5)"
  res = modDatabase.$myConn.Exec(sql, cmbdiagnosis.Text, modPatient.GetPatientSex($encid), "Both Sex", modPatient.GetAgeGroupFIxed($encid, Now()), "All Age")

  GridView2.Clear
  GridView2.Columns.Count = res.Fields.Count
  GridView2.Rows.Count = res.Count

  For Each res
    Column = 0
    For Each fld In res.Fields
      modGeneralMain.GridExplicitDecoration(GridView2, res.Index, Column)
      If Column = 7 Then
        GridView2[res.Index, Column].Picture = Picture["icon:/small/attach"]
        GridView2[res.Index, Column].Text = ""
      Else If Column = 8 Then
        GridView2[res.Index, Column].Picture = Picture["icon:/small/attach"]
        GridView2[res.Index, Column].Text = ""
      Else If Column = 9 Then
        GridView2[res.Index, Column].Picture = Picture["icon:/small/attach"]
        GridView2[res.Index, Column].Text = ""
      Else
        GridView2[res.Index, Column].Text = res[fld.Name]
      Endif
      Column = Column + 1
    Next
  Next
  GridView2.Row = 0

  With GridView2
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 1
    .Columns[1].Width = 275 * modBasic.$AppWidthRatio
    .Columns[2].Width = 100 * modBasic.$AppWidthRatio
    .Columns[3].Width = 75 * modBasic.$AppWidthRatio
    .Columns[4].Width = 75 * modBasic.$AppWidthRatio
    .Columns[5].Width = 50 * modBasic.$AppWidthRatio
    .Columns[6].Width = 50 * modBasic.$AppWidthRatio
    .Columns[7].Width = 25 * modBasic.$AppWidthRatio
    .Columns[8].Width = 25 * modBasic.$AppWidthRatio
    .Columns[9].Width = 25 * modBasic.$AppWidthRatio

    .Columns[1].Text = "Drug"
    .Columns[2].Text = "Type"
    .Columns[3].Text = "Dose"
    .Columns[4].Text = "Unit"
    .Columns[5].Text = "Freq"
    .Columns[6].Text = "Day"
  End With

End

Public Sub btndiagnosis_Click()

  If cmbdiagnosis.Text Then
    ShowStockGrid()
  Endif

End

''==================================== USE OWN ==============================
Private Sub ShowCurrStockGrid()

  If rbmed.Value = True Then
    $rData = modDatabase.$syConn.Exec("select fldbrandid,fldbrand,fldbrandid,fldbrandid as qty from tblmedbrand where lower(fldbrandid) like &1 and fldbrandid in(select fldstockid from tblentry where fldqty>&2 and fldcomp like &3) order by fldbrandid ASC", LCase(txtname.Text) & "%", 0, modGeneralMain.compID)                                   ''
  Else If rbsurg.Value = True Then
    $rData = modDatabase.$syConn.Exec("select fldbrandid,fldbrand,fldbrandid,fldbrandid as qty from tblsurgbrand where lower(fldbrandid) like &1 and fldbrandid in(select fldstockid from tblentry where fldqty>&2 and fldcomp like &3) order by fldbrandid ASC", LCase(txtname.Text) & "%", 0, modGeneralMain.compID)
  Else If rbextra.Value = True Then
    $rData = modDatabase.$syConn.Exec("select fldbrandid,fldbrand,fldbrandid,fldbrandid as qty from tblextrabrand where lower(fldbrandid) like &1 and fldbrandid in(select fldstockid from tblentry where fldqty>&2 and fldcomp like &3) order by fldbrandid ASC", LCase(txtname.Text) & "%", 0, modGeneralMain.compID)
  Endif

  $aMyFields = New String[]
  modGridView.ReadSmallData(GridView3, $rData, $aMyFields)
  With GridView3
    .Columns[0].Width = 275 * modBasic.$AppWidthRatio
    .Columns[1].Width = 1
    .Columns[2].Width = 1
    .Columns[3].Width = 40 * modBasic.$AppWidthRatio
    .Columns[0].Text = "Particulars"
    .Columns[3].Text = "QTY"
  End With

End

Public Sub GridView3_Data(Row As Integer, Column As Integer)

  $rData.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView3, Row)
  If Column = 3 Then
    GridView3.Data.Text = modStock.TotalQTYbyBrand($rData["qty"], modGeneralMain.compID)
  Else
    GridView3.Data.Text = $rData[$aMyFields[Column]]
  Endif

End

Public Sub rbmed_Click()

  ShowCurrStockGrid()
  txtname.SetFocus

End

Public Sub rbsurg_Click()

  ShowCurrStockGrid()
  txtname.SetFocus

End

Public Sub rbextra_Click()

  ShowCurrStockGrid()
  txtname.SetFocus

End

Public Sub txtname_Change()

  ShowCurrStockGrid()

End

Public Sub txtname_Click()

  txtname.Text = ""
  ShowCurrStockGrid()

End

Public Sub GridView3_Click()

  Dim xval As Float
  Dim sType As String

  If GridView3.Rows.Selection.Count Then
    Panel4.Enabled = False
    If rbmed.Value = True Then
      sType = "Medicines"
    Else If rbsurg.Value = True Then
      sType = "Surgicals"
    Else If rbextra.Value = True Then
      sType = "Extra Items"
    Endif
    xval = InputValue("QUANTITY OF <b>" & GridView3[GridView3.Row, 0].Text & "</b>", "Use Record", 0)
    Panel4.Enabled = True
    If xval Then
      EntryUseOwndata(sType, GridView3[GridView3.Row, 0].Text, xval)
      ShowUsedGridViewList()
    Endif
  Endif

End

Private Sub EntryUseOwndata(sType As String, sItem As String, sQty As Float)

  Dim xroute As String
  Dim xtax As Float
  Dim xdisc As Float
  Dim xdose As Float

  xtax = modNonMedical.ShowTaxValues(sType, sItem)
  xdisc = modNonMedical.DiscPercentForItem($encid, sType, sItem)
  xroute = modMedicine.GetRouteFromItem(sItem, sType)

  If sType = "Medicines" Then
    xdose = sQty * modPharmLabel.GetPackVolValue(sItem) * modMedConstant.GetDrugInitialStrength(sItem)
    modPharmacy.InsertDosingEntry($encid, xroute, sItem, xdose, 1, 1, sQty, $status, "", "", 0, xtax, xdisc, "UseOwn", $Dept)
  Else
    modPharmacy.InsertNonMedDosingEntry($encid, xroute, sItem, sQty, $status, 0, xtax, xdisc, "UseOwn", $Dept)
  Endif

End

Private Sub ShowUsedGridViewList()

  Dim sql As String
  Dim Column As Integer
  Dim fld As ResultField
  Dim res As Result

  sql = "select fldid,fldstarttime,fldroute,flditem,flddose,fldfreq,flddays,fldqtydisp,flduserid_order,fldid,fldid,fldstarttime from tblpatdosing where fldencounterval=&1 and fldsave_order=&2 and fldstatus=&3 and fldorder=&4 and fldcurval=&5 and flddispmode=&6"                                                   ''
  res = modDatabase.$myConn.Exec(sql, $encid, False, $status, "UseOwn", "Continue", $Dept)

  GridView4.Clear
  GridView4.Columns.Count = res.Fields.Count
  GridView4.Rows.Count = res.Count

  For Each res
    Column = 0
    For Each fld In res.Fields
      modGeneralMain.GridExplicitDecoration(GridView4, res.Index, Column)
      If Column = 9 Then
        GridView4[res.Index, Column].Picture = Picture["icon:/small/cancel"]
        GridView4[res.Index, Column].Text = ""
      Else If Column = 10 Then
        GridView4[res.Index, Column].Picture = Picture["icon:/small/apply"]
        GridView4[res.Index, Column].Text = ""
      Else
        GridView4[res.Index, Column].Text = res[fld.Name]
      Endif
      Column = Column + 1
    Next
  Next
  GridView4.Row = 0

  With GridView4
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 1
    .Columns[1].Width = 1
    .Columns[2].Width = 1
    .Columns[3].Width = 335 * modBasic.$AppWidthRatio
    .Columns[4].Width = 1
    .Columns[5].Width = 1
    .Columns[6].Width = 1
    .Columns[7].Width = 50 * modBasic.$AppWidthRatio
    .Columns[8].Width = 1
    .Columns[9].Width = 25 * modBasic.$AppWidthRatio
    .Columns[10].Width = 25 * modBasic.$AppWidthRatio
    .Columns[11].Width = 1

    .Columns[3].Text = "Particulars"
    .Columns[7].Text = "QTY"
  End With

End

Public Sub GridView4_Click()

  Dim xval As Float
  Dim Column As Integer
  Dim Row As Integer
  Dim res As Result

  Row = GridView4.Row
  Column = GridView4.Column
  If GridView4.Column = 7 Then
    xval = InputValue(GridView4[GridView4.Row, 3].Text, ("Change Value"), GridView4[GridView4.Row, 7].Text)
    modPharmacy.UpdateQTYBefDispensing(GridView4[GridView4.Row, 0].Text, xval)
    ShowUsedGridViewList()

  Else If GridView4.Column = 9 Then
    If Message.Question(("Are you sure?"), ("No"), ("Yes")) = 2 Then
      res = modDatabase.$myConn.Edit("tblpatdosing", "fldid=&1 and fldsave_order=&2", GridView4[GridView4.Row, 0].Text, False)
      If modGeneral.AllowClinicalEdit(res["flduserid_order"]) = True Then
        modDatabase.$myConn.Delete("tblpatdosing", "fldid=&1 and fldsave_order=&2", GridView4[GridView4.Row, 0].Text, False)
      Else
        res["fldcurval"] = "Cancelled"
        res["flduserid_order"] = modGeneralMain.$lbluser
        res["xyz"] = False
        res.Update
      Endif
      ShowUsedGridViewList()
    Endif

  Else If GridView4.Column = 10 Then
    If Message.Question(("Are you sure?"), ("No"), ("Yes")) = 2 Then
      If modBasic.$AutoBillPharmacy = "Yes" Or If modBasic.$AutoBillPharmacy = "Full" Then
        SaveOwnDispensing(GridView4[GridView4.Row, 0].Text)
        ShowUsedGridViewList()
        ShowCurrStockGrid()
      Endif
    Endif

  Endif
  GridView4.Row = Row
  GridView4.Column = Column

End

Private Sub SaveOwnDispensing(sID As Long)

  Dim sql1 As String
  Dim res1 As Result

  Dim tax As Float
  Dim disc As Float

  Dim res2 As Result
  Dim sql2 As String

  Dim qtynew As Float
  Dim xcateg As String

  sql1 = "select fldid,fldtime,fldroute,flditem,flddose,fldfreq,flddays,fldqtydisp,fldlabel,fldencounterval,flditemtype from tblpatdosing where fldid=&1"                                                   ''
  res1 = modDatabase.$myConn.Exec(sql1, sID)
  If res1.Available = True Then

    Inc Application.Busy
    modDatabase.$myConn.Begin
    'get tax and discount percentages
    xcateg = res1!flditemtype
    tax = modNonMedical.ShowTaxValues(xcateg, res1!flditem)
    disc = modNonMedical.DiscPercentForItem(res1!fldencounterval, xcateg, res1!flditem)

    qtynew = res1!fldqtydisp
    While qtynew > 0

      'get stockno, rate and quantity based on expiry check
      If modBasic.$SkipExpiry = "ExpireOnUse" Then
        sql2 = "select fldstockno,fldexpiry,fldqty,fldstatus,fldsellpr from tblentry where fldstockid=&1 and fldcomp=&2 and fldstatus=&3 and fldexpiry>&4 and fldqty>&5"
        res2 = modDatabase.$myConn.Exec(sql2, res1!flditem, modGeneralMain.compID, 1, DateAdd(modDate.StartSqlDate(Now()), gb.Day, CInt(res1!flddays)), 0)
      Else If modBasic.$SkipExpiry = "Expired" Then
        sql2 = "select fldstockno,fldexpiry,fldqty,fldstatus,fldsellpr from tblentry where fldstockid=&1 and fldcomp=&2 and fldstatus=&3 and fldexpiry>&4 and fldqty>&5"
        res2 = modDatabase.$myConn.Exec(sql2, res1!flditem, modGeneralMain.compID, 1, modDate.StartSqlDate(Now()), 0)
      Else
        sql2 = "select fldstockno,fldexpiry,fldqty,fldstatus,fldsellpr from tblentry where fldstockid=&1 and fldcomp=&2 and fldstatus=&3 and fldqty>&4"
        res2 = modDatabase.$myConn.Exec(sql2, res1!flditem, modGeneralMain.compID, 1, 0)
      Endif

      If res2.Count = 0 Then
        Dec Application.Busy
        Break
      Else If res2.Count > 0 Then
        If qtynew <= res2!fldqty Then
          modBillings.InsertBlankBillItem(res1!fldencounterval, $sBillMode, res1!flditemtype, res2!fldstockno, res1!flditem, res2!fldsellpr, qtynew, tax, disc, "Done", res1!fldid, True, False)
          modStock.AddToExistEntry(res2!fldstockno, (0 - qtynew), modGeneralMain.compID)
          qtynew = 0
        Else If qtynew > res2!fldqty Then
          modBillings.InsertBlankBillItem(res1!fldencounterval, $sBillMode, res1!flditemtype, res2!fldstockno, res1!flditem, res2!fldsellpr, res2!fldqty, tax, disc, "Done", res1!fldid, True, False)
          modStock.AddToExistEntry(res2!fldstockno, (0 - res2!fldqty), modGeneralMain.compID)
          qtynew = qtynew - res2!fldqty
        Endif
      Endif

    Wend

    If qtynew > 0 Then
      modPharmacy.DuplicateRecordWithQTY(res1!fldid, qtynew)
      modPharmacy.UpdateQTYBefDispensing(res1!fldid, res1!fldqtydisp - qtynew)
    Endif
    modPharmacy.UpdateDispensing(res1!fldid, True)
    modDatabase.$myConn.Commit
    Dec Application.Busy

  Endif

Catch
  modDatabase.$myConn.Rollback
  Dec Application.Busy
  modHelpVariable.CreateErrorReport()

End
