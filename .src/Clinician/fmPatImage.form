# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,117,64)
  Text = ("Patient Images")
  Resizable = False
  { dgimage GridView
    MoveScaled(1,5,38,58)
    Mode = Select.Single
    AutoResize = False
    Sorted = True
  }
  { ScrollView1 ScrollView
    MoveScaled(40,9,75,38)
    { PictureBox1 ImageView
      MoveScaled(1,1,73,36)
    }
  }
  { btnOpen Button
    MoveScaled(103,47,4,3.5)
    Picture = Picture["icon:/small/open"]
  }
  { btnwebcam Button
    MoveScaled(107,47,4,3.5)
    Picture = Picture["icon:/small/camera"]
  }
  { btnOK Button
    MoveScaled(99,51,16,3)
    Text = Shortcut(("Add"), "A")
    Picture = Picture["icon:/small/add"]
  }
  { btnChange Button
    MoveScaled(99,54,16,3)
    Text = Shortcut(("Edit"), "E")
    Picture = Picture["icon:/small/edit"]
  }
  { btnexport Button
    MoveScaled(99,57,16,3)
    Text = ("Export")
    Picture = Picture["icon:/small/html"]
  }
  { txttitle TextBox
    MoveScaled(40,5,70,3.5)
  }
  { txtkeyword TextBox
    MoveScaled(48,52,50,3)
  }
  { txtdetail TextArea
    MoveScaled(40,56,58,7)
    Wrap = True
    ScrollBar = Scroll.Vertical
  }
  { btnplay Button
    MoveScaled(111,5,4,3.5)
    Picture = Picture["icon:/small/play"]
  }
  { Slider1 Slider
    MoveScaled(40,48,58,3)
    MinValue = 1
    MaxValue = 1000
    Value = 100
  }
  { Label2 Label
    MoveScaled(1,1,6,3)
    Border = Border.Plain
    Text = ("Name")
  }
  { txtpatientname TextBox
    MoveScaled(8,1,37.5,3)
    Font = Font["Bold"]
    ReadOnly = True
  }
  { Label4 Label
    MoveScaled(97,1,7,3)
    Border = Border.Plain
    Text = ("Gender")
  }
  { txtgender TextBox
    MoveScaled(105,1,10,3)
    ReadOnly = True
  }
  { Label1 Label
    MoveScaled(40,52,7,3)
    Border = Border.Plain
    Text = ("Keys")
  }
  { btnclose Button
    MoveScaled(99,60,16,3)
    Text = ("Close")
    Picture = Picture["icon:/small/close"]
    Cancel = True
  }
}
