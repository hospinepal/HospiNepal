' Gambas class file

Private aObj[50] As PictureBox
Private aObk[50] As ListBox
Private aObjx[50] As ScrollView
Private aObj1[50] As TextLabel
Private aObj2[50] As Label

Private bObj[50] As PictureBox
Private bObk[50] As ListBox
Private bObjx[50] As ScrollView
Private bObj1[50] As TextLabel
Private bObj2[50] As Label

Private $encid As String
Private $labarr As String[]
Private $examarr As String[]
Private $unt As String
Private AppFactor As Float

Public Sub Form_Open()

  modGeneralMain.ArrangeEmbedForms(Me, Panel1)
  Me.Icon = Picture[modGeneralMain.$strLogo]
  modBasic.LoadClinicalChartSetting()
  AppFactor = modBasic.$AppScaleFactor
  Slider1.Value = 10
  FillCHartItems(Slider1.Value * 10)

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

Public Sub btnrefresh_Click()

  FillCHartItems(Slider1.Value * 10)

End

Public Sub _new(encid As String, examlst As String[], lablst As String[], unt As String)

  Dim i As Integer
  Dim j As Integer

  $encid = encid
  $labarr = lablst
  $examarr = examlst
  $unt = unt
  Me.Text = "ENCID: " & $encid

  If $examarr Then
    For i = 0 To $examarr.Count - 1
      aObj1[i] = New TextLabel(ListContainer1) As "TextLabelGroup"
      aObjx[i] = New ScrollView(ListContainer1) As "ScrollGroup"
      aObj[i] = New PictureBox(aObjx[i]) As "PictureBoxgroup"
      aObk[i] = New ListBox(ListContainer1) As "ListGroup"
      aObj2[i] = New Label(ListContainer1) As "LabelBlank"
    Next
  Endif

  If $labarr Then
    For j = 0 To $labarr.Count - 1
      bObj1[j] = New TextLabel(ListContainer1) As "TextLabelGroup"
      bObjx[j] = New ScrollView(ListContainer1) As "ScrollGroup"
      bObj[j] = New PictureBox(bObjx[j]) As "PictureBoxgroup"
      bObk[j] = New ListBox(ListContainer1) As "ListGroup"
      bObj2[j] = New Label(ListContainer1) As "LabelBlank"
    Next
  Endif

End

Private Sub FillCHartItems(sHt As Integer)

  Dim i As Integer
  Dim j As Integer

  If $examarr Then
    For i = 0 To $examarr.Count - 1

      With aObj1[i]
        .Left = 0
        .Width = 300 * AppFactor
        .Height = 20 * AppFactor
        .Top = (i * (sHt + 50)) * AppFactor
        .Text = "<b>" & $examarr[i] & "</b>"
      End With

      'get info and draw
      If modFixClinic.GetExaminationType($examarr[i]) = "Quantitative" Then
        With aObjx[i]
          .Height = sHt * AppFactor
          .Left = 0
          .Top = (i * (sHt + 50) + 20) * AppFactor
          .Width = (Panel1.Width - 75) * AppFactor
        End With
        With aObj[i]
          .Expand = True
          .AutoResize = True
          .Height = (sHt - 20) * AppFactor
          .Left = 0
          .Top = 0
        End With
        modClinic.FillQuantiExamChart(aObj[i], $encid, $examarr[i])

      Else
        With aObk[i]
          .Height = sHt * AppFactor
          .Left = 0
          .Top = (i * (sHt + 50) + 20) * AppFactor
          .Width = (Panel1.Width - 75) * AppFactor
          .List = modClinic.UniExamValueList($encid, $examarr[i])
        End With

      Endif

      With aObj2[i]
        .Left = 0
        .Width = 300 * AppFactor
        .Height = 20 * AppFactor
        .Top = (i * (sHt + 50) + 20 + sHt) * AppFactor
        .Text = "                                    "
      End With

    Next
  Endif

  If $labarr Then
    For j = 0 To $labarr.Count - 1

      With bObj1[j]
        .Left = 0
        .Width = 300 * AppFactor
        .Height = 20 * AppFactor
        .Top = ((i + j) * (sHt + 50)) * AppFactor
        .Text = "<b>" & $labarr[j] & "</b>"
      End With

      'get info and draw
      If modFixLab.GetLabTestType($labarr[j]) = "Quantitative" Then
        With bObjx[j]
          .Height = sHt * AppFactor
          .Left = 0
          .Top = ((i + j) * (sHt + 50) + 20) * AppFactor
          .Width = (Panel1.Width - 75) * AppFactor
        End With
        With bObj[j]
          .Expand = True
          .AutoResize = True
          .Height = (sHt - 20) * AppFactor
          .Left = 0
          .Top = 0
        End With
        modLabTest.FillQuantiTestChart(bObj[j], $encid, $labarr[j], $unt)

      Else
        With bObk[j]
          .Height = sHt * AppFactor
          .Left = 0
          .Top = ((i + j) * (sHt + 50) + 20) * AppFactor
          .Width = (Panel1.Width - 75) * AppFactor
          .List = modLabTest.UniLabValueList($encid, $labarr[j])
        End With

      Endif

      With bObj2[j]
        .Left = 0
        .Width = 300 * AppFactor
        .Height = 20 * AppFactor
        .Top = ((i + j) * (sHt + 50) + 20 + sHt) * AppFactor
        .Text = "                                    "
      End With

    Next
  Endif

End

Public Sub Form_Resize()

  ListContainer1.Left = 0
  ListContainer1.Top = 40 * AppFactor
  ListContainer1.Width = Panel1.Width - (50 * AppFactor)

End

Public Sub mnuexpo_Click()

  Dim xPath As String

  xPath = modCHTMLPatient.ExportMultiExamTestToHTML($encid, $examarr, $labarr, $unt, Me)
  modPrint.OpenHTMLPreview($encid, xPath, "ReportSize")

End
