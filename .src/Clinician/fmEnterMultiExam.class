' Gambas class file

''controls
Private aIndexLabel[50] As Label   ''aLab
Private aNameLabel[50] As TextLabel      ''aObj
Private aAbnormCheck[50] As CheckBox      ''aObj2
Private aHTMLText[50] As TextHTML         ''aObj11
Private aLineText[50] As TextBox
Private aUnitText[50] As TextBox
Private aValueBox[50] As ValueBox
Private aQuantiBox[50] As ValueBox
Private aClinBox[50] As ValueBox
Private aDateBox[50] As DateBox
Private aComboBox[50] As ComboBox
Private aTextArea[50] As TextArea
Private aDichoValue[50] As DichotomousValue
Private aLeftRight[50] As LeftRightTextArea
Private aGridView[50] As GridView          ''aObg11
Private aListBox[50] As ListBox
Private aHelpButton[50] As ButtonBox          ''aObj3
''other variables
Private $encid As String
Private $sTable As String
Private $idList As String[]
Private $AutoOption As String
''Arrays
Private $xType As String[]
Private $xOption As String[]
Private $xitem As String[]
Private $xOpList As String[]
Private $xSysCons As String[]

Private AppFactor As Float

''----------------------------------------- create controls -----------------------------------------
Public Sub _new(sPrompt As String, encid As String, sTable As String, idList As String[])

  Dim idx As String
  Dim i As Integer
  Dim ht As String

  Dim rsn As Result
  Dim res As Result

  Dim xType As String
  Dim xOption As String
  Dim xitem As String
  Dim xopList As String[]
  Dim xSysCons As String

  $encid = encid
  $sTable = sTable
  $idList = idList
  lblitem.Text = sPrompt

  AppFactor = modBasic.$AppScaleFactor
  ht = modSettings.ShowSettingFromFIle("MultipleTextBox/Height")
  If ht Then
    Slider1.Value = CInt(ht)
  Else
    Slider1.Value = 3
  Endif

  $xType = New String[]
  $xOption = New String[]
  $xitem = New String[]
  $xOpList = New String[]
  $xSysCons = New String[]

  If $sTable = "Rec Examination" Then
    For Each idx In $idList
      rsn = modDatabase.$myConn.Exec("select fldhead,fldtesttype,fldtanswertype,fldsysconst from tblstructexam where fldheadcode=&1 ORDER BY fldheadid", idx)
      xitem = rsn["fldhead"]
      xType = rsn["fldtesttype"]
      xOption = rsn["fldtanswertype"]
      xSysCons = rsn["fldsysconst"]
      xopList = modFillContainer.GetListFromResult(modDatabase.$myConn.Exec("select fldanswer from tblstructexamoption where fldheadcode=&1 ORDER BY fldindex", idx))                         ''

      ''get parameters
      If rsn["fldtanswertype"] = "Sys Constant" And If rsn["fldsysconst"] Then
        If modSysCons.SysExaminationList().Exist(rsn["fldsysconst"]) = True Then
          res = modDatabase.$myConn.Exec("select fldexamid,fldtype,fldoption from tblexam where fldsysconst=&1", rsn["fldsysconst"])
          If res.Available Then
            xType = res["fldtype"]
            xOption = res["fldoption"]
            xitem = res["fldexamid"]
            If res["fldoption"] = "Clinical Scale" Then
              xopList = modFixClinic.GetCLinicalScaleOptions("Exam", xitem)
            Else
              xopList = modFixClinic.SelectExamOptionList("Exam", xitem)
            Endif
          Endif
        Else If modSysCons.SysLabTestList().Exist(rsn["fldsysconst"]) = True Then
          res = modDatabase.$myConn.Exec("select fldtestid,fldtype,fldoption from tbltest where fldsysconst=&1", rsn["fldsysconst"])
          If res.Available Then
            xType = res["fldtype"]
            xOption = res["fldoption"]
            xitem = res["fldtestid"]
            If res["fldoption"] = "Clinical Scale" Then
              xopList = modFixClinic.GetCLinicalScaleOptions("Test", xitem)
            Else
              xopList = modFixClinic.SelectExamOptionList("Test", xitem)
            Endif
          Endif
        Else If modBasic.$sysRadioList.Exist(rsn["fldsysconst"]) = True Then
          res = modDatabase.$myConn.Exec("select fldexamid,fldtype,fldoption from tblradio where fldsysconst=&1", rsn["fldsysconst"])
          If res.Available Then
            xType = res["fldtype"]
            xOption = res["fldoption"]
            xitem = res["fldexamid"]
            If res["fldoption"] = "Clinical Scale" Then
              xopList = modFixClinic.GetCLinicalScaleOptions("Radio", xitem)
            Else
              xopList = modFixClinic.SelectExamOptionList("Radio", xitem)
            Endif
          Endif
        Else If modBasic.$DemogList.Exist(rsn["fldsysconst"]) = True Then
          res = modDatabase.$myConn.Exec("select flddemoid,fldoption from tbldemographic where flddemoid=&1", rsn["fldsysconst"])
          If res.Available Then
            xType = res["fldoption"]
            xOption = res["fldoption"]
            xitem = res["flddemoid"]
            xopList = modFixClinic.SelectExamOptionList("Demog", xitem)
          Endif
        Endif
      Endif

      $xitem.Add(xitem)
      If xType Then
        $xType.Add(xType)
      Else
        $xType.Add("NA")
      Endif
      If xOption Then
        $xOption.Add(xOption)
      Else
        $xOption.Add("NA")
      Endif
      If xopList And xopList.Count Then
        $xOpList.Add(xopList.Join(";"))
      Else
        $xOpList.Add("NA")
      Endif
      If xSysCons Then
        $xSysCons.Add(xSysCons)
      Else
        $xSysCons.Add("NA")
      Endif

    Next

  Else
    For Each idx In $idList
      res = modDatabase.$myConn.Exec("select fldexamid,fldtype,fldoption,fldsysconst from tblexam where fldexamid=&1", idx)
      If res.Available Then
        xType = res["fldtype"]
        xOption = res["fldoption"]
        xitem = res["fldexamid"]
        xSysCons = res["fldsysconst"]
        If res["fldoption"] = "Clinical Scale" Then
          xopList = modFixClinic.GetCLinicalScaleOptions("Exam", xitem)
        Else
          xopList = modFixClinic.SelectExamOptionList("Exam", xitem)
        Endif
      Endif

      $xitem.Add(xitem)
      If xType Then
        $xType.Add(xType)
      Else
        $xType.Add("NA")
      Endif
      If xOption Then
        $xOption.Add(xOption)
      Else
        $xOption.Add("NA")
      Endif
      If xopList And xopList.Count Then
        $xOpList.Add(xopList.Join(";"))
      Else
        $xOpList.Add("NA")
      Endif
      If xSysCons Then
        $xSysCons.Add(xSysCons)
      Else
        $xSysCons.Add("NA")
      Endif
    Next

  Endif

  For i = 0 To $xitem.Count - 1
    ''Create controls
    aIndexLabel[i] = New Label(Frame1) As "IndexLabel"
    aNameLabel[i] = New TextLabel(Frame1) As "NameLabel"
    aAbnormCheck[i] = New CheckBox(Frame1) As "CheckBoxgroup"
    If $xType[i] = "Quantitative" Then
      aQuantiBox[i] = New ValueBox(Frame1) As "QuantiGroup"
    Else
      Select $xOption[i]
        Case "Sys Constant"
          aHTMLText[i] = New TextHTML(Frame1) As "TextHTMLgroup"
        Case "Multiple Selection"
          aListBox[i] = New ListBox(Frame1) As "ListBoxgroup"
        Case "Text Table"
          aGridView[i] = New GridView(Frame1) As "GridViewgroup"
        Case "Left and Right"
          aLeftRight[i] = New LeftRightTextArea(Frame1) As "LeftRightGroup"
        Case "Date Time"
          aDateBox[i] = New DateBox(Frame1) As "DateGroup"
        Case "Single Selection"
          aComboBox[i] = New ComboBox(Frame1) As "ComboGroup"
        Case "Dichotomous"
          aDichoValue[i] = New DichotomousValue(Frame1) As "DichoText"
        Case "Quantitative"
          aValueBox[i] = New ValueBox(Frame1) As "ValueGroup"
          aUnitText[i] = New TextBox(Frame1) As "UnitGroup"
        Case "Qualitative"
          aLineText[i] = New TextBox(Frame1) As "TextLineGroup"
        Case "Clinical Scale"
          aTextArea[i] = New TextArea(Frame1) As "TextAreaGroup"
          aClinBox[i] = New ValueBox(Frame1) As "ClinGroup"
        Case Else
          aHTMLText[i] = New TextHTML(Frame1) As "TextHTMLgroup"
      End Select
    Endif
    aHelpButton[i] = New ButtonBox(Frame1) As "ButtonBoxgroup"
  Next
  DIsplayTextForm()

End

''------------------------ General form
Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me, "False")
  $AutoOption = modSettings.ShowSettingFromFIle("EntrySetting/AutoDisplayOptions")
  If $AutoOption = "Yes" Then
    chkautoption.Value = True
  Else If $AutoOption = "No" Then
    chkautoption.Value = False
  Endif

End

Public Sub Form_Resize()

  Dim xht As Integer

  xht = ($xitem.Count * 25 * Slider1.Value + 30) * AppFactor
  If Frame1.Height < xht Then
    Frame1.Height = xht
  Endif

End

Private Sub DIsplayTextForm()

  Dim i As Integer

  Frame1.Height = ($xitem.Count * 25 * Slider1.Value + 30) * AppFactor
  Frame1.Width = 875 * AppFactor

  For i = 0 To $xitem.Count - 1

    ''create index label
    With aIndexLabel[i]
      .X = 5 * AppFactor
      .Y = (i * 25 * Slider1.Value + 15) * AppFactor
      .Width = 25 * AppFactor
      .Height = 25 * AppFactor
      .Text = i + 1
      .Tag = i
    End With

    ''create Name Label
    With aNameLabel[i]
      .X = (5 + 25) * AppFactor
      .Y = (i * 25 * Slider1.Value + 15) * AppFactor
      .Width = 250 * AppFactor
      .Height = 25 * Slider1.Value * AppFactor
      .Text = $xitem[i]
      .Tag = i
      .Wrap = True
    End With

    ''create abnormal checkbox
    With aAbnormCheck[i]
      .X = (260 + 25) * AppFactor
      .Y = (i * 25 * Slider1.Value + 15) * AppFactor
      .Width = 100 * AppFactor
      .Height = 25 * AppFactor
      .Text = "Abnormal"
      .Tag = i
    End With

    ''create observation entry
    If $xType[i] = "Quantitative" Then
      With aQuantiBox[i]
        .X = (365 + 25) * AppFactor
        .Y = (i * 25 * Slider1.Value + 15) * AppFactor
        .Width = 250 * AppFactor
        .Height = 25 * AppFactor
        .Tag = i
      End With

    Else
      If $xOption[i] = "Multiple Selection" Then
        With aListBox[i]
          .X = (365 + 25) * AppFactor
          .Y = (i * 25 * Slider1.Value + 15) * AppFactor
          .Width = 250 * AppFactor
          .Height = 25 * Slider1.Value * AppFactor
          .ScrollBar = Scroll.Both
          .Tag = i
        End With

      Else If $xOption[i] = "Text Table" Then
        DisplayAgegrid(Split($xOpList[i], ";"), "", aGridView[i])
        With aGridView[i]
          .X = (365 + 25) * AppFactor
          .Y = (i * 25 * Slider1.Value + 15) * AppFactor
          .Width = 400 * AppFactor
          .Height = 25 * Slider1.Value * AppFactor
          .ScrollBar = Scroll.Both
          .ScrollBar = Scroll.Both
          .AutoResize = True
          .Tag = i
        End With

      Else If $xOption[i] = "Single Selection" Then
        With aComboBox[i]
          .X = (365 + 25) * AppFactor
          .Y = (i * 25 * Slider1.Value + 15) * AppFactor
          .Width = 250 * AppFactor
          .Height = 25 * AppFactor
          .List = Split($xOpList[i], ";")
          .Tag = i
        End With

      Else If $xOption[i] = "Dichotomous" Then
        With aDichoValue[i]
          .X = (365 + 25) * AppFactor
          .Y = (i * 25 * Slider1.Value + 15) * AppFactor
          .Width = 250 * AppFactor
          .Height = 25 * AppFactor
          .List = Split($xOpList[i], ";")
          .Tag = i
        End With

      Else If $xOption[i] = "Left and Right" Then
        With aLeftRight[i]
          .X = (365 + 25) * AppFactor
          .Y = (i * 25 * Slider1.Value + 15) * AppFactor
          .Width = 400 * AppFactor
          .Height = 25 * Slider1.Value * AppFactor
          .Tag = i
        End With

      Else If $xOption[i] = "Date Time" Then
        With aDateBox[i]
          .X = (365 + 25) * AppFactor
          .Y = (i * 25 * Slider1.Value + 15) * AppFactor
          .Width = 250 * AppFactor
          .Height = 25 * AppFactor
          .Mode = DateChooser.DateTime
          .Tag = i
        End With

      Else If $xOption[i] = "Clinical Scale" Then
        With aTextArea[i]
          .X = (365 + 25) * AppFactor
          .Y = (i * 25 * Slider1.Value + 15) * AppFactor
          .Width = 250 * AppFactor
          .Height = 25 * Slider1.Value * AppFactor
          .Tag = i
        End With
        With aClinBox[i]
          .X = (625 + 25) * AppFactor
          .Y = (i * 25 * Slider1.Value + 15) * AppFactor
          .Width = 100 * AppFactor
          .Height = 25 * AppFactor
          .Tag = i
        End With

      Else If $xOption[i] = "Quantitative" Then
        With aValueBox[i]
          .X = (365 + 25) * AppFactor
          .Y = (i * 25 * Slider1.Value + 15) * AppFactor
          .Width = 150 * AppFactor
          .Height = 25 * AppFactor
          .Tag = i
        End With
        With aUnitText[i]
          .X = (525 + 25) * AppFactor
          .Y = (i * 25 * Slider1.Value + 15) * AppFactor
          .Width = 100 * AppFactor
          .Height = 25 * AppFactor
          .Tag = i
        End With

      Else If $xOption[i] = "Qualitative" Then
        With aLineText[i]
          .X = (365 + 25) * AppFactor
          .Y = (i * 25 * Slider1.Value + 15) * AppFactor
          .Width = 250 * AppFactor
          .Height = 25 * AppFactor
          .Tag = i
        End With

      Else
        With aHTMLText[i]
          .X = (365 + 25) * AppFactor
          .Y = (i * 25 * Slider1.Value + 15) * AppFactor
          .Width = 400 * AppFactor
          .Height = 25 * Slider1.Value * AppFactor
          .DictionaryPath = modBasic.$dictPathList
          .Tag = i
        End With

      Endif
    Endif

    ''create help button
    With aHelpButton[i]
      .X = (792 + 25) * AppFactor
      .Y = (i * 25 * Slider1.Value + 15) * AppFactor
      .Width = 25 * AppFactor
      .Height = 25 * AppFactor
      .Text = ""
      .Picture = Picture["icon:/small/info"]
      .Tag = i
    End With

  Next

  If aHTMLText[0] Then
    aHTMLText[0].SetFocus
  Else If aLineText[0] Then
    aLineText[0].SetFocus
  Else If aValueBox[0] Then
    aValueBox[0].SetFocus
  Else If aDateBox[0] Then
    aDateBox[0].SetFocus
  Else If aQuantiBox[0] Then
    aQuantiBox[0].SetFocus
  Endif

End

Public Sub btnexectext_Click()

  Dim j As Integer

  Try j = Application.ActiveControl.Tag
  If aHTMLText[j] Then
    aHTMLText[j].RichText = aHTMLText[j].RichText & modExternal.RunTextHelpScript(aHTMLText[j].Text)
  Endif

End

Public Sub dctexectext_Click()

  Dim xx As String
  Dim j As Integer

  Try j = Application.ActiveControl.Tag
  If aHTMLText[j] Then
    xx = GetRichTextArea(lblitem.Text, aHTMLText[j].RichText)
    If xx Then
      aHTMLText[j].RichText = xx
    Endif
  Endif

End

Public Sub btntemplsumm_Click()

  Dim j As Integer

  Try j = Application.ActiveControl.Tag
  If aHTMLText[j] Then
    aHTMLText[j].RichText = aHTMLText[j].RichText & DictionaryVIew(modBasic.$dictadvPath)
  Endif

End

Public Sub chkautoption_Click()

  modSettings.EnterCheckSetting(chkautoption, "EntrySetting/AutoDisplayOptions")

End

Public Sub btnrefresh_Click()

  modSettings.SaveSettingsToFile("MultipleTextBox/Height", Slider1.Value)
  DIsplayTextForm()

End

Public Sub btnBrChange_Click()

  modGeneralMain.SaveFormArrangement(Me)
  Me.Close()

End

Public Sub btnBrOK_Click()

  If $sTable = "Rec Examination" Then
    FillExamSubExam()
  Else
    FillGenExams($sTable)
  Endif
  Balloon.Info(("Information saved"), btnBrOK)
  Balloon.Delay = modBasic.$BalloonDelay

End

Private Sub FillGenExams(sTable As String)

  Dim i As Integer
  Dim xval As String

  For i = 0 To $xitem.Count - 1
    If $xType[i] = "Quantitative" Then
      If aQuantiBox[i].Value Then
        modClinic.AddQuantiData($encid, "", $xitem[i], aQuantiBox[i].Value, aAbnormCheck[i].Value, sTable, $xSysCons[i])
      Endif
    Else
      If $xOption[i] = "Multiple Selection" Then
        If aListBox[i].Count Then
          modClinic.AddQualiData($encid, "", $xitem[i], aListBox[i].List.Join(gb.NewLine), aAbnormCheck[i].Value, sTable, $xSysCons[i])
        Endif
      Else If $xOption[i] = "Text Table" Then
        xval = GetTableData(Split($xOpList[i]), aGridView[i])
        If xval Then
          modClinic.AddQualiData($encid, "", $xitem[i], modString.GetTableFormatFromText(xval), aAbnormCheck[i].Value, sTable, $xSysCons[i])
        Endif
      Else If $xOption[i] = "Single Selection" Then
        If aComboBox[i].Text Then
          modClinic.AddQualiData($encid, "", $xitem[i], aComboBox[i].Text, aAbnormCheck[i].Value, sTable, $xSysCons[i])
        Endif
      Else If $xOption[i] = "Dichotomous" Then
        If aDichoValue[i].Value Then
          modClinic.AddQualiData($encid, "", $xitem[i], aDichoValue[i].Value, aAbnormCheck[i].Value, sTable, $xSysCons[i])
        Endif
      Else If $xOption[i] = "Left and Right" Then
        If aLeftRight[i].DataText Then
          modClinic.AddQualiData($encid, "", $xitem[i], aLeftRight[i].DataText, aAbnormCheck[i].Value, sTable, $xSysCons[i])
        Endif
      Else If $xOption[i] = "Date Time" Then
        If aDateBox[i].Value Then
          modClinic.AddQualiData($encid, "", $xitem[i], aDateBox[i].Value, aAbnormCheck[i].Value, sTable, $xSysCons[i])
        Endif
      Else If $xOption[i] = "Quantitative" Then
        If aValueBox[i].Value Then
          modClinic.AddQualiData($encid, "", $xitem[i], CStr(aValueBox[i].Value) & Space(1) & aUnitText[i].Text, aAbnormCheck[i].Value, sTable, $xSysCons[i])
        Endif
      Else If $xOption[i] = "Qualitative" Then
        If aLineText[i].Text Then
          modClinic.AddQualiData($encid, "", $xitem[i], aLineText[i].Text, aAbnormCheck[i].Value, sTable, $xSysCons[i])
        Endif
      Else If $xOption[i] = "Clinical Scale" Then
        If aTextArea[i].Text Then
          modClinic.AddClinicExam($encid, "", $xitem[i], aTextArea[i].Text, aClinBox[i].Value, aAbnormCheck[i].Value, sTable, $xSysCons[i], "Regular")
        Endif
      Else
        If aHTMLText[i].RichText Then
          modClinic.AddQualiData($encid, "", $xitem[i], aHTMLText[i].RichText, aAbnormCheck[i].Value, sTable, $xSysCons[i])
        Endif
      Endif
    Endif
  Next

End

Private Sub FillExamSubExam()

  Dim i As Integer
  Dim xval As String

  For i = 0 To $xitem.Count - 1
    If $xType[i] = "Quantitative" Then
      If aQuantiBox[i].Value Then
        modClinic.AddClinicQuantiData($encid, $idList[i], $xitem[i], aQuantiBox[i].Value, aAbnormCheck[i].Value, $xSysCons[i])
      Endif
    Else
      If $xOption[i] = "Multiple Selection" Then
        If aListBox[i].Count Then
          modClinic.AddClinicQualiData($encid, $idList[i], $xitem[i], aListBox[i].List.Join(gb.NewLine), aAbnormCheck[i].Value, $xSysCons[i])
        Endif
      Else If $xOption[i] = "Text Table" Then
        xval = GetTableData(Split($xOpList[i]), aGridView[i])
        If xval Then
          modClinic.AddClinicQualiData($encid, $idList[i], $xitem[i], modString.GetTableFormatFromText(xval), aAbnormCheck[i].Value, $xSysCons[i])
        Endif
      Else If $xOption[i] = "Single Selection" Then
        If aComboBox[i].Text Then
          modClinic.AddClinicQualiData($encid, $idList[i], $xitem[i], aComboBox[i].Text, aAbnormCheck[i].Value, $xSysCons[i])
        Endif
      Else If $xOption[i] = "Dichotomous" Then
        If aDichoValue[i].Value Then
          modClinic.AddClinicQualiData($encid, $idList[i], $xitem[i], aDichoValue[i].Value, aAbnormCheck[i].Value, $xSysCons[i])
        Endif
      Else If $xOption[i] = "Left and Right" Then
        If aLeftRight[i].DataText Then
          modClinic.AddClinicQualiData($encid, $idList[i], $xitem[i], aLeftRight[i].DataText, aAbnormCheck[i].Value, $xSysCons[i])
        Endif
      Else If $xOption[i] = "Date Time" Then
        If aDateBox[i].Value Then
          modClinic.AddClinicQualiData($encid, $idList[i], $xitem[i], aDateBox[i].Value, aAbnormCheck[i].Value, $xSysCons[i])
        Endif
      Else If $xOption[i] = "Quantitative" Then
        If aValueBox[i].Value Then
          modClinic.AddClinicQualiData($encid, $idList[i], $xitem[i], CStr(aValueBox[i].Value) & Space(1) & aUnitText[i].Text, aAbnormCheck[i].Value, $xSysCons[i])
        Endif
      Else If $xOption[i] = "Qualitative" Then
        If aLineText[i].Text Then
          modClinic.AddClinicQualiData($encid, $idList[i], $xitem[i], aLineText[i].Text, aAbnormCheck[i].Value, $xSysCons[i])
        Endif
      Else If $xOption[i] = "Clinical Scale" Then
        If aTextArea[i].Text Then
          modClinic.AddClinicExam($encid, $idList[i], $xitem[i], aTextArea[i].Text, aClinBox[i].Value, aAbnormCheck[i].Value, "Rec Examination", $xSysCons[i], "Regular")
        Endif
      Else
        If aHTMLText[i].RichText Then
          modClinic.AddClinicQualiData($encid, $idList[i], $xitem[i], aHTMLText[i].RichText, aAbnormCheck[i].Value, $xSysCons[i])
        Endif
      Endif
    Endif
  Next

End

''------------------------------------- short cut keys ------------------------------
Public Sub Form_KeyRelease()

  Dim i As Integer
  Dim j As Integer

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    '     modGeneralmain.GoToNextControlTab()
  Else

    If Application.ActiveControl.Tag Then
      j = Application.ActiveControl.Tag
      If Key.Code = Key["O"] And If Key.Control Then
        OpenOption(j)
      Else If Key.Code = Key["A"] And If Key.Control Then
        If aAbnormCheck[j].Value = False Then
          aAbnormCheck[j].Value = True
        Else If aAbnormCheck[j].Value = True Then
          aAbnormCheck[j].Value = False
        Endif
      Endif
    Endif

    If Key.Code = Key.F1 Then
      i = 1
      If aHTMLText[i - 1] Then
        ScrollView1.EnsureVisible(aHTMLText[i - 1].x, aHTMLText[i - 1].y, aHTMLText[i - 1].Width, aHTMLText[i - 1].Height)
        OpenAutoOptions(i)
        aHTMLText[i - 1].SetFocus
      Endif
    Else If Key.Code = Key.F2 Then
      i = 2
      If aHTMLText[i - 1] Then
        ScrollView1.EnsureVisible(aHTMLText[i - 1].x, aHTMLText[i - 1].y, aHTMLText[i - 1].Width, aHTMLText[i - 1].Height)
        OpenAutoOptions(i)
        aHTMLText[i - 1].SetFocus
      Endif
    Else If Key.Code = Key.F3 Then
      i = 3
      If aHTMLText[i - 1] Then
        ScrollView1.EnsureVisible(aHTMLText[i - 1].x, aHTMLText[i - 1].y, aHTMLText[i - 1].Width, aHTMLText[i - 1].Height)
        OpenAutoOptions(i)
        aHTMLText[i - 1].SetFocus
      Endif
    Else If Key.Code = Key.F4 Then
      i = 4
      If aHTMLText[i - 1] Then
        ScrollView1.EnsureVisible(aHTMLText[i - 1].x, aHTMLText[i - 1].y, aHTMLText[i - 1].Width, aHTMLText[i - 1].Height)
        OpenAutoOptions(i)
        aHTMLText[i - 1].SetFocus
      Endif
    Else If Key.Code = Key.F5 Then
      i = 5
      If aHTMLText[i - 1] Then
        ScrollView1.EnsureVisible(aHTMLText[i - 1].x, aHTMLText[i - 1].y, aHTMLText[i - 1].Width, aHTMLText[i - 1].Height)
        OpenAutoOptions(i)
        aHTMLText[i - 1].SetFocus
      Endif
    Else If Key.Code = Key.F6 Then
      i = 6
      If aHTMLText[i - 1] Then
        ScrollView1.EnsureVisible(aHTMLText[i - 1].x, aHTMLText[i - 1].y, aHTMLText[i - 1].Width, aHTMLText[i - 1].Height)
        OpenAutoOptions(i)
        aHTMLText[i - 1].SetFocus
      Endif
    Else If Key.Code = Key.F7 Then
      i = 7
      If aHTMLText[i - 1] Then
        ScrollView1.EnsureVisible(aHTMLText[i - 1].x, aHTMLText[i - 1].y, aHTMLText[i - 1].Width, aHTMLText[i - 1].Height)
        OpenAutoOptions(i)
        aHTMLText[i - 1].SetFocus
      Endif
    Else If Key.Code = Key.F8 Then
      i = 8
      If aHTMLText[i - 1] Then
        ScrollView1.EnsureVisible(aHTMLText[i - 1].x, aHTMLText[i - 1].y, aHTMLText[i - 1].Width, aHTMLText[i - 1].Height)
        OpenAutoOptions(i)
        aHTMLText[i - 1].SetFocus
      Endif
    Else If Key.Code = Key.F9 Then
      i = 9
      If aHTMLText[i - 1] Then
        ScrollView1.EnsureVisible(aHTMLText[i - 1].x, aHTMLText[i - 1].y, aHTMLText[i - 1].Width, aHTMLText[i - 1].Height)
        OpenAutoOptions(i)
        aHTMLText[i - 1].SetFocus
      Endif
    Else If Key.Code = Key.F10 Then
      i = 10
      If aHTMLText[i - 1] Then
        ScrollView1.EnsureVisible(aHTMLText[i - 1].x, aHTMLText[i - 1].y, aHTMLText[i - 1].Width, aHTMLText[i - 1].Height)
        OpenAutoOptions(i)
        aHTMLText[i - 1].SetFocus
      Endif
    Else If Key.Code = Key.F11 Then
      i = 11
      If aHTMLText[i - 1] Then
        ScrollView1.EnsureVisible(aHTMLText[i - 1].x, aHTMLText[i - 1].y, aHTMLText[i - 1].Width, aHTMLText[i - 1].Height)
        OpenAutoOptions(i)
        aHTMLText[i - 1].SetFocus
      Endif
    Else If Key.Code = Key.F12 Then
      i = 12
      If aHTMLText[i - 1] Then
        ScrollView1.EnsureVisible(aHTMLText[i - 1].x, aHTMLText[i - 1].y, aHTMLText[i - 1].Width, aHTMLText[i - 1].Height)
        OpenAutoOptions(i)
        aHTMLText[i - 1].SetFocus
      Endif
    Endif

  Endif

End

''-----------------------------help options  --------------------------------------
Public Sub ButtonBoxgroup_Click()

  Dim j As Integer

  j = Last.Tag
  OpenOption(j)

End

Public Sub ComboGroup_GotFocus()

  Dim j As Integer

  j = Last.Tag
  If modBasic.$ItemListFormat = "GridView" Then
    If Not aComboBox[j].Text Then
      aComboBox[j].Popup
    Endif
  Endif

End

Public Sub ComboGroup_KeyRelease()

  Dim j As Integer

  j = Last.Tag
  modFillContainer.AutoFillComboBox(aComboBox[j])

End

Private Sub OpenAutoOptions(j As Integer)

  If $AutoOption = "Yes" Then
    If Not aHTMLText[j - 1].Text Then
      OpenOption(j - 1)
    Endif
  Endif

End

Private Sub OpenOption(j As Integer)

  Dim sVal As String[]
  Dim sPath As String
  Dim xval As String
  Dim xopt As String[]
  Dim xflot As Variant[]

  If $xType[j] = "Quantitative" Then
    xflot = GetQuantiValues("Exam", $encid, $xitem[j], 0, 0, aQuantiBox[j].Value)
    aQuantiBox[j].Value = xflot[0]

  Else
    If $xOpList[j] Then
      xopt = Split($xOpList[j], ";")

      If $xOption[j] = "Single Selection" Then
        sVal = SubChoose(xopt, "Single Selection", $xitem[j])
        If sVal Then
          aComboBox[j].Text = sVal.Join(";")
        Endif

      Else If $xOption[j] = "Dichotomous" Then

      Else If $xOption[j] = "Multiple Selection" Then
        sVal = SubChoose(xopt, "Multiple Selection", $xitem[j])
        If sVal Then
          aListBox[j].List = sVal
        Endif

      Else If $xOption[j] = "Text Table" Then
        xval = TableEntry(xopt, $xitem[j], "")
        If xval Then
          DisplayAgegrid(Split($xOpList[j], ";"), xval, aGridView[j])
        Endif

      Else If $xOption[j] = "Clinical Scale" Then
        sVal = SubChoose(xopt, "Clinical Scale", $xitem[j])
        If sVal Then
          aClinBox[j].Value = sVal[0]
          aTextArea[j].Text = sVal[1]
        Endif

      Else If $xOption[j] = "Visual Input" Then
        sPath = modImage.DisplayVisualData(lblitem.Text, $xitem[j], $xOption[j])
        If sPath Then
          xval = CVisualValue(lblitem.Text, sPath, aHTMLText[j].Text)
          If xval Then
            aHTMLText[j].Text = xval
          Endif
        Endif

      Endif
    Endif

  Endif

End

''======================= For GridView (copied from TextTable)=================
Private Sub DisplayAgegrid(sColumns As String[], sTable As String, GridView1 As GridView)

  Dim $ageFile As String[]
  Dim sline As String
  Dim sCol As String[]
  Dim Row As Integer
  Dim Column As Integer

  GridView1.Clear
  GridView1.Columns.Count = sColumns.Count
  GridView1.Rows.Count = Split(sTable, gb.NewLine).Count - 1

  Row = 0
  $ageFile = Split(sTable, gb.NewLine)
  For Each sline In $ageFile
    sCol = Split(sline, ";")
    If sline = $ageFile[0] Then
    Else
      For Column = 0 To sCol.Count - 1
        GridView1[Row - 1, Column].Text = sCol[Column]
      Next
    Endif
    Row = Row + 1
  Next

  For Column = 0 To sColumns.Count - 1
    GridView1.Columns[Column].Text = sColumns[Column]
    Try GridView1.Columns.Width = CInt(Floor(Frame1.Width / sCol.Count))
  Next

End

Private Function GetTableData(sColumns As String[], GridView1 As GridView) As String

  Dim Row As Integer
  Dim Column As Integer
  Dim sCol As String[]
  Dim sRow As String[]
  Dim xval As String

  sRow = New String[]
  sRow.Add(sColumns.Join(";"))
  For Row = 0 To GridView1.Rows.Count - 1
    sCol = New String[]
    For Column = 0 To GridView1.Columns.Count - 1
      sCol.Add(GridView1[Row, Column].Text)
    Next
    sRow.Add(sCol.Join(";"))
  Next
  xval = sRow.Join(gb.NewLine)
  Return xval

End
