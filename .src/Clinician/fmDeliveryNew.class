Private Function GetDeliveryExamCategory(sCateg As String) As String

  Dim xx As String

  If sCateg = "Pre Delivery Exam" Then
    xx = "Pre Delivery"
  Else If sCateg = "On Delivery Exam" Then
    xx = "On Delivery"
  Else If sCateg = "Post Delivery Exam" Then
    xx = "Post Delivery"
  Else If sCateg = "Baby Examination" Then
    xx = "Baby Examination"
  Endif
  Return xx

End

Private Sub AddDeliverySelection(encid As String, sExamLabel As String, sysConst As String, sType As String, xcategory As String, OptionType As String)

  Dim sExam As String
  Dim sName As String
  Dim xquantival As Variant[]
  Dim yqualival As Variant[]
  Dim lftrtval As Variant[]
  Dim xlimit As Float[]
  Dim opt As String[]
  Dim sVal As String[]
  Dim xdate As Date
  Dim xval As String
  Dim examtype As String

  If modSysCons.SysExaminationList().Exist(sysConst) = True Then
    sExam = modFixClinic.GetExamIDFromSysConst(sysConst)
    examtype = "Exam"
  Else If modSysCons.SysLabTestList().Exist(sysConst) = True Then
    sExam = modFixLab.GetLabTestIDFromSysConst(sysConst)
    examtype = "Test"
  Else If modBasic.$sysRadioList.Exist(sysConst) = True Then
    sExam = modFixRadio.GetRadioTestIDFromSysConst(sysConst)
    examtype = "Radio"
  Else If modBasic.$DemogList.Exist(sysConst) = True Then
    sExam = sysConst
    examtype = "Demog"
  Else
    examtype = "Exam"
  Endif

  If sExam Then
    sName = sExam
  Else
    sName = sExamLabel
  Endif

  If sType = "Quantitative" Then
    xlimit = modClinic.GetBothQuantiExamVal(sExam, encid)
    xquantival = GetQuantiValues(examtype, encid, sName, xlimit[0], xlimit[1], 0)
    If xquantival Then
      modClinic.AddQuantiData(encid, "", sExamLabel, xquantival[0], xquantival[1], xcategory, sysConst)
    Endif
  Else
    If OptionType = "Sys Constant" Then
      yqualival = modExamOption.GetQualiExamOptionDirectValue(sName, "", examtype)

    Else If OptionType = "Date Time" Then
      xdate = GetDateValue(("Select Date Time"), sName, "")
      If xdate Then
        yqualival = [Format(xdate, gb.GeneralDate), False]
      Endif

    Else If OptionType = "Qualitative" Then
      xval = InputBox(sName, "Qualitative", "")
      If xval Then
        yqualival = [xval, False]
      Endif

    Else If OptionType = "Left and Right" Then
      lftrtval = CLeftRight(sName, "")
      If lftrtval Then
        yqualival = [modString.GetLefRightJSON(lftrtval[0], lftrtval[1]), lftrtval[2]]
      Endif

    Else If OptionType = "Single Selection" Or If OptionType = "Dichotomous" Or If OptionType = "Multiple Selection" Then
      opt = modFillContainer.GetListFromResult(modDatabase.$myConn.Exec("select fldanswer from tbldeptexamoption where fldexamid=&1 and flddept=&2 and fldtanswertype=&3 ORDER BY fldindex", sExamLabel, GetDeliveryExamCategory(xcategory), OptionType))
      If opt.Count Then
        sVal = SubChoose(opt, OptionType, sExamLabel)
        If sVal Then
          yqualival = [sVal.Join(gb.NewLine), False]
        Endif
      Else
        yqualival = GetQualiValues(sName, "", "Exam")
      Endif

    Else If OptionType = "Text Table" Then
      opt = modFillContainer.GetListFromResult(modDatabase.$myConn.Exec("select fldanswer from tbldeptexamoption where fldexamid=&1 and flddept=&2 and fldtanswertype=&3 ORDER BY fldindex", sExamLabel, GetDeliveryExamCategory(xcategory), OptionType))
      If opt.Count Then
        xval = TableEntry(opt, sExamLabel, "")
        If xval Then
          yqualival = [modString.GetTableFormatFromText(xval), False]
        Endif
      Else
        yqualival = GetQualiValues(sName, "", "Exam")
      Endif

    Else
      yqualival = GetQualiValues(sName, "", "Exam")
    Endif
    If yqualival Then
      If yqualival.Count = 3 And If yqualival[2] Then
        modClinic.AddClinicExam(encid, "", sExamLabel, yqualival[0], CFloat(yqualival[2]), yqualival[1], xcategory, sysConst, "Regular")
      Else
        modClinic.AddClinicExam(encid, "", sExamLabel, yqualival[0], 0, yqualival[1], xcategory, sysConst, "Regular")
      Endif
    Endif
  Endif ''quali or quanti

End

