    }
    { TextBox1 TextBox
      MoveScaled(37,5,37,3)
      Visible = False
    }
    { ComboBox1 ComboBox
      MoveScaled(37,5,37,3)
      Visible = False
    }
    { ValueBox1 ValueBox
      MoveScaled(37,5,37,3)
      Visible = False
    }
    { btnadd Button
      MoveScaled(75,5,13,3)
      Tag = "Auto"
      Text = ("Add")
      Picture = Picture["icon:/small/add"]
    }
    { GridView1 GridView
      MoveScaled(29,9,59,48)
