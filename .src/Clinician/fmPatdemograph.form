      ReadOnly = True
    }
    { Label4 Label
      MoveScaled(64,1,8,3)
      Text = ("Gender")
      Border = Border.Plain
    }
    { txtgender TextBox
      MoveScaled(73,1,15,3)
      ReadOnly = True
    }
    { btnreport Button
      MoveScaled(1,54,27,3)
      Text = ("Export")
      Picture = Picture["icon:/small/file"]
    }
    { Label1 Label
      MoveScaled(29,5,7,3)
      Text = ("Value")
      Border = Border.Plain
    }
    { Panel2 Panel
      MoveScaled(1,51,27,3)
