Public Sub btnnutrition_Click()

  Dim xPath As String
  Dim encList As String[]
  Dim i As Integer

  encList = New String[]
  For i = 0 To GridView1.Rows.Count - 1
    encList.Add(GridView1[i, 2].Text)
  Next
  If encList Then
    Dialog.Title = "Select Diet Plan Date"
    If Dialog.SelectDate() Then Return
    xPath = modCHTMLPatSummary.GetPlannedFoodReport(Dialog.Date, encList, cmbdept.Text)
    modPrint.OpenHTMLPreview("", xPath, "ReportSize")
  Endif

End

