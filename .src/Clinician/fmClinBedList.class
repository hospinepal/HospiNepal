Private Sub OpenPatientForms()

  Dim hForm As FmPatientMain
  Dim hForm1 As FmDeliveryNew
  Dim hForm2 As FmExamReporting
  Dim hForm3 As FmVital
  Dim hForm4 As FmDosecount
  Dim hForm5 As FmMiniProcedure
  Dim hForm6 As FmEquipment
  Dim hForm7 As FmPatdemograph
  Dim hForm8 As FmPatImage
  Dim hForm9 As FmEventTime
  Dim hForm10 As FmTestList
  Dim hForm11 As FmRadioList
  Dim hForm12 As FmMedOrder
  Dim hForm13 As FmOralIntake
  Dim hForm14 As FmClinOutValue

  Dim hForm16 As FmReqVital
  Dim hForm17 As FmPersonImage
  Dim hForm18 As FmWardHistory

  Dim xPath As String

  If modHelpVariable.$LogInCategory = "Clinician" Then
    If cmbdefform.Text Then
      If cmbdefform.Text = "Essen Exams" Then
        hForm3 = New FmVital(GridView1[GridView1.Row, 2].Text)
        hForm3.ShowModal
      Else If cmbdefform.Text = "Drug Dosing" Then
        hForm4 = New FmDosecount(GridView1[GridView1.Row, 2].Text, "IPD")
        hForm4.ShowModal
      Else If cmbdefform.Text = "PO Intake" Then
        hForm13 = New FmOralIntake(GridView1[GridView1.Row, 2].Text)
        hForm13.ShowModal
      Else If cmbdefform.Text = "Fluid Output" Then
        hForm14 = New FmClinOutValue("Output Fluid", GridView1[GridView1.Row, 2].Text, modBasic.$ClinBodyFluidAll, 0, "mL")
        hForm14.ShowModal
      Else If cmbdefform.Text = "Minor Procedures" Then
        If modNonMedical.AllowEntryWithDeposit(GridView1[GridView1.Row, 2].Text, "Procedure") = True Then
          hForm5 = New FmMiniProcedure(GridView1[GridView1.Row, 2].Text, modBillings.GetDefaultIPCashMode("Procedure", GridView1[GridView1.Row, 2].Text))
          hForm5.ShowModal
        Endif
      Else If cmbdefform.Text = "Equipment" Then
        If modNonMedical.AllowEntryWithDeposit(GridView1[GridView1.Row, 2].Text, "Equipment") = True Then
          hForm6 = New FmEquipment(GridView1[GridView1.Row, 2].Text, modBillings.GetDefaultIPCashMode("Equipment", GridView1[GridView1.Row, 2].Text))
          hForm6.ShowModal
        Endif
      Else If cmbdefform.Text = "Demographics" Then
        hForm7 = New FmPatdemograph(GridView1[GridView1.Row, 2].Text)
        hForm7.ShowModal
      Else If cmbdefform.Text = "Profile Picture" Then
        hForm17 = New FmPersonImage("Patient", modPatient.GetPatientNoByEnc(GridView1[GridView1.Row, 2].Text))
        hForm17.ShowModal
      Else If cmbdefform.Text = "Patient Images" Then
        hForm8 = New FmPatImage("IMAGE", GridView1[GridView1.Row, 2].Text, "")
        hForm8.ShowModal
      Else If cmbdefform.Text = "Patient Events" Then
        hForm9 = New FmEventTime(GridView1[GridView1.Row, 2].Text, "General")
        hForm9.ShowModal

      Else If cmbdefform.Text = "Laboratory" Then
        If modNonMedical.AllowEntryWithDeposit(GridView1[GridView1.Row, 2].Text, "Test") = True Then
          hForm10 = New FmTestList(GridView1[GridView1.Row, 2].Text, modBillings.GetDefaultIPCashMode("Test", GridView1[GridView1.Row, 2].Text))
          hForm10.ShowModal
        Endif
      Else If cmbdefform.Text = "Radiology" Then
        If modNonMedical.AllowEntryWithDeposit(GridView1[GridView1.Row, 2].Text, "Radio") = True Then
          hForm11 = New FmRadioList(GridView1[GridView1.Row, 2].Text, modBillings.GetDefaultIPCashMode("Radio", GridView1[GridView1.Row, 2].Text))
          hForm11.ShowModal
        Endif
      Else If cmbdefform.Text = "Pharmacy" Then
        If modNonMedical.AllowEntryWithDeposit(GridView1[GridView1.Row, 2].Text, "Pharmacy") = True Then
          hForm12 = New FmMedOrder(GridView1[GridView1.Row, 2].Text, "Admitted", modBillings.GetDefaultIPCashMode("Pharmacy", GridView1[GridView1.Row, 2].Text), "IPD")
          hForm12.ShowModal
        Endif

      Else If cmbdefform.Text = "Monitoring" Then
        hForm16 = New FmReqVital(GridView1[GridView1.Row, 2].Text, modPatient.CurrentAdmissionStatus(GridView1[GridView1.Row, 2].Text))
        hForm16.ShowModal

      Else If cmbdefform.Text = "Complete" Then
        xPath = modPatReports.ShowCompleteReport(GridView1[GridView1.Row, 2].Text, "Metric")
        modPrint.OpenHTMLPreview(GridView1[GridView1.Row, 2].Text, xPath, "ReportSize")
      Else If cmbdefform.Text = "Nursing" Then
        xPath = modCHTMLPatient.NursingCheckReport(GridView1[GridView1.Row, 2].Text)
        modPrint.OpenHTMLPreview(GridView1[GridView1.Row, 2].Text, xPath, "ReportSize")

      Else If cmbdefform.Text = "Delivery" Then
        hForm1 = New FmDeliveryNew(GridView1[GridView1.Row, 2].Text, True)
        modHelpVariable.AddNewFormToWorkspace(hForm1)
      Else If cmbdefform.Text = "Examination" Then
        hForm2 = New FmExamReporting(GridView1[GridView1.Row, 2].Text, True)
        modHelpVariable.AddNewFormToWorkspace(hForm2)
      Else If cmbdefform.Text = "InPatient" Then
        hForm = New FmPatientMain(GridView1[GridView1.Row, 2].Text, True)
        modHelpVariable.AddNewFormToWorkspace(hForm)
      Else
        hForm18 = New FmWardHistory(cmbdefform.Text, GridView1[GridView1.Row, 2].Text, "Departmental")
        modHelpVariable.FindWorSpace(modHelpVariable.$LogInCategory).Add(hForm18)
      Endif

    Else
      hForm = New FmPatientMain(GridView1[GridView1.Row, 2].Text, True)
      modHelpVariable.AddNewFormToWorkspace(hForm)
    Endif
  Endif

End

