' Gambas class file

Private $UserRestrict As String[]
Private $ExamLst As String[]

Public Sub Form_Open()

  modGeneralMain.ArrangeEmbedForms(Me, Panel1, "Vertical")
  Me.Icon = Picture[modGeneralMain.$strLogo]
  $UserRestrict = modBasic.$ClinicDisableCompo
  $ExamLst = modMedicine.FillClinicalSubClass("Departmental")
  cmbdept.List = modBasic.$IPDDepartmentsAll
  cmbdept.Add("Unallocated")
  cmbdept.Add("%")
  If modHelpVariable.$LogInCategory = "Clinician" Then
    cmbdefform.List = GetComboItemList()
  Endif
  If modBasic.$FixedDepartment Then
    cmbdept.Text = modBasic.$FixedDepartment
    If modBasic.$LockToOwnDepart = "Yes" Then
      cmbdept.Enabled = False
    Endif
  Endif

  If modHelpVariable.$LogInCategory = "Cashier" Then
    btnautoround.Visible = True
    btnautobill.Visible = True
    If modGlobalSetting.ShowSettingFromDB("AutoServiceBilling/BedCharge") = "Yes" Then
      ActivateAutoBilling()
    Endif
    If modGlobalSetting.ShowSettingFromDB("AutoServiceBilling/RoundCharge") = "Yes" Then
      ActivateAutoRound()
    Endif
  Endif
  cmbdept.SetFocus

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

Public Function GetComboItemList() As String[]

  Dim xx As String[]

  xx = New String[]
  xx.Add("- ACTIVITIES -")
  If $UserRestrict.Exist("Essential Examinations") = False Then
    xx.Add("Essen Exams")
  Endif
  If $UserRestrict.Exist("Medicine Dosing") = False Then
    xx.Add("Drug Dosing")
  Endif
  If $UserRestrict.Exist("Input Output") = False Then
    xx.Add("PO Intake")
    xx.Add("Fluid Output")
  Endif
  If $UserRestrict.Exist("Minor Procedure") = False Then
    xx.Add("Minor Procedures")
  Endif
  If $UserRestrict.Exist("Equipments Used") = False Then
    xx.Add("Equipment")
  Endif
  If $UserRestrict.Exist("Demographics") = False Then
    xx.Add("Demographics")
  Endif
  xx.Add("Profile Picture")
  If $UserRestrict.Exist("General Images") = False Then
    xx.Add("Patient Images")
  Endif
  If $UserRestrict.Exist("Event Timing") = False Then
    xx.Add("Patient Events")
  Endif

  xx.Add("- REQUESTS -")
  If $UserRestrict.Exist("Laboratory Request") = False Then
    xx.Add("Laboratory")
  Endif
  If $UserRestrict.Exist("Radiology Request") = False Then
    xx.Add("Radiology")
  Endif
  If $UserRestrict.Exist("Pharmacy Request") = False Then
    xx.Add("Pharmacy")
  Endif
  If $UserRestrict.Exist("Monitoring Plan") = False Then
    xx.Add("Monitoring")
  Endif
  If $UserRestrict.Exist("PO Intake Plan") = False Then
    xx.Add("Nutrition")
  Endif

  xx.Add("-- FORMS --")
  xx.Add("InPatient")
  xx.Add("Delivery")
  xx.Add("Examination")
  If $ExamLst Then
    xx.Insert($ExamLst)
  Endif

  xx.Add("- REPORTS -")
  xx.Add("Nursing")
  xx.Add("Complete")
  Return xx                                             ''

End

Public Sub cmbdefform_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbdefform)
  modFillContainer.RestrictComboToContent(cmbdefform)

End

Public Sub btnrefresh_Click()

  If cmbdept.Text Then
    FillBedGrid()
    GridView1.SetFocus
  Endif

End

Public Sub btnrefresh_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    btnrefresh_Click()
  Endif

End

Private Sub FillBedGrid()

  Dim sql As String
  Dim res As Result

  If cmbdept.Text = "%" Then
    sql = "select fldencounterval,fldcurrlocat,fldencounterval,fldencounterval,fldencounterval,fldencounterval,fldencounterval,fldencounterval from tblencounter where fldadmission=&1 ORDER BY flddoa DESC"                       ''
    res = modDatabase.$myConn.Exec(sql, "Admitted")
  Else If cmbdept.Text = "Unallocated" Then
    sql = "select fldencounterval,fldcurrlocat,fldencounterval,fldencounterval,fldencounterval,fldencounterval,fldencounterval,fldencounterval from tblencounter where fldadmission=&1 and fldcurrlocat IS &2"                       ''
    res = modDatabase.$myConn.Exec(sql, "Admitted", Null)
  Else
    sql = "select fldencounterval,fldbed,fldencounterval,fldencounterval,fldencounterval,fldencounterval,fldencounterval,fldencounterval from tbldepartmentbed where fldencounterval like &1 and flddept=&2 ORDER BY fldbed ASC"                       ''
    res = modDatabase.$myConn.Exec(sql, "%", cmbdept.Text)
  Endif
  ResizeGrid(res)

End

Public Sub btnsearch_Click()

  Dim sql As String
  Dim enc As String
  Dim res As Result

  If modBasic.$AutoEncPrefix = "Yes" Then
    enc = InputBox(("Encounter ID of Patient"), ("Search Patient"), modBasic.$EncIdPrefix)
  Else
    enc = InputBox(("Encounter ID of Patient"), ("Search Patient"), "")
  Endif
  If enc Then
    sql = "select fldencounterval,fldcurrlocat,fldencounterval,fldencounterval,fldencounterval,fldencounterval,fldencounterval,fldencounterval from tblencounter where fldadmission=&1 and fldencounterval=&2"                       ''
    res = modDatabase.$myConn.Exec(sql, "Admitted", enc)
    ResizeGrid(res)
  Endif

End

Private Sub ResizeGrid(res As Result)

  Dim Column As Integer
  Dim fld As ResultField

  GridView1.Clear()
  GridView1.Columns.Count = 8
  GridView1.Rows.Count = res.Count

  For Each res
    Column = 0
    For Each fld In res.Fields
      modGeneralMain.GridExplicitDecoration(GridView1, res.Index, Column)
      If Column = 0 Then
        GridView1[res.Index, Column].Text = ""
        GridView1[res.Index, Column].Background = modPatient.GetPatientColor(res[fld.Name])
      Else If Column = 1 Then
        GridView1[res.Index, Column].Text = res[fld.Name]
      Else If Column = 3 Then
        GridView1[res.Index, Column].Text = modPatient.GetPatientNameByEnc(res[fld.Name], modDatabase.$syConn)
        GridView1[res.Index, Column].WordWrap = True
      Else If Column = 4 Then
        GridView1[res.Index, Column].RichText = modPatient.GetPatientAgeString(res[fld.Name], Now()) & "/" & modPatient.GetPatientSex(res[fld.Name], modDatabase.$syConn) & "<br>" & "<small>" & modReportVar.GetDateTimeReport(modPatient.GetAdmissionDate(res[fld.Name]), gb.GeneralDate) & "</small>"                           ''
      Else If Column = 5 Then
        GridView1[res.Index, Column].Picture = Picture["icon:/small/access"]
        GridView1[res.Index, Column].Text = ""
      Else If Column = 6 Then
        GridView1[res.Index, Column].Font.Grade = -1
        GridView1[res.Index, Column].Text = modPatient.PatientDiagnoCurrentList(res[fld.Name]).Join(gb.NewLine)
        GridView1[res.Index, Column].WordWrap = True
      Else If Column = 7 Then
        GridView1[res.Index, Column].Text = modGeneral.GetUserFullName(modPatient.GetAttendingConsultant(res[fld.Name]))
        GridView1[res.Index, Column].WordWrap = True
      Else
        GridView1[res.Index, Column].Text = res[fld.Name]
      Endif
      Column = Column + 1
    Next
  Next
  GridView1.Row = 0

  With GridView1
    .Rows.Height = 50 * modBasic.$AppWidthRatio
    .Columns[0].Width = 25
    .Columns[1].Width = 75 * modBasic.$AppWidthRatio
    .Columns[2].Width = 100 * modBasic.$AppWidthRatio
    .Columns[3].Width = 175 * modBasic.$AppWidthRatio
    .Columns[4].Width = 100 * modBasic.$AppWidthRatio
    .Columns[5].Width = 25 * modBasic.$AppWidthRatio
    .Columns[6].Width = 275 * modBasic.$AppWidthRatio
    .Columns[7].Width = 100 * modBasic.$AppWidthRatio

    .Columns[1].Text = "Bed"
    .Columns[2].Text = "EncID"
    .Columns[3].Text = "Name"
    .Columns[4].Text = "Age/Sex"
    .Columns[6].Text = "Diagnosis"
    .Columns[7].Text = "Consult"
  End With

End

Public Sub GridView1_Click()

  If GridView1.Column = 5 Then
    GridView1.Enabled = False
    If modHelpVariable.$LogInCategory = "Clinician" Then
      OpenPatientForms()
    Endif
    GridView1.Enabled = True
  Endif

End

Public Sub GridView1_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    If modHelpVariable.$LogInCategory = "Clinician" Then
      OpenPatientForms()
    Endif
  Endif

End

