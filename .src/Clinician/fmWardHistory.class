End

''-------------------
Public Sub Form_KeyRelease()

  If Key.Code = Key.Up Or If Key.Code = Key.Down Then
    grdtreeview.SetFocus
  Else If Key.Code = Key["F"] And If Key.Control Then
    txtencid.Text = GetEncid()
  Else
    modGeneralmain.GoToNextControlTab()
  Endif

End

Private Sub ButtonControl()

  Dim xx As Boolean

  xx = modPatient.EnableClinicForm(txtnow.Text)
  grdtreeview.Enabled = xx
  TableView1.Enabled = xx
  mnudemo.Enabled = xx
  mnulab.Enabled = xx
  mnuradioreq.Enabled = xx

  If $UserRestrict Then
    UserAccessRestrict()
  Endif

End

Private Sub UserAccessRestrict()

  If $UserRestrict.Exist("Bed Assignment") Then
    tlbtnaddbed.Enabled = False
  Endif
  If $UserRestrict.Exist("Body Weight") Then
    tlbtnadwt.Enabled = False
  Endif
  If $UserRestrict.Exist("Body Height") Then
    tlbtnadd1.Enabled = False
  Endif
  If $UserRestrict.Exist("Complete Examination") Then
    grdtreeview.Enabled = False
    TableView1.Enabled = False
  Endif
  If $UserRestrict.Exist("Laboratory Request") Then
    mnulab.Enabled = False
  Endif
  If $UserRestrict.Exist("Radiology Request") Then
    mnuradioreq.Enabled = False
  Endif
  If $UserRestrict.Exist("Demographics") Then
    mnudemo.Enabled = False
  Endif
  If $UserRestrict.Exist("General Images") Then
    mnupatimage.Enabled = False
  Endif
  If $UserRestrict.Exist("DICOM Images") Then
    mnupacsimage.Enabled = False
  Endif

End

''=================== Examination ===============================
Private Sub LoadTreeData()

  FillClinicalTree(grdtreeview, $Category, cmbcategory.Text, $sDepart)
  grdtreeview.SetFocus

End

Public Sub cmbcategory_Click()

  If cmbcategory.Text Then
    LoadTreeData()
  Endif

End

Public Sub cmbcategory_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbcategory)
  modFillContainer.RestrictComboToContent(cmbcategory)

End

Public Sub grdtreeview_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    grdtreeview_Click()
  Endif

End

Public Sub grdtreeview_Click()

  Dim res As Result
  Dim sList As String[]
  Dim hForm As FmEnterMultiExam

  If grdtreeview.Current Then
    If txtencid.Text Then
      If modSettings.ShowSettingFromFIle("ClinicForms/GroupStructuredExams") = "Yes" Then
        sList = New String[]
        res = modDatabase.$myConn.Exec("select fldheadcode from tblstructexam where fldclass=&1 and fldsubclass=&2 and fldcategory=&3 and flditem=&4 and fldreferencee=&5", $sDepart, $Category, cmbcategory.Text, grdtreeview.Current.Text, $reference)
        If res.Available Then
          For Each res
            sList.Add(res!fldheadcode)
          Next
          hForm = New FmEnterMultiExam(grdtreeview.Current.Text, Trim(txtencid.Text), "Rec Examination", sList)
          hForm.ShowModal
        Endif

      Else
        If grdtreeview.Current.Picture = Picture["icons/coll3.png"] Then
          SelectDIrectEntryForm()
        Else
          modFillContainer.ExpandClickTreeView(grdtreeview)
        Endif
      Endif
      ShowClinicTable()
    Endif
  Endif

End

Private Sub ShowClinicTable()

  If grdtreeview.Current.Picture = Picture["icons/coll2.png"] Then
    If $secText Then
      grdtreeview[$secText].Expanded = False
    Endif
    $rData = modDatabase.$myConn.Exec("select fldid,fldtype,fldtime,fldhead,fldabnormal,fldid,fldid,fldserialval,fldrepquali,fldrepquanti from tblpatientexam where fldinput=&1 and fldencounterval=&2 and fldsave=&3 and fldserialval in(select fldheadcode from tblstructexam where fldsubclass=&4 and fldcategory=&5 and flditem=&6 and fldclass=&7 and fldreferencee=&8)", "Rec Examination", Trim(txtencid.Text), True, $Category, cmbcategory.Text, grdtreeview.Current.Text, $sDepart, $reference)
    $secText = grdtreeview.Current.Key

  Else
    $rData = modDatabase.$myConn.Exec("select fldid,fldtype,fldtime,fldhead,fldabnormal,fldid,fldid,fldserialval,fldrepquali,fldrepquanti from tblpatientexam where fldinput=&1 and fldencounterval=&2 and fldsave=&3 and fldserialval in(select fldheadcode from tblstructexam where fldsubclass=&4 and fldcategory=&5 and flditem=&6 and fldclass=&7 and fldreferencee=&8)", "Rec Examination", Trim(txtencid.Text), True, $Category, cmbcategory.Text, modFillContainer.GetTextFromTreeKey(grdtreeview.Current.ParentKey), $sDepart, $reference)                                                                      ''

  Endif

  $aMyFields = New String[]
  modGridView.ReadSmallData(TableView1, $rData, $aMyFields)
  With TableView1
    .Columns[0].Width = 1
    .Columns[1].Width = 1
    .Columns[2].Width = 150 * modBasic.$AppWidthRatio
    .Columns[3].Width = 175 * modBasic.$AppWidthRatio
    .Columns[4].Width = 20
    .Columns[5].Width = 250 * modBasic.$AppWidthRatio
    .Columns[6].Width = 25 * modBasic.$AppWidthRatio
    .Columns[7].Width = 1
    .Columns[8].Width = 1
    .Columns[9].Width = 1

    .Columns[2].Text = "Time"
    .Columns[3].Text = "Examination"
    .Columns[5].Text = "Observation"
  End With

End

Public Sub TableView1_Data(Row As Integer, Column As Integer)

  $rData.MoveTo(Row)
  modGeneralMain.GridViewDecoration(TableView1, Row)
  If Column = 2 Then
    Try TableView1.Data.Text = modReportVar.GetDateTimeReport($rData["fldtime"], gb.GeneralDate)
  Else If Column = 5 Then
    TableView1.Data.RichText = modClinic.GetExamValueString(Trim(txtencid.Text), $rData["fldid"], False)
  Else If Column = 4 Then
    TableView1.Data.Picture = Picture[modGridView.GetGridIcon($rData["fldabnormal"])]
    TableView1.Data.Text = ""
  Else If Column = 6 Then
    TableView1.Data.Picture = Picture["icon:/small/cancel"]
    TableView1.Data.Text = ""
  Else
    TableView1.Data.Text = $rData[$aMyFields[Column]]
  Endif

End

Public Sub TableView1_Click()

  Dim yqualival As Variant[]
  Dim xquantival As Variant[]
  Dim rsn As Result
  Dim Row As Integer
  Dim abc As String
  Dim xdate As Date
  Dim res As Result

  Dim opt As String[]
  Dim xval As String
  Dim sTable As String[]
  Dim examtype As String
  Dim sExam As String
  Dim sName As String
  Dim xType As String

  Row = TableView1.Row
  If TableView1.Column = 5 Then
    If TableView1[TableView1.Row, 1].Text = "Qualitative" Then
      rsn = modDatabase.$myConn.Exec("select fldhead,fldtesttype,fldtanswertype,fldsysconst from tblstructexam where fldheadcode=&1", TableView1[TableView1.Row, 7].Text)

      If rsn!fldsysconst Then
        If modSysCons.SysExaminationList().Exist(rsn!fldsysconst) = True Then
          sExam = modFixClinic.GetExamIDFromSysConst(rsn!fldsysconst)
          examtype = "Exam"
        Else If modSysCons.SysLabTestList().Exist(rsn!fldsysconst) = True Then
          sExam = modFixLab.GetLabTestIDFromSysConst(rsn!fldsysconst)
          examtype = "Test"
        Else If modBasic.$sysRadioList.Exist(rsn!fldsysconst) = True Then
          sExam = modFixRadio.GetRadioTestIDFromSysConst(rsn!fldsysconst)
          examtype = "Radio"
        Else If modBasic.$DemogList.Exist(rsn!fldsysconst) = True Then
          sExam = rsn!fldsysconst
          examtype = "Demog"
        Else
          examtype = "Exam"
        Endif
      Else
        examtype = "Exam"
      Endif

      If sExam Then
        sName = sExam
      Else
        sName = TableView1[TableView1.Row, 3].Text
      Endif

      If rsn!fldtanswertype = "Left and Right" Then
        yqualival = CLeftRight(TableView1[TableView1.Row, 3].Text, TableView1[TableView1.Row, 8].Text)
        If yqualival Then
          modClinic.UpdateClinicQualiData(TableView1[TableView1.Row, 0].Text, modString.GetLefRightJSON(yqualival[0], yqualival[1]), yqualival[2])
        Endif

      Else If rsn!fldtanswertype = "Date Time" Then
        xdate = GetDateValue(TableView1[TableView1.Row, 0].Text, ("Select Date Time"), CDate(TableView1[TableView1.Row, 5].RichText))
        If xdate Then
          modClinic.UpdateClinicQualiData(TableView1[TableView1.Row, 0].Text, Format(xdate, gb.GeneralDate), False)
        Endif

      Else If rsn!fldtanswertype = "Text Table" Then
        sTable = modString.ConverTableRichTextToGrid(TableView1[TableView1.Row, 5].RichText)
        opt = Split(sTable[0], ";")
        xval = TableEntry(opt, TableView1[TableView1.Row, 3].Text, sTable[1])
        If xval Then
          modClinic.UpdateClinicQualiData(TableView1[TableView1.Row, 0].Text, modString.GetTableFormatFromText(xval), False)
        Endif

      Else If rsn!fldtanswertype = "Qualitative" Then
        xval = InputBox(TableView1[TableView1.Row, 3].Text, "Qualitative", TableView1[TableView1.Row, 5].RichText)
        If xval Then
          modClinic.UpdateClinicQualiData(TableView1[TableView1.Row, 0].Text, xval, False)
        Endif

      Else
        xType = modExamOption.GetVariableOptionType(examtype, sName) ''modFixClinic.GetExamtOptionType(sName)
        If xType = "Clinical Scale" Then
          yqualival = modExamOption.GetClinScalePopUp(examtype, sName)
          If yqualival Then
            modClinic.UpdateQualiQuantiData(TableView1[TableView1.Row, 0].Text, yqualival[1], CFloat(yqualival[0]), False)
          Endif
        Else
          yqualival = GetQualiValues(sName, TableView1[TableView1.Row, 5].RichText, examtype)
          If yqualival Then
            modClinic.UpdateClinicQualiData(TableView1[TableView1.Row, 0].Text, yqualival[0], yqualival[1], yqualival[2])
          Endif
        Endif
      Endif

    Else If TableView1[TableView1.Row, 1].Text = "Quantitative" Then
      xquantival = GetQuantiValues(examtype, Trim(txtencid.Text), sName, 0, 0, TableView1[TableView1.Row, 9].Text)
      If xquantival Then
        modClinic.UpdateClinicQuantiData(TableView1[TableView1.Row, 0].Text, xquantival[0], xquantival[1])
      Endif
    Endif
    ShowClinicTable()

  Else If TableView1.Column = 4 Then
    abc = InputCombo("Select Flag for the observation", "Change Flag", ["Normal", "Abnormal"], modGridView.GetIconValue(TableView1[TableView1.Row, 4].Picture), True)
    If abc Then
      modClinic.UpdateExamFlag(TableView1[TableView1.Row, 0].Text, abc)
      ShowClinicTable()
    Endif

  Else If TableView1.Column = 6 Then
    If Message.Question(("Are you sure?"), ("No"), ("Yes")) = 2 Then
      res = modDatabase.$myConn.Edit("tblpatientexam", "fldid=&1", TableView1[TableView1.Row, 0].Text)
      If modGeneral.AllowClinicalEdit(res["flduserid"]) = True Then
        res["fldsave"] = False
        res["flduserid"] = modGeneralMain.$lbluser
        res.Update
        ShowClinicTable()
      Else
        Message.Warning("Authorization with " & res["flduserid"], ("OK"))
      Endif
    Endif

  Endif
  TableView1.Row = Row

End

''XXXXXXXX VIEW OPTIONS
Private Sub SelectDIrectEntryForm()

  Dim sExam As String
  Dim sName As String
  Dim xquantival As Variant[]
  Dim yqualival As Variant[]
  Dim lftrtval As Variant[]
  Dim xlimit As Float[]
  Dim opt As String[]
  Dim sVal As String[]
  Dim xval As String
  Dim xdate As Date

  Dim rsn As Result
  Dim sysConst As String
  Dim examtype As String
  Dim sType As String
  Dim OptionType As String

  rsn = modDatabase.$myConn.Exec("select fldhead,fldtesttype,fldtanswertype,fldsysconst from tblstructexam where fldheadcode=&1", grdtreeview.Current.Key)
  If rsn.Available Then
    sysConst = rsn!fldsysconst
    sType = rsn!fldtesttype
    OptionType = rsn!fldtanswertype

    If sysConst Then
      If modSysCons.SysExaminationList().Exist(sysConst) = True Then
        sExam = modFixClinic.GetExamIDFromSysConst(sysConst)
        examtype = "Exam"
      Else If modSysCons.SysLabTestList().Exist(sysConst) = True Then
        sExam = modFixLab.GetLabTestIDFromSysConst(sysConst)
        examtype = "Test"
      Else If modBasic.$sysRadioList.Exist(sysConst) = True Then
        sExam = modFixRadio.GetRadioTestIDFromSysConst(sysConst)
        examtype = "Radio"
      Else If modBasic.$DemogList.Exist(sysConst) = True Then
        sExam = sysConst
        examtype = "Demog"
      Else
        examtype = "Exam"
      Endif
    Else
      examtype = "Exam"
    Endif
    If sExam Then
      sName = sExam
    Else
      sName = grdtreeview.Current.Text
    Endif

    If sType = "Quantitative" Then
      xlimit = modClinic.GetBothQuantiExamVal(sExam, Trim(txtencid.Text))
      xquantival = GetQuantiValues(examtype, Trim(txtencid.Text), sName, xlimit[0], xlimit[1], 0)
      If xquantival Then
        modClinic.AddClinicQuantiData(Trim(txtencid.Text), grdtreeview.Current.Key, grdtreeview.Current.Text, xquantival[0], xquantival[1], sysConst)
      Endif
    Else
      If OptionType = "Sys Constant" Then
        yqualival = modExamOption.GetQualiExamOptionDirectValue(sName, "", examtype)
      Else If OptionType = "Date Time" Then
        xdate = GetDateValue(("Select Date Time"), sName, "")
        If xdate Then
          yqualival = [Format(xdate, gb.GeneralDate), False]
        Endif
      Else If OptionType = "Qualitative" Then
        xval = InputBox(sName, "Qualitative", "")
        If xval Then
          yqualival = [xval, False]
        Endif
      Else If OptionType = "Left and Right" Then
        lftrtval = CLeftRight(sName, "")
        If lftrtval Then
          yqualival = [modString.GetLefRightJSON(lftrtval[0], lftrtval[1]), lftrtval[2]]
        Endif
      Else If OptionType = "Single Selection" Or If OptionType = "Dichotomous" Or If OptionType = "Multiple Selection" Then
        opt = modFillContainer.GetListFromResult(modDatabase.$myConn.Exec("select fldanswer from tblstructexamoption where fldheadcode=&1 ORDER BY fldindex", grdtreeview.Current.Key))
        If opt.Count Then
          sVal = SubChoose(opt, OptionType, grdtreeview.Current.Text)
          If sVal Then
            yqualival = [sVal.Join(gb.NewLine), False]
          Endif
        Else
          yqualival = GetQualiValues(sName, "", "Exam")
        Endif
      Else If OptionType = "Text Table" Then
        opt = modFillContainer.GetListFromResult(modDatabase.$myConn.Exec("select fldanswer from tblstructexamoption where fldheadcode=&1 ORDER BY fldindex", grdtreeview.Current.Key))
        If opt.Count Then
          xval = TableEntry(opt, grdtreeview.Current.Text, "")
          If xval Then
            yqualival = [modString.GetTableFormatFromText(xval), False]
          Endif
        Else
          yqualival = GetQualiValues(sName, "", "Exam")
        Endif
      Else
        yqualival = GetQualiValues(sName, "", "Exam")
      Endif
      If yqualival Then
        If yqualival.Count = 3 And If yqualival[2] Then
          modClinic.AddClinicExam(Trim(txtencid.Text), grdtreeview.Current.Key, grdtreeview.Current.Text, yqualival[0], CFloat(yqualival[2]), yqualival[1], "Rec Examination", sysConst, "Regular")
        Else
          modClinic.AddClinicExam(Trim(txtencid.Text), grdtreeview.Current.Key, grdtreeview.Current.Text, yqualival[0], 0, yqualival[1], "Rec Examination", sysConst, "Regular")
        Endif
      Endif
    Endif ''quali or quanti

  Endif

End

Public Sub btnfullrep_Click()

  modCHTMLReport.ExportGridToHTML(TableView1, UCase($Category), "",, txtencid.text)

End

Public Sub btnreposel_Click()

  Dim xPath As String

  If txtencid.text Then
    xPath = modCHTMLPatient.ShowRecomExaminationpatient(Trim(txtencid.text), $Category, cmbcategory.Text, $sDepart, $reference)
    modPrint.OpenHTMLPreview(Trim(txtencid.text), xPath, "ReportSize")
  Endif

End

Public Sub txtencid_KeyPress()

  If Key.Code = Key.Down Then
    If modBasic.$AutoEncSuffix = "Yes" Then
      txtencid.Text = txtencid.Text & modBasic.$HospCode
    Endif
  Else
    modGeneralMain.InputUpCaseOnly()
  Endif

End

''--------------------Populate Tree View -------------------------------
Private Sub FillClinicalTree(TreeView1 As TreeView, xSubClass As String, xCategory As String, sDepart As String)

  Dim str3 As String
  Dim str4 As String

  Dim res3 As Result
  Dim k As Integer
  Dim res4 As Result
  Dim l As Integer

  Dim pic2 As Picture
  Dim pic3 As Picture
  Dim ref As String

  pic2 = Picture["icons/coll2.png"]
  pic3 = Picture["icons/coll3.png"]

  ref = $reference
  TreeView1.Clear

  str3 = "select distinct(flditem) from tblstructexam where fldsubclass=&1 and fldcategory=&2 and fldreferencee=&3 and fldclass=&4 ORDER BY flditemid"
  res3 = modDatabase.$myConn.Exec(str3, xSubClass, xCategory, ref, sDepart)
  If res3.Count > 0 Then
    res3.MoveFirst
    For k = 1 To res3.Count
      TreeView1.Add(CStr(k) & "@" & res3!flditem, res3!flditem, pic2)

      str4 = "select fldheadcode,fldhead from tblstructexam where fldsubclass=&1 and fldcategory=&2 and flditem=&3 and fldreferencee=&4 and fldclass=&5 ORDER BY fldheadid"
      res4 = modDatabase.$myConn.Exec(str4, xsubClass, xCategory, res3!flditem, ref, sDepart)
      If res4.Count > 0 Then
        res4.MoveFirst
        For l = 1 To res4.Count
          TreeView1.Add(res4!fldheadcode, res4!fldhead, pic3, CStr(k) & "@" & res3!flditem)
          res4.MoveNext
        Next
      Endif

      res3.MoveNext
    Next
  Endif

End
