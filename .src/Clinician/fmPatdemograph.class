' Gambas class file

Private $rData As Result
Private $aMyFields As String[]
Private $encid As String
Private $ItemList As String[]

Public Sub _new(encid As String)

  $encid = encid

End

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me, "False")
  txtpatientname.Text = modPatient.GetPatientNameByEnc($encid)
  txtgender.Text = modPatient.GetPatientSex($encid)
  rbaplha.Value = True
  TextBox1.Visible = True
  LoadListData()
  ShowExamGrid()

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.Esc Then
    Me.Close
  Else
    modGeneralmain.GoToNextControlTab()
  Endif

End

Private Sub LoadListData()

  If rbentry.Value = True Then
    $ItemList = modFillContainer.GetListFromResult(modDatabase.$myConn.Exec("select flddemoid as col from tbldemographic where (fldcomp=&1 or fldcomp=&2) ORDER BY fldindex", modGeneralMain.compID, "%"))
  Else If rbaplha.Value = True Then
    $ItemList = modBasic.$DemogList.Sort()
  Endif

End

Public Sub rbentry_Click()

  LoadListData()

End

Public Sub rbaplha_Click()

  LoadListData()

End

Private Sub ShowExamGrid()

  Dim prList As String[]

  $rData = modDatabase.$myConn.Exec("select fldid,flditem,fldreportquali from tblexamgeneral where fldencounterval=&1 and fldinput=&2 ORDER by fldid DESC", $encid, "Demographics")                                                                                 ''
  $aMyFields = New String[]
  modGridView.ReadSmallData(GridView1, $rData, $aMyFields)

  With GridView1
    .Columns[0].Width = 1
    .Columns[1].Width = 250 * modBasic.$AppWidthRatio
    .Columns[2].Width = 250 * modBasic.$AppWidthRatio

    .Columns[1].Text = "Variable"
    .Columns[2].Text = "Value"
  End With

  If $rData.Available Then
    prList = New String[]
    For Each $rData
      prList.Add($rData["flditem"])
    Next
    ListBox1.List = modString.GetRemainingArray($ItemList, prList)
  Else
    ListBox1.List = $ItemList
  Endif

End

Public Sub GridView1_Data(Row As Integer, Column As Integer)

  $rData.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView1, Row)
  GridView1.Data.Text = $rData[$aMyFields[Column]]

End

Public Sub ComboBox1_KeyRelease()

  modFillContainer.AutoFillComboBox(ComboBox1)
  ' modFillContainer.RestrictComboToContent(ComboBox1)

End

Public Sub ListBox1_Click()

  Dim sType As String
  Dim opt As String[]
  Dim strLst As String[]

  ComboBox1.Clear()
  sType = modFixPatho.GetDemographicType(ListBox1.Text)
  ListBox1.Tag = sType
  If sType = "Single Selection" Then
    TextBox1.Visible = False
    ComboBox1.Visible = True
    ValueBox1.Visible = False
    opt = modFixPatho.GetDemographicOptionList(ListBox1.Text, sType)
    ComboBox1.List = opt

  Else If sType = "Multiple Selection" Then
    TextBox1.Visible = True
    ComboBox1.Visible = False
    ValueBox1.Visible = False
    opt = modFixPatho.GetDemographicOptionList(ListBox1.Text, sType)
    strLst = SubChoose(opt, "Multiple Selection", ListBox1.Text)
    TextBox1.Text = strLst.Join(";")
    TextBox1.SetFocus

  Else If sType = "Quantitative" Then
    TextBox1.Visible = False
    ComboBox1.Visible = False
    ValueBox1.Visible = True
    ValueBox1.Type = ValueBox.Number

  Else If sType = "Date Time" Then
    TextBox1.Visible = False
    ComboBox1.Visible = False
    ValueBox1.Visible = True
    ValueBox1.Type = ValueBox.DateTime

  Else
    TextBox1.Visible = True
    ComboBox1.Visible = False
    ValueBox1.Visible = False

  Endif

End

Public Sub ListBox1_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    ListBox1_Click()
  Endif

End

Public Sub btnadd_Click()

  Dim sType As String

  sType = ListBox1.Tag
  If sType = "Single Selection" Then
    If ComboBox1.Text Then
      modPatientGeneral.AddExamGeneralQualiData($encid, "Demographics", ListBox1.Text, ComboBox1.Text, "", True)
    Endif

  Else If sType = "Multiple Selection" Then
    If TextBox1.Text Then
      modPatientGeneral.AddExamGeneralQualiData($encid, "Demographics", ListBox1.Text, TextBox1.Text, "", True)
    Endif

  Else If sType = "Quantitative" Then
    If ValueBox1.Value Then
      modPatientGeneral.AddExamGeneralQuantiData($encid, "Demographics", ListBox1.Text, ValueBox1.Value, "", True)
    Endif

  Else If sType = "Date Time" Then
    If ValueBox1.Value Then
      modPatientGeneral.AddExamGeneralQualiData($encid, "Demographics", ListBox1.Text, Format(ValueBox1.Value, gb.GeneralDate), "", True)
    Endif

  Else
    modPatientGeneral.AddExamGeneralQualiData($encid, "Demographics", ListBox1.Text, TextBox1.Text, "", True)
  Endif
  ListBox1.Tag = ""
  TextBox1.Text = ""
  ComboBox1.Text = ""
  ValueBox1.Value = 0
  ListBox1.SetFocus
  ShowExamGrid()

End

Public Sub btnadd_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    btnadd_Click()
  Endif

End

Public Sub GridView1_Click()

  Dim sType As String
  Dim opt As String[]
  Dim strLst As String[]
  Dim xx As String
  Dim yy As Variant[]
  Dim Row As Integer
  Dim xdate As Date
  Dim Column As Integer

  If GridView1.Rows.Selection.Count > 0 Then
    Row = GridView1.Row
    Column = GridView1.Column

    sType = modFixPatho.GetDemographicType(GridView1[GridView1.Row, 1].Text)
    If sType = "Single Selection" Then
      opt = modFixPatho.GetDemographicOptionList(GridView1[GridView1.Row, 1].Text, sType)
      strLst = SubChoose(opt, "Single Selection", GridView1[GridView1.Row, 1].Text)
      If strLst Then
        For Each xx In strLst
          modPatientGeneral.UpdateExamGeneralQualiData(GridView1[GridView1.Row, 0].Text, GridView1[GridView1.Row, 1].Text, xx, "")
        Next
      Endif

    Else If sType = "Multiple Selection" Then
      opt = modFixPatho.GetDemographicOptionList(GridView1[GridView1.Row, 1].Text, sType)
      strLst = SubChoose(opt, "Multiple Selection", GridView1[GridView1.Row, 1].Text)
      If strLst Then
        For Each xx In strLst
          modPatientGeneral.UpdateExamGeneralQualiData(GridView1[GridView1.Row, 0].Text, GridView1[GridView1.Row, 1].Text, xx, "")
        Next
      Endif

    Else If sType = "Quantitative" Then
      yy = GetQuantiValues("Demographics", $encid, GridView1[GridView1.Row, 1].Text, 0, 0, CFloat(GridView1[GridView1.Row, 2].Text))
      If yy Then
        modPatientGeneral.UpdateExamGeneralQuantiData(GridView1[GridView1.Row, 0].Text, GridView1[GridView1.Row, 1].Text, yy[0], "")
      Endif

    Else If sType = "Date Time" Then
      xdate = GetDateValue(GridView1[GridView1.Row, 1].Text, "Date Value", CDate(GridView1[GridView1.Row, 2].Text))
      If xdate Then
        modPatientGeneral.UpdateExamGeneralQualiData(GridView1[GridView1.Row, 0].Text, GridView1[GridView1.Row, 1].Text, Format(xdate, gb.GeneralDate), "")
      Endif

    Else
      xx = GetTextArea(GridView1[GridView1.Row, 1].Text, GridView1[GridView1.Row, 2].Text)
      If xx Then
        modPatientGeneral.UpdateExamGeneralQualiData(GridView1[GridView1.Row, 0].Text, GridView1[GridView1.Row, 1].Text, xx, "")
      Endif
    Endif
    ShowExamGrid()
    GridView1.Row = Row
    GridView1.Column = Column
  Endif

End

Public Sub btnreport_Click()

  modCHTMLReport.ExportGridToHTML(GridView1, "DEMOGRAPHIC VALUES", modReportVar.GetDateTimeReport(Now(), gb.GeneralDate))

End

Public Sub btnadd_GotFocus()

  btnadd.Font.Bold = True
  btnadd.Picture = Picture["icon:/small/down"]

End

Public Sub btnadd_LostFocus()

  btnadd.Font.Bold = False
  btnadd.Picture = Picture["icon:/small/add"]

End
