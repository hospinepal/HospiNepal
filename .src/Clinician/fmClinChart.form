# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,120,75)
  Text = ("Chart View")
  { mnufile Menu
    Text = ("File")
    { mnusave Menu
      Text = ("Save to PNG")
    }
    { mnuexport Menu
      Text = ("HTML View")
    }
  }
  { Panel1 Panel
    MoveScaled(0,0,120,72)
    { ScrollView1 ScrollView
      MoveScaled(0,0,120,70.75)
      { drwchart PictureBox
        MoveScaled(1,1,118,70)
        Background = &HFFFFFF&
        Expand = True
        AutoResize = True
        Border = Border.Plain
      }
    }
  }
}
