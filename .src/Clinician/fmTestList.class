' Gambas class file

Private $encid As String
Private $rData As Result
Private $aMyFields As String[]
Private $rData1 As Result
Private $aMyFields1 As String[]
Private $rData2 As Result
Private $aMyFields2 As String[]
Private $TestList As String[]

Public Sub _new(encid As String, BillingMode As String)

  $encid = encid
  txtbilling.Text = BillingMode

End

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me, "False")

  txtpatientname.Text = modPatient.GetPatientNameByEnc($encid)
  txtgender.Text = modPatient.GetPatientSex($encid)
  modLabTest.DisplayDefaultTestUnit(rbsi, rbmetric)
  modGeneral.FixPayableUser("Test", btnrefer, $encid)
  cmbtarget.List = modBasic.$AllCompList
  cmbtestgroup.List = modNonMedical.NonSTockCostingGroupList("Test")
  cmbtarget.Text = modSettings.ShowSettingFromFIle("Laboratory/DefaultTarget")
  $TestList = New String[]

  SHowSavedGrid()
  ShowSampled()
  txtsearch.SetFocus

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.Insert Then
    btnselect_Click()
  Else If Key.Code = Key.Esc Then
    Me.Close
  Else If Key.Code = Key.F1 Then
    TabPanel1.Index = 0
  Else If Key.Code = Key.F2 Then
    TabPanel1.Index = 1
  Else If Key.Code = Key.F3 Then
    TabPanel1.Index = 2
  Else
    modGeneralmain.GoToNextControlTab()
  Endif

End

Public Sub TabPanel1_Click()

  If TabPanel1.Index = 0 Then
    SHowSavedGrid()
    ShowSampled()
  Else If TabPanel1.Index = 1 Then
    If modBasic.$DefaultTestList Then
      btnshowsel.Value = True
      FillSelLabCOlumnView(modBasic.$DefaultTestList)
    Else
      FillLabCOlumnView()
    Endif
    modFillContainer.FillListViewFromArray(ListView1, $TestList)
    lstletter.List = modString.GetFirstLetterArray($TestList)
    ShowGrid()
  Else If TabPanel1.Index = 2 Then
    lsttestname.List = modFillContainer.GetListFromResult(modDatabase.$myConn.Exec("select distinct(fldtestid) as col from tblpatlabtest where fldencounterval=&1", $encid))
  Endif

End

Public Sub btnrefer_Click()

  btnrefer.Tag = MedicalSelectedUser(("Select Referral User"), modBasic.$ReferUserList)
  btnrefer.Text = modGeneral.GetUserFullName(btnrefer.Tag)

End

Public Sub btnrefer_Change()

  If btnrefer.Text = "" Then
    btnrefer.Tag = ""
  Endif

End

''------------------------------------- Listview -----------------------------------
Public Sub txtsearch_KeyRelease()

  If Key.Code = Key.Down Then
    ListView1.SetFocus
  Endif

End

Public Sub txtsearch_Change()

  modFillContainer.FillListViewFromArray(ListView1, modString.SelectStringArrayToText(txtsearch.Text, $TestList, chkleftmain.Value))

End

Public Sub txtsearch_Click()

  txtsearch.Text = ""

End

Public Sub lstletter_Click()

  txtsearch.Text = lstletter.Text

End

Private Sub FillLabCOlumnView()

  Dim sstr1 As String
  Dim res As Result
  Dim xxx As String[]

  If Not $TestList.Count Then
    sstr1 = "select distinct(fldgroupname) as col from tblgrouptest where fldgroupname in(select flditemname from tblservicecost where (fldgroup=&1 or fldgroup=&2) and fldstatus=&3)"                                                ''
    res = modDatabase.$myConn.Exec(sstr1, txtbilling.Text, "%", "Active")
    xxx = modFillContainer.GetListFromResult(res)
    $TestList = xxx
  Endif

End

Private Sub FillSelLabCOlumnView(sItem As String)

  Dim sstr1 As String
  Dim res As Result
  Dim xxx As String[]

  If Not $TestList.Count Then
    sstr1 = "select distinct(fldgroupname) as col from tblgrouptest where fldgroupname in(select flditemname from tblservicecost where (fldgroup=&1 or fldgroup=&2) and fldstatus=&3) and fldgroupname in(select flditemname from tblcostgroup where fldgroup=&4)"                                                ''
    res = modDatabase.$myConn.Exec(sstr1, txtbilling.Text, "%", "Active", sItem)
    xxx = modFillContainer.GetListFromResult(res)
    $TestList = xxx
  Endif

End

Private Sub DisplayTestList()

  If btnshowsel.Value = True Then
    FillSelLabCOlumnView(modBasic.$DefaultTestList)
  Else
    FillLabCOlumnView()
  Endif
  modFillContainer.FillListViewFromArray(ListView1, $TestList)
  lstletter.List = modString.GetFirstLetterArray($TestList)

End

Public Sub btnshowsel_Click()

  ListView1.Clear()
  $TestList.Clear()
  DisplayTestList()

End

Public Sub btnclear_Click()

  ListView1.Clear()
  $TestList.Clear()
  cmbtestgroup.Text = ""
  DisplayTestList()

End

Public Sub cmbtestgroup_Click()

  If cmbtestgroup.Text Then
    ListView1.Clear()
    $TestList.Clear()
    FillSelLabCOlumnView(cmbtestgroup.Text)
    modFillContainer.FillCheckListViewFromArray(ListView1, $TestList)
    lstletter.List = modString.GetFirstLetterArray($TestList)
  Endif

End

Public Sub ListView1_Click()

  modFillContainer.ShowCheckedListView(ListView1)

End

Public Sub ListView1_KeyRelease()

  If Key.Code = Key.Space Then
    ListView1_Click()
  Endif

End

Public Sub ListView1_Menu()

  mnufile.Popup

End

Public Sub mnuinfo_Click()

  Balloon.Info(modGeneralMain.GetToolTipFromDB("tbltest", "fldcomment", "fldtestid", ListView1.Current.Text), ListView1, ListView1.Current.X, ListView1.Current.Y - 15)
  Balloon.Delay = modBasic.$BalloonDelay

End

Public Sub btnselect_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    btnselect_Click()
  Endif

End

Public Sub btnselect_Click()

  Dim i As Integer
  Dim xauto As String

  xauto = modBasic.$AutoBillTest
  If xauto = "Yes" Or If xauto = "Full" Or If xauto = "Partial" Then
    Inc Application.Busy
    modDatabase.$myConn.Begin
    For i = 1 To ListView1.Count
      If ListView1[CStr(i)].Picture = modBasic.$PictureChecked Then     '
        modBillings.ServiceBillBlankTaxDisc($encid, txtbilling.Text, "Test", ListView1[CStr(i)].Text, 1, "Punched", 0, False, False, "", btnrefer.Tag, cmbtarget.Text)
        ListView1[CStr(i)].Picture = modBasic.$PictureUnchecked
      Endif
    Next
    modDatabase.$myConn.Commit
    Dec Application.Busy
    ShowGrid()
    txtsearch.Text = ""
    txtsearch.SetFocus
  Endif

Catch
  modDatabase.$myConn.Rollback
  Dec Application.Busy
  modHelpVariable.CreateErrorReport()

End

''--------------------------------------------------- Gridview -------------------------------------------
Private Sub ShowGrid()

  Dim sql As String
  Dim res As Result
  Dim Column As Integer
  Dim fld As ResultField

  sql = "select fldid,fldordtime,flditemname,fldstatus,fldreason,fldtarget from tblpatbilling where fldencounterval=&1 and flditemtype=&2 and fldsave=&3"
  res = modDatabase.$myConn.Exec(sql, $encid, "Diagnostic Tests", False)
  GridView1.Clear
  GridView1.Columns.Count = res.Fields.Count
  GridView1.Rows.Count = res.Count

  For Each res
    Column = 0
    For Each fld In res.Fields
      modGeneralMain.GridExplicitDecoration(GridView1, res.Index, Column)
      If Column = 1 Then
        GridView1[res.Index, Column].Text = modReportVar.GetDateTimeReport(res[fld.Name], gb.GeneralDate)
      Else
        GridView1[res.Index, Column].Text = res[fld.Name]
      Endif
      Column = Column + 1
    Next
  Next
  GridView1.Row = 0

  With GridView1
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 1
    .Columns[1].Width = 150 * modBasic.$AppWidthRatio
    .Columns[2].Width = 250 * modBasic.$AppWidthRatio
    .Columns[3].Width = 100 * modBasic.$AppWidthRatio
    .Columns[4].Width = 1
    .Columns[5].Width = 75 * modBasic.$AppWidthRatio
    .Columns[1].Text = "Date Time"
    .Columns[2].Text = "Test Name"
    .Columns[3].Text = "Status"
    .Columns[5].Text = "Target"
  End With

End

Public Sub btncancel_Click()

  Dim res As Result

  res = modDatabase.$myConn.Edit("tblpatbilling", "fldid=&1", GridView1[GridView1.Row, 0].Text)
  res["fldstatus"] = "Cancelled"
  res["fldorduserid"] = modGeneralMain.$lbluser
  res["fldordtime"] = Now()
  res["fldordcomp"] = modGeneralMain.compID
  res["xyz"] = False
  res.Update()
  ShowGrid()

End

Public Sub btnreorder_Click()

  Dim res As Result

  res = modDatabase.$myConn.Edit("tblpatbilling", "fldid=&1", GridView1[GridView1.Row, 0].Text)
  res["fldstatus"] = "Punched"
  res["fldorduserid"] = modGeneralMain.$lbluser
  res["fldordtime"] = Now()
  res["fldordcomp"] = modGeneralMain.compID
  res["xyz"] = False
  res.Update()
  ShowGrid()

End

Public Sub btnsave_Click()

  Dim res As Result
  Dim xauto As String

  xauto = modBasic.$AutoBillTest
  If xauto = "Yes" Or If xauto = "Full" Then
    res = modDatabase.$myConn.Edit("tblpatbilling", "fldencounterval= &1 and flditemtype=&2 and fldsave=&3 and fldstatus=&4", $encid, "Diagnostic Tests", False, "Punched")                 ''
    Inc Application.Busy
    modDatabase.$myConn.Begin
    For Each res
      res["fldstatus"] = "Done"
      res["fldsave"] = True
      res["flduserid"] = modGeneralMain.$lbluser
      res["fldtime"] = Now()
      res["fldcomp"] = modGeneralMain.compID
      res["xyz"] = False
      res.Update()
    Next
    modDatabase.$myConn.Commit
    Dec Application.Busy
    ShowGrid()
  Endif

  If chksend.Value = True Then
    If cmbtarget.Text Then
      SendLabAlert(cmbtarget.Text)
    Endif
  Endif

Catch
  modDatabase.$myConn.Rollback
  Dec Application.Busy
  modHelpVariable.CreateErrorReport()

End

Private Sub SendLabAlert(compid As String)

  Dim xline As String
  Dim xuserList As String[]
  Dim xuser As String

  xline = "TestAlert : New Request for EncID: " & $encid & " From " & modGeneral.GetCompNameFromCompID(modGeneralMain.compID)
  xuserList = modGeneral.FillCurrentUseronJob(compid)

  Inc Application.Busy
  If xuserList.Count Then
    For Each xuser In xuserList
      modDevice.TransferTextSocket(modGeneral.GetCurrentIPFromUser(xuser), modHelpVariable.GetTransferPort(xuser), xline)
    Next
  Endif
  Dec Application.Busy

Catch
  Dec Application.Busy
  Message.Warning(Error.Text, ("OK"))

End

Public Sub cmbtarget_Click()

  lblcomp.Text = modGeneral.GetCompNameFromCompID(cmbtarget.Text)

End

Public Sub btndefault_Click()

  Dim xx As String

  xx = InputCombo("Default Target", "Laboratory", modBasic.$AllCompList, cmbtarget.Text, True)
  If xx Then
    cmbtarget.Text = xx
    modSettings.SaveSettingsToFile("Laboratory/DefaultTarget", xx)
    Balloon.Info(("Information saved"), btndefault)
    Balloon.Delay = modBasic.$BalloonDelay
  Endif

End

Public Sub GridView1_Menu()

  mnuhide.Popup

End

Public Sub mnutarget_Click()

  Dim xx As String
  Dim res As Result

  If GridView1.Rows.Selection.Count > 0 Then
    xx = InputCombo("Change Target", GridView1[GridView1.Row, 2].Text, modBasic.$AllCompList, GridView1[GridView1.Row, 5].Text, True)
    If xx Then
      res = modDatabase.$myConn.Edit("tblpatbilling", "fldid=&1", GridView1[GridView1.Row, 0].Text)
      res["fldtarget"] = xx
      res["xyz"] = False
      res.Update
      ShowGrid()
    Endif
  Endif

End

Public Sub mnucomment_Click()

  Dim xx As String
  Dim res As Result

  If GridView1.Rows.Selection.Count > 0 Then
    xx = GetTextArea(GridView1[GridView1.Row, 2].Text, GridView1[GridView1.Row, 4].Text)
    If xx Then
      res = modDatabase.$myConn.Edit("tblpatbilling", "fldid=&1", GridView1[GridView1.Row, 0].Text)
      res["fldreason"] = xx
      res["xyz"] = False
      res.Update
      ShowGrid()
    Endif
  Endif

End

Public Sub mnudel_Click()

  If GridView1.Rows.Selection.Count > 0 Then
    modDatabase.$myConn.Delete("tblpatbilling", "fldid=&1", GridView1[GridView1.Row, 0].Text)
    ShowGrid()
  Endif

End

''----------------------------------- Billed but not sampled ------------------------------------
Private Sub SHowSavedGrid()

  Dim sql As String

  sql = "select fldid,fldtime,flditemname,fldrefer,fldtarget from tblpatbilling where fldencounterval=&1 and flditemtype=&2 and fldsave=&3 and (fldstatus=&4 or fldstatus=&5)"
  $rData1 = modDatabase.$myConn.Exec(sql, $encid, "Diagnostic Tests", True, "Done", "Cleared")
  $aMyFields1 = New String[]
  modGridView.ReadSmallData(GridView2, $rData1, $aMyFields1)

  With GridView2
    .Columns[0].Width = 1
    .Columns[1].Width = 150 * modBasic.$AppWidthRatio
    .Columns[2].Width = 300 * modBasic.$AppWidthRatio
    .Columns[3].Width = 150 * modBasic.$AppWidthRatio
    .Columns[4].Width = 100 * modBasic.$AppWidthRatio
    .Columns[1].Text = "DateTime"
    .Columns[2].Text = "Test Name"
    .Columns[3].Text = "ReferBy"
    .Columns[4].Text = "Target"
  End With

End

Public Sub GridView2_Data(Row As Integer, Column As Integer)

  $rData1.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView2, Row)
  If Column = 1 Then
    GridView2.Data.Text = modReportVar.GetDateTimeReport($rData1[$aMyFields1[Column]], gb.GeneralDate)
  Else If Column = 3 Then
    GridView2.Data.Text = modGeneral.GetUserFullName($rData1[$aMyFields1[Column]])
  Else
    GridView2.Data.Text = $rData1[$aMyFields1[Column]]
  Endif

End

''------------------------------------------- Reported -----------------------------------
Public Sub FillLabtable()

  Dim sql As String

  sql = "select fldid,fldsampletype,fldmethod,fldabnormal,fldid,fldstatus,fldtime_sample,fldtime_report,fldtest_type from tblpatlabtest where fldencounterval=&1 and fldtestid=&2 and (fldstatus=&3 or fldstatus=&4)"
  $rData = modDatabase.$myConn.Exec(sql, $encid, lsttestname.Text, "Reported", "Verified")
  $aMyFields = New String[]
  modGridView.ReadSmallData(TableView1, $rData, $aMyFields)
  With TableView1
    .Columns[0].Width = 1
    .Columns[1].Width = 100 * modBasic.$AppWidthRatio
    .Columns[2].Width = 125 * modBasic.$AppWidthRatio
    .Columns[3].Width = 20
    .Columns[4].Width = 225 * modBasic.$AppWidthRatio
    .Columns[5].Width = 75 * modBasic.$AppWidthRatio
    .Columns[6].Width = 150 * modBasic.$AppWidthRatio
    .Columns[7].Width = 150 * modBasic.$AppWidthRatio
    .Columns[8].Width = 1

    .Columns[1].Text = "Specimen"
    .Columns[2].Text = "Method"
    .Columns[4].Text = "Observation"
    .Columns[5].Text = "Status"
    .Columns[6].Text = "SampleTime"
    .Columns[7].Text = "ReportTime"
  End With

End

Public Sub TableView1_Data(Row As Integer, Column As Integer)

  $rData.MoveTo(Row)
  modGeneralMain.GridViewDecoration(TableView1, Row)
  If Column = 3 Then
    TableView1.Data.Picture = Picture[modGridView.GetGridIcon($rData[$aMyFields[Column]])]
    TableView1.Data.Text = ""
  Else If Column = 4 Then
    TableView1.Data.RichText = modLabTest.GetLabTestValueSubString($rData["fldid"], modLabTest.GetTestUnitFromButton(rbsi, rbmetric))
  Else If Column = 6 Then
    TableView1.Data.Text = modReportVar.GetDateTimeReport($rData["fldtime_sample"], gb.GeneralDate)
  Else If Column = 7 Then
    TableView1.Data.Text = modReportVar.GetDateTimeReport($rData["fldtime_report"], gb.GeneralDate)
  Else
    TableView1.Data.Text = $rData[$aMyFields[Column]]
  Endif

End

Public Sub lsttestname_Click()

  If lsttestname.Text Then
    FillLabtable()
  Endif

End

Public Sub lsttestname_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    lsttestname_Click()
  Endif

End

''----------------------------- Sampled but not Reported -----------------------------
Private Sub ShowSampled()

  Dim sql As String

  sql = "select fldid,fldsampletype,fldtestid,fldabnormal,fldsampleid,fldmethod,fldtime_sample from tblpatlabtest where fldencounterval=&1 and fldstatus=&2"
  $rData2 = modDatabase.$myConn.Exec(sql, $encid, "Sampled")
  $aMyFields2 = New String[]
  modGridView.ReadSmallData(GridView3, $rData2, $aMyFields2)
  With GridView3
    .Columns[0].Width = 1
    .Columns[1].Width = 100 * modBasic.$AppWidthRatio
    .Columns[2].Width = 250 * modBasic.$AppWidthRatio
    .Columns[3].Width = 20
    .Columns[4].Width = 100 * modBasic.$AppWidthRatio
    .Columns[5].Width = 100 * modBasic.$AppWidthRatio
    .Columns[6].Width = 150 * modBasic.$AppWidthRatio

    .Columns[1].Text = "Specimen"
    .Columns[2].Text = "Test Name"
    .Columns[4].Text = "Sample"
    .Columns[5].Text = "Method"
    .Columns[6].Text = "SampleDate"
  End With

End

Public Sub GridView3_Data(Row As Integer, Column As Integer)

  $rData2.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView3, Row)
  If Column = 3 Then
    GridView3.Data.Picture = Picture["icons/null.svg"]
    GridView3.Data.Text = ""
  Else If Column = 6 Then
    GridView3.Data.Text = modReportVar.GetDateTimeReport($rData2["fldtime_sample"], gb.GeneralDate)
  Else
    GridView3.Data.Text = $rData2[$aMyFields2[Column]]
  Endif

End

Public Sub txtsearch_KeyPress()

  modGeneralMain.InputTextSearchKeyOnly()

End
