' Gambas class file

Private $encid As String
Private $strType As String
Private $strItem As String
Private $unt As String

Public Sub _new(strType As String, strItem As String, encid As String, unt As String)

  $encid = encid
  $strType = strType
  $strItem = strItem
  $unt = unt
  Me.Text = "ENC: " & $encid

End

Public Sub Form_Open()

  modGeneralMain.ArrangeEmbedForms(Me, Panel1)
  Me.Icon = Picture[modGeneralMain.$strLogo]
  modBasic.LoadClinicalChartSetting()

  If $strType = "Exam" Then
    modClinic.FillQuantiExamChart(drwchart, $encid, $strItem)
  Else If $strType = "Test" Then
    modLabTest.FillQuantiTestChart(drwchart, $encid, $strItem, $unt)
  Else If $strType = "SetA" Then
    modClinic.DrawClinicalCharts_SetA(drwchart, $encid, $strItem)
  Endif

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

Public Sub mnuexport_Click()

  Dim xx As String[]
  Dim xPath As String

  xx = New String[]
  xx.Add($strItem)
  xPath = modCHTMLPatient.ExportQuantiClinToHTML($encid, $strType, xx, $unt, Me)
  modPrint.OpenHTMLPreview($encid, xPath, "ReportSize")

End

Public Sub mnusave_Click()

  If Dialog.SelectDirectory() Then Return
  drwchart.Picture.Save(Dialog.Path &/ modString.GetNowString() & ".png")

End
