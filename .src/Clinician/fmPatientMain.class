Public Sub btnaddexamlistmain_Click()

  Dim hForm As FmEnterMultiExam
  Dim res As Result
  Dim asx As String[]
  Dim xval As String

  If txtencid.Text Then
    xval = InputListView(("Select Examination Group"), "Examination", $examGrpList)
    If xval Then
      asx = New String[]
      res = modDatabase.$myConn.Exec("select fldexamid from tblgroupexam where fldgroupname=&1", xval)
      If res.Available Then
        For Each res
          asx.Add(res["fldexamid"])
        Next
        hForm = New FmEnterMultiExam(xval, Trim(txtencid.Text), "Examination", asx)
        hForm.ShowModal
        FillExamtable()
      Endif
    Endif
  Endif

End

Public Sub btnfinadd_Click()

  Dim sType As String
  Dim abn As Boolean
  Dim xsys As String

  If txtencid.Text Then
    If cmbfinding.Text Then
      sType = modFixClinic.GetExaminationType(cmbfinding.Text)
      xsys = modFixClinic.SysConstFromGetExamID(cmbfinding.Text)
      If sType = "Quantitative" Then
        pnlquantiexam.Visible = False
        If txtfindmin.Value > txtfinval.Value Or If txtfindmax.Value < txtfinval.Value Then
          abn = True
        Else
          abn = False
        Endif
        modClinic.AddQuantiData(Trim(txtencid.Text), "", cmbfinding.Text, txtfinval.Value, abn, "Examination", xsys)
      Else
        modClinic.AddClinicExam(Trim(txtencid.Text), "", cmbfinding.Text, txtfinding.Text, txtfinval.Value, False, "Examination", xsys, "Regular")
      Endif
      FillExamtable()
      cmbfinding.Text = ""
      txtfinding.Text = ""
      txtfinding.Clear()
      txtfinval.Value = 0
      txtfinval.Tag = ""
    Endif
  Endif

End

Public Sub FillExamtable()

  Dim Column As Integer
  Dim fld As ResultField
  Dim res As Result

  If btnallexam.Value = False Then
    res = modDatabase.$myConn.Exec("select fldid,fldtype,fldhead,fldabnormal,fldid,fldid,fldtime,fldencounterval,flduserid,fldcomp from tblpatientexam where fldencounterval=&1 and fldinput=&2 and fldsave=&3 and fldtime>=&4 and fldtime<=&5", Trim(txtencid.Text), "Examination", True, modDate.StartSqlDate(dtfind.Value), modDate.EndSqlDate(dtfind.Value))
  Else
    res = modDatabase.$myConn.Exec("select fldid,fldtype,fldhead,fldabnormal,fldid,fldid,fldtime,fldencounterval,flduserid,fldcomp from tblpatientexam where fldencounterval=&1 and (fldinput=&2 or fldinput=&3 or fldinput=&4) and fldsave=&5", Trim(txtencid.Text), "Examination", "OPD Examination", "Rec Examination", True)
  Endif
  GridView1.Clear
  GridView1.Columns.Count = res.Fields.Count
  GridView1.Rows.Count = res.Count

  For Each res
    Column = 0
    For Each fld In res.Fields
      modGeneralMain.GridExplicitDecoration(GridView1, res.Index, Column)
      If Column = 3 Then
        GridView1[res.Index, Column].Picture = Picture[modGridView.GetGridIcon(res[fld.Name])]
        GridView1[res.Index, Column].Text = ""
      Else If Column = 4 Then
        GridView1[res.Index, Column].RichText = modClinic.GetExamValueString(Trim(txtencid.Text), res["fldid"], False)
      Else If Column = 5 Then
        GridView1[res.Index, Column].Picture = Picture["icon:/small/cancel"]
        GridView1[res.Index, Column].Text = ""
      Else If Column = 6 Then
        GridView1[res.Index, Column].Text = modReportVar.GetDateTimeReport(res["fldtime"], gb.GeneralDate)
      Else
        GridView1[res.Index, Column].Text = res[fld.Name]
      Endif
      Column = Column + 1
    Next
  Next
  GridView1.Row = 0

  With GridView1
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 1
    .Columns[1].Width = 1
    .Columns[2].Width = 175 * modBasic.$AppWidthRatio
    .Columns[3].Width = 20
    .Columns[4].Width = 300 * modBasic.$AppWidthRatio
    .Columns[5].Width = 25 * modBasic.$AppWidthRatio
    .Columns[6].Width = 150 * modBasic.$AppWidthRatio
    .Columns[7].Width = 1
    .Columns[8].Width = 100 * modBasic.$AppWidthRatio
    .Columns[9].Width = 100 * modBasic.$AppWidthRatio

    .Columns[2].Text = "Examination"
    .Columns[4].Text = "Observation"
    .Columns[6].Text = "ReportTime"
    .Columns[8].Text = "UserID"
    .Columns[9].Text = "Location"
  End With

End

