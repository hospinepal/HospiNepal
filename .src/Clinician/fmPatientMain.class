Private Function GetClearanceForExit() As Boolean

  Dim sTypeList As String[] = ["General", "Delivery", "Procedure"]
  Dim xType As String
  Dim res As Result
  Dim res1 As Result
  Dim xval As Boolean

  xval = True
  res1 = modDatabase.$myConn.Exec("select fldid,flditem,fldfirsttime from tblpattiming where fldencounterval=&1 and fldtype=&2 and fldfirstsave=&3 and fldsecondsave=&4", Trim(txtencid.Text), "Equipment", True, False)
  If res1.Available Then
    xval = False
    Message.Warning(("Please Close running Equipment(s)"), ("OK"))
  Endif

  For Each xType In sTypeList
    res = modDatabase.$myConn.Exec("select fldid,flditem,fldfirsttime from tblpattiming where fldencounterval=&1 and fldtype=&2 and fldfirstsave=&3 and fldsecondsave=&4", Trim(txtencid.Text), xType, True, False)
    If res.Available Then
      xval = False
      Message.Warning(("Please Close running Event(s) for " & xType), ("OK"))
    Endif
  Next
  Return xval

End

Public Sub mnudischarge_Click()

  Dim xx As String
  Dim hForm As FmTriage

  If txtencid.Text Then
    If GetClearanceForExit() = True Then
      If Message.Question(("The patient information will be locked. <b>Do you want to initiate discharge process?</b>"), ("No"), ("Yes")) = 2 Then
        xx = InputCombo("Current Condition of Patient", Trim(txtencid.Text), ["Recovered", "Improved", "Unchanged", "Worse"], "", True)
        If xx Then
          modBillings.ExitPatientWithBillingOfService(Trim(txtencid.Text))
          modPatient.UpdateCurrentStatus(Trim(txtencid.Text), "Discharged", xx)
          If modBasic.$ClinDischargeComp And If modBasic.$ClinDischargeComp.Count Then
            hForm = New FmTriage("Discharge Examinations", Trim(txtencid.Text))
            hForm.ShowModal
          Endif
        Endif

        mnublank_Click()
      Endif
    Endif
  Endif

End

