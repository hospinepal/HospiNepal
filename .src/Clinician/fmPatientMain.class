      modGeneralMain.GridExplicitDecoration(grdnote, res.Index, Column)
      If Column = 1 Then
        grdnote[res.Index, Column].Text = modPatient.GetDayTimeFromAdmission(Trim(txtencid.Text), res["fldtime"])
      Else
        grdnote[res.Index, Column].Text = res[fld.Name]
