  Endif
  res = modDatabase.$myConn.Exec(sql, Trim(txtencid.Text), "Notes", modDate.StartSqlDate(dtnote.Value), modDate.EndSqlDate(dtnote.Value))

  grdnote.Clear
  grdnote.Columns.Count = res.Fields.Count
