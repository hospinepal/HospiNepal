Public Sub btnaddsymptom_Click()

  Dim sName As String[]
  Dim sText As String

  If txtencid.Text Then
    sName = GridListView(("Select Symptoms"), modMedicine.GetSymptomAllTypeList())
    If sName Then
      For Each sText In sName
        modPatientGeneral.AddExamGeneralQualiData(Trim(txtencid.Text), "Patient Symptoms", sText, "", "")
      Next
    Endif
    ShowSymptomData()
  Endif

End

