Private Sub ShowSurgUser()

  Dim Column As Integer
  Dim fld As ResultField
  Dim $sData3 As Result

  $sData3 = modDatabase.$myConn.Exec("select fldid,fldtime,fldchapter,fldreportquali,fldreport from tblpatsubgeneral where flditemid=&1 and (fldchapter=&2 or fldchapter=&3 or fldchapter=&4 or fldchapter=&5 or fldchapter=&6)", $ProcIndex, "Surgeon", "Anaesthetist", "Assistant", "Scrub Nurse", "Count Nurse")

  grdperson.Clear
  grdperson.Columns.Count = $sData3.Fields.Count
  grdperson.Rows.Count = $sData3.Count

  For Each $sData3
    Column = 0
    For Each fld In $sData3.Fields
      modGeneralMain.GridExplicitDecoration(grdperson, $sData3.Index, Column)
      If Column = 3 Then
        grdperson[$sData3.Index, Column].Text = modGeneral.GetUserFullName($sData3["fldreportquali"])
      Else If Column = 1 Then
        grdperson[$sData3.Index, Column].Text = modReportVar.GetDateTimeReport($sData3["fldtime"], gb.GeneralDate)
      Else
        grdperson[$sData3.Index, Column].Text = $sData3[fld.Name]
      Endif
      Column = Column + 1
    Next
  Next
  grdperson.Row = 0

  With grdperson
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 1
    .Columns[1].Width = 150 * modBasic.$AppWidthRatio
    .Columns[2].Width = 150 * modBasic.$AppWidthRatio
    .Columns[3].Width = 200 * modBasic.$AppWidthRatio
    .Columns[4].Width = 300 * modBasic.$AppWidthRatio

    .Columns[1].Text = "DateTime"
    .Columns[2].Text = "Category"
    .Columns[3].Text = "User Name"
    .Columns[4].Text = "Description"
  End With

End

''================================ Other Items ====================================
Private Sub ShowCurrStockGrid()

  If rbmed.Value = True Then
    $rData = modDatabase.$syConn.Exec("select fldbrandid,fldbrand,fldbrandid,fldbrandid as qty from tblmedbrand where lower(fldbrandid) like &1 and fldbrandid in(select fldstockid from tblentry where fldqty>&2 and fldcomp like &3) order by fldbrandid ASC", LCase(txtname.Text) & "%", 0, modGeneralMain.compID)                                   ''
  Else If rbsurg.Value = True Then
    $rData = modDatabase.$syConn.Exec("select fldbrandid,fldbrand,fldbrandid,fldbrandid as qty from tblsurgbrand where lower(fldbrandid) like &1 and fldbrandid in(select fldstockid from tblentry where fldqty>&2 and fldcomp like &3) order by fldbrandid ASC", LCase(txtname.Text) & "%", 0, modGeneralMain.compID)
  Else If rbextra.Value = True Then
    $rData = modDatabase.$syConn.Exec("select fldbrandid,fldbrand,fldbrandid,fldbrandid as qty from tblextrabrand where lower(fldbrandid) like &1 and fldbrandid in(select fldstockid from tblentry where fldqty>&2 and fldcomp like &3) order by fldbrandid ASC", LCase(txtname.Text) & "%", 0, modGeneralMain.compID)
  Endif

  $aMyFields = New String[]
  modGridView.ReadSmallData(GridView3, $rData, $aMyFields)
  With GridView3
    .Columns[0].Width = 275 * modBasic.$AppWidthRatio
    .Columns[1].Width = 1
    .Columns[2].Width = 1
    .Columns[3].Width = 40 * modBasic.$AppWidthRatio
    .Columns[0].Text = "Particulars"
    .Columns[3].Text = "QTY"
  End With

End

Public Sub GridView3_Data(Row As Integer, Column As Integer)

  $rData.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView3, Row)
  If Column = 3 Then
    GridView3.Data.Text = modStock.TotalQTYbyBrand($rData["qty"], modGeneralMain.compID)
  Else
    GridView3.Data.Text = $rData[$aMyFields[Column]]
  Endif

End

