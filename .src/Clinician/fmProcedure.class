        res["flduserid"] = modGeneralMain.$lbluser
        res.Update
        FillExamtable("Anaesthesia:" & CStr($ProcIndex), grdanes)
      Else
        Message.Warning("Authorization with " & res["flduserid"], ("OK"))
      Endif
    Endif

  Endif
  grdanes.Row = Row

End

