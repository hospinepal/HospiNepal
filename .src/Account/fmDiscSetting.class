' Gambas class file

Private $rDisc As Result

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me)
  cmbdiscmode.List = ["Fixed Percent", "Custom Values", "None"]
  ShowDiscount()

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.Esc Then
    Me.Close
  Else
    modGeneralmain.GoToNextControlTab()
  Endif

End

Public Sub cmbdiscmode_KeyRelease()

  modFillContainer.RestrictComboToContent(cmbdiscmode)

End

Public Sub cmbdiscmode_Click()

  If cmbdiscmode.Text = "Fixed Percent" Then
    txtdiscper.Enabled = True
  Else If cmbdiscmode.Text = "Custom Values" Then
    txtdiscper.Enabled = False
  Endif

End

Public Sub btnOKdisc_Click()

  Dim res As Result

  If txtdisctyp.Text And If cmbdiscmode.Text Then
    res = modDatabase.$myConn.Create("tbldiscount")
    res["fldtype"] = Trim(txtdisctyp.Text)
    res["fldmode"] = cmbdiscmode.Text
    res["fldpercent"] = txtdiscper.Value
    res["fldamount"] = txtdiscamt.Value
    res["fldcredit"] = txtcredit.Value
    res["fldyear"] = dtstart.Value
    res["fldlab"] = 0
    res["fldradio"] = 0
    res["fldproc"] = 0
    res["fldequip"] = 0
    res["fldservice"] = 0
    res["fldother"] = 0
    res["fldmedicine"] = 0
    res["fldsurgical"] = 0
    res["fldextra"] = 0
    res["fldregist"] = 0
    res["flduserid"] = modGeneralMain.$lbluser
    res["fldtime"] = Now()
    res["fldcomp"] = modGeneralMain.compID
    res["fldsave"] = False
    res.Update()
    ShowDiscount()
    Balloon.Info(("Information saved"), btnOKdisc)
    Balloon.Delay = modBasic.$BalloonDelay
    txtdisctyp.SetFocus
  Endif

End

Public Sub btnedit_Click()

  Dim res As Result
  Dim Row As Integer

  If txtdisctyp.Text And If cmbdiscmode.Text Then
    Row = GridView1.Row
    res = modDatabase.$myConn.Edit("tbldiscount", "fldtype=&1", txtdisctyp.Text)
    res["fldmode"] = cmbdiscmode.Text
    res["fldpercent"] = txtdiscper.Value
    res["fldamount"] = txtdiscamt.Value
    res["fldcredit"] = txtcredit.Value
    res["fldyear"] = dtstart.Value
    res["flduserid"] = modGeneralMain.$lbluser
    res["fldtime"] = Now()
    res["fldcomp"] = modGeneralMain.compID
    res["fldsave"] = True
    res.Update()
    ShowDiscount()
    Balloon.Info(("Information saved"), btnOKdisc)
    Balloon.Delay = modBasic.$BalloonDelay
    GridView1.Row = Row
    txtdisctyp.SetFocus
  Endif

End

Private Sub ShowDiscount()

  Dim Column As Integer
  Dim fld As ResultField

  $rDisc = modDatabase.$myConn.Exec("select fldtype,fldmode,fldyear,fldamount,fldcredit,fldpercent from tbldiscount")

  GridView1.Clear
  GridView1.Columns.Count = $rDisc.Fields.Count
  GridView1.Rows.Count = $rDisc.Count

  For Each $rDisc
    Column = 0
    For Each fld In $rDisc.Fields
      modGeneralMain.GridExplicitDecoration(GridView1, $rDisc.Index, Column)
      If Column = 11 Then
        GridView1[$rDisc.Index, Column].Text = modReportVar.GetDateTimeReport($rDisc[fld.Name], gb.MediumDate)
      Else
        GridView1[$rDisc.Index, Column].Text = $rDisc[fld.Name]
      Endif
      Column = Column + 1
    Next
  Next
  GridView1.Row = 0

  With GridView1
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 150 * modBasic.$AppWidthRatio
    .Columns[1].Width = 120 * modBasic.$AppWidthRatio
    .Columns[2].Width = 120 * modBasic.$AppWidthRatio
    .Columns[3].Width = 100 * modBasic.$AppWidthRatio
    .Columns[4].Width = 100 * modBasic.$AppWidthRatio
    .Columns[5].Width = 1

    .Columns[0].Text = "DiscLabel"
    .Columns[1].Text = "DiscMode"
    .Columns[2].Text = "StartDate"
    .Columns[3].Text = "DiscAMT/Year"
    .Columns[4].Text = "CreditAMT"
  End With

End

Public Sub GridView1_Click()

  txtdiscper.Enabled = True
  txtdisctyp.Text = GridView1[GridView1.Row, 0].Text
  cmbdiscmode.Text = GridView1[GridView1.Row, 1].Text
  dtstart.Value = GridView1[GridView1.Row, 2].Text
  txtdiscamt.Value = GridView1[GridView1.Row, 3].Text
  txtcredit.Value = GridView1[GridView1.Row, 4].Text
  txtdiscper.Value = GridView1[GridView1.Row, 5].Text

End

Public Sub btnexport_Click()

  modCHTMLReport.ExportGridToHTML(GridView1, "DISCOUNT MODES", modReportVar.GetDateTimeReport(Now(), gb.GeneralDate))

End

Public Sub btncustom_Click()

  Dim hForm As FmDiscCategory

  If txtdisctyp.Text Then
    If cmbdiscmode.Text = "Custom Values" Then
      hForm = New FmDiscCategory(txtdisctyp.Text)
      hForm.ShowModal
    Endif
  Endif

End

Public Sub GridView1_Menu()

  mnufile.Popup

End

Public Sub mnudelete_Click()

  Dim res As Result

  If GridView1.Rows.Selection.Count > 0 Then
    If Message.Question(("Are you sure?"), ("No"), ("Yes")) = 2 Then
      res = modDatabase.$myConn.Exec("select fldid from tblcustdiscount where fldtype=&1", GridView1[GridView1.Row, 0].Text)
      If res.Available Then
        For Each res
          modDatabase.$myConn.Delete("tblcustdiscount", "fldid=&1", res["fldid"])
        Next
      Endif
      modDatabase.$myConn.Delete("tbldiscount", "fldtype=&1", GridView1[GridView1.Row, 0].Text)
      ShowDiscount()
      Balloon.Delete(("Information deleted"), btnedit)
      Balloon.Delay = modBasic.$BalloonDelay
    Endif
  Endif

End

Public Sub btnnodisclist_Click()

  fmNoDiscForm.Close
  fmNoDiscForm.ShowModal

End

Public Sub txtdisctyp_KeyPress()

  modGeneralMain.InputTextKeyOnly()

End
