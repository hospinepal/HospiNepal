' Gambas class file

Private $rData As Result
Private $ItemList As String[]

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me)
  cmbtype.List = ["Test", "Service", "Procedure", "Equipment", "Radio"]
  cmbcategory.List = ["Payable", "Referral"]
  $ItemList = New String[]

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

Public Sub Form_KeyRelease()

  modGeneralmain.GoToNextControlTab()

End

Public Sub btnconsult_Click()

  btnconsult.Tag = MedicalSelectedUser(("Select Professional User"), modGeneral.CategoricalUserList("%"))
  btnconsult.Text = modGeneral.GetUserFullName(btnconsult.Tag)

End

Public Sub btnitemulti_Click()

  $ItemList.Clear()
  If cmbtype.Text Then
    $ItemList = GridListView(("Select Items"), modNonMedical.NonStockBillingItemArray(modNonMedical.GetBillItemCategoryFromCombo(cmbtype.Text), "%"))
  Endif

End

Public Sub cmbtype_LostFocus()

  $ItemList.Clear()
  If cmbtype.Text Then
    cmbitem.List = modNonMedical.NonStockBillActiveItemArray(modNonMedical.GetBillItemCategoryFromCombo(cmbtype.Text), "%")
  Endif

End

Public Sub btnrefresh_Click()

  If btnconsult.Text Then
    FillUserGridShare()
    cmbtype.SetFocus
  Endif

End

Private Sub FillUserGridShare()

  Dim sql As String
  Dim Column As Integer
  Dim fld As ResultField

  sql = "select fldid,flditemtype,flditemname,flditemshare,flditemtax from tbluserpay where flduserid=&1 ORDER BY flditemname ASC"
  $rData = modDatabase.$myConn.Exec(sql, btnconsult.Tag)

  GridView1.Clear
  GridView1.Columns.Count = $rData.Fields.Count
  GridView1.Rows.Count = $rData.Count

  For Each $rData
    Column = 0
    For Each fld In $rData.Fields
      modGeneralMain.GridExplicitDecoration(GridView1, $rData.Index, Column)
      GridView1[$rData.Index, Column].Text = $rData[fld.Name]
      Column = Column + 1
    Next
  Next
  GridView1.Row = 0

  With GridView1
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 1
    .Columns[1].Width = 75 * modBasic.$AppWidthRatio
    .Columns[2].Width = 325 * modBasic.$AppWidthRatio
    .Columns[3].Width = 75 * modBasic.$AppWidthRatio
    .Columns[4].Width = 75 * modBasic.$AppWidthRatio

    .Columns[1].Text = "Category"
    .Columns[2].Text = "Particulars"
    .Columns[3].Text = "Share(%)"
    .Columns[4].Text = "Tax(%)"
  End With

End

Public Sub btnadd_Click()

  Dim res As Result
  Dim xx As String

  If btnconsult.Tag And If cmbcategory.Text Then
    If cmbitem.Text Then
      res = modDatabase.$myConn.Create("tbluserpay")
      res["flduserid"] = btnconsult.Tag
      res["flditemname"] = cmbitem.Text
      res["flditemtype"] = cmbcategory.Text
      res["flditemshare"] = txtshare.Value
      res["flditemtax"] = txttax.Value
      res.Update()
    Else
      For Each xx In $ItemList
        res = modDatabase.$myConn.Create("tbluserpay")
        res["flduserid"] = btnconsult.Tag
        res["flditemname"] = xx
        res["flditemtype"] = cmbcategory.Text
        res["flditemshare"] = txtshare.Value
        res["flditemtax"] = txttax.Value
        res.Update()
      Next
    Endif
    $ItemList.Clear()
    FillUserGridShare()
    Balloon.Info(("Information saved"), btnadd)
    Balloon.Delay = modBasic.$BalloonDelay

    cmbitem.Clear()
    cmbitem.Text = ""
    cmbtype.SetFocus
  Endif

End

Public Sub btnexpo_Click()

  modCHTMLReport.ExportGridToHTML(GridView1, "NAME: " & btnconsult.Text & " [" & btnconsult.Tag & "]", modReportVar.GetDateTimeReport(Now(), gb.GeneralDate))                                                 ''

End

Public Sub cmbtype_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbtype)
  modFillContainer.RestrictComboToContent(cmbtype)

End

Public Sub cmbcategory_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbcategory)
  modFillContainer.RestrictComboToContent(cmbcategory)

End

Public Sub GridView1_Menu()

  mnuhide.Popup

End

Public Sub mnudel_Click()

  If GridView1.Rows.Selection.Count > 0 Then
    modDatabase.$myConn.Delete("tbluserpay", "fldid=&1", GridView1[GridView1.Row, 0].Text)
    FillUserGridShare()
    Balloon.Delete(("Information deleted"), GridView1)
    Balloon.Delay = modBasic.$BalloonDelay
  Endif

End

Public Sub btnadd2_Click()

  Dim xPath As String

  xPath = modReportBilling.ShowPaybleUserListHTML()
  modPrint.OpenHTMLPreview("", xPath, "ReportSize")

End

Public Sub cmbitem_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbitem)
  modFillContainer.RestrictComboToContent(cmbitem)

End
