' Gambas class file

Private $rData As Result

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me)
  cmbtype.List = ["Test", "Service", "Procedure", "Equipment", "Radio", "Others"]
  cmbtypeextra.List = ["AllTime", "Before", "After"]
  cmbgroup.List = modMisc.GetDepartmentAllList("Consultation")
  cmbbilmode.List = modNonMedical.FillCashModeCombo()

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

Public Sub Form_KeyRelease()

  modGeneralmain.GoToNextControlTab()

End

Private Sub FillGroupGrid()

  Dim sql As String
  Dim Column As Integer
  Dim fld As ResultField

  If cmbgroup.Text Then
    sql = "select fldid,fldbillingmode,flditemname,flditemqty,fldexitemtype,fldcutoff from tblautogroup where fldgroup=&1"
    $rData = modDatabase.$myConn.Exec(sql, cmbgroup.Text)

    GridView1.Clear
    GridView1.Columns.Count = $rData.Fields.Count
    GridView1.Rows.Count = $rData.Count

    For Each $rData
      Column = 0
      For Each fld In $rData.Fields
        modGeneralMain.GridExplicitDecoration(GridView1, $rData.Index, Column)
        GridView1[$rData.Index, Column].Text = $rData[fld.Name]
        Column = Column + 1
      Next
    Next
    GridView1.Row = 0

    With GridView1
      .Rows.Height = 25 * modBasic.$AppHeightRatio
      .Columns[0].Width = 1
      .Columns[1].Width = 100 * modBasic.$AppWidthRatio
      .Columns[2].Width = 200 * modBasic.$AppWidthRatio
      .Columns[3].Width = 50 * modBasic.$AppWidthRatio
      .Columns[4].Width = 100 * modBasic.$AppWidthRatio
      .Columns[5].Width = 100 * modBasic.$AppWidthRatio

      .Columns[1].Text = "Billing Mode"
      .Columns[2].Text = "ItemName"
      .Columns[3].Text = "QTY"
      .Columns[4].Text = "Timing"
      .Columns[5].Text = "CutOff"
    End With
  Endif

End

Public Sub cmbtype_LostFocus()

  If cmbbilmode.Text And If cmbtype.Text Then
    cmbtest.List = modNonMedical.NonStockBillActiveItemArray(modNonMedical.GetBillItemCategoryFromCombo(cmbtype.Text), "%")
  Endif

End

Public Sub cmbtype_GotFocus()

  cmbtest.Clear

End

Public Sub btnBrOK_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    btnBrOK_Click()
  Endif

End

Public Sub btnBrOK_Click()

  Dim res As Result

  If cmbgroup.Text And If cmbtest.Text And If cmbtype.Text And If cmbbilmode.Text Then
    res = modDatabase.$myConn.Create("tblautogroup")
    res["fldgroup"] = cmbgroup.Text
    res["flditemtype"] = cmbtype.Text
    res["flditemname"] = cmbtest.Text
    res["flditemqty"] = txtqty.Value
    res["fldbillingmode"] = cmbbilmode.Text
    res["fldexitemtype"] = cmbtypeextra.Text
    res["fldcutoff"] = dtextra.Value
    res.Update
    FillGroupGrid()
    cmbtype.Text = ""
    cmbtest.Text = ""
    txtqty.Value = 0
    cmbtypeextra.Text = ""
    Balloon.Info(("Information saved"), btnBrOK)
    Balloon.Delay = modBasic.$BalloonDelay
    cmbtype.SetFocus
  Endif

End

Public Sub btnrefresh_Click()

  FillGroupGrid()
  cmbtype.SetFocus

End

Public Sub cmbtype_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbtype)
  modFillContainer.RestrictComboToContent(cmbtype)

End

Public Sub GridView1_Menu()

  mnuhide.Popup

End

Public Sub mnudel_Click()

  If GridView1.Rows.Selection.Count > 0 Then
    modDatabase.$myConn.Delete("tblautogroup", "fldid=&1", GridView1[GridView1.Row, 0].Text)
    FillGroupGrid()
    Balloon.Delete(("Information deleted"), GridView1)
    Balloon.Delay = modBasic.$BalloonDelay
  Endif

End

Public Sub btnexport_Click()

  modCHTMLReport.ExportGridToHTML(GridView1, Me.Text, cmbgroup.Text)

End

Public Sub GridView1_Click()

  Dim res As Result

  res = modDatabase.$myConn.Exec("select fldgroup,flditemtype,fldbillingmode,flditemname,flditemqty,fldexitemtype,fldcutoff from tblautogroup where fldid=&1", GridView1[GridView1.Row, 0].Text)                                                 ''
  If res.Available Then
    cmbgroup.Text = res!fldgroup
    cmbbilmode.Text = res!fldbillingmode
    cmbtype.Text = res!flditemtype
    cmbtest.Text = res!flditemname
    txtqty.Value = res!flditemqty
    cmbtypeextra.Text = res!fldexitemtype
    dtextra.Value = res!fldcutoff
  Endif

End

Public Sub btnedit_Click()

  Dim res As Result
  Dim Row As Integer

  If GridView1.Rows.Selection.Count > 0 Then
    Row = GridView1.Row
    res = modDatabase.$myConn.Edit("tblautogroup", "fldid=&1", GridView1[GridView1.Row, 0].Text)
    res["fldgroup"] = cmbgroup.Text
    res["flditemtype"] = cmbtype.Text
    res["flditemname"] = cmbtest.Text
    res["flditemqty"] = txtqty.Value
    res["fldbillingmode"] = cmbbilmode.Text
    res["fldexitemtype"] = cmbtypeextra.Text
    res["fldcutoff"] = dtextra.Value
    res.Update
    FillGroupGrid()
    GridView1.Row = Row
    Balloon.Info(("Information updated"), btnedit)
    Balloon.Delay = modBasic.$BalloonDelay
  Endif

End

Public Sub btnadd2_Click()

  Dim xPath As String

  xPath = modReportBilling.RegistAutoBillingList()
  modPrint.OpenHTMLPreview("", xPath, "ReportSize")

End

Public Sub cmbtypeextra_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbtypeextra)
  modFillContainer.RestrictComboToContent(cmbtypeextra)

End

Public Sub cmbtypeextra_LostFocus()

  modFillContainer.RestrictCombo(cmbtypeextra)

End

Public Sub cmbbilmode_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbbilmode)
  modFillContainer.RestrictComboToContent(cmbbilmode)

End

Public Sub cmbtest_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbtest)
  modFillContainer.RestrictComboToContent(cmbtest)

End
