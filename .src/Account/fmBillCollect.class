' Gambas class file

Private $rData As Result
Private $aMyFields As String[]

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me)
  dtentry.Value = Now()

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.Esc Then
    Me.Close
  Else
    modGeneralmain.GoToNextControlTab()
  Endif

End

Public Sub btnadd_Click()

  Dim res As Result

  If txtuser.Text And If txtfrominv.Text And txttoinv.Text Then
    If Message.Question(("Are you sure ?"), ("No"), ("Yes")) = 2 Then
      res = modDatabase.$myConn.Create("tblusercollection")
      res["fldcashier"] = Trim(txtuser.Text)
      res["fldfrominvoice"] = txtfrominv.Text
      res["fldtoinvoice"] = txttoinv.Text
      res["fldbillamt"] = txtbillamt.Value
      res["fldretinvoice"] = txtretinvoice.Text
      res["fldretamt"] = txtretamt.Value
      res["fldrecvamt"] = txtrecvamt.Value
      res["flduserid"] = modGeneralMain.$lbluser
      res["fldtime"] = Now()
      res["fldcomp"] = modGeneralMain.compID
      res["fldsave"] = True
      res.Update
      ShowCOllection()
      Balloon.Info(("Information saved"), btnadd)
      Balloon.Delay = modBasic.$BalloonDelay
    Endif
  Endif

End

Private Sub ShowCOllection()

  Dim xrecv As Float
  Dim xpaid As Float
  Dim res1 As Result
  Dim res2 As Result

  $rData = modDatabase.$myConn.Exec("select fldid,fldfrominvoice,fldtoinvoice,fldbillamt,fldretinvoice,fldretamt,fldrecvamt from tblusercollection where fldcashier=&1", Trim(txtuser.Text))                                                       ''
  $aMyFields = New String[]
  modGridView.ReadSmallData(GridView1, $rData, $aMyFields)

  res1 = modDatabase.$syConn.Exec("select SUM(fldreceivedamt) as totrecv from tblpatbilldetail where flduserid=&1", Trim(txtuser.Text))
  If res1.Available Then
    If res1!totrecv Then
      xrecv = res1!totrecv
    Else
      xrecv = 0
    Endif
  Else
    xrecv = 0
  Endif
  res2 = modDatabase.$syConn.Exec("select SUM(fldrecvamt) as paidtot from tblusercollection where fldcashier=&1", Trim(txtuser.Text))
  If res2.Available Then
    If res2!paidtot Then
      xpaid = res2!paidtot
    Else
      xpaid = 0
    Endif
  Else
    xpaid = 0
  Endif
  With GridView1
    .Columns[0].Width = 1
    .Columns[1].Width = 120 * modBasic.$AppWidthRatio
    .Columns[2].Width = 120 * modBasic.$AppWidthRatio
    .Columns[3].Width = 120 * modBasic.$AppWidthRatio
    .Columns[4].Width = 100 * modBasic.$AppWidthRatio
    .Columns[5].Width = 1
    .Columns[6].Width = 120 * modBasic.$AppWidthRatio

    .Columns[1].Text = "From Inv"
    .Columns[2].Text = "To Inv"
    .Columns[3].Text = "Inv AMT"
    .Columns[4].Text = "Returns"
    .Columns[6].Text = "Recv AMT"
  End With
  txtrecvtotal.Value = xrecv
  txtpaidtotal.Value = xpaid

End

Public Sub GridView1_Data(Row As Integer, Column As Integer)

  $rData.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView1, Row)
  If Column = 3 Then
    GridView1.Data.Text = modReportVar.GetLocaleNumberFormat($rData[$aMyFields[Column]], gb.Currency)
  Else If Column = 5 Then
    GridView1.Data.Text = modReportVar.GetLocaleNumberFormat($rData[$aMyFields[Column]], gb.Currency)
  Else If Column = 6 Then
    GridView1.Data.Text = modReportVar.GetLocaleNumberFormat($rData[$aMyFields[Column]], gb.Currency)
  Else
    GridView1.Data.Text = $rData[$aMyFields[Column]]
  Endif

End

Public Sub btnrefresh_Click()

  Dim res As Result

  If txtuser.Text Then
    ShowCOllection()
    txtfrominv.Text = ""
    res = modDatabase.$myConn.Exec("select fldbillno from tblpatbilldetail where fldtime>=&1 and fldtime<=&2", modDate.StartSqlDate(dtentry.value), modDate.EndSqlDate(dtentry.value))
    If res.Available Then
      res.MoveLast
      txttoinv.Text = res!fldbillno
    Endif
  Endif

End

Public Sub GridView1_Click()

  Dim res As Result

  res = modDatabase.$myConn.Exec("select fldcashier,fldfrominvoice,fldtoinvoice,fldbillamt,fldretinvoice,fldretamt,fldrecvamt from tblusercollection where fldid=&1", GridView1[GridView1.Row, 0].Text)
  If res.Available Then
    txtuser.Text = res["fldcashier"]
    txtfrominv.Text = res["fldfrominvoice"]
    txttoinv.Text = res["fldtoinvoice"]
    txtbillamt.Value = res["fldbillamt"]
    txtretinvoice.Text = res["fldretinvoice"]
    txtretamt.Value = res["fldretamt"]
    txtrecvamt.Value = res["fldrecvamt"]
  Endif

End

Public Sub btnprint_Click()

  Dim xPath As String

  If GridView1.Rows.Selection.Count > 0 Then
    xPath = modReportBilling.ShowUserCollection(GridView1[GridView1.Row, 0].Text)
    modPrint.OpenHTMLPreview("", xPath, "ReportSize")
  Endif

End

Public Sub btngetval_Click()

  If txtfrominv.Text And If txttoinv.Text Then
    txtbillamt.Value = modBillings.GetInvoiceAmountBetweenBills(txtuser.Text, txtfrominv.Text, txttoinv.Text, "%")
    btnadd.Enabled = True
  Endif

End

Public Sub btnexpo_Click()

  Dim sAmt As String[]

  sAmt = New String[]
  sAmt.Add("")
  sAmt.Add("")
  sAmt.Add("")
  sAmt.Add("")
  sAmt.Add(modReportVar.GetLocaleNumberFormat(txtpaidtotal.Value, gb.Currency))
  modCHTMLReport.ExportGridToHTML(GridView1, "User: " & txtuser.Text, modReportVar.GetDateTimeReport(Now(), gb.GeneralDate), sAmt)

End

Public Sub txtfrominv_KeyPress()

  modGeneralMain.InputUpCaseOnly()

End

Public Sub txttoinv_KeyPress()

  modGeneralMain.InputUpCaseOnly()

End
