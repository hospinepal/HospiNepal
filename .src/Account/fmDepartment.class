' Gambas class file

Private $rData As Result

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me)
  cmbcategory.List = ["Consultation", "Patient Ward"]
  cmbbedcharge.List = modNonMedical.NonStockBillingItemArray("General Services", "%")
  cmbround.List = modNonMedical.NonStockBillingItemArray("General Services", "%")
  ShowCostGrid()

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.Esc Then
    Me.Close
  Else
    modGeneralmain.GoToNextControlTab()
  Endif

End

Public Sub cmbcategory_KeyRelease()

  modFillContainer.RestrictComboToContent(cmbcategory)

End

Public Sub cmbbedcharge_KeyRelease()

  modFillContainer.RestrictComboToContent(cmbbedcharge)

End

Public Sub cmbround_KeyRelease()

  modFillContainer.RestrictComboToContent(cmbround)

End

Public Sub btnBrOK_Click()

  Dim res As Result

  If txtdept.Text Then
    res = modDatabase.$myConn.Create("tbldepartment")
    res["flddept"] = Trim(txtdept.Text)
    res["fldroom"] = txtroom.Text
    res["fldbedcharge"] = cmbbedcharge.Text
    res["fldround"] = cmbround.Text
    res["fldcateg"] = cmbcategory.Text
    res["fldactive"] = btnconsult.Tag
    res.Update()
    ShowCostGrid()
    Balloon.Info(("Information saved"), btnBrOK)
    Balloon.Delay = modBasic.$BalloonDelay
    txtdept.SetFocus
  Endif

End

Public Sub btnrefresh_Click()

  ShowCostGrid()

End

Private Sub ShowCostGrid()

  Dim sql As String
  Dim Column As Integer
  Dim fld As ResultField
  Dim xcateg As String

  If cmbcategory.Text Then
    xcateg = cmbcategory.Text
  Else
    xcateg = "%"
  Endif
  sql = "select fldid,flddept,fldcateg,fldroom,fldbedcharge,fldround,fldactive from tbldepartment where fldcateg like &1 ORDER BY flddept ASC"
  $rData = modDatabase.$myConn.Exec(sql, xcateg)

  GridView1.Clear
  GridView1.Columns.Count = $rData.Fields.Count
  GridView1.Rows.Count = $rData.Count

  For Each $rData
    Column = 0
    For Each fld In $rData.Fields
      modGeneralMain.GridExplicitDecoration(GridView1, $rData.Index, Column)
      GridView1[$rData.Index, Column].Text = $rData[fld.Name]
      Column = Column + 1
    Next
  Next
  GridView1.Row = 0

  With GridView1
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 1
    .Columns[1].Width = 150 * modBasic.$AppWidthRatio
    .Columns[2].Width = 1
    .Columns[3].Width = 50 * modBasic.$AppWidthRatio
    .Columns[4].Width = 150 * modBasic.$AppWidthRatio
    .Columns[5].Width = 150 * modBasic.$AppWidthRatio
    .Columns[6].Width = 1

    .Columns[1].Text = "Department"
    .Columns[3].Text = "RoomNo"
    .Columns[4].Text = "Bed Charge"
    .Columns[5].Text = "Round"
  End With

End

Public Sub mnudel_Click()

  If GridView1.Rows.Selection.Count > 0 Then
    If Message.Question(("Are you sure?"), ("No"), ("Yes")) = 2 Then
      modDatabase.$myConn.Delete("tbldepartment", "fldid=&1", GridView1[GridView1.Row, 0].Text)
      ShowCostGrid()
      Message.Delete(("Information deleted"), ("OK"))
    Endif
  Endif

End

Public Sub GridView1_Click()

  txtdept.Text = GridView1[GridView1.Row, 1].Text
  cmbcategory.Text = GridView1[GridView1.Row, 2].Text
  txtroom.Text = GridView1[GridView1.Row, 3].Text
  cmbbedcharge.Text = GridView1[GridView1.Row, 4].Text
  cmbround.Text = GridView1[GridView1.Row, 5].Text

  btnconsult.Tag = GridView1[GridView1.Row, 6].Text
  btnconsult.Text = modGeneral.GetUserFullName(btnconsult.Tag)

End

Public Sub btnbed_Click()

  Dim hForm As FmAddVariable1

  hForm = New FmAddVariable1("fldbed", "flddept", txtdept.Text, "tbldepartmentbed")
  hForm.ShowModal

End

Public Sub btnedit_Click()

  Dim res As Result
  Dim Row As Integer

  If GridView1.Rows.Selection.Count > 0 Then
    Row = GridView1.Row
    res = modDatabase.$myConn.Edit("tbldepartment", "fldid=&1", GridView1[GridView1.Row, 0].Text)
    res["flddept"] = Trim(txtdept.Text)
    res["fldroom"] = txtroom.Text
    res["fldbedcharge"] = cmbbedcharge.Text
    res["fldround"] = cmbround.Text
    res["fldcateg"] = cmbcategory.Text
    res["fldactive"] = btnconsult.Tag
    res.Update()
    ShowCostGrid()
    GridView1.Row = Row
    Balloon.Info(("Information updated"), btnedit)
    Balloon.Delay = modBasic.$BalloonDelay
  Endif

End

Public Sub GridView1_Menu()

  mnuhide.Popup

End

Public Sub btnconsult_Click()

  If cmbcategory.Text = "Consultation" Then
    btnconsult.Tag = MedicalSelectedUser(("Select Incharge User"), modBasic.$OPConsulUserList)
  Else If cmbcategory.Text = "Patient Ward" Then
    btnconsult.Tag = MedicalSelectedUser(("Select Incharge User"), modBasic.$IPConsultUserList)
  Endif
  btnconsult.Text = modGeneral.GetUserFullName(btnconsult.Tag)

End

Public Sub btnexport_Click()

  modCHTMLReport.ExportGridToHTML(GridView1, "DEPARTMENTS", modReportVar.GetDateTimeReport(Now(), gb.GeneralDate))

End

Public Sub txtdept_KeyPress()

  modGeneralMain.InputTextKeyOnly()

End
