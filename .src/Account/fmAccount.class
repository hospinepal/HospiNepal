Public Sub mnuyearly_Click()

  Dim xdate As Date[]
  Dim inidate As Date
  Dim lstdate As Date
  Dim res As Result
  Dim hForm As FRequest

  xdate = DoubleDates("Select Dates", "Yearly Report", [Now(), Now()])
  If xdate Then
    inidate = xdate[0]
    lstdate = xdate[1]

    If inidate And If lstdate Then
      res = modDatabase.$syConn.Exec("select fldfiscal,fldbillno,fldpatname,fldpan,flddate,flditemamt,flddiscountamt,fldtaxable,fldtaxamt,fldtotamt,fldsync,fldprinted,fldactive,fldtime,fldpunch,fldprint,xyz from tblfiscal where flddate>=&1 and flddate<=&2", modDate.StartSqlDate(inidate), modDate.EndSqlDate(lstdate))                                                                ''
      hForm = New FRequest(res, "Yearly Report", "YearReport", True)
      hForm.ShowModal
    Endif
  Endif

End
