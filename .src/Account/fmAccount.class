Public Sub mnubackstock_Click()

  Dim res As Result

  Inc Application.Busy
  res = modDatabase.$myConn.Exec("select distinct(fldcomp) from tblentry")
  For Each res
    modStock.BackupEntryStock(res!fldcomp)
  Next
  Dec Application.Busy

  Message.Info(("Backup completed"), ("OK"))

End

