    Header = GridView.Both
    AutoResize = False
  }
  { Label2 Label
    MoveScaled(1,1,13,3.25)
    Text = ("Group Name")
    Border = Border.Plain
  }
  { btnadd Button
    MoveScaled(55,1,3,3)
    Picture = Picture["icon:/small/add"]
  }
  { btnadd2 Button
    MoveScaled(61,1,11.25,3)
