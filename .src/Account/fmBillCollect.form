    Border = Border.Plain
  }
  { Label3 Label
    MoveScaled(1,9,13.4,3)
    Text = ("Invoice AMT")
    Border = Border.Plain
  }
  { Label4 Label
    MoveScaled(1,13,13.4,3)
    Text = ("Return Inv")
    Border = Border.Plain
  }
  { Label5 Label
    MoveScaled(52,13,5,3)
    Text = ("AMT")
    Border = Border.Plain
  }
  { Label6 Label
    MoveScaled(1,1,13.4,3)
    Text = ("User ID")
    Border = Border.Plain
  }
  { Separator2 Separator
    MoveScaled(1,4,68,1)
  }
  { Separator3 Separator
    MoveScaled(1,16,69,1)
  }
  { Label7 Label
    MoveScaled(1,17,13,3)
    Text = ("Paid AMT")
    Border = Border.Plain
  }
  { Label8 Label
    MoveScaled(39,1,11,3)
    Text = ("DateTime")
    Border = Border.Plain
  }
  { dtentry DateBox
    MoveScaled(51,1,18,3)
  }
