    MoveScaled(15,9,15,3)
    ReadOnly = True
  }
  { txtretinvoice TextBox
    MoveScaled(15,13,36,3)
  }
  { txtretamt ValueBox
    MoveScaled(58,13,11,3)
  }
  { txtrecvamt ValueBox
    MoveScaled(15,17,18,3)
  }
  { btnadd Button
    MoveScaled(50,17,13,3)
