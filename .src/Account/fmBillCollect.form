# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,71,64)
  Tag = "User Collection"
  Text = ("User Collection")
  Resizable = False
  { txtuser TextBox
    MoveScaled(15,1,15,3)
  }
  { btnrefresh Button
    MoveScaled(30,1,3.5333,3)
    Picture = Picture["icon:/small/refresh"]
  }
  { txtfrominv TextBox
    MoveScaled(15,5,18,3)
  }
  { txttoinv TextBox
    MoveScaled(51,5,18,3)
  }
