    Tag = "Auto"
    Text = Shortcut(("Save"), "S")
    Picture = Picture["icon:/small/add"]
  }
  { btnprint Button
    MoveScaled(66,17,3.5333,3)
    Picture = Picture["icon:/small/print"]
  }
