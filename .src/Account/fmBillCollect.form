    Header = GridView.Both
    AutoResize = False
  }
  { btngetval Button
    MoveScaled(30,9,3.5333,3)
    Picture = Picture["icon:/small/refresh"]
  }
  { btnexpo Button
    MoveScaled(63,17,3,3)
