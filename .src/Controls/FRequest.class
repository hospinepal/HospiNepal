      .Columns[3].Text = "Count"

    Else If $strType = "InPatientForm" Then
      .Columns[0].Width = 100 * modBasic.$AppWidthRatio
      .Columns[1].Width = 180 * modBasic.$AppWidthRatio
      .Columns[2].Width = 100 * modBasic.$AppWidthRatio
      .Columns[3].Width = 120 * modBasic.$AppWidthRatio
      .Columns[4].Width = 170 * modBasic.$AppWidthRatio
      .Columns[5].Width = 180 * modBasic.$AppWidthRatio

      .Columns[0].Text = "Encounter"
      .Columns[1].Text = "DORec"
      .Columns[2].Text = "Status"
      .Columns[3].Text = "LastLocat"
      .Columns[4].Text = "Consultant"
      .Columns[5].Text = "FollowUp"

    Endif

  End With

End

Public Sub mnudetreport_Click()

  Dim xPath As String

  If GridView1.Rows.Selection.Count > 0 Then
    If $strType = "Supplier" Then
      xPath = modHTMLStock.PurchaseEntryReport(GridView1[GridView1.Row, 1].Text, "PurEntry", modStock.GetDiscountFromPurchaseBill(GridView1[GridView1.Row, 1].Text), modStock.GetTaxFromPurchaseBill(GridView1[GridView1.Row, 1].Text))      '
      modPrint.OpenHTMLPreview("", xPath, "ReportSize")
    Else If $strType = "InPatientForm" Then
      xPath = modPatReports.ShowCompleteReport(GridView1[GridView1.Row, 0].Text, "Metric")                                           ''
      modPrint.OpenHTMLPreview(GridView1[GridView1.Row, 0].Text, xPath, "ReportSize")
    Endif
  Endif

End

Public Sub GridView1_Menu()

  If $strType = "Supplier" Or If $strType = "InPatientForm" Then
    mnuhide.Popup
  Endif

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.Esc Then
    Me.Close
  Endif

End

Public Sub mnuexpo_Click()

  modCHTMLReport.ExportGridToHTML(GridView1, Me.Text, modReportVar.GetDateTimeReport(Now(), gb.GeneralDate))

End

Public Sub mnutransfer_Click()

  modSQLite.ExportGridToSqlite(GridView1)

End
