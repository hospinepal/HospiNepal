      .Columns[3].Text = "Date"
      .Columns[4].Text = "Invoice"
      .Columns[5].Text = "Category"
      .Columns[6].Text = "Debit"
      .Columns[7].Text = "Credit"

    Else If $strType = "StockDB" Then
      .Columns[0].Width = 50 * modBasic.$AppWidthRatio
      .Columns[1].Width = 300 * modBasic.$AppWidthRatio
      .Columns[2].Width = 100 * modBasic.$AppWidthRatio
      .Columns[3].Width = 120 * modBasic.$AppWidthRatio
      .Columns[4].Width = 75 * modBasic.$AppWidthRatio
      .Columns[5].Width = 75 * modBasic.$AppWidthRatio
      .Columns[6].Width = 50 * modBasic.$AppWidthRatio
