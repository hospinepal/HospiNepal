' Gambas class file

Private $txtval As TextHTML

Public Sub _new(sTextArea As TextHTML)

  $txtval = sTextArea

End

Public Sub Keygroup_Click()

  Dim xx As String

  xx = Last.Text
  If xx = "Space" Then
    $txtval.RichText = $txtval.RichText & Space(1)
  Else If xx = "Enter" Then
    $txtval.RichText = $txtval.RichText & gb.NewLine
  Else
    If btnshift.Value = False Then
      $txtval.RichText = $txtval.RichText & LCase(xx)
    Else If btnshift.Value = True Then
      $txtval.RichText = $txtval.RichText & UCase(xx)
    Endif
  Endif

End

Public Sub Form_KeyRelease()

End
