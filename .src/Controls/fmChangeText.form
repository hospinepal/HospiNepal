# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,35,12)
  Text = ("Update")
  Resizable = False
  { txtchangetext TextBox
    MoveScaled(0,4,35,4)
  }
  { btnchange Button
    MoveScaled(0,8,35,4)
    Text = Shortcut(("Update"), "U")
    Picture = Picture["icon:/small/apply"]
    Default = True
  }
  { txtfixtext Label
    MoveScaled(0,0,35,4)
    Border = Border.Plain
  }
}
