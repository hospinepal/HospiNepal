' Gambas module file

Private $ProgressBar1 As ProgressBar

''--------------------------------- FAST REPORTS -------------------------------------
Public Function ShowTotalInvoicebyPatient(encid As String) As String

  Dim $BillingReport As CReportHTML
  Dim asx As New String[0]
  Dim RepoPath As String
  Dim sql As String
  Dim res As Result

  Dim subtotal As Float
  Dim tax As Float
  Dim disc As Float
  Dim tot As Float
  Dim recv As Float

  Inc Application.Busy                                                                                       ''
  $BillingReport = New CReportHTML([("DATE"), ("TYPE"), ("INVOICE NO"), ("PREV DEPO"), ("SUBTOTAL"), ("TAX AMT"), ("DISC AMT"), ("TOTAL AMT"), ("RECV AMT"), ("CURR DEPO"), ("CATEGORY"), ("VALUE")], modHelpVariable.$htmlDirectory, "PatientReport", encid)
  $BillingReport.UserData.Add("REPORT", "Report")
  $BillingReport.UserData.Add("INVOICES", "PARAM1")

  subtotal = 0
  tax = 0
  disc = 0
  tot = 0
  recv = 0

  sql = "select fldtime,fldbillno,fldprevdeposit,flditemamt,fldtaxamt,flddiscountamt,fldchargedamt,fldreceivedamt,fldcurdeposit,fldbilltype,fldchequeno,fldbankname from tblpatbilldetail where fldencounterval=&1"                                                                    '''
  res = modDatabase.$syConn.Exec(sql, encid)
  For Each res
    subtotal = subtotal + res!flditemamt
    tax = tax + res!fldtaxamt
    disc = disc + res!flddiscountamt
    tot = tot + res!fldchargedamt
    recv = recv + res!fldreceivedamt

    With asx
      .Add(modReportVar.GetDateTimeReport(res!fldtime, gb.GeneralDate))
      .Add(res!fldbilltype)
      .Add(res!fldbillno)
      .Add(modReportVar.GetLocaleNumberFormat(res!fldprevdeposit, gb.Currency))
      .Add(modReportVar.GetLocaleNumberFormat(res!flditemamt, gb.Currency))
      .Add(modReportVar.GetLocaleNumberFormat(res!fldtaxamt, gb.Currency))
      .Add(modReportVar.GetLocaleNumberFormat(res!flddiscountamt, gb.Currency))
      .Add(modReportVar.GetLocaleNumberFormat(res!fldchargedamt, gb.Currency))
      .Add(modReportVar.GetLocaleNumberFormat(res!fldreceivedamt, gb.Currency))
      .Add(modReportVar.GetLocaleNumberFormat(res!fldcurdeposit, gb.Currency))
      .Add(res!fldbankname)
      .Add(res!fldchequeno)
    End With
    $BillingReport.Add(asx)
    asx.Clear()
  Next

  With asx
    .Add("..")
    .Add("..")
    .Add("..")
    .Add("..")
    .Add(modReportVar.GetLocaleNumberFormat(subtotal, gb.Currency))
    .Add(modReportVar.GetLocaleNumberFormat(tax, gb.Currency))
    .Add(modReportVar.GetLocaleNumberFormat(disc, gb.Currency))
    .Add("..")
    .Add(modReportVar.GetLocaleNumberFormat(recv, gb.Currency))
    .Add("..")
    .Add("..")
    .Add("..")
  End With
  $BillingReport.Add(asx)
  asx.Clear()
  Dec Application.Busy

  RepoPath = $BillingReport.NewHTMLPath()
  Return RepoPath

End

Public Function BillDepartmentWise($con As Connection, billno As String, encid As String) As String

  Dim $BillingReport As CReportHTML
  Dim RepoPath As String
  Dim asx As New String[0]

  Dim grpList As String[]
  Dim sCateg As String
  Dim res As Result
  Dim xtot As Float
  Dim xtax As Float
  Dim xdisc As Float
  Dim altot As Float
  Dim altax As Float
  Dim aldisc As Float
  Dim i As Integer
  Dim res1 As Result
  Dim extax As Float
  Dim exdisc As Float

  $BillingReport = New CReportHTML([("SNO"), ("PARTICULARS"), ("DISC AMT"), ("TAX AMT"), ("TOTAL AMT")], modHelpVariable.$htmlDirectory, "PatientReport", encid)
  $BillingReport.UserData.Add("INVOICE", "Report")
  $BillingReport.UserData.Add(billno, "PARAM1")

  Inc Application.Busy
  grpList = modNonMedical.GetGroupNameAccount()
  altot = 0
  altax = 0
  aldisc = 0
  i = 1
  For Each sCateg In grpList
    xtot = 0
    xtax = 0
    xdisc = 0
    res = $con.Exec("select SUM(flddiscamt) as totdisc,SUM(fldtaxamt) as totax,SUM(fldditemamt) as tot from tblpatbilling where flditemname in(select flditemname from tblreportgroup where fldgroup like &1) and fldbillno=&2", sCateg, billno)
    If res.Available Then
      If res!totdisc Then
        xdisc = res!totdisc
      Endif
      If res!totax Then
        xtax = res!totax
      Endif
      If res!tot Then
        xtot = res!tot
      Endif
      altot = altot + xtot
      altax = altax + xtax
      aldisc = aldisc + xdisc

      If xtot Then
        With asx
          .Add(CStr(i))
          .Add(sCateg)
          .Add(modReportVar.GetLocaleNumberFormat(xdisc, gb.Currency))
          .Add(modReportVar.GetLocaleNumberFormat(xtax, gb.Currency))
          .Add(modReportVar.GetLocaleNumberFormat(xtot, gb.Currency))
        End With
        $BillingReport.Add(asx)
        asx.Clear()
        i = i + 1
      Endif

    Endif
  Next

  With asx
    .Add("***")
    .Add("***")
    .Add("***")
    .Add("***")
    .Add("***")
  End With
  $BillingReport.Add(asx)
  asx.Clear()
  With asx
    .Add("")
    .Add("SUBTOTAL")
    .Add(modReportVar.GetLocaleNumberFormat(aldisc, gb.Currency))
    .Add(modReportVar.GetLocaleNumberFormat(altax, gb.Currency))
    .Add(modReportVar.GetLocaleNumberFormat(altot, gb.Currency))
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  extax = 0
  exdisc = 0
  res1 = $con.Exec("select fldtaxamt,flddiscountamt,flditemamt from tblpatbilldetail where fldbillno=&1", billno)
  If res.Available Then
    extax = altax - res1!fldtaxamt
    exdisc = aldisc - res1!flddiscountamt
    With asx
      .Add("")
      .Add("EXTRA")
      .Add(modReportVar.GetLocaleNumberFormat(exdisc, gb.Currency))
      .Add(modReportVar.GetLocaleNumberFormat(extax, gb.Currency))
      .Add("")
    End With
    $BillingReport.Add(asx)
    asx.Clear()
  Endif

  With asx
    .Add("")
    .Add("GRAND TOTAL")
    .Add(modReportVar.GetLocaleNumberFormat(res1!flddiscountamt, gb.Currency))
    .Add(modReportVar.GetLocaleNumberFormat(res1!fldtaxamt, gb.Currency))
    .Add(modReportVar.GetLocaleNumberFormat(altot + extax - exdisc, gb.Currency))
  End With
  $BillingReport.Add(asx)
  asx.Clear()
  Dec Application.Busy

  RepoPath = $BillingReport.NewHTMLPath()
  Return RepoPath

End

'--------------------------------- SLOW REPORTS ---------------------------------------
Public Function RunningRepoDepartmentWise($con As Connection, encid As String) As String

  Dim $BillingReport As CReportHTML
  Dim RepoPath As String
  Dim asx As New String[0]

  Dim grpList As String[]
  Dim sCateg As String
  Dim res As Result
  Dim xtot As Float
  Dim xtax As Float
  Dim xdisc As Float
  Dim altot As Float
  Dim altax As Float
  Dim aldisc As Float
  Dim i As Integer
  Dim xdepo As Float

  $BillingReport = New CReportHTML([("SNO"), ("PARTICULARS"), ("DISC AMT"), ("TAX AMT"), ("TOTAL AMT")], modHelpVariable.$htmlDirectory, "PatientReport", encid)
  $BillingReport.UserData.Add("REPORT", "Report")
  $BillingReport.UserData.Add("NON-INVOICED", "PARAM1")

  Inc Application.Busy
  grpList = modNonMedical.GetGroupNameAccount()
  altot = 0
  altax = 0
  aldisc = 0
  i = 1
  For Each sCateg In grpList
    xtot = 0
    xtax = 0
    xdisc = 0
    res = $con.Exec("select SUM(flddiscamt) as totdisc,SUM(fldtaxamt) as totax,SUM(fldditemamt) as tot from tblpatbilling where fldencounterval=&1 and fldsave=&2 and fldprint=&3 and flditemname in(select flditemname from tblreportgroup where fldgroup like &4)", encid, True, False, sCateg)
    If res.Available Then
      If res!totdisc Then
        xdisc = res!totdisc
      Endif
      If res!totax Then
        xtax = res!totax
      Endif
      If res!tot Then
        xtot = res!tot
      Endif
      altot = altot + xtot
      altax = altax + xtax
      aldisc = aldisc + xdisc

      If xtot Then
        With asx
          .Add(CStr(i))
          .Add(sCateg)
          .Add(modReportVar.GetLocaleNumberFormat(xdisc, gb.Currency))
          .Add(modReportVar.GetLocaleNumberFormat(xtax, gb.Currency))
          .Add(modReportVar.GetLocaleNumberFormat(xtot, gb.Currency))
        End With
        $BillingReport.Add(asx)
        asx.Clear()
        i = i + 1
      Endif

    Endif
  Next

  With asx
    .Add("***")
    .Add("***")
    .Add("***")
    .Add("***")
    .Add("***")
  End With
  $BillingReport.Add(asx)
  asx.Clear()
  With asx
    .Add("")
    .Add("Unpaid Expense")
    .Add(modReportVar.GetLocaleNumberFormat(aldisc, gb.Currency))
    .Add(modReportVar.GetLocaleNumberFormat(altax, gb.Currency))
    .Add(modReportVar.GetLocaleNumberFormat(altot, gb.Currency))
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  With asx
    .Add("***")
    .Add("***")
    .Add("***")
    .Add("***")
    .Add("***")
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  xdepo = modNonMedical.GetPatientDeposit(encid)
  With asx
    .Add("..")
    .Add("Total Deposit")
    .Add("..")
    .Add("..")
    .Add(modReportVar.GetLocaleNumberFormat(xdepo, gb.Currency))
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  With asx
    .Add("***")
    .Add("***")
    .Add("***")
    .Add("***")
    .Add("***")
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  With asx
    .Add("..")
    .Add("Surplus Deposit")
    .Add("..")
    .Add("..")
    .Add(modReportVar.GetLocaleNumberFormat(xdepo - altot, gb.Currency))
  End With
  $BillingReport.Add(asx)
  asx.Clear()
  Dec Application.Busy

  RepoPath = $BillingReport.NewHTMLPath()
  Return RepoPath

End

Public Function ShowPendingExpensebyPatient($con As Connection, encid As String) As String

  Dim $BillingReport As CReportHTML
  Dim RepoPath As String
  Dim rs As Result
  Dim res As Result
  Dim asx As New String[0]
  Dim i As Integer
  Dim rte As Float
  Dim qty As Float
  Dim amt As Float
  Dim tot As Float
  Dim xdepo As Float
  Dim scateg As String
  Dim stot As Float

  If MMain.$IsGUIApp = True Then
    $ProgressBar1 = modHelpVariable.FindWorkProgressBar(modHelpVariable.$LogInCategory)
    $ProgressBar1.Tag = "Const"
  Endif

  $BillingReport = New CReportHTML([("SNo"), ("Particulars"), ("Rate"), ("QTY"), ("Total")], modHelpVariable.$htmlDirectory, "PatientReport", encid)
  $BillingReport.UserData.Add("REPORT", "Report")
  $BillingReport.UserData.Add("NON-INVOICED ITEMS", "PARAM1")

  Inc Application.Busy
  stot = 0
  For Each scateg In modNonMedical.BillItemCategory()
    $BillingReport.AddSection(scateg, True)

    rs = $con.Exec("select distinct(flditemname) from tblpatbilling where fldencounterval=&1 and fldsave=&2 and fldprint=&3 and flditemtype=&4", encid, True, False, scateg)
    i = 1
    tot = 0
    For Each rs
      res = $con.Exec("select avg(flditemrate) as rate,SUM(flditemqty) as qnty,SUM(fldditemamt) as atot from tblpatbilling where fldencounterval=&1 and fldsave=&2 and flditemname=&3 and fldprint=&4 and flditemtype=&5", encid, True, rs!flditemname, False, scateg)
      rte = 0
      qty = 0
      amt = 0
      If res!rate Then
        rte = res!rate
      Endif
      If res!qnty Then
        qty = res!qnty
      Endif
      If res!atot Then
        amt = res!atot
      Endif
      If qty Then
        tot = tot + amt
        With asx
          .Add(CStr(i))
          .Add(rs!flditemname)
          .Add(modReportVar.GetLocaleNumberFormat(rte, gb.Currency))
          .Add(modReportVar.GetLocaleNumberFormat(qty, -2))
          .Add(modReportVar.GetLocaleNumberFormat(amt, gb.Currency))
        End With
        $BillingReport.Add(asx)
        asx.Clear()
        i = i + 1
      Endif

      If MMain.$IsGUIApp = True Then
        $ProgressBar1.Value = (rs.Index + 1) / rs.Count
        Wait
      Endif
    Next 'ends rs

    stot = stot + tot
    With asx
      .Add("..")
      .Add(scateg)
      .Add("..")
      .Add("..")
      .Add(modReportVar.GetLocaleNumberFormat(tot, gb.Currency))
    End With
    $BillingReport.Add(asx)
    asx.Clear()
  Next   ''end category
  With asx
    .Add("***")
    .Add("***")
    .Add("***")
    .Add("***")
    .Add("***")
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  With asx
    .Add("..")
    .Add("Unpaid Expense")
    .Add("..")
    .Add("..")
    .Add(modReportVar.GetLocaleNumberFormat(stot, gb.Currency))
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  With asx
    .Add("***")
    .Add("***")
    .Add("***")
    .Add("***")
    .Add("***")
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  xdepo = modNonMedical.GetPatientDeposit(encid)
  With asx
    .Add("..")
    .Add("Total Deposit")
    .Add("..")
    .Add("..")
    .Add(modReportVar.GetLocaleNumberFormat(xdepo, gb.Currency))
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  With asx
    .Add("***")
    .Add("***")
    .Add("***")
    .Add("***")
    .Add("***")
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  With asx
    .Add("..")
    .Add("Surplus Deposit")
    .Add("..")
    .Add("..")
    .Add(modReportVar.GetLocaleNumberFormat(xdepo - stot, gb.Currency))
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  Dec Application.Busy

  RepoPath = $BillingReport.NewHTMLPath()
  Return RepoPath

End

Public Function ShowTotalExpensebyPatient($con As Connection, encid As String) As String

  Dim $BillingReport As CReportHTML
  Dim RepoPath As String
  Dim rs As Result
  Dim res As Result
  Dim asx As New String[0]
  Dim tot As Float
  Dim xx As Float
  Dim xsub As Float
  Dim res1 As Result
  Dim xsub1 As Float
  Dim xx1 As Float

  If MMain.$IsGUIApp = True Then
    $ProgressBar1 = modHelpVariable.FindWorkProgressBar(modHelpVariable.$LogInCategory)
    $ProgressBar1.Tag = "Const"
  Endif

  $BillingReport = New CReportHTML([("Date"), ("Particulars"), ("Rate"), ("Tax%"), ("Disc%"), ("QTY"), ("Total"), ("Invoice")], modHelpVariable.$htmlDirectory, "PatientReport", encid)
  $BillingReport.UserData.Add("REPORT", "Report")
  $BillingReport.UserData.Add("EXPENSE", "PARAM1")

  Inc Application.Busy
  rs = $con.Exec("select distinct(flditemtype) from tblpatbilling where fldencounterval=&1 and fldsave=&2", encid, True)
  tot = 0
  For Each rs
    ''BILLING
    $BillingReport.AddSection(rs!flditemtype & " BILLING", True)
    res = $con.Exec("select fldditemamt as tot,fldtime,flditemtype,flditemname,flditemrate,fldtaxper,flddiscper,flditemqty,fldstatus,fldbillno from tblpatbilling where fldencounterval=&1 and fldsave=&2 and flditemtype=&3 and flditemqty>&4", encid, True, rs!flditemtype, 0)
    xx = 0
    For Each res
      xsub = 0
      If res.Available = True Then
        If res!tot Then
          xsub = res!tot
        Endif
      Endif
      xx = xx + xsub
      With asx
        .Add(modReportVar.GetDateTimeReport(res!fldtime, gb.GeneralDate))
        .Add(res!flditemname)
        .Add(modReportVar.GetLocaleNumberFormat(res!flditemrate, gb.Currency))
        .Add(modReportVar.GetLocaleNumberFormat(res!fldtaxper, -2))
        .Add(modReportVar.GetLocaleNumberFormat(res!flddiscper, -2))
        .Add(modReportVar.GetLocaleNumberFormat(res!flditemqty, -2))
        .Add(modReportVar.GetLocaleNumberFormat(xsub, gb.Currency))
        .Add(res!fldbillno)
      End With
      $BillingReport.Add(asx)
      asx.Clear()
    Next 'ends res

    tot = tot + xx
    With asx
      .Add("Sub Total")
      .Add(rs!flditemtype & " BILLING")
      .Add("..")
      .Add("..")
      .Add("..")
      .Add("..")
      .Add(modReportVar.GetLocaleNumberFormat(xx, gb.Currency))
      .Add("..")
    End With
    $BillingReport.Add(asx)
    asx.Clear()

    ''RETURN
    $BillingReport.AddSection(rs!flditemtype & " RETURN", True)
    res1 = $con.Exec("select fldditemamt as tot,fldtime,flditemtype,flditemname,flditemrate,fldtaxper,flddiscper,flditemqty,fldstatus,fldbillno from tblpatbilling where fldencounterval=&1 and fldsave=&2 and flditemtype=&3 and flditemqty<&4", encid, True, rs!flditemtype, 0)
    xx1 = 0
    For Each res1
      xsub1 = 0
      If res1.Available = True Then
        If res1!tot Then
          xsub1 = res1!tot
        Endif
      Endif
      xx1 = xx1 + xsub1
      With asx
        .Add(modReportVar.GetDateTimeReport(res1!fldtime, gb.GeneralDate))
        .Add(res1!flditemname)
        .Add(modReportVar.GetLocaleNumberFormat(res1!flditemrate, gb.Currency))
        .Add(modReportVar.GetLocaleNumberFormat(res1!fldtaxper, -2))
        .Add(modReportVar.GetLocaleNumberFormat(res1!flddiscper, -2))
        .Add(modReportVar.GetLocaleNumberFormat(res1!flditemqty, -2))
        .Add(modReportVar.GetLocaleNumberFormat(xsub1, gb.Currency))
        .Add(res1!fldbillno)
      End With
      $BillingReport.Add(asx)
      asx.Clear()
    Next 'ends res1

    tot = tot + xx1
    With asx
      .Add("Sub Total")
      .Add(rs!flditemtype & " RETURN")
      .Add("..")
      .Add("..")
      .Add("..")
      .Add("..")
      .Add(modReportVar.GetLocaleNumberFormat(xx1, gb.Currency))
      .Add("..")
    End With
    $BillingReport.Add(asx)
    asx.Clear()
    If MMain.$IsGUIApp = True Then
      $ProgressBar1.Value = (rs.Index + 1) / rs.Count
      Wait
    Endif

  Next 'ends rs

  With asx
    .Add("***")
    .Add("***")
    .Add("***")
    .Add("***")
    .Add("***")
    .Add("***")
    .Add("***")
    .Add("***")
  End With
  $BillingReport.Add(asx)
  asx.Clear()
  With asx
    .Add("Grand Total")
    .Add("All Categories")
    .Add("***")
    .Add("***")
    .Add("***")
    .Add("***")
    .Add(modReportVar.GetLocaleNumberFormat(tot, gb.Currency))
    .Add("***")
  End With
  $BillingReport.Add(asx)
  asx.Clear()
  Dec Application.Busy

  RepoPath = $BillingReport.NewHTMLPath()
  Return RepoPath

End

Public Function ShowTotalExpenseDeptbyPatient($con As Connection, encid As String) As String

  Dim $BillingReport As CReportHTML
  Dim RepoPath As String
  Dim res As Result
  Dim asx As New String[0]
  Dim tot As Float
  Dim xx As Float
  Dim xsub As Float
  Dim accList As String[]
  Dim xgrp As String
  Dim i As Integer
  Dim res1 As Result
  Dim xsub1 As Float
  Dim xx1 As Float

  If MMain.$IsGUIApp = True Then
    $ProgressBar1 = modHelpVariable.FindWorkProgressBar(modHelpVariable.$LogInCategory)
    $ProgressBar1.Tag = "Const"
  Endif

  $BillingReport = New CReportHTML([("Date"), ("Particulars"), ("Rate"), ("Tax%"), ("Disc%"), ("QTY"), ("Total"), ("Invoice")], modHelpVariable.$htmlDirectory, "PatientReport", encid)
  $BillingReport.UserData.Add("REPORT", "Report")
  $BillingReport.UserData.Add("EXPENSE", "PARAM1")

  Inc Application.Busy
  tot = 0
  i = 0
  accList = modNonMedical.GetGroupNameAccount()
  For Each xgrp In accList
    'Billing
    $BillingReport.AddSection(xgrp & " BILLING", True)
    res = $con.Exec("select fldditemamt as tot,fldtime,flditemtype,flditemname,flditemrate,fldtaxper,flddiscper,flditemqty,fldstatus,fldbillno from tblpatbilling where fldencounterval=&1 and fldsave=&2 and flditemname in(select flditemname from tblreportgroup where fldgroup=&3) and flditemqty>&4", encid, True, xgrp, 0)
    xx = 0
    For Each res
      xsub = 0
      If res.Available = True Then
        If res!tot Then
          xsub = res!tot
        Endif
      Endif
      xx = xx + xsub
      With asx
        .Add(modReportVar.GetDateTimeReport(res!fldtime, gb.GeneralDate))
        .Add(res!flditemname)
        .Add(modReportVar.GetLocaleNumberFormat(res!flditemrate, gb.Currency))
        .Add(modReportVar.GetLocaleNumberFormat(res!fldtaxper, -2))
        .Add(modReportVar.GetLocaleNumberFormat(res!flddiscper, -2))
        .Add(modReportVar.GetLocaleNumberFormat(res!flditemqty, -2))
        .Add(modReportVar.GetLocaleNumberFormat(xsub, gb.Currency))
        .Add(res!fldbillno)
      End With
      $BillingReport.Add(asx)
      asx.Clear()
    Next 'ends res

    tot = tot + xx
    With asx
      .Add(xgrp)
      .Add("Sub Total")
      .Add("..")
      .Add("..")
      .Add("..")
      .Add("..")
      .Add(modReportVar.GetLocaleNumberFormat(xx, gb.Currency))
      .Add("..")
    End With
    $BillingReport.Add(asx)
    asx.Clear()

    ''Return
    $BillingReport.AddSection(xgrp & " RETURN", True)
    res1 = $con.Exec("select fldditemamt as tot,fldtime,flditemtype,flditemname,flditemrate,fldtaxper,flddiscper,flditemqty,fldstatus,fldbillno from tblpatbilling where fldencounterval=&1 and fldsave=&2 and flditemname in(select flditemname from tblreportgroup where fldgroup=&3) and flditemqty<&4", encid, True, xgrp, 0)
    xx1 = 0
    For Each res1
      xsub1 = 0
      If res1.Available = True Then
        If res1!tot Then
          xsub1 = res1!tot
        Endif
      Endif
      xx1 = xx1 + xsub1
      With asx
        .Add(modReportVar.GetDateTimeReport(res1!fldtime, gb.GeneralDate))
        .Add(res1!flditemname)
        .Add(modReportVar.GetLocaleNumberFormat(res1!flditemrate, gb.Currency))
        .Add(modReportVar.GetLocaleNumberFormat(res1!fldtaxper, -2))
        .Add(modReportVar.GetLocaleNumberFormat(res1!flddiscper, -2))
        .Add(modReportVar.GetLocaleNumberFormat(res1!flditemqty, -2))
        .Add(modReportVar.GetLocaleNumberFormat(xsub1, gb.Currency))
        .Add(res1!fldbillno)
      End With
      $BillingReport.Add(asx)
      asx.Clear()
    Next 'ends res1

    tot = tot + xx1
    With asx
      .Add(xgrp)
      .Add("Sub Total")
      .Add("..")
      .Add("..")
      .Add("..")
      .Add("..")
      .Add(modReportVar.GetLocaleNumberFormat(xx1, gb.Currency))
      .Add("..")
    End With
    $BillingReport.Add(asx)
    asx.Clear()

    If MMain.$IsGUIApp = True Then
      $ProgressBar1.Value = (i + 1) / accList.Count
      Wait
    Endif
    i = i + 1
  Next 'ends rs

  With asx
    .Add("All Types")
    .Add("Grand Total")
    .Add("***")
    .Add("***")
    .Add("***")
    .Add("***")
    .Add(modReportVar.GetLocaleNumberFormat(tot, gb.Currency))
    .Add("***")
  End With
  $BillingReport.Add(asx)
  asx.Clear()
  Dec Application.Busy

  RepoPath = $BillingReport.NewHTMLPath()
  Return RepoPath

End

Public Function ShowTotalExpenseDatebyPatient($con As Connection, encid As String) As String

  Dim $BillingReport As CReportHTML
  Dim RepoPath As String
  Dim rs As Result
  Dim res As Result
  Dim asx As New String[0]
  Dim tot As Float
  Dim xx As Float
  Dim xsub As Float
  Dim dtval As Date[]
  Dim xdt As Date
  Dim res1 As Result
  Dim xsub1 As Float
  Dim xx1 As Float

  If MMain.$IsGUIApp = True Then
    $ProgressBar1 = modHelpVariable.FindWorkProgressBar(modHelpVariable.$LogInCategory)
    $ProgressBar1.Tag = "Const"
  Endif

  $BillingReport = New CReportHTML([("Date"), ("Particulars"), ("Rate"), ("Tax%"), ("Disc%"), ("QTY"), ("Total"), ("Invoice")], modHelpVariable.$htmlDirectory, "PatientReport", encid)
  $BillingReport.UserData.Add("REPORT", "Report")
  $BillingReport.UserData.Add("EXPENSE", "PARAM1")

  Inc Application.Busy
  rs = $con.Exec("select fldtime from tblpatbilling where fldencounterval=&1 and fldsave=&2", encid, True)
  If rs.Available Then
    dtval = New Date[]
    For Each rs
      If dtval.Count = 0 Then
        dtval.Add(modDate.StartSqlDate(rs!fldtime))
      Else
        If dtval.Exist(modDate.StartSqlDate(rs!fldtime)) = False Then
          dtval.Add(modDate.StartSqlDate(rs!fldtime))
        Endif
      Endif
    Next

    tot = 0
    For Each xdt In dtval
      ''Billing
      $BillingReport.AddSection(modReportVar.GetDateTimeReport(xdt, gb.MediumDate) & " BILLING", True)
      res = $con.Exec("select fldditemamt as tot,fldtime,flditemtype,flditemname,flditemrate,fldtaxper,flddiscper,flditemqty,fldstatus,fldbillno from tblpatbilling where fldencounterval=&1 and fldsave=&2 and fldtime>=&3 and fldtime<=&4 and flditemqty>&5", encid, True, modDate.StartSqlDate(xdt), modDate.EndSqlDate(xdt), 0)
      xx = 0
      For Each res
        xsub = 0
        If res.Available = True Then
          If res!tot Then
            xsub = res!tot
          Endif
        Endif
        xx = xx + xsub
        With asx
          .Add(modReportVar.GetDateTimeReport(res!fldtime, gb.MediumTime))
          .Add(res!flditemname)
          .Add(modReportVar.GetLocaleNumberFormat(res!flditemrate, gb.Currency))
          .Add(modReportVar.GetLocaleNumberFormat(res!fldtaxper, -2))
          .Add(modReportVar.GetLocaleNumberFormat(res!flddiscper, -2))
          .Add(modReportVar.GetLocaleNumberFormat(res!flditemqty, -2))
          .Add(modReportVar.GetLocaleNumberFormat(xsub, gb.Currency))
          .Add(res!fldbillno)
        End With
        $BillingReport.Add(asx)
        asx.Clear()
      Next 'ends res

      tot = tot + xx
      With asx
        .Add(modReportVar.GetDateTimeReport(xdt, gb.MediumDate))
        .Add("Sub Total")
        .Add("..")
        .Add("..")
        .Add("..")
        .Add("..")
        .Add(modReportVar.GetLocaleNumberFormat(xx, gb.Currency))
        .Add("..")
      End With
      $BillingReport.Add(asx)
      asx.Clear()

      ''Return
      $BillingReport.AddSection(modReportVar.GetDateTimeReport(xdt, gb.MediumDate) & "RETURN", True)
      res1 = $con.Exec("select fldditemamt as tot,fldtime,flditemtype,flditemname,flditemrate,fldtaxper,flddiscper,flditemqty,fldstatus,fldbillno from tblpatbilling where fldencounterval=&1 and fldsave=&2 and fldtime>=&3 and fldtime<=&4 and flditemqty<&5", encid, True, modDate.StartSqlDate(xdt), modDate.EndSqlDate(xdt), 0)
      xx1 = 0
      For Each res1
        xsub1 = 0
        If res1.Available = True Then
          If res1!tot Then
            xsub1 = res1!tot
          Endif
        Endif
        xx1 = xx1 + xsub1
        With asx
          .Add(modReportVar.GetDateTimeReport(res1!fldtime, gb.MediumTime))
          .Add(res1!flditemname)
          .Add(modReportVar.GetLocaleNumberFormat(res1!flditemrate, gb.Currency))
          .Add(modReportVar.GetLocaleNumberFormat(res1!fldtaxper, -2))
          .Add(modReportVar.GetLocaleNumberFormat(res1!flddiscper, -2))
          .Add(modReportVar.GetLocaleNumberFormat(res1!flditemqty, -2))
          .Add(modReportVar.GetLocaleNumberFormat(xsub1, gb.Currency))
          .Add(res1!fldbillno)
        End With
        $BillingReport.Add(asx)
        asx.Clear()
      Next 'ends res1

      tot = tot + xx1
      With asx
        .Add(modReportVar.GetDateTimeReport(xdt, gb.MediumDate))
        .Add("Sub Total")
        .Add("..")
        .Add("..")
        .Add("..")
        .Add("..")
        .Add(modReportVar.GetLocaleNumberFormat(xx1, gb.Currency))
        .Add("..")
      End With
      $BillingReport.Add(asx)
      asx.Clear()
      If MMain.$IsGUIApp = True Then
        $ProgressBar1.Value = (rs.Index + 1) / rs.Count
        Wait
      Endif
    Next 'ends rs

    With asx
      .Add("All Dates")
      .Add("Grand Total")
      .Add("***")
      .Add("***")
      .Add("***")
      .Add("***")
      .Add(modReportVar.GetLocaleNumberFormat(tot, gb.Currency))
      .Add("***")
    End With
    $BillingReport.Add(asx)
    asx.Clear()
  Endif
  Dec Application.Busy

  RepoPath = $BillingReport.NewHTMLPath()
  Return RepoPath

End

Public Function ShowItemDispensedByPatient($con As Connection, encid As String, sType As String) As String

  Dim $BillingReport As CReportHTML
  Dim RepoPath As String
  Dim res As Result
  Dim asx As New String[0]
  Dim totamt As Float

  Inc Application.Busy
  If sType = "Medicines" Or If sType = "Surgicals" Or If sType = "Extra Items" Then
    $BillingReport = New CReportHTML([("Date"), ("Particulars"), ("Batch"), ("Expiry"), ("Rate"), ("Tax%"), ("Disc%"), ("QTY"), ("Total"), ("Invoice")], modHelpVariable.$htmlDirectory, "PatientReport", encid)
  Else
    $BillingReport = New CReportHTML([("Date"), ("Particulars"), ("Rate"), ("Tax%"), ("Disc%"), ("QTY"), ("Total"), ("Invoice")], modHelpVariable.$htmlDirectory, "PatientReport", encid)
  Endif
  res = $con.Exec("select fldid,fldtime,fldcomp,flditemname,flditemno,flditemrate,fldtaxper,flddiscper,flditemqty,fldditemamt as tot,flduserid,fldstatus,fldbillno from tblpatbilling where fldencounterval=&1 and fldsave=&2 and flditemtype=&3", encid, True, sType)                                                                                        ''
  $BillingReport.UserData.Add("REPORT", "Report")
  $BillingReport.UserData.Add(sType, "PARAM1")

  totamt = 0
  For Each res
    totamt = totamt + res!tot
    With asx
      .Add(modReportVar.GetDateTimeReport(res!fldtime, gb.GeneralDate))
      .Add(res!flditemname)
      If sType = "Medicines" Or If sType = "Surgicals" Or If sType = "Extra Items" Then
        .Add(modStock.GetBatchFromStockNo(res!flditemno))
        .Add(modReportVar.GetDateTimeReport(modStock.GetExpiryFromStockNo(res!flditemno), gb.MediumDate))
      Endif
      .Add(modReportVar.GetLocaleNumberFormat(res!flditemrate, gb.Currency))
      .Add(modReportVar.GetLocaleNumberFormat(res!fldtaxper, -2))
      .Add(modReportVar.GetLocaleNumberFormat(res!flddiscper, -2))
      .Add(modReportVar.GetLocaleNumberFormat(res!flditemqty, -2))
      .Add(modReportVar.GetLocaleNumberFormat(res!tot, gb.Currency))
      .Add(res!fldbillno)
    End With
    $BillingReport.Add(asx)
    asx.Clear()
  Next

  With asx
    .Add("***")
    .Add("***")
    If sType = "Medicines" Or If sType = "Surgicals" Or If sType = "Extra Items" Then
      .Add("***")
      .Add("***")
    Endif
    .Add("***")
    .Add("***")
    .Add("***")
    .Add("***")
    .Add(modReportVar.GetLocaleNumberFormat(totamt, gb.Currency))
    .Add("***")
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  Dec Application.Busy

  RepoPath = $BillingReport.NewHTMLPath()
  Return RepoPath

End

