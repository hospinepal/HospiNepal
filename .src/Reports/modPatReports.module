'''-------------------------- Test and Examination Functions --------------------------------
Public Function GetChartImageExam(encid As String, exam As String) As String

  Dim sql As String
  Dim res As Result
  Dim maxval As Float
  Dim minval As Float
  Dim normval As Float
  Dim pointsArr_x As Float[]
  Dim pointsArr_y As Float[]
  Dim xx As String
  Dim xlimit As Float[]

  pointsArr_x = New Float[]
  pointsArr_y = New Float[]
  xlimit = modClinic.GetBothQuantiExamVal(exam, encid)
  minval = xlimit[0]
  maxval = xlimit[1]
  normval = modClinic.GetNormalQuantiExamVal(exam, encid)
  sql = "select fldrepquanti,fldtime from tblpatientexam where fldencounterval=&1 and fldhead=&2 and fldtype=&3 and fldsave=&4"
  res = modDatabase.$syConn.Exec(sql, encid, exam, "Quantitative", True)
  If res.Count Then
    For Each res
      pointsArr_x.Add(res!fldtime)
      pointsArr_y.Add(res!fldrepquanti)
    Next
  Endif

  xx = modChart.ClinicalChart(100, encid, pointsArr_x, pointsArr_y, maxval, minval, normval)
  Return xx

End

Public Function GetChartImageTest(encid As String, test As String, strUnit As String) As String

  Dim sql As String
  Dim res As Result
  Dim maxval As Float
  Dim minval As Float
  Dim normval As Float
  Dim pointsArr_x As Float[]
  Dim pointsArr_y As Float[]
  Dim xx As String
  Dim xlimit As Float[]

  pointsArr_x = New Float[]
  pointsArr_y = New Float[]

  xlimit = modLabTest.LabBothLimitValue(test, encid, strUnit)
  minval = xlimit[0]
  maxval = xlimit[1]
  normval = modLabTest.LabNormalValue(test, encid, strUnit)

  sql = "select fldid,fldencounterval,fldtime_sample from tblpatlabtest where fldencounterval=&1 and fldtestid=&2 and fldtest_type=&3 and (fldstatus=&4 or fldstatus=&5)"
  res = modDatabase.$syConn.Exec(sql, encid, test, "Quantitative", "Reported", "Verified")
  If res.Count Then
    For Each res
      pointsArr_x.Add(res!fldtime_sample)
      pointsArr_y.Add(modLabTest.GetTestQuantiValue(res!fldencounterval, res!fldid, strUnit))
    Next
  Endif

  xx = modChart.ClinicalChart(100, encid, pointsArr_x, pointsArr_y, maxval, minval, normval)
  Return xx

End

Public Function GetChartImageRadio(encid As String, test As String) As String

  Dim sql As String
  Dim res As Result
  Dim maxval As Float
  Dim minval As Float
  Dim normval As Float
  Dim pointsArr_x As Float[]
  Dim pointsArr_y As Float[]
  Dim xx As String

  pointsArr_x = New Float[]
  pointsArr_y = New Float[]
  maxval = modRadioTest.GetMaxQuantiRadioVal(test, encid)
  minval = modRadioTest.GetMinQuantiRadioVal(test, encid)
  normval = modRadioTest.RadioNormalValue(test, encid)
  sql = "select fldid,fldtime_report from tblpatlabtest where fldencounterval=&1 and fldtestid=&2 and fldtest_type=&3 and (fldstatus=&4 or fldstatus=&5)"
  res = modDatabase.$syConn.Exec(sql, encid, test, "Quantitative", "Reported", "Verified")
  If res.Count Then
    For Each res
      pointsArr_x.Add(res!fldtime_report)
      pointsArr_y.Add(modRadioTest.GetRadioTestValue(res!fldid))
    Next
  Endif

  xx = modChart.ClinicalChart(100, encid, pointsArr_x, pointsArr_y, maxval, minval, normval)
  Return xx

End

Public Function UniProcedureExamination(encid As String, itemid As Long, sType As String) As String[]

  Dim res As Result
  Dim xx As String[]
  Dim xType As String
  Dim xval As String

  res = modDatabase.$syConn.Exec("select fldtime,fldhead,fldrepquali,fldrepquanti,fldoption from tblpatientexam where fldencounterval=&1 and fldinput=&2 and fldsave=&3", encid, sType & ":" & CStr(itemid), True)
  xx = New String[]
  If res.Available Then
    For Each res
      xType = res["fldoption"]
      If xType = "Clinical Scale" Then
        If modBasic.$ShowScaleMedFormat = "GroupWise" Then
          xval = modString.GetJSONToDualHTMLTable(Trim(res!fldrepquali))
        Else
          xval = CStr(res!fldrepquanti)
        Endif
      Else If xType = "Left and Right" Then
        xval = modString.GetJSONToDualHTMLTable(Trim(res!fldrepquali))
      Else
        xval = Trim(res!fldrepquali)
      Endif
      If modBasic.$ShowDayMedReport = "Yes" Then
        xx.Add("[ " & modReportVar.GetDateTimeReport(res!fldtime, gb.GeneralDate) & " ] " & res!fldhead & ": " & modString.TextToHTML(xval))
      Else
        xx.Add(res!fldhead & " : " & modString.TextToHTML(xval))
      Endif
    Next
  Endif
  Return xx

End

Public Function DeliveryReportbyMother(encid As String) As String[]

  Dim res As Result
  Dim xx As String
  Dim xlst As String[]

  xlst = New String[]
  res = modDatabase.$syConn.Exec("select fldid,flddelresult,flddeltype,fldbabypatno,flddeltime,flddelwt from tblconfinement where fldencounterval=&1", encid)
  If res.Available Then
    For Each res
      xx = "<p>"
      xx = xx & "Delivery Date: " & modReportVar.GetDateTimeReport(res!flddeltime, gb.GeneralDate) & "<br>"
      xx = xx & "Delivery Type: " & res!flddeltype & "<br>"
      xx = xx & "Delivery Result: " & res!flddelresult & "<br>"
      If res!fldbabypatno Then
        xx = xx & "Baby Patient No: " & res!fldbabypatno & "<br>"
        xx = xx & "Baby Gender: " & modPatient.PatientGenderByPatNo(res!fldbabypatno) & "<br>"
        xx = xx & "Birth Weight: " & res!flddelwt & " grams" & "<br>"
      Endif
      xx = xx & "</p>"
      xlst.Add(xx)
      xx = ""
    Next
  Endif
  Return xlst

End

''-------------------------Laboratory -------------------------------
Private Function GetReportTestSelString(sPos As String, encid As String, test As String, strUnit As String) As String

  Dim sql As String
  Dim res As Result
  Dim metr As Float
  Dim xx As String
  Dim yy As String[]

  xx = ""
  sql = "select fldid,fldencounterval,fldsampletype,fldtime_sample,fldreportquali,fldreportquanti,fldtestunit,fldtest_type from tblpatlabtest where fldencounterval=&1 and fldtestid=&2 and (fldstatus=&3 or fldstatus=&4)"
  res = modDatabase.$syConn.Exec(sql, encid, test, "Reported", "Verified")
  If res.Available = True Then
    If sPos = "First" Then
      res.MoveFirst
    Else
      res.MoveLast
    Endif

    If res!fldtest_type = "Quantitative" Then
      If res!fldreportquanti Then
        If strUnit = "Metric" Then
          If res!fldtestunit = "Metric" Then
            metr = res!fldreportquanti
          Else If res!fldtestunit = "SI" Then
            metr = Round(res!fldreportquanti / modLabTest.GetConvFactorTest(encid, test), -3)
          Endif
        Else If strUnit = "SI" Then
          If res!fldtestunit = "Metric" Then
            metr = Round(res!fldreportquanti * modLabTest.GetConvFactorTest(encid, test), -3)
          Else If res!fldtestunit = "SI" Then
            metr = res!fldreportquanti
          Endif
        Endif
      Else
        metr = 0
      Endif

      If metr Then
        If modBasic.$ShowDayMedReport = "Yes" Then
          xx = "[ " & modReportVar.GetDateTimeReport(res!fldtime_sample, gb.GeneralDate) & " ] " & test & " [Spec: " & res["fldsampletype"] & "]" & " : " & CStr(metr) & Space(1) & modLabTest.LabTestUnit(test, encid, strUnit)
        Else
          xx = test & " [Spec: " & res["fldsampletype"] & "]" & " : " & CStr(metr) & Space(1) & modLabTest.LabTestUnit(test, encid, strUnit)
        Endif
      Else
        xx = ""
      Endif

    Else
      If res!fldreportquali Then
        If modBasic.$ShowDayMedReport = "Yes" Then
          xx = "[ " & modReportVar.GetDateTimeReport(res!fldtime_sample, gb.GeneralDate) & " ] " & test & " [Spec: " & res["fldsampletype"] & "]" & " : " & Trim(res!fldreportquali)
        Else
          xx = test & " [Spec: " & res["fldsampletype"] & "]" & " : " & Trim(res!fldreportquali)
        Endif
      Else
        If modBasic.$ShowDayMedReport = "Yes" Then
          xx = "[ " & modReportVar.GetDateTimeReport(res!fldtime_sample, gb.GeneralDate) & " ] " & test & " [Spec: " & res["fldsampletype"] & "]" & " : "
        Else
          xx = test & " [Spec: " & res["fldsampletype"] & "]" & " : "
        Endif

      Endif

      yy = modLabTest.GetLabSubTestQuali(res!fldencounterval, res!fldid)
      If yy.Count Then
        xx = xx & modString.GetHTMLListFormat(yy)
      Endif

    Endif
  Endif
  Return xx

End

Private Function GetCompleteTestByEnc(encid As String, strTest As String, sUnit As String) As String[]

  Dim xx As String[]
  Dim res As Result
  Dim xval As String
  Dim i As Integer
  Dim xtable As String

  i = 1
  res = modDatabase.$syConn.Exec("select fldid,fldencounterval,fldtime_sample,fldsampletype,fldreportquali,fldtest_type from tblpatlabtest where fldencounterval=&1 and fldtestid=&2 and (fldstatus=&3 or fldstatus=&4)", encid, strTest, "Reported", "Verified")
  xx = New String[]
  If res.Available Then
    xx.Add(strTest & " [Spec: " & res["fldsampletype"] & "]")
    For Each res

      If res!fldtest_type = "Quantitative" Then
        xval = CStr(modLabTest.GetTestQuantiValue(res!fldencounterval, res!fldid, sUnit))
      Else
        If res!fldreportquali Then
          xval = Trim(res!fldreportquali)
        Else
          xval = ""
        Endif
        xtable = modString.GetHTMLListFormat(modLabTest.GetLabSubTestQuali(res!fldencounterval, res!fldid))
        If xtable Then
          xval = xval & xtable
        Endif
      Endif

      If modBasic.$ShowDayMedReport = "Yes" Then
        xval = CStr(i) & ".. " & modString.HTMLBlankSpace(3) & "[ " & modReportVar.GetDateTimeReport(res!fldtime_sample, gb.GeneralDate) & " ] " & " : " & xval
      Else
        xval = CStr(i) & ".. " & modString.HTMLBlankSpace(3) & xval
      Endif
      xx.Add(xval)

      i = i + 1
    Next
  Endif
  Return xx

End

Public Function GetQuantiLaboratoryForReport(encid As String, xexam As String, strUnit As String) As String

  Dim xrep As String

  If modBasic.$ShowQuantiMedReport = "Chart" Then
    xrep = xexam & gb.NewLine & modString.GetImageForHTML(GetChartImageTest(encid, xexam, strUnit))
  Else If modBasic.$ShowQuantiMedReport = "FitsrVal" Then
    xrep = GetReportTestSelString("First", encid, xexam, strUnit)
  Else If modBasic.$ShowQuantiMedReport = "First-LastVal" Then
    xrep = GetReportTestSelString("First", encid, xexam, strUnit) & gb.NewLine & GetReportTestSelString("Last", encid, xexam, strUnit)
  Else If modBasic.$ShowQuantiMedReport = "LastVal" Then
    xrep = GetReportTestSelString("Last", encid, xexam, strUnit)
  Else
    xrep = GetCompleteTestByEnc(encid, xexam, strUnit).Join(gb.NewLine)
  Endif

  Return xrep

End

Public Function GetQualiLaboratoryForReport(encid As String, xexam As String) As String

  Dim xrep As String

  If modBasic.$ShowQualiMedReport = "FitsrVal" Then
    xrep = GetReportTestSelString("First", encid, xexam, "Metric")
  Else If modBasic.$ShowQualiMedReport = "First-LastVal" Then
    xrep = GetReportTestSelString("First", encid, xexam, "Metric") & gb.NewLine & GetReportTestSelString("Last", encid, xexam, "Metric")
  Else If modBasic.$ShowQualiMedReport = "LastVal" Then
    xrep = GetReportTestSelString("Last", encid, xexam, "Metric")
  Else
    xrep = GetCompleteTestByEnc(encid, xexam, "Metric").Join(gb.NewLine)
  Endif

  Return xrep

End

''----------------------- Examination ---------------------------------------------
Private Function GetReportExamSelString(sPos As String, encid As String, exam As String) As String

  Dim sql As String
  Dim res As Result
  Dim xx As String
  Dim yy As String[]
  Dim xType As String
  Dim xval As String

  xx = ""
  sql = "select fldid,fldtime,fldhead,fldrepquali,fldrepquanti,fldtype,fldoption from tblpatientexam where fldencounterval=&1 and fldhead=&2 and fldsave=&3 and fldinput=&4"
  res = modDatabase.$syConn.Exec(sql, encid, exam, True, "Examination")
  If res.Available = True Then
    If sPos = "First" Then
      res.MoveFirst
    Else
      res.MoveLast
    Endif

    If res!fldtype = "Quantitative" Then
      If res!fldrepquanti Then
        If modBasic.$ShowDayMedReport = "Yes" Then
          xx = "[ " & modReportVar.GetDateTimeReport(res!fldtime, gb.GeneralDate) & " ] " & exam & " : " & CStr(res!fldrepquanti) & Space(1) & modClinic.GetExamUnit(exam, encid)
        Else
          xx = exam & " : " & CStr(res!fldrepquanti) & Space(1) & modClinic.GetExamUnit(exam, encid)
        Endif
      Else
        xx = ""
      Endif

    Else
      xType = res["fldoption"]
      If xType = "Clinical Scale" Then
        If modBasic.$ShowScaleMedFormat = "GroupWise" Then
          xval = modString.GetJSONToDualHTMLTable(Trim(res!fldrepquali))
        Else
          xval = CStr(res!fldrepquanti)
        Endif
      Else If xType = "Left and Right" Then
        xval = modString.GetJSONToDualHTMLTable(Trim(res!fldrepquali))
      Else
        xval = Trim(res!fldrepquali)
      Endif
      If modBasic.$ShowDayMedReport = "Yes" Then
        xx = "[ " & modReportVar.GetDateTimeReport(res!fldtime, gb.GeneralDate) & " ] " & exam & " : " & xval
      Else
        xx = exam & " : " & xval
      Endif

      yy = modClinic.GetSubExamQualiList(encid, res!fldid)
      If yy.Count Then
        xx = xx & modString.GetHTMLListFormat(yy)
      Endif

    Endif
  Endif
  Return xx

End

Private Function GetCompleteExamByEnc(encid As String, strTest As String) As String[]

  Dim xx As String[]
  Dim sql As String
  Dim res As Result
  Dim i As Integer
  Dim xtable As String
  Dim xType As String
  Dim xval As String

  i = 1
  sql = "select fldid,fldtime,fldhead,fldrepquali,fldrepquanti,fldtype,fldcomp,fldoption from tblpatientexam where fldencounterval=&1 and fldhead=&2 and fldsave=&3 and fldinput=&4"
  res = modDatabase.$syConn.Exec(sql, encid, strTest, True, "Examination")
  xx = New String[]
  If res.Available Then
    xx.Add(strTest & " [Dept: " & res["fldcomp"] & "]")
    For Each res

      If res!fldtype = "Quantitative" Then
        xval = CStr(res!fldrepquanti)
      Else
        If res!fldrepquali Then

          xType = res["fldoption"]
          If xType = "Clinical Scale" Then
            If modBasic.$ShowScaleMedFormat = "GroupWise" Then
              xval = modString.GetJSONToDualHTMLTable(Trim(res!fldrepquali))
            Else
              xval = CStr(res!fldrepquanti)
            Endif
          Else If xType = "Left and Right" Then
            xval = modString.GetJSONToDualHTMLTable(Trim(res!fldrepquali))
          Else
            xval = Trim(res!fldrepquali)
          Endif
        Else
          xval = ""
        Endif
        xtable = modString.GetHTMLListFormat(modClinic.GetSubExamQualiList(encid, res!fldid))
        If xtable Then
          xval = xval & xtable
        Endif
      Endif

      If modBasic.$ShowDayMedReport = "Yes" Then
        xval = CStr(i) & ".. " & modString.HTMLBlankSpace(3) & "[ " & modReportVar.GetDateTimeReport(res!fldtime, gb.GeneralDate) & " ] " & " : " & xval
      Else
        xval = CStr(i) & ".. " & modString.HTMLBlankSpace(3) & xval
      Endif
      xx.Add(xval)

      i = i + 1
    Next
  Endif
  Return xx

End

