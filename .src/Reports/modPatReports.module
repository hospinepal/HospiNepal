Public Function GetPatProcedureList(encid As String, strType As String, sCondi As String) As String[]

  Dim res As Result
  Dim xlst As String[]
  Dim xx As String
  Dim xval As String

  xlst = New String[]
  res = modDatabase.$syConn.Exec("select fldid,fldnewdate,flditem,flddetail from tblpatgeneral where fldencounterval=&1 and fldinput=&2 and fldreportquali=&3", encid, strType, sCondi)
  If res.Available = True Then
    For Each res
      If res!flddetail Then
        xval = " : " & res!flddetail & gb.NewLine
      Else
        xval = ""
      Endif
      If modBasic.$ShowDayMedReport = "Yes" Then
        xx = "[ " & modReportVar.GetDateTimeReport(res!fldnewdate, gb.GeneralDate) & " ] " & res!flditem & xval
      Else
        xx = "[ " & modReportVar.GetDateTimeReport(res!fldnewdate, gb.GeneralDate) & " ] " & res!flditem & xval
      Endif
      xlst.Add(xx)
    Next
  Endif
  Return xlst

End

Public Function GetPatExtProcedureList(encid As String, sCondi As String) As String[]

  Dim res As Result
  Dim xlst As String[]
  Dim xx As String
  Dim xval As String

  xlst = New String[]
  res = modDatabase.$syConn.Exec("select fldid,fldnewdate,flditem,flddetail from tblpatgeneral where fldencounterval=&1 and fldinput=&2 and fldreportquali=&3", encid, "Extra Procedures", sCondi)
  If res.Available = True Then
    For Each res
      xval = modPatientGeneral.GetExtProcedTable(res!fldid, encid, res!flditem)
      If modBasic.$ShowDayMedReport = "Yes" Then
        xx = "[ " & modReportVar.GetDateTimeReport(res!fldnewdate, gb.GeneralDate) & " ] " & res!flditem & xval
      Else
        xx = "[ " & modReportVar.GetDateTimeReport(res!fldnewdate, gb.GeneralDate) & " ] " & res!flditem & xval
      Endif
      xlst.Add(xx)
    Next
  Endif
  Return xlst

End

''-------------Notes -----------------------------
Public Function GetPatientNoteReport(encid As String, sType As String) As String

  Dim sql As String
  Dim res As Result
  Dim xx As String

  sql = "select flddetail,fldtime from tblexamgeneral where fldencounterval=&1 and fldinput=&2 and flditem=&3"
  res = modDatabase.$syConn.Exec(sql, encid, "Notes", sType)
  If res.Available = True Then
    res.MoveLast
    If modBasic.$ShowDayMedReport = "Yes" Then
      xx = "[ " & modReportVar.GetDateTimeReport(res!fldtime, gb.GeneralDate) & " ]" & " : " & res!flddetail
    Else
      xx = res!flddetail
    Endif
  Else
    xx = ""
  Endif

  Return xx

End

Public Function GetClinNotesReport(encid As String) As String[]

  Dim res As Result
  Dim xx As String[]

  res = modDatabase.$syConn.Exec("select fldtime,flditem,fldreportquali,flddetail from tblexamgeneral where fldencounterval=&1 and fldinput=&2 and (flditem=&3 or flditem=&4 or flditem=&5)", encid, "Notes", "Progress Note", "Clinicians Note", "Nurses Note")
  xx = New String[]
  If res.Available = True Then
    For Each res
      If modBasic.$ShowDayMedReport = "Yes" Then
        xx.Add("<p>" & "[" & modReportVar.GetDateTimeReport(res!fldtime, gb.GeneralDate) & "] Category: " & res!flditem & "<br>" & modString.TextToHTML(res!flddetail) & "<br>" & "IMPRESSION: " & res!fldreportquali & "</p>")
      Else
        xx.Add("<p>" & "Category: " & res!flditem & "<br>" & modString.TextToHTML(res!flddetail) & "<br>" & "IMPRESSION: " & res!fldreportquali & "</p>")
      Endif
    Next
  Endif
  Return xx

End

''-------------------------- Daily -------------------------------------------------------
Public Function OPDMedString(encid As String) As String[]

  Dim rs As Result
  Dim xx As String[]

  xx = New String[]
  rs = modDatabase.$syConn.Exec("select fldid,fldstarttime,fldroute,flditem,flddose,fldfreq,flddays,flditemtype from tblpatdosing where fldencounterval=&1 and flditemtype=&2 and (fldstatus=&3 or fldstatus=&4 or fldstatus=&5)", encid, "Medicines", "Registered", "Admitted", "Recorded")
  If rs.Available = True Then
    For Each rs
      If rs!flditemtype = "Medicines" Then
        If modBasic.$ShowDayMedReport = "Yes" Then
          xx.Add("[ " & modReportVar.GetDateTimeReport(rs!fldstarttime, gb.GeneralDate) & " ] " & modPharmacy.GetMedFormatForMedReport(rs!flditem, rs!fldroute) & Space(1) & modPharmacy.GetDoseRegimenString(rs!fldid, True))
        Else
          xx.Add(modPharmacy.GetMedFormatForMedReport(rs!flditem, rs!fldroute) & Space(1) & modPharmacy.GetDoseRegimenString(rs!fldid, True))
        Endif
      Endif
    Next
  Endif

  Return xx

End

Public Function GetPatientPlanningReport(encid As String) As String[]

  Dim res As Result
  Dim xx As String
  Dim xlst As String[]

  xlst = New String[]
  res = modDatabase.$syConn.Exec("select fldtime,fldproblem,fldsubjective,fldobjective,fldassess,fldplan from tblpatplanning where fldencounterval=&1 and fldplancategory=&2", encid, "Clinician Plan")
  If res.Available = True Then
    For Each res
      If modBasic.$ShowDayMedReport = "Yes" Then
        xx = "<p>" & "[" & modReportVar.GetDateTimeReport(res!fldtime, gb.GeneralDate) & "]" & "<br>" & " Problem: " & res!fldproblem
      Else
        xx = "<p>" & " Problem: " & res!fldproblem
      Endif
      If res!fldsubjective Then
        xx = xx & "<br>" & "Subjective: " & modString.TextToHTML(res!fldsubjective)
      Endif
      If res!fldobjective Then
        xx = xx & "<br>" & "Objective: " & modString.TextToHTML(res!fldobjective)
      Endif
      If res!fldassess Then
        xx = xx & "<br>" & "Assessment: " & modString.TextToHTML(res!fldassess)
      Endif
      If res!fldplan Then
        xx = xx & "<br>" & "Planning: " & modString.TextToHTML(res!fldplan)
      Endif
      xx = xx & "</p>"                       ''
      xlst.Add(xx)
      xx = ""
    Next
  Endif
  Return xlst

End

Public Function GetPatientMonitorReport(encid As String) As String[]

  Dim res As Result
  Dim xx As String
  Dim xlst As String[]

  res = modDatabase.$syConn.Exec("select fldid,fldtime,fldproblem,fldsubjective,fldobjective,fldassess,fldplan from tblpatplanning where fldencounterval=&1 and fldplancategory=&2", encid, "IP Monitoring")
  xlst = New String[]
  If res.Available = True Then
    For Each res
      If modBasic.$ShowDayMedReport = "Yes" Then
        xx = "<p>" & "[" & modReportVar.GetDateTimeReport(res!fldtime, gb.GeneralDate) & "]"
      Else
        xx = "<p>"
      Endif
      If res!fldsubjective Then
        xx = xx & "<br>" & "Problems: " & modString.TextToHTML(res!fldsubjective)
      Endif
      If res!fldobjective Then
        xx = xx & "<br>" & "Treatment: " & modString.TextToHTML(res!fldobjective)
      Endif
      If res!fldassess Then
        xx = xx & "<br>" & "I/O Assessment: " & modString.TextToHTML(res!fldassess)
      Endif
      xx = xx & "<br>" & "On Examination" & "<br>" & UniProcedureExamination(encid, res!fldid, "IP Monitoring").Join("<br>")
      If res!fldproblem Then
        xx = xx & "<br>" & "Impression: " & modString.TextToHTML(res!fldproblem)
      Endif
      If res!fldplan Then
        xx = xx & "<br>" & "Planning: " & modString.TextToHTML(res!fldplan)
      Endif
      xx = xx & "</p>"             ''
      xlst.Add(xx)
      xx = ""
    Next
  Endif
  Return xlst

End

