Public Function AddSelectedExamination(encid As String, exam As String[]) As String[]

  Dim asx As New String[0]
  Dim xx As String
  Dim yy As String
  Dim sType As String

  Dim stChapter As String
  Dim stObservation As String

  yy = ""
  For Each xx In exam
    sType = modFixClinic.GetExaminationType(xx)
    If sType = "Quantitative" Then
      yy = yy & modString.TextToHTML(GetQuantiExaminationForReport(encid, xx) & gb.NewLine & "<br>")
    Else If sType = "Qualitative" Then
      yy = yy & modString.TextToHTML(GetQualiExaminationForReport(encid, xx) & gb.NewLine & "<br>")
    Endif
  Next

  ' With asx
  '   If modBasic.$MedRepoBody = "Paragraph" Then
  '     .Add("<b>" & "Examinations" & "</b><br>" & yy)
  '   Else
  '     .Add("Examinations")
  '     .Add(yy)
  '   Endif
  ' End With

  stChapter = "Examinations"
    stObservation = yy
    asx = AddCustomReport(stChapter, stObservation)
  Return asx

End

Public Function AddSelectedTest(encid As String, test As String[], sUnit As String) As String[]

  Dim asx As New String[0]
  Dim xx As String
  Dim yy As String
  Dim sType As String

  Dim stChapter As String
  Dim stObservation As String

  yy = ""
  For Each xx In test
    sType = modFixLab.GetLabTestType(xx)
    If sType = "Quantitative" Then
      yy = yy & modString.TextToHTML(GetQuantiLaboratoryForReport(encid, xx, sUnit) & gb.NewLine & "<br>")
    Else If sType = "Qualitative" Then
      yy = yy & modString.TextToHTML(GetQualiLaboratoryForReport(encid, xx) & gb.NewLine & "<br>")
    Endif
  Next

  ' With asx
  '   If modBasic.$MedRepoBody = "Paragraph" Then
  '     .Add("<b>" & "Laboratory" & "</b><br>" & yy)
  '   Else
  '     .Add("Laboratory")
  '     .Add(yy)
  '   Endif
  ' End With

  stChapter = "Laboratory"
    stObservation = yy
    asx = AddCustomReport(stChapter, stObservation)
  Return asx

End

