Public Function ShowDischargeReport(encid As String, exam As String[], radio As String[], test As String[], strUnit As String) As String

  Dim $BillingReport As CReportHTML
  Dim xdelivery As String[]

  Inc Application.Busy
  If modBasic.$MedRepoBody = "Paragraph" Then
    $BillingReport = New CReportHTML([("Description")], modHelpVariable.$htmlDirectory, "PatientReport", encid)
  Else
    $BillingReport = New CReportHTML([("Category"), ("Observations")], modHelpVariable.$htmlDirectory, "PatientReport", encid)
  Endif
  $BillingReport.UserData.Add("REPORT", "Report")
  $BillingReport.UserData.Add("DISCHARGE REPORT", "PARAM1")

  $BillingReport.AddSection("General", True)
  $BillingReport.Add(AddCourseOfTreatment(encid))
  $BillingReport.Add(AddTriageFindings(encid))
  $BillingReport.Add(AddPresentingComplaints(encid))
  $BillingReport.Add(AddOPDFindings(encid))
  $BillingReport.Add(AddGenComplaints(encid))
  $BillingReport.Add(AddHistoryOfIllness(encid))
  $BillingReport.Add(AddPastHistory(encid))
  $BillingReport.Add(AddTreatmentHistory(encid))
  $BillingReport.Add(AddMedicatHistory(encid))
  $BillingReport.Add(AddFamilyHistory(encid))
  $BillingReport.Add(AddPersonalHistory(encid))
  $BillingReport.Add(AddPatDemographics(encid))
  $BillingReport.Add(AddDrugAllergy(encid))
  $BillingReport.Add(AddProvisionalDiagnosis(encid))
  $BillingReport.Add(AddOPDAdvice(encid))

  $BillingReport.Add(AddFinalDiagnosis(encid))
  $BillingReport.Add(AddProminientSymptoms(encid))
  $BillingReport.Add(AddMajorProcedures(encid))
  $BillingReport.Add(AddExtraProcedures(encid))
  $BillingReport.Add(AddMedicationUsed(encid))

  xdelivery = DeliveryReportbyMother(encid)
  If xdelivery Then
    $BillingReport.Add(AddCustomReport("Delivery Profile", xdelivery.Join(gb.NewLine)))
  Endif

  $BillingReport.AddSection("Investigations", True)
  $BillingReport.Add(AddSelectedExamination(encid, exam))
  $BillingReport.Add(AddSelectedTest(encid, test, strUnit))
  $BillingReport.Add(AddSelectedRadio(encid, radio))

  $BillingReport.AddSection("Discharge", True)
  $BillingReport.Add(AddPlannedProcedures(encid))
  $BillingReport.Add(AddDischargeFindings(encid))
  $BillingReport.Add(AddConditionAtDischarge(encid))
  $BillingReport.Add(AddDischargeMedication(encid))
  $BillingReport.Add(AddAdviceDischarge(encid))
  Dec Application.Busy
  Return $BillingReport.NewHTMLPath()

End

Public Function ShowAllCompleteReport(encid As String, strUnit As String) As String

  Dim $BillingReport As CReportHTML
  Dim xdelivery As String[]

  Inc Application.Busy
  $BillingReport = New CReportHTML([("Category"), ("Observations")], modHelpVariable.$htmlDirectory, "PatientReport", encid)
  $BillingReport.UserData.Add("REPORT", "Report")
  $BillingReport.UserData.Add("COMPLETE REPORT", "PARAM1")

  $BillingReport.AddSection("General", True)
  $BillingReport.Add(AddCourseOfTreatment(encid))
  $BillingReport.Add(AddBedTransition(encid))
  $BillingReport.Add(AddPatDemographics(encid))
  $BillingReport.Add(AddTriageFindings(encid))
  $BillingReport.Add(AddCauseofAdmission(encid))
  $BillingReport.Add(AddPresentingComplaints(encid))
  $BillingReport.Add(AddOPDFindings(encid))
  $BillingReport.Add(AddGenComplaints(encid))
  $BillingReport.Add(AddHistoryOfIllness(encid))
  $BillingReport.Add(AddPastHistory(encid))
  $BillingReport.Add(AddTreatmentHistory(encid))
  $BillingReport.Add(AddMedicatHistory(encid))
  $BillingReport.Add(AddFamilyHistory(encid))
  $BillingReport.Add(AddPersonalHistory(encid))
  $BillingReport.Add(AddDrugAllergy(encid))
  $BillingReport.Add(AddProvisionalDiagnosis(encid))
  $BillingReport.Add(AddOPDAdvice(encid))

  $BillingReport.Add(AddFinalDiagnosis(encid))
  $BillingReport.Add(AddProminientSymptoms(encid))
  $BillingReport.Add(AddMajorProcedures(encid))
  $BillingReport.Add(AddMinorProcedures(encid))
  $BillingReport.Add(AddConsultationAll(encid))
  $BillingReport.Add(AddEquipmentsUsed(encid))
  $BillingReport.Add(AddExtraProcedures(encid))
  $BillingReport.Add(AddMedicationUsed(encid))
  $BillingReport.Add(AddTreatmentAdvised(encid))

  xdelivery = DeliveryReportbyMother(encid)
  If xdelivery Then
    $BillingReport.Add(AddCustomReport("Delivery Profile", xdelivery.Join(gb.NewLine)))
  Endif

  $BillingReport.AddSection("Investigations & Planning", True)
  $BillingReport.Add(AddClinicalFindingsVital(encid))
  $BillingReport.Add(AddClinicalFindingsStructured(encid))
  $BillingReport.Add(AddClinicalFindingsNonVital(encid))
  $BillingReport.Add(AddSelectedTest(encid, modLabTest.PaientAllTestNameArray(encid), strUnit))
  $BillingReport.Add(AddSelectedRadio(encid, modRadioTest.PaientAllRadioNameArray(encid)))
  $BillingReport.Add(AddClinicalNotes(encid))
  $BillingReport.Add(AddIPMonitoring(encid))
  $BillingReport.Add(AddTherapeuticPlanning(encid))

  If modPatient.CurrentAdmissionStatus(encid) = "Discharged" Then
    $BillingReport.AddSection("Discharge", True)
    $BillingReport.Add(AddPlannedProcedures(encid))
    $BillingReport.Add(AddDischargeFindings(encid))
    $BillingReport.Add(AddConditionAtDischarge(encid))
    $BillingReport.Add(AddDischargeMedication(encid))
    $BillingReport.Add(AddAdviceDischarge(encid))
  Endif

  Dec Application.Busy
  Return $BillingReport.NewHTMLPath()

End

Public Function ShowCompleteReport(encid As String, strUnit As String) As String

  Dim $BillingReport As CReportHTML
  Dim xdelivery As String[]
  Dim xList As String[]
  Dim xvarList As Variant[]

  Dim examlist As String[]
  Dim lablist As String[]
  Dim radiolist As String[]

  xList = SelectMedBody("")
  Wait
  If xList Then
    If xList.Exist("Selected Investigations") Then
      xvarList = ListViewMulti(encid)
      If xvarList Then
        examlist = xvarList[0]
        lablist = xvarList[1]
        radiolist = xvarList[2]
      Endif
    Endif
  Endif

  Inc Application.Busy
  If modBasic.$MedRepoBody = "Paragraph" Then
    $BillingReport = New CReportHTML([("Description")], modHelpVariable.$htmlDirectory, "PatientReport", encid)
  Else
    $BillingReport = New CReportHTML([("Category"), ("Observations")], modHelpVariable.$htmlDirectory, "PatientReport", encid)
  Endif
  $BillingReport.UserData.Add("REPORT", "Report")
  $BillingReport.UserData.Add("SELECTED PARAMETERS", "PARAM1")

  $BillingReport.AddSection("General", True)
  If xList Then

    If xList.Exist("Course of Treatment") Then
      $BillingReport.Add(AddCourseOfTreatment(encid))
    Endif
    If xList.Exist("Bed Transitions") Then
      $BillingReport.Add(AddBedTransition(encid))
    Endif
    If xList.Exist("Demographics") Then
      $BillingReport.Add(AddPatDemographics(encid))
    Endif
    If xList.Exist("Triage Examinations") Then
      $BillingReport.Add(AddTriageFindings(encid))
    Endif
    If xList.Exist("Cause of Admission") Then
      $BillingReport.Add(AddCauseofAdmission(encid))
    Endif
    If xList.Exist("Presenting Complaints") Then
      $BillingReport.Add(AddPresentingComplaints(encid))
    Endif
    If xList.Exist("OPD Examinations") Then
      $BillingReport.Add(AddOPDFindings(encid))
    Endif
    If xList.Exist("General Complaints") Then
      $BillingReport.Add(AddGenComplaints(encid))
    Endif
    If xList.Exist("History of Illness") Then
      $BillingReport.Add(AddHistoryOfIllness(encid))
    Endif
    If xList.Exist("Past History") Then
      $BillingReport.Add(AddPastHistory(encid))
    Endif
    If xList.Exist("Treatment History") Then
      $BillingReport.Add(AddTreatmentHistory(encid))
    Endif
    If xList.Exist("Medication History") Then
      $BillingReport.Add(AddMedicatHistory(encid))
    Endif
    If xList.Exist("Family History") Then
      $BillingReport.Add(AddFamilyHistory(encid))
    Endif
    If xList.Exist("Personal History") Then
      $BillingReport.Add(AddPersonalHistory(encid))
    Endif
    If xList.Exist("Surgical History") Then
      $BillingReport.Add(AddSurgicalHistory(encid))
    Endif
    If xList.Exist("Occupational History") Then
      $BillingReport.Add(AddOccupationalHistory(encid))
    Endif
    If xList.Exist("Social History") Then
      $BillingReport.Add(AddSocialHistory(encid))
    Endif
    If xList.Exist("Drug Allergy") Then
      $BillingReport.Add(AddDrugAllergy(encid))
    Endif
    If xList.Exist("Provisional Diagnosis") Then
      $BillingReport.Add(AddProvisionalDiagnosis(encid))
    Endif
    If xList.Exist("Initial Planning") Then
      $BillingReport.Add(AddOPDAdvice(encid))
    Endif

    If xList.Exist("Final Diagnosis") Then
      $BillingReport.Add(AddFinalDiagnosis(encid))
    Endif
    If xList.Exist("Prominent Symptoms") Then
      $BillingReport.Add(AddProminientSymptoms(encid))
    Endif
    If xList.Exist("Major Procedures") Then
      $BillingReport.Add(AddMajorProcedures(encid))
    Endif
    If xList.Exist("Minor Procedures") Then
      $BillingReport.Add(AddMinorProcedures(encid))
    Endif
    If xList.Exist("Consultations") Then
      $BillingReport.Add(AddConsultationAll(encid))
    Endif
    If xList.Exist("Equipments Used") Then
      $BillingReport.Add(AddEquipmentsUsed(encid))
    Endif
    If xList.Exist("Extra Procedures") Then
      $BillingReport.Add(AddExtraProcedures(encid))
    Endif
    If xList.Exist("Medication Used") Then
      $BillingReport.Add(AddMedicationUsed(encid))
    Endif
    If xList.Exist("Treatment Advised") Then
      $BillingReport.Add(AddTreatmentAdvised(encid))
    Endif

    If xList.Exist("Delivery Profile") Then
      xdelivery = DeliveryReportbyMother(encid)
      If xdelivery Then
        $BillingReport.Add(AddCustomReport("Delivery Profile", xdelivery.Join(gb.NewLine)))
      Endif
    Endif

    $BillingReport.AddSection("Investigations", True)
    If xList.Exist("Selected Investigations") Then
      If examlist Then
        If examlist.Count Then
          $BillingReport.Add(AddSelectedExamination(encid, examlist))
        Endif
      Endif
      If lablist Then
        If lablist.Count Then
          $BillingReport.Add(AddSelectedTest(encid, lablist, strUnit))
        Endif
      Endif
      If radiolist Then
        If radiolist.Count Then
          $BillingReport.Add(AddSelectedRadio(encid, radiolist))
        Endif
      Endif
    Endif

    If xList.Exist("Essential Examinations") Then
      $BillingReport.Add(AddClinicalFindingsVital(encid))
    Endif
    If xList.Exist("Structured Examinations") Then
      $BillingReport.Add(AddClinicalFindingsStructured(encid))
    Endif
    If xList.Exist("Clinical Findings") Then
      $BillingReport.Add(AddClinicalFindingsNonVital(encid))
    Endif
    If xList.Exist("Laboratory Tests") Then
      $BillingReport.Add(AddSelectedTest(encid, modLabTest.PaientAllTestNameArray(encid), strUnit))
    Endif
    If xList.Exist("Radiological Findings") Then
      $BillingReport.Add(AddSelectedRadio(encid, modRadioTest.PaientAllRadioNameArray(encid)))
    Endif
    If xList.Exist("Clinical Notes") Then
      $BillingReport.Add(AddClinicalNotes(encid))
    Endif
    If xList.Exist("IP Monitoring") Then
      $BillingReport.Add(AddIPMonitoring(encid))
    Endif
    If xList.Exist("Therapeutic Planning") Then
      $BillingReport.Add(AddTherapeuticPlanning(encid))
    Endif

    If modPatient.CurrentAdmissionStatus(encid) = "Discharged" Then
      $BillingReport.AddSection("Discharge", True)
      If xList.Exist("Planned Procedures") Then
        $BillingReport.Add(AddPlannedProcedures(encid))
      Endif
      If xList.Exist("Discharge Examinations") Then
        $BillingReport.Add(AddDischargeFindings(encid))
      Endif
      If xList.Exist("Condition at Discharge") Then
        $BillingReport.Add(AddConditionAtDischarge(encid))
      Endif
      If xList.Exist("Discharge Medication") Then
        $BillingReport.Add(AddDischargeMedication(encid))
      Endif
      If xList.Exist("Advice on Discharge") Then
        $BillingReport.Add(AddAdviceDischarge(encid))
      Endif
    Endif

  Endif

  Dec Application.Busy
  Return $BillingReport.NewHTMLPath()

End

Public Function ShowAllEncounterSpecific(patno As String, strUnit As String, sType As String) As String

  Dim $BillingReport As CReportHTML
  Dim encounter As String
  Dim encid As String
  Dim encList As String[]

  Inc Application.Busy
  encounter = modPatient.GetLastEncoutnerFromPatNo(patno)
  If modBasic.$MedRepoBody = "Paragraph" Then
    $BillingReport = New CReportHTML([("Description")], modHelpVariable.$htmlDirectory, "PatientReport", encounter)
  Else
    $BillingReport = New CReportHTML([("Category"), ("Observations")], modHelpVariable.$htmlDirectory, "PatientReport", encounter)
  Endif
  $BillingReport.UserData.Add("REPORT: " & sType, "Report")
  $BillingReport.UserData.Add("ALL ENCOUNTERS REPORT", "PARAM1")

  encList = modPatient.GetEncListFromPatNo(patno)
  For Each encid In encList
    $BillingReport.AddChapter("Encounter : " & encid)

    If sType = "Medicines" Then
      $BillingReport.Add(AddMedicationUsed(encid))
      $BillingReport.Add(AddTreatmentAdvised(encid))
    Else If sType = "Laboratory" Then
      $BillingReport.Add(AddSelectedTest(encid, modLabTest.PaientAllTestNameArray(encid), strUnit))
    Else If sType = "Radiology" Then
      $BillingReport.Add(AddSelectedRadio(encid, modRadioTest.PaientAllRadioNameArray(encid)))
    Endif

  Next

  Dec Application.Busy
  Return $BillingReport.NewHTMLPath()

End

Public Function ShowAllEncounterReport(patno As String, strUnit As String) As String

  Dim $BillingReport As CReportHTML
  Dim encounter As String
  Dim encid As String
  Dim encList As String[]
  Dim xdelivery As String[]
  Dim xList As String[]
  Dim xvarList As Variant[]

  Dim examlist As String[]
  Dim lablist As String[]
  Dim radiolist As String[]

  encounter = modPatient.GetLastEncoutnerFromPatNo(patno)
  xList = SelectMedBody("")
  Wait
  If xList Then
    If xList.Exist("Selected Investigations") Then
      xvarList = ListViewMulti(encounter)
      If xvarList Then
        examlist = xvarList[0]
        lablist = xvarList[1]
        radiolist = xvarList[2]
      Endif
    Endif
  Endif

  Inc Application.Busy
  If modBasic.$MedRepoBody = "Paragraph" Then
    $BillingReport = New CReportHTML([("Description")], modHelpVariable.$htmlDirectory, "PatientReport", encounter)
  Else
    $BillingReport = New CReportHTML([("Category"), ("Observations")], modHelpVariable.$htmlDirectory, "PatientReport", encounter)
  Endif
  $BillingReport.UserData.Add("REPORT", "Report")
  $BillingReport.UserData.Add("ALL ENCOUNTERS REPORT", "PARAM1")

  encList = modPatient.GetEncListFromPatNo(patno)
  For Each encid In encList
    $BillingReport.AddChapter("Encounter : " & encid)

    If xList Then
      If xList.Exist("Course of Treatment") Then
        $BillingReport.Add(AddCourseOfTreatment(encid))
      Endif
      If xList.Exist("Bed Transitions") Then
        $BillingReport.Add(AddBedTransition(encid))
      Endif
      If xList.Exist("Demographics") Then
        $BillingReport.Add(AddPatDemographics(encid))
      Endif
      If xList.Exist("Triage Examinations") Then
        $BillingReport.Add(AddTriageFindings(encid))
      Endif
      If xList.Exist("Cause of Admission") Then
        $BillingReport.Add(AddCauseofAdmission(encid))
      Endif
      If xList.Exist("Presenting Complaints") Then
        $BillingReport.Add(AddPresentingComplaints(encid))
      Endif
      If xList.Exist("OPD Examinations") Then
        $BillingReport.Add(AddOPDFindings(encid))
      Endif
      If xList.Exist("General Complaints") Then
        $BillingReport.Add(AddGenComplaints(encid))
      Endif
      If xList.Exist("History of Illness") Then
        $BillingReport.Add(AddHistoryOfIllness(encid))
      Endif
      If xList.Exist("Past History") Then
        $BillingReport.Add(AddPastHistory(encid))
      Endif
      If xList.Exist("Treatment History") Then
        $BillingReport.Add(AddTreatmentHistory(encid))
      Endif
      If xList.Exist("Medication History") Then
        $BillingReport.Add(AddMedicatHistory(encid))
      Endif
      If xList.Exist("Family History") Then
        $BillingReport.Add(AddFamilyHistory(encid))
      Endif
      If xList.Exist("Personal History") Then
        $BillingReport.Add(AddPersonalHistory(encid))
      Endif
      If xList.Exist("Surgical History") Then
        $BillingReport.Add(AddSurgicalHistory(encid))
      Endif
      If xList.Exist("Occupational History") Then
        $BillingReport.Add(AddOccupationalHistory(encid))
      Endif
      If xList.Exist("Social History") Then
        $BillingReport.Add(AddSocialHistory(encid))
      Endif
      If xList.Exist("Drug Allergy") Then
        $BillingReport.Add(AddDrugAllergy(encid))
      Endif
      If xList.Exist("Provisional Diagnosis") Then
        $BillingReport.Add(AddProvisionalDiagnosis(encid))
      Endif
      If xList.Exist("Initial Planning") Then
        $BillingReport.Add(AddOPDAdvice(encid))
      Endif

      If xList.Exist("Final Diagnosis") Then
        $BillingReport.Add(AddFinalDiagnosis(encid))
      Endif
      If xList.Exist("Prominent Symptoms") Then
        $BillingReport.Add(AddProminientSymptoms(encid))
      Endif
      If xList.Exist("Major Procedures") Then
        $BillingReport.Add(AddMajorProcedures(encid))
      Endif
      If xList.Exist("Minor Procedures") Then
        $BillingReport.Add(AddMinorProcedures(encid))
      Endif
      If xList.Exist("Consultations") Then
        $BillingReport.Add(AddConsultationAll(encid))
      Endif
      If xList.Exist("Equipments Used") Then
        $BillingReport.Add(AddEquipmentsUsed(encid))
      Endif
      If xList.Exist("Extra Procedures") Then
        $BillingReport.Add(AddExtraProcedures(encid))
      Endif
      If xList.Exist("Medication Used") Then
        $BillingReport.Add(AddMedicationUsed(encid))
      Endif
      If xList.Exist("Treatment Advised") Then
        $BillingReport.Add(AddTreatmentAdvised(encid))
      Endif

      If xList.Exist("Delivery Profile") Then
        xdelivery = DeliveryReportbyMother(encid)
        If xdelivery Then
          $BillingReport.Add(AddCustomReport("Delivery Profile", xdelivery.Join(gb.NewLine)))
        Endif
      Endif

      If xList.Exist("Selected Investigations") Then
        If examlist Then
          If examlist.Count Then
            $BillingReport.Add(AddSelectedExamination(encid, examlist))
          Endif
        Endif
        If lablist Then
          If lablist.Count Then
            $BillingReport.Add(AddSelectedTest(encid, lablist, strUnit))
          Endif
        Endif
        If radiolist Then
          If radiolist.Count Then
            $BillingReport.Add(AddSelectedRadio(encid, radiolist))
          Endif
        Endif
      Endif

      If xList.Exist("Essential Examinations") Then
        $BillingReport.Add(AddClinicalFindingsVital(encid))
      Endif
      If xList.Exist("Structured Examinations") Then
        $BillingReport.Add(AddClinicalFindingsStructured(encid))
      Endif
      If xList.Exist("Clinical Findings") Then
        $BillingReport.Add(AddClinicalFindingsNonVital(encid))
      Endif
      If xList.Exist("Laboratory Tests") Then
        $BillingReport.Add(AddSelectedTest(encid, modLabTest.PaientAllTestNameArray(encid), strUnit))
      Endif
      If xList.Exist("Radiological Findings") Then
        $BillingReport.Add(AddSelectedRadio(encid, modRadioTest.PaientAllRadioNameArray(encid)))
      Endif
      If xList.Exist("Clinical Notes") Then
        $BillingReport.Add(AddClinicalNotes(encid))
      Endif
      If xList.Exist("IP Monitoring") Then
        $BillingReport.Add(AddIPMonitoring(encid))
      Endif
      If xList.Exist("Therapeutic Planning") Then
        $BillingReport.Add(AddTherapeuticPlanning(encid))
      Endif

      If xList.Exist("Planned Procedures") Then
        $BillingReport.Add(AddPlannedProcedures(encid))
      Endif
      If xList.Exist("Discharge Examinations") Then
        $BillingReport.Add(AddDischargeFindings(encid))
      Endif
      If xList.Exist("Condition at Discharge") Then
        $BillingReport.Add(AddConditionAtDischarge(encid))
      Endif
      If xList.Exist("Discharge Medication") Then
        $BillingReport.Add(AddDischargeMedication(encid))
      Endif
      If xList.Exist("Advice on Discharge") Then
        $BillingReport.Add(AddAdviceDischarge(encid))
      Endif

    Endif
  Next

  Dec Application.Busy
  Return $BillingReport.NewHTMLPath()

End

''------------------------ General ------------------------------------------------------
Public Function GetPatientSymptomReport(encid As String) As String[]

  Dim sql As String
  Dim res As Result
  Dim xx As String[]

  sql = "select fldtime,flditem,fldreportquali,flddetail from tblexamgeneral where fldencounterval=&1 and fldinput=&2 and fldsave=&3"
  res = modDatabase.$syConn.Exec(sql, encid, "Patient Symptoms", True)
  xx = New String[]
  If res.Available = True Then
    For Each res
      If res!fldreportquali Then
        If modBasic.$ShowDayMedReport = "Yes" Then
          xx.Add("[" & modReportVar.GetDateTimeReport(res!fldtime, gb.GeneralDate) & "] " & res!flditem & " (" & res!fldreportquali & ")" & " [" & res!flddetail & " ]")
        Else
          xx.Add(res!flditem & " (" & res!fldreportquali & ")" & " [" & res!flddetail & " ]")
        Endif
      Else
        If modBasic.$ShowDayMedReport = "Yes" Then
          xx.Add("[" & modReportVar.GetDateTimeReport(res!fldtime, gb.GeneralDate) & "] " & res!flditem & " [" & res!flddetail & " ]")
        Else
          xx.Add(res!flditem & " [" & res!flddetail & " ]")
        Endif
      Endif
    Next
  Endif

  Return xx

End

Public Function GetPatientPresentingSymptomReport(encid As String) As String[]

  Dim sql As String
  Dim res As Result
  Dim xx As String[]
  Dim xqty As String

  sql = "select fldtime,flditem,fldreportquali,fldreportquanti,flddetail from tblexamgeneral where fldencounterval=&1 and fldinput=&2 and fldsave=&3"
  res = modDatabase.$syConn.Exec(sql, encid, "Presenting Symptoms", True)
  xx = New String[]
  If res.Available = True Then
    For Each res

      If res!fldreportquanti Then
        xqty = modDate.ConvertHoursToString(res!fldreportquanti)
      Else
        xqty = ""
      Endif

      If res!flddetail Then
        If modBasic.$ShowDayMedReport = "Yes" Then
          xx.Add("[ " & modReportVar.GetDateTimeReport(res!fldtime, gb.GeneralDate) & " ] " & res!flditem & " : " & xqty & Space(1) & res!fldreportquali & " [" & res!flddetail & "]")
        Else
          xx.Add(res!flditem & " : " & xqty & Space(1) & res!fldreportquali & " [" & res!flddetail & "]")
        Endif
      Else
        If modBasic.$ShowDayMedReport = "Yes" Then
          xx.Add("[ " & modReportVar.GetDateTimeReport(res!fldtime, gb.GeneralDate) & " ] " & res!flditem & " : " & xqty & Space(1) & res!fldreportquali)
        Else
          xx.Add(res!flditem & " : " & xqty & Space(1) & res!fldreportquali)
        Endif
      Endif

    Next
  Endif

  Return xx

End

