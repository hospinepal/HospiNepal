''-------------------------- Recommended Examinations -----------------------------
Public Function GetRecommendedExam(encid As String) As String

  Dim res As Result
  Dim catlst As String[]
  Dim itmlst As String[]
  Dim xval As String[]
  Dim xcateg As String
  Dim xitem As String

  Dim res1 As Result
  Dim xfinal As String
  Dim xfull As String
  Dim xType As String
  Dim xquali As String

  xfull = ""
  res = modDatabase.$syConn.Exec("select distinct(fldserialval) as col from tblpatientexam where fldserialval like &1 and fldencounterval=&2 and fldinput=&3 and fldsave=&4", "%", encid, "Rec Examination", True)
  If res.Available Then
    catlst = New String[]
    itmlst = New String[]
    For Each res
      xval = Split(modFixClinic.GetChapterFromRecommendedID(res!col), "@")

      If catlst.Count = 0 Then
        catlst.Add(xval[0])
      Else
        If catlst.Exist(xval[0]) = False Then
          catlst.Add(xval[0])
        Endif
      Endif

      If itmlst.Count = 0 Then
        itmlst.Add(xval[1])
      Else
        If itmlst.Exist(xval[1]) = False Then
          itmlst.Add(xval[1])
        Endif
      Endif

    Next

    For Each xcateg In catlst
      xfull = xfull & xcateg
      xfull = xfull & "<ul>"
      For Each xitem In itmlst
        xfull = xfull & xitem
        xfull = xfull & "<ul>"

        res1 = modDatabase.$syConn.Exec("select fldid,fldtime,fldhead,fldrepquali,fldrepquanti,fldtype,fldoption from tblpatientexam where fldencounterval=&1 and fldinput=&2 and fldsave=&3 and fldserialval in(select fldheadcode from tblstructexam where fldcategory=&4 and flditem=&5)", encid, "Rec Examination", True, xcateg, xitem)                                            ''
        If res1.Available Then
          For Each res1
            If res1!fldtype = "Quantitative" Then
              xfinal = res1!fldhead & " : " & CStr(res1!fldrepquanti) & Space(1) & modClinic.GetExamUnit(res1!fldhead, encid)
            Else

              xType = res1["fldoption"]
              If xType = "Clinical Scale" Then
                If modBasic.$ShowScaleMedFormat = "GroupWise" Then
                  xquali = modString.GetJSONToDualHTMLTable(Trim(res1!fldrepquali))
                Else
                  xquali = CStr(res1!fldrepquanti)
                Endif
              Else If xType = "Left and Right" Then
                xquali = modString.GetJSONToDualHTMLTable(Trim(res1!fldrepquali))
              Else
                xquali = Trim(res1!fldrepquali)
              Endif
              xfinal = res1!fldhead & " : " & xquali
            Endif
            If modBasic.$ShowDayMedReport = "Yes" Then
              xfull = xfull & "<li>" & "[ " & modReportVar.GetDateTimeReport(res1!fldtime, gb.GeneralDate) & " ] " & xfinal & "</li>"
            Else
              xfull = xfull & "<li>" & xfinal & "</li>"
            Endif
          Next
        Endif

        xfull = xfull & "</ul>" & gb.NewLine
      Next
      xfull = xfull & "</ul>" & gb.NewLine
    Next

  Endif

  Return xfull

End

''---------------------------- OPD Findings -----------------------------
Public Function GetSelectFindingReport(encid As String, sType As String) As String[]

  Dim sql As String
  Dim res As Result
  Dim xx As String
  Dim yy As String[]
  Dim xList As String[]
  Dim xType As String
  Dim xquali As String

  xlist = New String[]
  sql = "select fldid,fldtime,fldhead,fldrepquali,fldrepquanti,fldtype,fldoption from tblpatientexam where fldencounterval=&1 and fldsave=&2 and fldinput=&3"
  res = modDatabase.$syConn.Exec(sql, encid, True, sType)
  If res.Available = True Then
    For Each res

      xx = ""
      If res!fldtype = "Quantitative" Then
        If res!fldrepquanti Then
          If modBasic.$ShowDayMedReport = "Yes" Then
            xx = "[ " & modReportVar.GetDateTimeReport(res!fldtime, gb.GeneralDate) & " ] " & res["fldhead"] & " : " & CStr(res!fldrepquanti) & Space(1) & modClinic.GetExamUnit(res["fldhead"], encid)
          Else
            xx = res["fldhead"] & " : " & CStr(res!fldrepquanti) & Space(1) & modClinic.GetExamUnit(res["fldhead"], encid)
          Endif
        Else
          xx = ""
        Endif

      Else

        xType = res["fldoption"]
        If xType = "Clinical Scale" Then
          If modBasic.$ShowScaleMedFormat = "GroupWise" Then
            xquali = modString.GetJSONToDualHTMLTable(Trim(res!fldrepquali))
          Else
            xquali = CStr(res!fldrepquanti)
          Endif
        Else If xType = "Left and Right" Then
          xquali = modString.GetJSONToDualHTMLTable(Trim(res!fldrepquali))
        Else
          xquali = Trim(res!fldrepquali)
        Endif
        If modBasic.$ShowDayMedReport = "Yes" Then
          xx = "[ " & modReportVar.GetDateTimeReport(res!fldtime, gb.GeneralDate) & " ] " & res["fldhead"] & " : " & xquali
        Else
          xx = res["fldhead"] & " : " & xquali
        Endif

        yy = modClinic.GetSubExamQualiList(encid, res!fldid)
        If yy.Count Then
          xx = xx & modString.GetHTMLListFormat(yy)
        Endif

      Endif
      xList.Add(xx)

    Next
  Endif
  Return xList

End
