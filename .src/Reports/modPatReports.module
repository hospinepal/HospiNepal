' Gambas module file

'NOTE: ----------------------------- Medical Report --------------------------------------------
Public Function AddCustomReport(stChapter As String, stObservation As String) As String[]

  Dim asx As New String[0]

  With asx
    If modBasic.$MedRepoBody = "Paragraph" Then
      .Add("<b>" & stChapter & "</b><br>" & modString.TextToHTML(stObservation))
    Else
      .Add(stChapter)
      .Add(modString.TextToHTML(stObservation))
    Endif
  End With
  Return asx

End

Public Function AddCustomParam(sParam As String) As String[]

  Dim asx As New String[0]
  Dim xx As String

  Dim stChapter As String
  Dim stObservation As String

  xx = GetRichTextArea(sParam, "")

  ' With asx
  '   If modBasic.$MedRepoBody = "Paragraph" Then
  '     .Add("<b>" & sParam & "</b><br>" & xx)
  '   Else
  '     .Add(sParam)
  '     .Add(xx)
  '   Endif
  ' End With

  stChapter = sParam
  stObservation = xx
  asx = AddCustomReport(stChapter, stObservation)
  Return asx

End

Public Function AddCourseOfTreatment(encid As String) As String[]

  Dim asx As New String[0]
  Dim res As Result
  Dim xx As String
  Dim xcom As String
  Dim folDate As Date

  Dim stChapter As String
  Dim stObservation As String

  res = modDatabase.$syConn.Exec("select fldhead,fldtime,fldcomment from tblpatientdate where fldencounterval=&1", encid)
  xx = ""
  If res.Available Then
    For Each res
      xcom = ""
      If res!fldcomment Then
        xcom = " (" & res!fldcomment & ")"
      Endif
      xx = xx & " Date: " & modReportVar.GetDateTimeReport(res!fldtime, gb.GeneralDate) & "::" & res!fldhead & xcom & gb.NewLine
    Next
  Endif

  folDate = modPatient.GetFollowUpDate(encid)
  If folDate Then
    xx = xx & "Follow-up: " & modReportVar.GetDateTimeReport(folDate, gb.GeneralDate)
  Endif

  ' With asx
  '   If modBasic.$MedRepoBody = "Paragraph" Then
  '     .Add("<b>" & "Course of Treatment" & "</b><br>" & modString.TextToHTML(xx))
  '   Else
  '     .Add("Course of Treatment")
  '     .Add(modString.TextToHTML(xx))
  '   Endif '
  ' End With

  stChapter = "Course of Treatment"
  stObservation = xx
  asx = AddCustomReport(stChapter, stObservation)
  Return asx

End

