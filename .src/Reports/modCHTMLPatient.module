Public Function ShowNursingDosing(encid As String) As String

  Dim $BillingReport As CReportHTML
  Dim res As Result
  Dim rs As Result
  Dim asx As New String[0]

  Dim zzz As Date[]
  Dim red1 As Result
  Dim $dt As Date

  Inc Application.Busy
  $BillingReport = New CReportHTML([("Time"), ("Medicine"), ("Regimen"), ("Dose")], modHelpVariable.$htmlDirectory, "PatientReport", encid)
  $BillingReport.UserData.Add("REPORT", "Report")
  $BillingReport.UserData.Add("Dosing Report", "PARAM1")

  zzz = New Date[]
  red1 = modDatabase.$syConn.Exec("select fldtime from tblnurdosing where fldencounterval=&1", encid)
  For Each red1

    If zzz.Count = 0 Then
      zzz.Add(modDate.StartSqlDate(red1!fldtime))
    Else
      If zzz.Exist(modDate.StartSqlDate(red1!fldtime)) = False Then
        zzz.Add(modDate.StartSqlDate(red1!fldtime))
      Endif
    Endif

  Next

  zzz.Sort()
  For Each $dt In zzz
    $BillingReport.AddSection(modReportVar.GetDateTimeReport($dt, gb.MediumDate), True)

    res = modDatabase.$syConn.Exec("select fldtime,flddoseno,fldvalue,fldunit from tblnurdosing where fldencounterval=&1 and fldtime>=&2 and fldtime<=&3", encid, modDate.StartSqlDate($dt), modDate.EndSqlDate($dt))
    For Each res
      rs = modDatabase.$syConn.Exec("select fldid,fldroute,flditem,flddose,fldfreq,flddays,flditemtype from tblpatdosing where fldid=&1", res!flddoseno)
      If rs!flditemtype = "Medicines" Then
        With asx
          .Add(modReportVar.GetDateTimeReport(res!fldtime, gb.MediumTime))
          .Add(modPharmacy.GetMedFormatForMedReport(rs!flditem, rs!fldroute))
          .Add(modPharmacy.GetDoseRegimenString(rs!fldid, True))
          .Add(res!fldvalue & Space(1) & res!fldunit)
        End With
        $BillingReport.Add(asx)
        asx.Clear()
      Endif
    Next

  Next
  Dec Application.Busy
  Return $BillingReport.NewHTMLPath()

End

Public Function ExportQuantiClinToHTML(encid As String, strType As String, strItem As String[], unt As String, frm As Form) As String

  Dim $BillingReport As CReportHTML
  Dim drwNewCht As PictureBox
  Dim sPath As String
  Dim asx As New String[0]
  Dim xx As String

  Inc Application.Busy
  $BillingReport = New CReportHTML([("Parameters"), ("Chart View")], modHelpVariable.$htmlDirectory, "PatientReport", encid)
  $BillingReport.UserData.Add("REPORT", "Report")
  $BillingReport.UserData.Add(strType, "PARAM1")

  For Each xx In strItem
    sPath = Temp() & ".png"
    drwNewCht = New PictureBox(frm)
    drwNewCht.Height = 150 * modBasic.$AppScaleFactor
    If strType = "Exam" Then
      modClinic.FillQuantiExamChart(drwNewCht, encid, xx)
    Else If strType = "Test" Then
      modLabTest.FillQuantiTestChart(drwNewCht, encid, xx, unt)
    Else If strType = "SetA" Then
      modClinic.DrawClinicalCharts_SetA(drwNewCht, encid, xx)
    Endif
    drwNewCht.Picture.Save(sPath)
    drwNewCht.Delete()

    With asx
      .Add(xx)
      .Add(modString.GetImageForHTML(sPath))
    End With
    $BillingReport.Add(asx)
    asx.Clear()
  Next
  Dec Application.Busy
  Return $BillingReport.NewHTMLPath()

End

Public Function ExportMultiExamTestToHTML(encid As String, examlist As String[], testlist As String[], unt As String, frm As Form) As String

  Dim $BillingReport As CReportHTML
  Dim drwNewCht As PictureBox
  Dim sPath As String
  Dim asx As New String[0]
  Dim xx As String
  Dim yy As String

  Inc Application.Busy
  $BillingReport = New CReportHTML([("Parameters"), ("Chart View")], modHelpVariable.$htmlDirectory, "PatientReport", encid)
  $BillingReport.UserData.Add("REPORT", "Report")
  $BillingReport.UserData.Add("ChartView", "PARAM1")

  For Each xx In examlist
    If modFixClinic.GetExaminationType(xx) = "Quantitative" Then
      sPath = Temp() & ".png"
      drwNewCht = New PictureBox(frm)
      drwNewCht.Height = 150 * modBasic.$AppScaleFactor
      modClinic.FillQuantiExamChart(drwNewCht, encid, xx)
      drwNewCht.Picture.Save(sPath)
      drwNewCht.Delete()
      With asx
        .Add(xx)
        .Add(modString.GetImageForHTML(sPath))
      End With
      $BillingReport.Add(asx)
      asx.Clear()

    Else
      With asx
        .Add(xx)
        .Add(modClinic.UniExamValueList(encid, xx).Join("<br>"))
      End With
      $BillingReport.Add(asx)
      asx.Clear()

    Endif
  Next

  For Each yy In testlist
    If modFixLab.GetLabTestType(yy) = "Quantitative" Then
      sPath = Temp() & ".png"
      drwNewCht = New PictureBox(frm)
      drwNewCht.Height = 150 * modBasic.$AppScaleFactor
      modLabTest.FillQuantiTestChart(drwNewCht, encid, yy, unt)
      drwNewCht.Picture.Save(sPath)
      drwNewCht.Delete()
      With asx
        .Add(yy)
        .Add("<div style='height:200px;width:800px;overflow:auto;'><img src=" & sPath & "></div>")
      End With
      $BillingReport.Add(asx)
      asx.Clear()

    Else
      With asx
        .Add(yy)
        .Add(modLabTest.UniLabValueList(encid, yy).Join("<br>"))
      End With
      $BillingReport.Add(asx)
      asx.Clear()

    Endif
  Next

  Dec Application.Busy
  Return $BillingReport.NewHTMLPath()

End

''--------------------------------- Medication order -----------------------------------------------------------------------------
Public Function ShowMedicationOrder(encid As String) As String

  Dim $BillingReport As CReportHTML
  Dim res As Result
  Dim asx As New String[0]

  $BillingReport = New CReportHTML([("SNo"), ("StartDate"), ("Medicine"), ("Route"), ("Regimen")], modHelpVariable.$htmlDirectory, "LaboratoryReport", encid)
  $BillingReport.UserData.Add("REPORT", "Report")
  $BillingReport.UserData.Add("Medication Order", "PARAM1")

  Inc Application.Busy
  res = modDatabase.$syConn.Exec("select fldid,fldstarttime,fldroute,flditem,flddose,fldfreq,flddays from tblpatdosing where fldencounterval=&1 and fldsave_order=&2 and flduserid_order=&3 and flditemtype=&4", encid, False, modGeneralMain.$lbluser, "Medicines")
  For Each res
    With asx
      .Add(CStr(res.Index + 1))
      .Add(modReportVar.GetDateTimeReport(res!fldstarttime, gb.GeneralDate))
      .Add(modPharmacy.GetMedFormatForMedReport(res!flditem, res!fldroute))
      .Add(res!fldroute)
      .Add(modPharmacy.GetDoseRegimenString(res!fldid, False))
    End With
    $BillingReport.Add(asx)
    asx.Clear()
  Next
  Dec Application.Busy
  Return $BillingReport.NewHTMLPath()

End

Public Function ShowMedicationLabelReport(encid As String, dosid As Long[], LabelMode As String) As String

  Dim $BillingReport As CReportHTML
  Dim xx As Long
  Dim res As Result
  Dim asx As New String[0]
  Dim hCls As CLabelFreq

  Inc Application.Busy
  $BillingReport = New CReportHTML([("StartDate"), ("Medicine"), ("Regimen"), ("Direction"), ("Advice")], modHelpVariable.$htmlDirectory, "PatientReport", encid)
  $BillingReport.UserData.Add("REPORT", "Report")
  $BillingReport.UserData.Add("Medication Labels", "PARAM1")

  For Each xx In dosid
    res = modDatabase.$syConn.Exec("select fldid,fldstarttime,fldroute,flditem,flddose,fldfreq,flddays,flditemtype from tblpatdosing where fldencounterval=&1 and fldid=&2 and (fldstatus=&3 or fldstatus=&4)", encid, xx, "Registered", "Admitted") '"Ordered"
    For Each res
      If res!flditemtype = "Medicines" Then
        hCls = New CLabelFreq(res!fldfreq, LabelMode)

        With asx
          .Add(modReportVar.GetDateTimeReport(res!fldstarttime, gb.GeneralDate))
          .Add(modPharmacy.GetMedFormatForMedReport(res!flditem, res!fldroute))
          .Add(modPharmLabel.GetQuantityLabel(res!flddose, res!flditem, LabelMode) & Space(1) & modPharmLabel.GetDosageFormForLabel(res!flditem, LabelMode) & Space(1) & modPharmLabel.GetLabelWordsFromDB("Every", LabelMode) & Space(1) & hCls.HourValue() & Space(1) & hCls.HourLabelText() & Space(1) & modPharmLabel.GetLabelWordsFromDB("Difference", LabelMode) & Space(1) & res!flddays & Space(1) & modPharmLabel.GetLabelWordsFromDB("Day", LabelMode))
          .Add(hCls.PrecaytionText())
          .Add(modPharmLabel.GetDirectionForLabel(res!fldroute, res!flditem, LabelMode))
        End With
        $BillingReport.Add(asx)
        asx.Clear()

      Endif
    Next
  Next
  Dec Application.Busy
  Return $BillingReport.NewHTMLPath()

End

Public Function ShowCounselingReport(encid As String, doslst As Long[]) As String

  Dim $BillingReport As CReportHTML
  Dim asx As New String[0]
  Dim did As Long

  Inc Application.Busy
  $BillingReport = New CReportHTML([("Medicine"), ("Regimen"), ("Comment")], modHelpVariable.$htmlDirectory, "PatientReport", encid)
  $BillingReport.UserData.Add("REPORT", "Report")
  $BillingReport.UserData.Add("COUNSELING", "PARAM1")

  For Each did In doslst
    With asx
      .Add(modPharmacy.GetMedFormatForMedReport(modPharmacy.GetStockIDFromDosing(did), modPharmacy.GetRouteFromDosing(did)))
      .Add(modPharmacy.GetDoseRegimenString(did, True))
      .Add("")
    End With
    $BillingReport.Add(asx)
    asx.Clear()
    $BillingReport.AddSummary(modPharmLabel.GetCounselingInfo(modPharmacy.GetRouteFromDosing(did), modPharmacy.GetStockIDFromDosing(did)))

    With asx
      .Add("***")
      .Add("***")
      .Add("***")
    End With
    $BillingReport.Add(asx)
    asx.Clear()
  Next
  Dec Application.Busy
  Return $BillingReport.NewHTMLPath()

End

Public Function ShowSingleCounselingReport(dosid As Long) As String

