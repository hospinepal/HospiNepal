  $BillingReport = New CReportHTML([("Time"), ("Symptom"), ("Description"), ("Comment")], modHelpVariable.$htmlDirectory, "PatientReport", encid)
  $BillingReport.UserData.Add("REPORT", "Report")
  $BillingReport.UserData.Add("CLINICAL SYMPTOMS", "PARAM1")

  zzz = New Date[]
