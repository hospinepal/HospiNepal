''====================== Receive ======================================
Public Sub btnsaveto_Click()

  Dim res As Result
  Dim res1 As Result
  Dim ref As String
  Dim idLock As Boolean

  If Message.Question(("The Stock Transfer Process will be complete. Are you sure?"), ("No"), ("Yes")) = 2 Then
    res = modDatabase.$myConn.Exec("select fldid,fldstockno,fldoldstockno,fldqty,fldfromcomp,fldtocomp from tbltransfer where fldtocomp=&1 and fldsav=&2 and fldfromsav=&3 and fldtosav=&4", modGeneralMain.compID, True, True, False)
    If res.Available = True Then

      Inc Application.Busy
      idLock = modNonMedical.LockTableForID("Reference")
      If idLock = True Then

        modDatabase.$myConn.Begin
        ref = modNonMedical.ReferenceString("Stock Transfer")
        If ref Then
          For Each res
            If res!fldqty <= modStock.TotalQTYbyStockNo(res!fldoldstockno) Then
              modStock.AddToExistEntry(res["fldstockno"], res["fldqty"], res["fldtocomp"]) ''add to new
              modStock.AddToExistEntry(res["fldoldstockno"], (0 - res["fldqty"]), res["fldfromcomp"])  ''reduce from old
              res1 = modDatabase.$myConn.Edit("tbltransfer", "fldid=&1", res!fldid)
              res1["fldtoentrytime"] = Now()
              res1["fldtouser"] = modGeneralMain.$lbluser
              res1["fldtocomp"] = modGeneralMain.compID
              res1["fldtosav"] = True
              res1["fldreference"] = ref
              res1["xyz"] = False
              res1.Update()
            Endif
          Next
        Endif  ''if ref no exist
        modDatabase.$myConn.Commit

        modNonMedical.ReleaseLockTable("Reference")
      Endif  ''if locked
      Dec Application.Busy
      ShowReceiveGrid()

    Endif  ''if result available
  Endif

Catch
  modDatabase.$myConn.Rollback
  Dec Application.Busy
  If idLock = True Then
    modNonMedical.ReleaseLockTable("Reference")
  Endif

End

Public Sub mnurecvdel_Click()

  Dim res As Result

  If GridView2.Rows.Selection.Count > 0 Then
    res = modDatabase.$myConn.Edit("tbltransfer", "fldid=&1", GridView2[GridView2.Row, 0].Text)
    res["fldsav"] = False
    res["xyz"] = False
    res.Update()
    ShowReceiveGrid()
    Message.Warning(("Item rejected"), ("OK"))
  Endif

End

