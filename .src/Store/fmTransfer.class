' Gambas class file

Private $rData As Result
Private $rData1 As Result
Private $aMyFields As String[]
Private $aMyFields1 As String[]

Private $MSurgicalLst As String[]
Private $ExtraItemLst As String[]
Private $OralBrandLst As String[]
Private $OralGenricLst As String[]
Private $InjBrandLst As String[]
Private $InjGenricLst As String[]
Private $LiqBrandLst As String[]
Private $LiqGenricLst As String[]

Public Sub Form_Open()

  modGeneralMain.ArrangeEmbedForms(Me, Panel1, "Vertical")
  Me.Icon = Picture[modGeneralMain.$strLogo]

  cmbroute.List = modMedicine.ComboRoute()
  cmbcomp.List = modBasic.$AllCompList
  modStock.DisplayDefaultTransferMode(rbrand, rbgeneric)
  IniateCategoryArray()
  BlankAllBox()

  ShowTransferGrid()
  If cmbcomp.Text = "" Then
    cmbcomp.SetFocus
  Endif

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

Public Sub Form_KeyRelease()

  modGeneralmain.GoToNextControlTab()

End

Public Sub mnublank_Click()

  Me.Close
  Wait
  modHelpVariable.AddNewFormToWorkspace(fmTransfer)

End

Public Sub TabPanel1_Click()

  ShowReceiveGrid()

End

''-------------------------------- send items -----------------------------------------------
Public Sub cmbcomp_Click()

  lblcomp.Text = modGeneral.GetCompNameFromCompID(cmbcomp.Text)

End

Public Sub rbgeneric_Click()

  modSettings.SaveSettingsToFile("BrandOrGeneric/Transfer", "Generic")

End

Public Sub rbrand_Click()

  modSettings.SaveSettingsToFile("BrandOrGeneric/Transfer", "Brand")

End

Public Sub cmbcomp_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbcomp)
  modFillContainer.RestrictComboToContent(cmbcomp)

End

Public Sub cmbroute_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbroute)
  modFillContainer.RestrictComboToContent(cmbroute)

End

Public Sub cmbroute_Click()

  chksave.Value = False
  cmbmedicine.Clear
  cmbmedicine.Text = ""

End

''--------------------- Array for Items to Load ----------------------------
Private Sub IniateCategoryArray()

  $MSurgicalLst = New String[]
  $ExtraItemLst = New String[]
  $OralBrandLst = New String[]
  $OralGenricLst = New String[]
  $InjBrandLst = New String[]
  $InjGenricLst = New String[]
  $LiqBrandLst = New String[]
  $LiqGenricLst = New String[]

End

Private Function GetCategoryArray(sRoute As String, sMode As String) As String[]

  Dim xarry As String[]

  If sRoute = "oral" Then
    If sMode = "Brand" Then
      If Not $OralBrandLst.Count Then
        $OralBrandLst.Insert(modFillContainer.GetListFromResult(modStock.FillMedicinesTransferComboResult(sRoute, sMode, "", modGeneralMain.compID)))
      Endif
      xarry = $OralBrandLst
    Else If sMode = "Generic" Then
      If Not $OralGenricLst.Count Then
        $OralGenricLst.Insert(modFillContainer.GetListFromResult(modStock.FillMedicinesTransferComboResult(sRoute, sMode, "", modGeneralMain.compID)))
      Endif
      xarry = $OralGenricLst
    Endif

  Else If sRoute = "liquid" Then
    If sMode = "Brand" Then
      If Not $LiqBrandLst.Count Then
        $LiqBrandLst.Insert(modFillContainer.GetListFromResult(modStock.FillMedicinesTransferComboResult(sRoute, sMode, "", modGeneralMain.compID)))
      Endif
      xarry = $LiqBrandLst
    Else If sMode = "Generic" Then
      If Not $LiqGenricLst.Count Then
        $LiqGenricLst.Insert(modFillContainer.GetListFromResult(modStock.FillMedicinesTransferComboResult(sRoute, sMode, "", modGeneralMain.compID)))
      Endif
      xarry = $LiqGenricLst
    Endif

  Else If sRoute = "injection" Then
    If sMode = "Brand" Then
      If Not $InjBrandLst.Count Then
        $InjBrandLst.Insert(modFillContainer.GetListFromResult(modStock.FillMedicinesTransferComboResult(sRoute, sMode, "", modGeneralMain.compID)))
      Endif
      xarry = $InjBrandLst
    Else If sMode = "Generic" Then
      If Not $InjGenricLst.Count Then
        $InjGenricLst.Insert(modFillContainer.GetListFromResult(modStock.FillMedicinesTransferComboResult(sRoute, sMode, "", modGeneralMain.compID)))
      Endif
      xarry = $InjGenricLst
    Endif

  Else If sRoute = "msurg" Then
    If Not $MSurgicalLst.Count Then
      $MSurgicalLst.Insert(modFillContainer.GetListFromResult(modStock.FillMedicinesTransferComboResult(sRoute, sMode, "", modGeneralMain.compID)))
    Endif
    xarry = $MSurgicalLst

  Else If sRoute = "extra" Then
    If Not $ExtraItemLst.Count Then
      $ExtraItemLst.Insert(modFillContainer.GetListFromResult(modStock.FillMedicinesTransferComboResult(sRoute, sMode, "", modGeneralMain.compID)))
    Endif
    xarry = $ExtraItemLst

  Else
    xarry = modFillContainer.GetListFromResult(modStock.FillMedicinesTransferComboResult(sRoute, sMode, "", modGeneralMain.compID))
  Endif

  Return xarry

End
''-------------------------------- END ------------------------------------

Public Sub cmbmedicine_GotFocus()

  Dim brandOrGeneric As String
  Dim res As Result

  If rbrand.Value = True Then
    brandOrGeneric = "Brand"
  Else
    brandOrGeneric = "Generic"
  Endif

  If Not cmbroute.Text Then
    cmbroute.SetFocus
  Else If cmbroute.Text Then
    If Not cmbmedicine.Text Then
      If modBasic.$ItemListFormat = "ComboBox" Then
      Else
        cmbbatch.Tag = "Auto"

        If modBasic.$LocalCache = "Yes" Then
          cmbmedicine.Enabled = False
          cmbmedicine.Text = GridViewNew("Select Particulars", GetCategoryArray(cmbroute.Text, brandOrGeneric), False)
          cmbmedicine.Enabled = True
        Else
          res = modStock.FillMedicinesTransferComboResult(cmbroute.Text, brandOrGeneric, "", modGeneralMain.compID)
          cmbmedicine.Enabled = False
          cmbmedicine.Text = GridViewNew("Select Particulars", modFillContainer.GetListFromResult(res), False)
          cmbmedicine.Enabled = True
        Endif

        cmbbatch.SetFocus
      Endif
    Endif
  Endif

End

Public Sub cmbmedicine_KeyRelease()

  Dim brandOrGeneric As String

  If rbrand.Value = True Then
    brandOrGeneric = "Brand"
  Else
    brandOrGeneric = "Generic"
  Endif
  modStock.FillMedicinesTransferCombo(cmbroute.Text, cmbmedicine, brandOrGeneric, modGeneralMain.compID)

End

Public Sub cmbbatch_KeyRelease()

  cmbbatch.Tag = ""
  modFillContainer.AutoFillComboBox(cmbbatch)
  modFillContainer.RestrictComboToContent(cmbbatch)

End

Public Sub cmbbatch_GotFocus()

  Dim res1 As Result

  If Not cmbbatch.Count Then
    If cmbmedicine.Text Then
      If modStock.GetComboControl(cmbroute.Text, cmbmedicine.Text, rbgeneric, rbrand) = False Then
        cmbmedicine.Text = ""
        Balloon.Warning(("Item not listed"), cmbmedicine)
        Balloon.Delay = modBasic.$BalloonDelay
        cmbroute.SetFocus
      Else
        If cmbroute.Text = "suture" Or cmbroute.Text = "msurg" Or cmbroute.Text = "ortho" Or cmbroute.Text = "extra" Then
        Else
          If rbrand.Value = True Then
            cmbmedicine.Text = modMedConstant.ConvertBrandToGeneric(cmbroute.Text, cmbmedicine.Text)
          Endif
        Endif
        res1 = modDatabase.$myConn.Exec("select distinct(fldbatch) as col from tblentry where fldstockid=&1 and fldcomp=&2 and fldqty>&3", cmbmedicine.Text, modGeneralMain.compID, 0)
        modFillContainer.FillComboBox(cmbbatch, res1)
      Endif
    Endif
  Endif

End

Public Sub cmbbatch_Click()

  Dim res As Result

  res = modDatabase.$myConn.Exec("select fldstockno,fldexpiry,fldqty,fldstatus,fldcategory,fldsellpr from tblentry where fldstockid=&1 and fldbatch=&2 and fldcomp=&3", cmbmedicine.Text, cmbbatch.Text, modGeneralMain.compID)                                                   ''
  If res.Available Then
    res.MoveFirst
    txtstatus.Value = res!fldstatus
    lbldate.Value = res!fldexpiry
    txtmax.Value = res!fldqty
    txtcategory.Text = res!fldcategory
  Endif

End

Public Sub chksave_Click()

  If chksave.Value Then
    If cmbcomp.Text And If cmbmedicine.Text And If cmbbatch.Text And If txtqty.Value Then
      SaveEntry()
      ShowTransferGrid()
      cmbroute.SetFocus
    Endif
  Endif

End

Public Sub chksave_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    chksave.Value = True
    chksave_Click()
  Endif

End

Private Sub SaveEntry()

  Dim res As Result
  Dim newstno As Long
  Dim xstock As Boolean
  Dim res1 As Result

  If chksave.Value = True Then
    res1 = modDatabase.$myConn.Exec("select fldstockno,fldexpiry,fldqty,fldstatus,fldcategory,fldsellpr from tblentry where fldstockid=&1 and fldbatch=&2 and fldcomp=&3", cmbmedicine.Text, cmbbatch.Text, modGeneralMain.compID)                                                   ''
    If res1.Available Then
      res1.MoveFirst
      If cmbcomp.Text <> modGeneralMain.compID And If txtqty.Value <= res1!fldqty Then

        Inc Application.Busy
        xstock = modStock.NewStock(cmbmedicine.Text, cmbbatch.Text, cmbcomp.Text)

        modDatabase.$myConn.Begin
        newstno = modStock.GetItemStockNo(cmbmedicine.Text, cmbbatch.Text, cmbcomp.Text)
        If newstno Then
          If xstock = True Then
            AddNewEntry(newstno, res1!fldsellpr)
          Endif                                                              ''
          res = modDatabase.$myConn.Create("tbltransfer")
          res["fldstockno"] = newstno
          res["fldoldstockno"] = res1!fldstockno
          res["fldstockid"] = cmbmedicine.Text
          res["fldcategory"] = modNonMedical.GetBillItemCategoryFromCombo(cmbroute.Text)
          res["fldqty"] = txtqty.Value
          res["fldnetcost"] = modStock.GetAverageCostPriceByStockNo(res1!fldstockno)
          res["fldsellpr"] = res1!fldsellpr
          res["fldsav"] = False
          res["fldfromentrytime"] = Now()
          res["fldfromuser"] = modGeneralMain.$lbluser
          res["fldfromcomp"] = modGeneralMain.compID
          res["fldfromsav"] = False
          res["fldtoentrytime"] = ""
          res["fldtouser"] = ""
          res["fldtocomp"] = cmbcomp.Text
          res["fldtosav"] = False
          res["fldreference"] = ""
          res["xyz"] = False
          res.Update()
        Endif
        modDatabase.$myConn.Commit
        Dec Application.Busy
        BlankAllBox()

      Endif
    Endif
  Endif

Catch
  modDatabase.$myConn.Rollback
  Dec Application.Busy
  modHelpVariable.CreateErrorReport()

End

Private Sub AddNewEntry(StockNo As Long, sellPr As Float)

  Dim res As Result

  res = modDatabase.$myConn.Create("tblentry")
  res["fldstockno"] = StockNo
  res["fldstockid"] = cmbmedicine.Text
  res["fldbatch"] = cmbbatch.Text
  res["fldexpiry"] = lbldate.Value
  res["fldqty"] = 0
  res["fldstatus"] = modStock.ItemSaleStatus(cmbmedicine.Text, cmbcomp.Text)
  res["fldsellpr"] = sellPr
  res["fldsav"] = False
  res["fldcategory"] = modNonMedical.GetBillItemCategoryFromCombo(cmbroute.Text)
  res["fldcomp"] = cmbcomp.Text
  res["fldcode"] = 0
  res.Update()

End

Private Sub BlankAllBox()

  cmbroute.Text = ""
  cmbmedicine.Text = ""
  cmbbatch.Clear()
  cmbbatch.Text = ""
  txtqty.Value = 0
  txtcategory.Text = ""
  txtmax.Value = 0
  txtstatus.Value = 0

End

Public Sub mnuall_Click()

  Dim sql As String
  Dim res As Result

  If Message.Question(("Do you want to transfer all your inventory ?"), ("No"), ("Yes")) = 2 Then
    If cmbcomp.Text Then
      sql = "select fldstockno,fldstockid,fldcategory,fldqty,fldsellpr from tblentry where fldcomp=&1 and fldqty>&2"
      res = modDatabase.$myConn.Exec(sql, modGeneralMain.compID, 0)
      If res.Available = True Then
        For Each res
          SaveEntryAll(res!fldstockno, res!fldstockid, res!fldcategory, res!fldqty, res!fldsellpr)
        Next
        ShowTransferGrid()
      Endif
    Endif
  Endif

End

Private Sub SaveEntryAll(stockno As Long, stockid As String, txtcateg As String, qty As Float, sellpr As Float)

  Dim res As Result
  Dim rs As Result
  Dim newstno As Long
  Dim xstock As Boolean

  Dim xbatch As String
  Dim xexpiry As Date
  Dim xstatus As Integer

  If modGeneralMain.compID <> cmbcomp.Text Then
    xstock = modStock.NewStock(stockid, modStock.GetBatchFromStockNo(stockno), cmbcomp.Text)
    xbatch = modStock.GetBatchFromStockNo(stockno)
    xexpiry = modStock.GetExpiryFromStockNo(stockno)
    xstatus = modStock.ItemSaleStatus(cmbmedicine.Text, cmbcomp.Text)

    modDatabase.$myConn.Begin
    newstno = modStock.GetItemStockNo(stockid, modStock.GetBatchFromStockNo(stockno), cmbcomp.Text)
    If newstno Then
      If xstock = True Then
        rs = modDatabase.$myConn.Create("tblentry")
        rs["fldstockno"] = newstno
        rs["fldstockid"] = stockid
        rs["fldbatch"] = xbatch
        rs["fldexpiry"] = xexpiry
        rs["fldqty"] = 0
        rs["fldstatus"] = xstatus
        rs["fldsellpr"] = sellpr
        rs["fldsav"] = True
        rs["fldcategory"] = txtcateg
        rs["fldcomp"] = cmbcomp.Text
        rs["fldcode"] = 0
        rs.Update()
      Endif
      ''
      res = modDatabase.$myConn.Create("tbltransfer")
      res["fldstockno"] = newstno
      res["fldoldstockno"] = stockno
      res["fldstockid"] = stockid
      res["fldcategory"] = txtcateg
      res["fldqty"] = qty
      res["fldnetcost"] = modStock.GetAverageCostPriceByStockNo(stockno)
      res["fldsellpr"] = sellpr
      res["fldsav"] = False
      res["fldfromentrytime"] = Now()
      res["fldfromuser"] = modGeneralMain.$lbluser
      res["fldfromcomp"] = modGeneralMain.compID
      res["fldfromsav"] = False
      res["fldtoentrytime"] = ""
      res["fldtouser"] = ""
      res["fldtocomp"] = cmbcomp.Text
      res["fldtosav"] = False
      res["fldreference"] = ""
      res["xyz"] = False
      res.Update()
    Endif
    modDatabase.$myConn.Commit

  Endif

Catch
  modDatabase.$myConn.Rollback
  modHelpVariable.CreateErrorReport()

End

''------------------------------ grid views ------------------------------------------------
Private Sub ShowTransferGrid()

  $rData = modDatabase.$myConn.Exec("select fldid,fldstockno,fldoldstockno,fldstockid,fldstockno,fldstockno,fldcategory,fldqty,fldnetcost,fldtocomp,fldreference from tbltransfer where fldfromcomp=&1 and fldsav=&2", modGeneralMain.compID, False)
  $aMyFields = New String[]
  modGridView.ReadSmallData(GridView1, $rData, $aMyFields)

  AdjustGrid(GridView1)
  txttranstotal.Value = Round(modGridView.SumGridAmountDoublet(GridView1, 7, 8), -2)

End

Public Sub GridView1_Data(Row As Integer, Column As Integer)

  Dim xdate As Date

  $rData.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView1, Row)
  If Column = 4 Then
    GridView1.Data.Text = modStock.GetBatchFromStockNo($rData["fldstockno"])
  Else If Column = 5 Then
    xdate = modStock.GetExpiryFromStockNo($rData["fldstockno"])
    If xdate <= Now() Then
      GridView1.Data.Foreground = modBasic.$HighLightColor
    Endif
    GridView1.Data.Text = modReportVar.GetDateTimeReport(xdate, gb.MediumDate)
  Else
    GridView1.Data.Text = $rData[$aMyFields[Column]]
  Endif

End

Private Sub ShowReceiveGrid()

  $rData1 = modDatabase.$myConn.Exec("select fldid,fldstockno,fldoldstockno,fldstockid,fldstockno,fldstockno,fldcategory,fldqty,fldnetcost,fldfromcomp,fldreference from tbltransfer where fldtocomp=&1 and fldsav=&2 and fldfromsav=&3 and fldtosav=&4", modGeneralMain.compID, True, True, False)                            ''
  $aMyFields1 = New String[]
  modGridView.ReadSmallData(GridView2, $rData1, $aMyFields1)
  AdjustGrid(GridView2)
  txttranstotal2.Value = Round(modGridView.SumGridAmountDoublet(GridView2, 7, 8), -2)

End

Private Sub AdjustGrid(GridView1x As GridView)

  With GridView1x
    .Columns[0].Width = 50 * modBasic.$AppWidthRatio
    .Columns[1].Width = 1
    .Columns[2].Width = 1
    .Columns[3].Width = 300 * modBasic.$AppWidthRatio
    .Columns[4].Width = 75 * modBasic.$AppWidthRatio
    .Columns[5].Width = 100 * modBasic.$AppWidthRatio
    .Columns[6].Width = 120 * modBasic.$AppWidthRatio
    .Columns[7].Width = 50 * modBasic.$AppWidthRatio
    .Columns[8].Width = 50 * modBasic.$AppWidthRatio
    .Columns[9].Width = 75 * modBasic.$AppWidthRatio
    .Columns[10].Width = 90 * modBasic.$AppWidthRatio

    .Columns[3].Text = "Particulars"
    .Columns[4].Text = "Batch"
    .Columns[5].Text = "Expiry"
    .Columns[6].Text = "Category"
    .Columns[7].Text = "QTY"
    .Columns[8].Text = "Cost"
    .Columns[9].Text = "Comp"
    .Columns[10].Text = "RefNo"
  End With

End

Public Sub GridView2_Data(Row As Integer, Column As Integer)

  Dim xdate As Date

  $rData1.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView2, Row)
  GridView2.Data.Text = $rData1[$aMyFields1[Column]]
  If Column = 4 Then
    GridView2.Data.Text = modStock.GetBatchFromStockNo($rData1["fldstockno"])
  Else If Column = 5 Then
    xdate = modStock.GetExpiryFromStockNo($rData1["fldstockno"])
    If xdate <= Now() Then
      GridView2.Data.Foreground = modBasic.$HighLightColor
    Endif
    GridView2.Data.Text = modReportVar.GetDateTimeReport(xdate, gb.MediumDate)
  Else
    GridView2.Data.Text = $rData1[$aMyFields1[Column]]
  Endif

End

Public Sub GridView1_Menu()

  mnuhide.Popup

End

Public Sub GridView2_Menu()

  mnuhide1.Popup

End

Public Sub mnudel_Click()

  If GridView1.Rows.Selection.Count > 0 Then
    modDatabase.$myConn.Delete("tbltransfer", "fldid=&1 and fldsav=&2", GridView1[GridView1.Row, 0].Text, False)
    ShowTransferGrid()
    Message.Info(("Information deleted"), ("OK"))
  Endif

End

Public Sub btnsavefrom_Click()

  Dim res As Result
  Dim res1 As Result

  res = modDatabase.$myConn.Exec("select fldid from tbltransfer where fldfromcomp=&1 and fldsav=&2", modGeneralMain.compID, False)
  If res.Available = True Then
    Inc Application.Busy
    modDatabase.$myConn.Begin
    For Each res
      res1 = modDatabase.$myConn.Edit("tbltransfer", "fldid=&1", res!fldid)
      res1["fldsav"] = True
      res1["fldfromsav"] = True
      res1["fldfromentrytime"] = Now()
      res1["fldfromuser"] = modGeneralMain.$lbluser
      res1["fldfromcomp"] = modGeneralMain.compID
      res1["xyz"] = False
      res1.Update()
    Next
    modDatabase.$myConn.Commit
    Dec Application.Busy
    ShowTransferGrid()
  Endif

Catch
  modDatabase.$myConn.Rollback
  Dec Application.Busy
  modHelpVariable.CreateErrorReport()

End

Public Sub btnfullsend_Click()

  modCHTMLReport.ExportGridToHTML(GridView1, "STOCK SEND TO", cmbcomp.Text)

End

