' Gambas class file

Private $rData As Result
Private $aMyFields As String[]

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me)
  cmbroute.List = modMedicine.InpatientRoute()
  cmbroute.Add("Group")
  cmbroute.Text = ""
  rbgeneric.Value = True
  SHowGridView()

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.Esc Then
    Me.Close
  Else
    modGeneralmain.GoToNextControlTab()
  Endif

End

Public Sub cmbroute_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbroute)
  modFillContainer.RestrictComboToContent(cmbroute)

End

Private Function GetBrandGenerricType() As String

  Dim brandOrGeneric As String

  If rbrand.Value = True Then
    brandOrGeneric = "Brand"
  Else
    brandOrGeneric = "Generic"
  Endif
  Return brandOrGeneric

End

Public Sub cmbroute_Click()

  cmbmedicine.Clear
  cmbmedicine.Text = ""
  txtqty.Value = 0

End

Public Sub cmbmedicine_GotFocus()

  Dim res As Result

  If Not cmbroute.Text Then
    cmbroute.SetFocus

  Else If cmbroute.Text Then
    If cmbroute.Text = "Group" Then
    Else
      If Not cmbmedicine.Text Then

        If modBasic.$ItemListFormat = "ComboBox" Then
        Else

          If cmbroute.Text = "suture" Or If cmbroute.Text = "msurg" Or If cmbroute.Text = "ortho" Or If cmbroute.Text = "extra" Then
            res = modStock.ItemListForPurchaseResult(cmbroute.Text, GetBrandGenerricType(), "")
            cmbmedicine.Enabled = False
            cmbmedicine.Text = GridViewNew("Select Particulars", modFillContainer.GetListFromResult(res), False)
            cmbmedicine.Enabled = True
          Else
            res = modStock.ItemListForPurchaseResult(cmbroute.Text, GetBrandGenerricType(), "")
            cmbmedicine.Enabled = False
            cmbmedicine.Text = GridViewNew("Select Particulars", modFillContainer.GetListFromResult(res), False)
            cmbmedicine.Enabled = True
          Endif

          If Not cmbmedicine.Text Then
            txtqty.SetFocus
          Endif

        Endif

      Endif
    Endif

  Endif

End

Public Sub cmbmedicine_KeyRelease()

  If cmbroute.Text = "suture" Or If cmbroute.Text = "msurg" Or If cmbroute.Text = "ortho" Or If cmbroute.Text = "extra" Then
    modStock.ItemListForPurchase(cmbroute.Text, cmbmedicine, "Generic")
  Else If cmbroute.Text = "Group" Then
    modStock.MedicineGroupItem(cmbmedicine)
  Else
    modStock.ItemListForPurchase(cmbroute.Text, cmbmedicine, GetBrandGenerricType())
  Endif

End

Public Sub txtqty_GotFocus()

  If cmbmedicine.Text Then
    If modStock.GetComboControl(cmbroute.Text, cmbmedicine.Text, rbgeneric, rbrand, modDatabase.$medConn) = False Then
      cmbmedicine.Text = ""
      Balloon.Warning(("Item not listed"), cmbmedicine)
      Balloon.Delay = modBasic.$BalloonDelay
      cmbroute.SetFocus
    Else

      If cmbroute.Text = "suture" Or If cmbroute.Text = "msurg" Or If cmbroute.Text = "ortho" Or If cmbroute.Text = "extra" Or If cmbroute.Text = "Group" Then
        txtqty.SetFocus

      Else
        If rbrand.Value = True Then
          cmbmedicine.Text = modMedConstant.ConvertBrandToGeneric(cmbroute.Text, cmbmedicine.Text)
        Endif
      Endif

    Endif
  Endif

End

Public Sub btnadd_Click()

  If cmbmedicine.Text And If txtqty.Value Then
    AddRequestStore()
    SHowGridView()
    cmbroute.SetFocus
  Endif

End

Public Sub btnadd_KeyRelease()

  btnadd_Click()

End

Private Sub AddRequestStore()

  Dim res As Result

  res = modDatabase.$myConn.Create("tblrequest")
  res["fldstockid"] = cmbmedicine.Text
  res["fldcategory"] = modNonMedical.GetBillItemCategoryFromCombo(cmbroute.Text)
  res["fldqty"] = txtqty.Value
  res["fldstatus"] = "Requested"
  res["fldorduserid"] = modGeneralMain.$lbluser
  res["fldordtime"] = Now()
  res["fldordcomp"] = modGeneralMain.compID
  res["flduserid"] = ""
  res["fldtime"] = ""
  res["fldcomp"] = ""
  res["fldsave"] = False
  res.Update
  cmbroute.Text = ""

End

Private Sub SHowGridView()

  Dim sql As String

  sql = "select fldid,fldordtime,fldstockid,fldcategory,fldqty,fldordcomp,fldstatus from tblrequest where fldordcomp=&1 and fldsave=&2"
  $rData = modDatabase.$myConn.Exec(sql, modGeneralMain.compID, False)
  $aMyFields = New String[]
  modGridView.ReadSmallData(GridView1, $rData, $aMyFields)

  With GridView1
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 1
    .Columns[1].Width = 125 * modBasic.$AppWidthRatio
    .Columns[2].Width = 250 * modBasic.$AppWidthRatio
    .Columns[3].Width = 1
    .Columns[4].Width = 50 * modBasic.$AppWidthRatio
    .Columns[5].Width = 75 * modBasic.$AppWidthRatio
    .Columns[6].Width = 75 * modBasic.$AppWidthRatio

    .Columns[1].Text = "DateTime"
    .Columns[2].Text = "Particulars"
    .Columns[4].Text = "QTY"
    .Columns[5].Text = "Comp"
    .Columns[6].Text = "Status"
  End With

End

Public Sub GridView1_Data(Row As Integer, Column As Integer)

  $rData.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView1, Row)
  If Column = 1 Then
    GridView1.Data.Text = modReportVar.GetDateTimeReport($rData[$aMyFields[Column]], gb.MediumDate)
  Else If Column = 4 Then
    GridView1.Data.Text = modReportVar.GetLocaleNumberFormat($rData[$aMyFields[Column]], -2)
  Else
    GridView1.Data.Text = $rData[$aMyFields[Column]]
  Endif

End

Public Sub btnreport_Click()

  modCHTMLReport.ExportGridToHTML(GridView1, "STORE REQUEST: " & modGeneralMain.compID, modReportVar.GetDateTimeReport(Now(), gb.GeneralDate))

End

Public Sub GridView1_Menu()

  mnuhide.Popup()

End

Public Sub mnudelete_Click()

  If GridView1.Rows.Selection.Count Then
    modDatabase.$myConn.Delete("tblrequest", "fldid=&1 and fldordcomp=&2", GridView1[GridView1.Row, 0].Text, modGeneralMain.compID)
    SHowGridView()
  Endif

End

Public Sub GridView1_Click()

  Dim res As Result
  Dim xval As Float
  Dim xstat As String
  Dim Row As Integer

  Row = GridView1.Row
  If GridView1.Column = 4 Then
    xval = InputValue(("Edit Quantity of the Particular"), "Store Request", GridView1[GridView1.Row, 4].Text)
    If xval Then
      res = modDatabase.$myConn.Edit("tblrequest", "fldid=&1 and fldordcomp=&2", GridView1[GridView1.Row, 0].Text, modGeneralMain.compID)
      res["fldqty"] = xval
      res.Update
      SHowGridView()
    Endif
  Else If GridView1.Column = 6 Then
    xstat = InputCombo(("Edit Status of the Particular"), "Store Request", ["Requested", "On Hold", "Rejected"], GridView1[GridView1.Row, 5].Text, True)
    If xstat Then
      res = modDatabase.$myConn.Edit("tblrequest", "fldid=&1 and fldordcomp=&2", GridView1[GridView1.Row, 0].Text, modGeneralMain.compID)
      res["fldstatus"] = xstat
      res.Update
      SHowGridView()
    Endif
  Endif
  GridView1.Row = Row

End
