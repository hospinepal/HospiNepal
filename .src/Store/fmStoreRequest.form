# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,83,63)
  Tag = "Store Request"
  Text = ("Store Request")
  Resizable = False
  { mnuhide Menu
    Visible = False
    { mnudelete Menu
      Text = ("Delete")
      Shortcut = "Ctrl+D"
    }
  }
  { cmbroute ComboBox
    MoveScaled(1,5,11,3)
    ToolTip = ("Category of Item")
  }
  { cmbmedicine ComboBox
    MoveScaled(12,5,55,3)
    ToolTip = ("Name of Medicines, surgical and extra items\nWrite few alphabets and press Down key to populate this combobox")
    Sorted = True
  }
  { txtqty ValueBox
    MoveScaled(68,5,6.2667,3)
    ToolTip = ("Quantity of item ordered")
  }
  { btnadd Button
    MoveScaled(75,5,7,3)
    Picture = Picture["icon:/small/add"]
  }
  { Panel2 Panel
    MoveScaled(1,1,21,3)
    { rbgeneric RadioButton
      MoveScaled(0,0,10,3)
      Text = ("Generic")
    }
    { rbrand RadioButton
      MoveScaled(11,0,10,3)
      Text = ("Brand")
    }
  }
  { GridView1 GridView
    MoveScaled(1,9,81,53)
    Mode = Select.Single
    Header = GridView.Both
    AutoResize = False
  }
  { btnreport Button
    MoveScaled(68,1,14,3)
    Text = ("Report")
    Picture = Picture["icon:/small/html"]
  }
}
