' Gambas class file

Private ReportPath As String 'Path to report
Private TablePath As String
Private TableFile As String[]

Public UserData As New Collection
Private $IndexData As New String[0]
Private $ChapterID As Integer

Private Template As String
Private Columns As String[]
Private $encid As String
Private $Type As String
Private $commentText As String
Private $RepoJSONCol As JSONCollection
Private $QRCodeData As String

Private $ProgressBar1 As ProgressBar
Private tim1 As Date
Private tim2 As Date

Private $TextAlignmentColumn1 As String
Private $TextAlignmentColumn2 As String
Private $VerticalAlignmentColumn1 As String
Private $VerticalAlignmentColumn2 As String
Private $ReportFontColumn1 As String
Private $ReportFontColumn2 As String
Private $ReportContentFont As String
Private $ReportTitleDisplay As String
Private $ReportTitleUpCase As String
Private $ReportTitleAlignment As String
Private $ReportTitleFont As String
Private $ReportTitleLink As String

Public Sub _new(hColumns As String[], hTemplate As String, hType As String, encid As String, Optional QRCodeData As String)

  Columns = hColumns
  Template = hTemplate
  $Type = hType
  $encid = encid
  $QRCodeData = QRCodeData
  LoadVariables()
  TableFile = New String[]

  If modBasic.$CommentColumn Then
    Columns.Add(modBasic.$CommentColumn)
  Endif

  If MMain.$IsGUIApp = True Then
    $ProgressBar1 = modHelpVariable.FindWorkProgressBar(modHelpVariable.$LogInCategory)
    If $ProgressBar1 Then
      $ProgressBar1.Visible = True
      If $ProgressBar1.Tag = "Const" Then
        $ProgressBar1.Value = 0
      Else
        $ProgressBar1.Pulse = True
      Endif
    Endif
  Endif

  $RepoJSONCol = New JSONCollection
  If modBasic.$CustomDataQR = "Yes" Then
    If Not $QRCodeData Then
      $RepoJSONCol.Add($encid, "ENCOUNTERID")
      $RepoJSONCol.Add(modPatient.GetPatientNameByEnc($encid), "NAME")
    Endif
  Endif

  $commentText = ""
  tim1 = Now()
  $ChapterID = 1

End

Private Sub LoadVariables()

  modBasic.DebugString("Loading Report Settings")

  $TextAlignmentColumn1 = modSettings.ShowSettingFromFIle("ReportFormat/ReportBody_TextAlignment_Column1")
  $TextAlignmentColumn2 = modSettings.ShowSettingFromFIle("ReportFormat/ReportBody_TextAlignment_Column2")
  $VerticalAlignmentColumn1 = modSettings.ShowSettingFromFIle("ReportFormat/ReportBody_VerticalAlignment_Column1")
  $VerticalAlignmentColumn2 = modSettings.ShowSettingFromFIle("ReportFormat/ReportBody_VerticalAlignment_Column2")
  $ReportFontColumn1 = modSettings.ShowSettingFromFIle("ReportFormat/ReportBody_Font_Column1")
  $ReportFontColumn2 = modSettings.ShowSettingFromFIle("ReportFormat/ReportBody_Font_Column2")
  $ReportContentFont = modSettings.ShowSettingFromFIle("ReportFormat/ReportBody_ContentFont")

  $ReportTitleDisplay = modSettings.ShowSettingFromFIle("ReportFormat/ReportBody_TitleDisplay")
  $ReportTitleUpCase = modSettings.ShowSettingFromFIle("ReportFormat/ReportBody_TitleUpCase")
  $ReportTitleAlignment = modSettings.ShowSettingFromFIle("ReportFormat/ReportBody_TitleAlignment")
  $ReportTitleFont = modSettings.ShowSettingFromFIle("ReportFormat/ReportBody_TitleFont")
  $ReportTitleLink = modSettings.ShowSettingFromFIle("ReportFormat/ChapterIndex")

End

Public Sub Add(colum_content As String[])

  Dim counter As Integer
  Dim sDesign1 As String
  Dim sDesign2 As String
  Dim xline As String

  Dim col_content As String[]

  col_content = colum_content

  If modBasic.$CommentColumn Then
    col_content.Add("")
  Endif

  sDesign1 = modString.GetDesignFormatString(, $TextAlignmentColumn1, $VerticalAlignmentColumn1)
  sDesign2 = modString.GetDesignFormatString(, $TextAlignmentColumn2, $VerticalAlignmentColumn2)

  If Not (col_content.Count = Columns.Count) Then
    Error.Raise("col_content must be equivalent to Columns")
  Endif

  TableFile.Add("  <tr>")
  For counter = 0 To Columns.Count - 1
    If modString.GetRichTextMode(col_content[counter]) = True Then
      TableFile.Add("    <td>" & col_content[counter] & "</td>")
    Else

      If counter = 0 Then
        If $ReportFontColumn1 Then
          xline = "    <td " & sDesign1 & ">" & modString.GetFormatTextFontString(col_content[counter], $ReportFontColumn1) & "</td>"
        Else
          If $ReportContentFont Then
            xline = "    <td " & sDesign1 & ">" & modString.GetFormatTextFontString(col_content[counter], $ReportContentFont) & "</td>"
          Else
            xline = "    <td " & sDesign1 & ">" & modString.TextToHTML(col_content[counter]) & "</td>"
          Endif
        Endif
      Else If counter = 1 Then
        If $ReportFontColumn2 Then
          xline = "    <td " & sDesign2 & ">" & modString.GetFormatTextFontString(col_content[counter], $ReportFontColumn2) & "</td>"
        Else
          If $ReportContentFont Then
            xline = "    <td " & sDesign2 & ">" & modString.GetFormatTextFontString(col_content[counter], $ReportContentFont) & "</td>"
          Else
            xline = "    <td " & sDesign2 & ">" & modString.TextToHTML(col_content[counter]) & "</td>"
          Endif
        Endif
      Else
        If $ReportContentFont Then
          xline = "    <td>" & modString.GetFormatTextFontString(col_content[counter], $ReportContentFont) & "</td>"
        Else
          xline = "    <td>" & modString.TextToHTML(col_content[counter]) & "</td>"
        Endif
      Endif
      TableFile.Add(xline)

    Endif
  Next

  If modBasic.$CustomDataQR = "Yes" Then
    If Not $QRCodeData Then
      If colum_content.Count > 1 Then
        Try $RepoJSONCol.Add(modString.ConvertRichTextToPlain(colum_content[1]), colum_content[0])
      Endif
    Endif
  Endif

  TableFile.Add("  </tr>")

  Wait

End

Public Sub AddSection(col_content As String, Optional sLink As Boolean)

  Dim chpid As Integer

  If $ReportTitleDisplay And If $ReportTitleDisplay = "No" Then
  Else
    If $ReportTitleAlignment Then
      TableFile.Add("<tr align='" & $ReportTitleAlignment & "'>")
    Else
      TableFile.Add("<tr align='center'>")
    Endif

    If sLink = True And If $ReportTitleLink = "Yes" Then
      chpid = $ChapterID
      $ChapterID = $ChapterID + 1
      $IndexData.Add("<A HREF=" & Quote("#chapter" & CStr(chpid)) & ">" & col_content & "</A>")
      If $ReportTitleFont Then
        TableFile.Add("<td colspan='" & Columns.Count & "' rowspan='1'>" & "<A NAME=" & Quote("chapter" & CStr(chpid)) & ">" & modString.GetFormatTextFontString(col_content, $ReportTitleFont) & "</A>" & "</td>")                                                 ''
      Else
        If $ReportTitleUpCase = "Yes" Then
          TableFile.Add("<td colspan='" & Columns.Count & "' rowspan='1'>" & "<A NAME=" & Quote("chapter" & CStr(chpid)) & ">" & "<span style='text-transform: uppercase;font-weight: bold;'>" & col_content & "</span>" & "</A>" & "</td>")
        Else
          TableFile.Add("<td colspan='" & Columns.Count & "' rowspan='1'>" & "<A NAME=" & Quote("chapter" & CStr(chpid)) & ">" & "<span style='font-weight: bold;'>" & col_content & "</span>" & "</A>" & "</td>")
        Endif
      Endif

    Else
      If $ReportTitleFont Then
        TableFile.Add("<td colspan='" & Columns.Count & "' rowspan='1'>" & modString.GetFormatTextFontString(col_content, $ReportTitleFont) & "</td>")                                                 ''
      Else
        If $ReportTitleUpCase = "Yes" Then
          TableFile.Add("<td colspan='" & Columns.Count & "' rowspan='1'><span style='text-transform: uppercase;font-weight: bold;'>" & col_content & "</span></td>")
        Else
          TableFile.Add("<td colspan='" & Columns.Count & "' rowspan='1'><span style='font-weight: bold;'>" & col_content & "</span></td>")
        Endif
      Endif

    Endif
    TableFile.Add("</tr>")
  Endif

End

Public Sub AddChapter(col_content As String)

  TableFile.Add("<tr align='left'>")
  TableFile.Add("<td colspan='" & Columns.Count & "' rowspan='1'><span style='font-weight: bold;'>" & col_content & "</span></td>")
  TableFile.Add("</tr>")

End

Public Sub AddSummary(col_content As String)

  TableFile.Add("<tr align='left'>")
  TableFile.Add("<td colspan='" & Columns.Count & "' rowspan='1'>" & col_content & "</span></td>")
  TableFile.Add("</tr>")

End

Public Sub AddCommentText(txtcomment As String)

  $commentText = $commentText & txtcomment

End

Private Sub MakeHTMLFile()

  Dim hCls As CReportFormat

  TablePath = Temp()
  File.Save(TablePath, TableFile.Join(gb.NewLine))

  If modBasic.$CustomDataQR = "Yes" Then
    If $QRCodeData Then
      hCls = New CReportFormat($encid, Columns, TablePath, Template, $Type, $commentText, UserData, $IndexData, $QRCodeData)
    Else
      hCls = New CReportFormat($encid, Columns, TablePath, Template, $Type, $commentText, UserData, $IndexData, JSON.Encode($RepoJSONCol))
    Endif
  Else
    hCls = New CReportFormat($encid, Columns, TablePath, Template, $Type, $commentText, UserData, $IndexData)
  Endif
  ReportPath = hCls.GetHTMLFile()
  TableFile.Clear()

  If MMain.$IsGUIApp = True Then
    If $ProgressBar1 Then
      $ProgressBar1.Tag = ""
      $ProgressBar1.Pulse = False
      $ProgressBar1.Visible = False
    Endif
  Endif
  tim2 = Now()

End

Public Function NewHTMLPath() As String

  If modGeneralMain.$ApplKey < 2 Then
    MakeHTMLFile()
    Return ReportPath

  Else
    If MMain.$IsGUIApp = True Then
      If $ProgressBar1 Then
        $ProgressBar1.Tag = ""
        $ProgressBar1.Pulse = False
        $ProgressBar1.Visible = False
      Endif
    Endif
    Message.Warning(("HTML Report disabled. Please insert validation key"), ("OK"))
  Endif

End
