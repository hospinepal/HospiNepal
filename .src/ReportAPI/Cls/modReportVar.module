Private Function GetBirthValue(sField As String, encid As String) As Variant

  Dim res As Result
  Dim sql As String
  Dim xx As Variant

  sql = Subst("select &1 from tblconfinement", sField)
  res = modDatabase.$myConn.Exec(sql & " where fldbabypatno in(select fldpatientval from tblencounter where fldencounterval=&1)", encid)
  If res.Available Then
    res.MoveLast
    xx = res[sField]
  Else
    xx = ""
  Endif
  Return xx

End

