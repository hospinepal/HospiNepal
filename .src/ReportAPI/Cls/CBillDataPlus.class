' Gambas class file

Private sRefer As String[]
Private sPayable As String[]
Private sRetBill As String[]
Private sReason As String[]
Private sBillMode As String[]

Public Sub _new(sBillNo As String)

  Dim res As Result

  res = modDatabase.$myConn.Exec("select fldrefer,fldpayto,fldretbill,fldreason,flditemname,flditemtype from tblpatbilling where fldbillno=&1", sBillNo)
  sRefer = New String[]
  sPayable = New String[]
  sRetBill = New String[]
  sReason = New String[]
  sBillMode = New String[]
  If res.Available Then
    For Each res
      sRefer.Add(modGeneral.GetUserFullNamePrint(res!fldrefer))
      sPayable.Add(modGeneral.GetUserFullNamePrint(res!fldpayto))
      sRetBill.Add(res!fldretbill)
      sReason.Add(res!fldreason)
      sBillMode.Add(modNonMedical.GetBillingModeFromItemName(res!flditemname))
    Next
  Endif

End

Public Function ReferName() As String

  Dim xx As String[]
  Dim sval As String

  xx = modString.GetDistinctStringArray(sRefer)
  If xx.Count = 1 Then
    sval = xx[0]
  Else
    sval = ""
  Endif
  Return sval

End

Public Function PayableName() As String

  Dim xx As String[]
  Dim sval As String

  xx = modString.GetDistinctStringArray(sPayable)
  If xx.Count = 1 Then
    sval = xx[0]
  Else
    sval = ""
  Endif
  Return sval

End

Public Function BillingMode() As String

  Dim xx As String[]
  Dim sval As String

  xx = modString.GetDistinctStringArray(sBillMode)
  If xx.Count = 1 Then
    sval = xx[0]
  Else
    sval = ""
  Endif
  Return sval

End

Public Function ReturnBillNo() As String

  Dim xx As String[]
  Dim sval As String

  xx = modString.GetDistinctStringArray(sRetBill)
  If xx.Count = 1 Then
    sval = xx[0]
  Else
    sval = ""
  Endif
  Return sval

End

Public Function ReturnReason() As String

  Dim xx As String[]
  Dim sval As String

  xx = modString.GetDistinctStringArray(sReason)
  If xx.Count = 1 Then
    sval = xx[0]
  Else
    sval = ""
  Endif
  Return sval

End
