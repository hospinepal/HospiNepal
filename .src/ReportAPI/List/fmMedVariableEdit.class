' Gambas class file

Private $txt As TextArea
Private $iPos As Integer
Private $sLevel As Integer

Public Sub _new(iPos As Integer, txt As TextArea, sLevel As Integer)

  $iPos = iPos
  $txt = txt
  $sLevel = sLevel

End

