' Gambas class file

Private $txtbuttFile As String
Private $sValue As String[]

Public Sub Run(txtbuttFile As String) As String[]

  $txtbuttFile = txtbuttFile
  If Me.ShowModal() Then Return $sValue

End

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me, "False")
  AddListBiewContent()
  ShowCheckedView()

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.Esc Then
    Me.Close()
  Endif

End

Public Sub chkselect_Click()

  AddListBiewContent()

End

Private Sub AddListBiewContent()

  Dim pic1 As Picture

  lstcontent.Clear()
  pic1 = modBasic.$PictureUnchecked
  With lstcontent
    .Add("1", "Course of Treatment", pic1)
    .Add("2", "Bed Transitions", pic1)
    .Add("3", "Demographics", pic1)
    .Add("4", "Triage Examinations", pic1)
    .Add("5", "Cause of Admission", pic1)
    .Add("6", "Presenting Complaints", pic1)
    .Add("7", "OPD Examinations", pic1)
    .Add("8", "General Complaints", pic1)
    .Add("9", "History of Illness", pic1)
    .Add("10", "Past History", pic1)
    .Add("11", "Treatment History", pic1)
    .Add("12", "Medication History", pic1)
    .Add("13", "Family History", pic1)
    .Add("14", "Personal History", pic1)
    .Add("15", "Surgical History", pic1)
    .Add("16", "Occupational History", pic1)
    .Add("17", "Social History", pic1)

    .Add("18", "Provisional Diagnosis", pic1)
    .Add("19", "Final Diagnosis", pic1)
    .Add("20", "Drug Allergy", pic1)
    .Add("21", "Investigation Advised", pic1)
    .Add("22", "Treatment Advised", pic1)
    .Add("23", "Initial Planning", pic1)
    .Add("24", "Prominent Symptoms", pic1)
    .Add("25", "Major Procedures", pic1)
    .Add("26", "Minor Procedures", pic1)
    .Add("27", "Consultations", pic1)
    .Add("28", "Equipments Used", pic1)
    .Add("29", "Medication Used", pic1)
    .Add("30", "Delivery Profile", pic1)
    .Add("31", "Extra Procedures", pic1)

    If chkselect.Value = True Then
      .Add("32", "Structured Examinations", pic1)
      .Add("33", "Selected Investigations", pic1)

      .Add("34", "Clinical Notes", pic1)
      .Add("35", "IP Monitoring", pic1)
      .Add("36", "Therapeutic Planning", pic1)
      .Add("37", "Planned Procedures", pic1)
      .Add("38", "Discharge Examinations", pic1)
      .Add("39", "Condition at Discharge", pic1)
      .Add("40", "Discharge Medication", pic1)
      .Add("41", "Advice on Discharge", pic1)
    Else
      .Add("32", "Essential Examinations", pic1)
      .Add("33", "Clinical Findings", pic1)
      .Add("34", "Structured Examinations", pic1)
      .Add("35", "Laboratory Tests", pic1)
      .Add("36", "Radiological Findings", pic1)

      .Add("37", "Clinical Notes", pic1)
      .Add("38", "IP Monitoring", pic1)
      .Add("39", "Therapeutic Planning", pic1)
      .Add("40", "Planned Procedures", pic1)
      .Add("41", "Condition at Discharge", pic1)
      .Add("42", "Discharge Examinations", pic1)
      .Add("43", "Discharge Medication", pic1)
      .Add("44", "Advice on Discharge", pic1)
    Endif
  End With

End

Public Sub lstcontent_Click()

  modFillContainer.ShowCheckedListView(lstcontent)

End

Private Sub ShowCheckedView()

  Dim i As Integer

  If $txtbuttFile Then
    For i = 1 To lstcontent.Count
      If modSettings.ShowSettingFromFIle($txtbuttFile & "/content_" & CStr(i)) Then
        lstcontent[CStr(i)].Picture = modBasic.$PictureChecked
      Endif
    Next
  Endif

End

Public Sub btnsave_Click()

  Dim i As Integer
  Dim xx As String[]

  xx = New String[]
  For i = 1 To lstcontent.Count
    If lstcontent[CStr(i)].Picture = modBasic.$PictureChecked Then
      If $txtbuttFile Then
        modSettings.SaveSettingsToFile($txtbuttFile & "/content_" & CStr(i), lstcontent[CStr(i)].Text)
      Endif
      xx.Add(lstcontent[CStr(i)].Text)

    Else If lstcontent[CStr(i)].Picture = modBasic.$PictureUnchecked Then
      If $txtbuttFile Then
        modSettings.SaveSettingsToFile($txtbuttFile & "/content_" & CStr(i), "")
      Endif
    Endif
  Next
  $sValue = xx
  Me.Close(True)

End

Public Sub chkall_Click()

  Dim xpict As Picture
  Dim i As Integer

  If chkall.Value = True Then
    xpict = modBasic.$PictureChecked
  Else If chkall.Value = False Then
    xpict = modBasic.$PictureUnchecked
  Endif

  For i = 1 To lstcontent.Count
    lstcontent[CStr(i)].Picture = xpict
  Next

End
