' Gambas class file

Private $sLink As String

Public Sub _new(sLink As String)

  $sLink = sLink

End

Public Sub Form_Open()

  Panel1.Top = 0
  Panel1.Width = 960 * modBasic.$AppScaleFactor
  Panel1.Left = 0.5 * (modGeneralMain.$DeskWidth - Panel1.Width)
  Panel1.Height = modGeneralMain.$DeskHeight - 60 * modBasic.$AppScaleFactor
  WebView1.Url = $sLink

End

Public Sub Form_Resize()

  WebView1.Top = 25
  WebView1.Left = 10
  WebView1.Width = Panel1.Width - 20
  WebView1.Height = Panel1.Height - 50

End

Public Sub WebView1_Load()

  WebView1.Enabled = True

End
