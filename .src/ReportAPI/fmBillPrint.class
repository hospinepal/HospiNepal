' Gambas class file

Private $path As String
Private $size As String

Public Sub _new(encid As String, strPath As String, strSize As String)

  $path = strPath
  $size = strSize
  Me.Text = encid

End

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me, "False")
  ShowCheckBox()

End

Public Sub tbprint_Click()

  modPrint.PrintDocumentSetting($path, $size)
  Me.Close

End

Public Sub tlview_Click()

  modPrint.HTMLViewInvoiceDOcument($path)
  Me.Close

End

Public Sub btnexport_Click()

  modPrint.OfficeExportDocument($path, $size)
  Me.Close

End

Public Sub tbprint_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    tbprint_Click()
  Endif

End

Public Sub tlview_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    tlview_Click()
  Endif

End

Public Sub btnexport_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    btnexport_Click()
  Endif

End

Private Sub ShowCheckBox()

  If modBasic.$ReportLogPrint = "Yes" Then
    chkprint.Value = True
  Endif
  If modBasic.$ReportLogHTML = "Yes" Then
    chkview.Value = True
  Endif
  If modBasic.$ReportLogExport = "Yes" Then
    chkexport.Value = True
  Endif

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.Esc Then
    Me.Close
  Endif

End
