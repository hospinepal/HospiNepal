# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,31,13)
  Text = ("Report Options")
  Resizable = False
  { Panel1 HBox
    MoveScaled(0,0,31,10)
    { tbprint ToolButton
      MoveScaled(0,0,10,9)
      Picture = Picture["icon:/huge/print"]
    }
    { tlview ToolButton
      MoveScaled(10,0,10,9)
      Picture = Picture["icon:/huge/html"]
    }
    { btnexport ToolButton
      MoveScaled(20,0,10,9)
      Picture = Picture["icon:/huge/grid"]
    }
  }
  { HBox1 HBox
    MoveScaled(0,10,31,3)
    { chkprint CheckBox
      MoveScaled(2,0,8,3)
      Enabled = False
      Text = ("Log")
    }
    { chkview CheckBox
      MoveScaled(12,0,8,3)
      Enabled = False
      Text = ("Log")
    }
    { chkexport CheckBox
      MoveScaled(22,0,8,3)
      Enabled = False
      Text = ("Log")
    }
  }
}
