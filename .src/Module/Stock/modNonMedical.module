Public Function GetSumCarryOnDeposit(bilid As Long) As Float

  Dim res As Result
  Dim res1 As Result
  Dim encdepo As Float

  encdepo = 0
  res = modDatabase.$myConn.Exec("select distinct(fldencounterval) from tblpatbilldetail where fldid<&1 and fldbilltype=&2", bilid, "Credit")
  If res.Available Then
    For Each res
      res1 = modDatabase.$myConn.Exec("select fldcurdeposit from tblpatbilldetail where fldencounterval=&1 and fldbilltype=&2 and fldid<&3", res!fldencounterval, "Credit", bilid)
      res1.MoveLast
      encdepo = encdepo + res1!fldcurdeposit
    Next
  Endif

  Return encdepo

End

Public Function GetSumCarryOnDepositByTime(sLast As Date) As Float

  Dim res As Result
  Dim res1 As Result
  Dim encdepo As Float

  encdepo = 0
  res = modDatabase.$myConn.Exec("select distinct(fldencounterval) from tblpatbilldetail where fldtime<&1 and fldbilltype=&2", sLast, "Credit")
  If res.Available Then
    For Each res
      res1 = modDatabase.$myConn.Exec("select fldcurdeposit from tblpatbilldetail where fldencounterval=&1 and fldbilltype=&2 and fldtime<&3", res!fldencounterval, "Credit", sLast)
      res1.MoveLast
      encdepo = encdepo + res1!fldcurdeposit
    Next
  Endif

  Return encdepo

End

