'NOTE: ----------------------------------- Variable List for Transection----------------------------
Public Sub CompleteServiceTree(TreeView1 As TreeView, sType As String, stint As Integer, Optional txtsearch As String)

  Dim sstr1 As String
  Dim sstr2 As String
  Dim pic2 As Picture
  Dim pic3 As Picture
  Dim res1 As Result
  Dim res2 As Result

  pic2 = Picture["icons/coll2.png"]
  pic3 = Picture["icons/coll3.png"]
  TreeView1.Clear()
  If txtsearch Then
    sstr1 = "select fldbillitem as fldparent from tblbillitem where flditemcateg=&1 and lower(fldbillitem) like &2 ORDER BY fldbillitem ASC"
    res1 = modDatabase.$myConn.Exec(sstr1, sType, Lower(txtsearch) & "%")
  Else
    sstr1 = "select fldbillitem as fldparent from tblbillitem where flditemcateg=&1 ORDER BY fldbillitem ASC LIMIT 100 OFFSET &2"
    res1 = modDatabase.$myConn.Exec(sstr1, sType, stint)
  Endif
  If res1.Available Then
    For Each res1
      TreeView1.Add(res1!fldparent, res1!fldparent, pic2)

      sstr2 = "select flditemname as fldparent from tblservicecost where flditemtype=&1 and fldbillitem=&2"
      res2 = modDatabase.$myConn.Exec(sstr2, sType, res1!fldparent)
      If res2.Available Then
        For Each res2
          TreeView1.Add(res2!fldparent, res2!fldparent, pic3, res1!fldparent)
        Next
      Endif

    Next
  Endif

End

Public Function GetControlServCombo(txtitem As String) As Boolean

  Dim xx As Boolean
  Dim res As Result

  res = modDatabase.$myConn.Exec("select flditemname from tblservicecost where flditemname=&1", txtitem)
  xx = res.Available
  Return xx

End

Public Sub NonStockGroupItem(ComboBox1 As ComboBox)

  Dim sql As String
  Dim res As Result
  Dim textToCursor As String
  Dim textPosition As Integer

  textPosition = ComboBox1.Pos
  textToCursor = Mid(ComboBox1.Text, 1, textPosition)

  If Key.Code = Key.BackSpace Then
    ComboBox1.Clear
  Else
    If Key.Code = Key.Down Then
      ComboBox1.Clear
      If Not ComboBox1.Count Then
        sql = "select distinct(fldgroup) as col from tblservicegroup where lower(fldgroup) like &1 ORDER BY fldgroup ASC"
        res = modDatabase.$myConn.Exec(sql, LCase(textToCursor) & "%")
        modFillContainer.FillComboBox(ComboBox1, res)
      Endif
      ComboBox1.Popup
    Endif
  Endif

End

