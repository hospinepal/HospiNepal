''----------------------------------- Discount Settings -------------------------------
''discount by setting(patient or service mode)  '''Use General Services etc
Public Function DiscPercentForItem(encid As String, sType As String, sItem As String) As Float

  Dim disc As Float

  If modBasic.$BillDiscMethod = "Department" Then
    disc = DiscPercentServiceMode(sType, encid)
  Else If modBasic.$BillDiscMethod = "Encounter" Then
    disc = DiscPercentPatientMode(sType, encid, sItem)
  Else
    disc = modBasic.$BillDiscFixedValue
  Endif

  Return disc

End

'discount by service mode
Private Function DiscPercentServiceMode(BillCateg As String, encid As String) As Float

  Dim res As Result
  Dim taxval As Float

  res = modDatabase.$myConn.Exec("select flddiscpercent from tblextrasetting where fldcomp=&1 and fldcateg=&2 and fldcashmode=&3", modGeneralMain.compID, BillCateg, ShowDiscountCategEnc(encid))
  If res.Available = True Then
    res.MoveFirst
    If res!flddiscpercent Then
      taxval = res!flddiscpercent
    Else
      taxval = 0
    Endif
  Else
    taxval = 0
  Endif
  Return taxval

End

''discount by patient mode
Private Function DiscPercentPatientMode(sType As String, encid As String, sItem As String) As Float

  Dim xPack As String
  Dim xx As Float

  xPack = ShowDiscountCategEnc(encid)
  xx = DiscPercentForCategoryValue(xPack, sType, sItem)
  Return xx

End

Public Function DiscPercentForCategoryValue(DiscPackage As String, sType As String, sItem As String) As Float

  Dim xx As Float
  Dim res As Result
  Dim res1 As Result
  Dim rsx As Result

  rsx = modDatabase.$myConn.Exec("select flditemname from tblnodiscount where flditemname=&1", sItem)
  If rsx.Available Then  ''if item included in nodiscount table
    xx = 0
  Else

    res = modDatabase.$myConn.Exec("select fldmode,fldpercent,fldlab,fldradio,fldproc,fldequip,fldservice,fldother,fldmedicine,fldsurgical,fldextra from tbldiscount where fldtype=&1", DiscPackage)
    If res.Available Then
      If res!fldmode = "Fixed Percent" Then
        If res!fldpercent Then
          xx = res!fldpercent
        Endif
      Else If res!fldmode = "Custom Values" Then
        res1 = modDatabase.$myConn.Exec("select fldpercent from tblcustdiscount where fldtype=&1 and flditemname=&2 and flditemtype=&3", DiscPackage, sItem, sType)
        If res1.Available Then
          If res1!fldpercent Then
            xx = res1!fldpercent
          Endif
        Else
          If sType = "Medicines" Then
            If res!fldmedicine Then
              xx = res!fldmedicine
            Endif
          Else If sType = "Surgicals" Then
            If res!fldsurgical Then
              xx = res!fldsurgical
            Endif
          Else If sType = "Extra Items" Then
            If res!fldextra Then
              xx = res!fldextra
            Endif
          Else If sType = "Diagnostic Tests" Then
            If res!fldlab Then
              xx = res!fldlab
            Endif
          Else If sType = "Radio Diagnostics" Then
            If res!fldradio Then
              xx = res!fldradio
            Endif
          Else If sType = "General Services" Then
            If res!fldservice Then
              xx = res!fldservice
            Endif
          Else If sType = "Procedures" Then
            If res!fldproc Then
              xx = res!fldproc
            Endif
          Else If sType = "Equipment" Then
            If res!fldequip Then
              xx = res!fldequip
            Endif
          Else If sType = "Other Items" Then
            If res!fldother Then
              xx = res!fldother
            Endif
          Endif
        Endif
      Endif
    Endif

  Endif

  Return xx

End

''---------------- yearly fixed amount as discount ----------------------
Private Function GetDiscountStartDate(DiscType As String) As Date

  Dim res As Result
  Dim xval As Date

  res = modDatabase.$myConn.Exec("select fldyear from tbldiscount where fldtype=&1", DiscType)
  If res.Available Then
    If res!fldyear Then
      xval = res!fldyear
    Else
      xval = ""
    Endif
  Else
    xval = ""
  Endif
  Return xval

End

Private Function GetTotalDiscountYearly(DiscType As String) As Float

  Dim res1 As Result
  Dim xval As Float

  res1 = modDatabase.$myConn.Exec("select fldyear,fldamount from tbldiscount where fldtype=&1 and fldyear<=&2", DiscType, Date())
  If res1.Available Then
    If res1!fldamount Then
      xval = res1!fldamount
    Else
      xval = 0
    Endif
  Else
    xval = 0
  Endif
  Return xval

End

Public Function GetDiscUsedCurYear(patno As String, DiscType As String) As Float

  Dim res As Result
  Dim xdate As Date
  Dim xfrom As Date
  Dim xval As Float

  xdate = GetDiscountStartDate(DiscType)
  If xdate Then
    xfrom = Date(Year(Date()), Month(xdate), Day(xdate))
    res = modDatabase.$myConn.Exec("select SUM(flddiscamt) as tot from tblpatbilling where fldtime>=&1 and fldtime>=&2 and fldsave=&3 and fldencounterval in(select fldencounterval from tblencounter where fldpatientval=&4)", modDate.StartSqlDate(xdate), modDate.StartSqlDate(xfrom), True, patno)
    If res.Available Then
      If res!tot Then
        xval = res!tot
      Else
        xval = 0
      Endif
    Else
      xval = 0
    Endif
  Endif
  Return xval

End

Public Function AllowedDiscountCurrYear(patno As String, DiscType As String) As Float

  Dim xval As Float
  Dim xused As Float
  Dim xrem As Float

  xval = GetTotalDiscountYearly(DiscType)
  If xval Then
    xused = GetDiscUsedCurYear(patno, DiscType)
    xrem = xval - xused
  Endif

  Return xrem

End

Public Function AllowFixDiscount(patno As String, DiscType As String, sAmt As Float) As Boolean

  Dim xx As Boolean
  Dim xval As Float

  If GetTotalDiscountYearly(DiscType) Then
    If GetDiscountStartDate(DiscType) Then
      xval = AllowedDiscountCurrYear(patno, DiscType)
      If xval > sAmt Then
        xx = True
      Else
        xx = False
      Endif
    Else
      xx = True
    Endif
  Else
    xx = True
  Endif
  Return xx

End

Public Function GetCurrConvertAmount(sAmt As Float, sUnit As String) As Float

  Dim res As Result
  Dim xrate As Float
  Dim xamt As Float

  If sUnit Then
    res = modDatabase.$myConn.Exec("select fldconversion from tblcurrency where flditemunit=&1", sUnit)
    If res.Available Then
      If res["fldconversion"] Then
        xrate = res["fldconversion"]
      Else
        xrate = 0
      Endif
    Else
      xrate = 0
    Endif

  Else
    xrate = 1
  Endif
  xamt = Round(xrate * sAmt, -2)
  Return xamt

End
