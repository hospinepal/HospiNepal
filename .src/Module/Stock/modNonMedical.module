Public Sub CurrentPayStatusMsg(encid As String)

  Dim xx As String

  xx = "<b> CURRENT DEPOSIT: </b>" & modReportVar.GetLocaleNumberFormat(GetPatientDeposit(encid), gb.Currency)
  xx = xx & "<br>" & "<b> TOTAL EXPENSES: </b>" & modReportVar.GetLocaleNumberFormat(TotalExpenseAmountbyPatient(modDatabase.$myConn, encid), gb.Currency)
  xx = xx & "<br>" & "<b> TOTAL PAYMENTS: </b>" & modReportVar.GetLocaleNumberFormat(TotalPaidAmountbyPatient(modDatabase.$myConn, encid), gb.Currency)
  xx = xx & "<br>" & "<b> CREDIT ALLOWED: </b>" & modReportVar.GetLocaleNumberFormat(ShowCreditVAlEnc(encid), gb.Currency)
  xx = xx & "<br>" & "<b> UNUSED CHARITY: </b>" & modReportVar.GetLocaleNumberFormat(GetPatCurrentCharity(encid), gb.Currency)
  Message.Info(xx, ("OK"))

End

''NOTE: --------------------------------- CONNECTION DEPENDENT PROCEDURES ----------------------------------------------
''---------------------------------------- Patient Expenses --------------------------------------------------------
Public Function TotalExpenseAmountbyPatient($conn As Connection, encid As String) As Float

  Dim amt As Float
  Dim res As Result

  res = $conn.Exec("select SUM(fldditemamt) as tot from tblpatbilling where fldencounterval=&1 and fldsave=&2", encid, True)
  If res.Available Then
    If res!tot Then
      amt = res!tot
    Else
      amt = 0
    Endif
  Else
    amt = 0
  Endif

  Return amt

End

Public Function TotalPaidAmountbyPatient($conn As Connection, encid As String) As Float

  Dim amt As Float
  Dim res As Result

  res = $conn.Exec("select SUM(fldreceivedamt) as tot from tblpatbilldetail where fldencounterval=&1", encid)
  If res.Available Then
    If res!tot Then
      amt = res!tot
    Else
      amt = 0
    Endif
  Else
    amt = 0
  Endif

  Return amt

End

Public Function TotalUnpaidAmountyPatient($conn As Connection, encid As String) As Float

  Dim amt As Float
  Dim res As Result

  res = $conn.Exec("select SUM(flditemrate*flditemqty) as tot from tblpatbilling where fldencounterval=&1 and fldsave=&2 and fldprint=&3", encid, True, False)
  If res.Available Then
    If res!tot Then
      amt = res!tot
    Else
      amt = 0
    Endif
  Else
    amt = 0
  Endif

  Return amt

End

''---------------------------------------- User share calculation ------------------------------------
Public Function GetUserPayPercent($conn As Connection, userid As String, itemname As String, sCategory As String) As Float

  Dim res As Result
  Dim xx As Float

  res = $conn.Exec("select flditemshare from tbluserpay where flduserid=&1 and flditemname=&2 and flditemtype=&3", userid, itemname, sCategory)
  If res.Available Then
    res.MoveFirst
    If res!flditemshare Then
      xx = res!flditemshare
    Else
      xx = 0
    Endif
  Else
    xx = 0
  Endif
  Return xx

End

Public Function GetUserPayTaxReduction($conn As Connection, userid As String, itemname As String, sCategory As String) As Float

  Dim res As Result
  Dim xx As Float

  res = $conn.Exec("select flditemtax from tbluserpay where flduserid=&1 and flditemname=&2 and flditemtype=&3", userid, itemname, sCategory)
  If res.Available Then
    res.MoveFirst
    If res!flditemtax Then
      xx = res!flditemtax
    Else
      xx = 0
    Endif
  Else
    xx = 0
  Endif
  Return xx

End

Public Function GetUserShareAmt($conn As Connection, id As Long, sType As String) As Float

  Dim ushare As Float
  Dim res1 As Result

  res1 = modDatabase.$syConn.Exec("select flditemname,(flditemrate*flditemqty*(1-flddiscper/100)) as totl,fldpayto,fldrefer from tblpatbilling where fldid=&1", id)

  If sType = "Payable" Then
    If res1!fldpayto Then
      ushare = res1!totl * GetUserPayPercent($conn, res1!fldpayto, res1!flditemname, sType) / 100
    Else
      ushare = 0
    Endif
  Else If sType = "Referral" Then
    If res1!fldrefer Then
      ushare = res1!totl * GetUserPayPercent($conn, res1!fldrefer, res1!flditemname, sType) / 100
    Else
      ushare = 0
    Endif
  Endif

  Return ushare

End

Public Function GetUserTaxReduction($conn As Connection, id As Long, sType As String) As Float

  Dim ushare As Float
  Dim utax As Float
  Dim res1 As Result

  res1 = modDatabase.$syConn.Exec("select flditemname,(flditemrate*flditemqty*(1-flddiscper/100)) as totl,fldpayto,fldrefer from tblpatbilling where fldid=&1", id)

  If sType = "Payable" Then
    If res1!fldpayto Then
      ushare = res1!totl * GetUserPayPercent($conn, res1!fldpayto, res1!flditemname, sType) / 100
      utax = ushare * GetUserPayTaxReduction($conn, res1!fldpayto, res1!flditemname, sType) / 100
    Else
      utax = 0
    Endif
  Else If sType = "Referral" Then
    If res1!fldrefer Then
      ushare = res1!totl * GetUserPayPercent($conn, res1!fldrefer, res1!flditemname, sType) / 100
      utax = ushare * GetUserPayTaxReduction($conn, res1!fldrefer, res1!flditemname, sType) / 100
    Else
      utax = 0
    Endif
  Endif

  Return utax

End

Public Function GetUserPayOrReferAmt($conn As Connection, id As Long, sType As String) As Float

  Dim ushare As Float
  Dim utax As Float
  Dim netot As Float
  Dim res1 As Result

  res1 = modDatabase.$syConn.Exec("select flditemname,(flditemrate*flditemqty*(1-flddiscper/100)) as totl,fldpayto,fldrefer from tblpatbilling where fldid=&1", id)

  If sType = "Payable" Then
    If res1!fldpayto Then
      ushare = res1!totl * GetUserPayPercent($conn, res1!fldpayto, res1!flditemname, sType) / 100
      utax = ushare * GetUserPayTaxReduction($conn, res1!fldpayto, res1!flditemname, sType) / 100
    Else
      ushare = 0
      utax = 0
    Endif
  Else If sType = "Referral" Then
    If res1!fldrefer Then
      ushare = res1!totl * GetUserPayPercent($conn, res1!fldrefer, res1!flditemname, sType) / 100
      utax = ushare * GetUserPayTaxReduction($conn, res1!fldrefer, res1!flditemname, sType) / 100
    Else
      ushare = 0
      utax = 0
    Endif
  Endif
  netot = ushare - utax

  Return netot

End

