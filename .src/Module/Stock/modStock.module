'''use at ComboBox1_KeyRelease()   'for dispensing stock present at comp with active (disp) status=1
Public Function FillMedicinesDispensingComboResult(txtroute As String, BrandOrGeneric As String, textToCursor As String, Optional sComp As String) As Result

  Dim sql As String
  Dim res As Result
  Dim xcomp As String

  If sComp Then
    xcomp = sComp
  Else
    xcomp = modGeneralMain.compID
  Endif

  If txtroute = "oral" Or txtroute = "liquid" Or txtroute = "fluid" Or txtroute = "injection" Or txtroute = "resp" Or txtroute = "topical" Or txtroute = "eye/ear" Or txtroute = "anal/vaginal" Then
    If BrandOrGeneric = "Generic" Then '''for generic
      sql = "select tblentry.fldstockid as col,tblentry.fldqty as qty from tblentry where lower(tblentry.fldstockid) like &1 and tblentry.fldstatus=&2 and tblentry.fldcomp=&3 and tblentry.fldqty>&4 and tblentry.fldstockid in(select tblmedbrand.fldbrandid From tblmedbrand where tblmedbrand.fldactive=&5 and tblmedbrand.flddrug in(select tbldrug.flddrug From tbldrug where tbldrug.fldroute=&6)) ORDER BY tblentry.fldstockid ASC"
    Else If BrandOrGeneric = "Brand" Then '''for brand
      sql = "select tblmedbrand.fldbrand as col,tblentry.fldqty as qty from (tblmedbrand inner join tblentry on tblentry.fldstockid=tblmedbrand.fldbrandid) inner join tbldrug on tblmedbrand.flddrug=tbldrug.flddrug where lower(tblmedbrand.fldbrand) like &1 and tblentry.fldstatus=&2 and tblentry.fldcomp=&3 and tblentry.fldqty>&4 and tblmedbrand.fldactive=&5 and tbldrug.fldroute=&6 ORDER BY tblmedbrand.fldbrand ASC"
    Endif
    res = modDatabase.$myConn.Exec(sql, LCase(textToCursor) & "%", 1, xcomp, 0, "Active", txtroute)

  Else If txtroute = "IVpush" Or txtroute = "CIV" Or txtroute = "IIV" Or txtroute = "SC" Or txtroute = "IM" Or txtroute = "IT" Or txtroute = "IDer" Or txtroute = "ICar" Or txtroute = "ISyn" Then
    If BrandOrGeneric = "Generic" Then '''for generic
      sql = "select tblentry.fldstockid as col,tblentry.fldqty as qty from tblentry where lower(tblentry.fldstockid) like &1 and tblentry.fldstatus=&2 and tblentry.fldcomp=&3 and tblentry.fldqty>&4 and tblentry.fldstockid in(select tblmedbrand.fldbrandid From tblmedbrand where tblmedbrand.fldactive=&5 and tblmedbrand.flddrug in(select tbllabel.flddrug from tbllabel where tbllabel.fldsubroute=&6)) ORDER BY tblentry.fldstockid ASC"
    Else If BrandOrGeneric = "Brand" Then '''for brand
      sql = "select tblmedbrand.fldbrand as col,tblentry.fldqty as qty from (tblmedbrand inner join tblentry on tblentry.fldstockid=tblmedbrand.fldbrandid) inner join tbllabel on tblmedbrand.flddrug=tbllabel.flddrug where lower(tblmedbrand.fldbrand) like &1 and tblentry.fldstatus=&2 and tblentry.fldcomp=&3 and tblentry.fldqty>&4 and tblmedbrand.fldactive=&5 and tbllabel.fldsubroute=&6 ORDER BY tblmedbrand.fldbrand ASC"
    Endif
    res = modDatabase.$myConn.Exec(sql, LCase(textToCursor) & "%", 1, xcomp, 0, "Active", txtroute)

  Else If txtroute = "suture" Or txtroute = "msurg" Or txtroute = "ortho" Then
    sql = "select tblentry.fldstockid as col,tblentry.fldqty as qty from tblentry where lower(tblentry.fldstockid) like &1 and tblentry.fldstatus=&2 and tblentry.fldcomp=&3 and tblentry.fldqty>&4 and tblentry.fldstockid in(Select tblsurgbrand.fldbrandid From tblsurgbrand where tblsurgbrand.fldactive=&5 and tblsurgbrand.fldsurgid in(select tblsurgicals.fldsurgid from tblsurgicals where tblsurgicals.fldsurgcateg=&6)) ORDER BY tblentry.fldstockid ASC"                         '''
    res = modDatabase.$myConn.Exec(sql, LCase(textToCursor) & "%", 1, xcomp, 0, "Active", txtroute)

  Else If txtroute = "extra" Then
    sql = "select tblentry.fldstockid as col,tblentry.fldqty as qty from tblentry where lower(tblentry.fldstockid) like &1 and tblentry.fldstatus=&2 and tblentry.fldcomp=&3 and tblentry.fldqty>&4 and tblentry.fldstockid in(Select tblextrabrand.fldbrandid From tblextrabrand where tblextrabrand.fldactive=&5) ORDER BY tblentry.fldstockid ASC"
    res = modDatabase.$myConn.Exec(sql, LCase(textToCursor) & "%", 1, xcomp, 0, "Active")

  Endif

  Return res

End

