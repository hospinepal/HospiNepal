''----------------------------------------- Interval wise data ----------------------------------------------
Public Function GetConsumptionQTY(sType As String, sItem As String, dt1 As Date, dt2 As Date, compid As String) As Float

  Dim rs3 As Result
  Dim salqty As Float

  rs3 = modDatabase.$myConn.Exec("select SUM(flditemqty) as qty from tblpatbilling where fldtime>=&1 and fldtime<=&2 and flditemname=&3 and flditemtype=&4 and fldcomp=&5", modDate.StartSqlDate(dt1), modDate.EndSqlDate(dt2), sItem, sType, compid)
  salqty = 0
  If rs3.Available = True Then
    If rs3!qty Then
      salqty = rs3!qty
    Endif
  Endif
  Return salqty

End

Public Function GetCurrentStockOneComp(sItem As String, compid As String) As Float

  Dim rs5 As Result
  Dim curqty As Float

  rs5 = modDatabase.$myConn.Exec("select SUM(fldqty) as col from tblentry where fldstockid=&1 and fldcomp=&2", sItem, compid)
  curqty = 0
  If rs5.Available = True Then
    If rs5!col Then
      curqty = rs5!col
    Endif
  Endif
  Return curqty

End

Public Function GetToDispenseStockOneComp(sItem As String, compid As String, txtday As Float) As Float

  Dim sql2 As String
  Dim res2 As Result
  Dim curqty As Float

  If modBasic.$SkipExpiry = "ExpireOnUse" Then
    sql2 = "select SUM(fldqty) as col from tblentry where fldstockid=&1 and fldcomp=&2 and fldstatus>&3 and fldexpiry>&4"
    res2 = modDatabase.$myConn.Exec(sql2, sItem, compid, 0, DateAdd(Date(), gb.Day, CInt(txtday)))
  Else If modBasic.$SkipExpiry = "Expired" Then
    sql2 = "select SUM(fldqty) as col from tblentry where fldstockid=&1 and fldcomp=&2 and fldstatus>&3 and fldexpiry>&4"
    res2 = modDatabase.$myConn.Exec(sql2, sItem, compid, 0, Date())
  Else
    sql2 = "select SUM(fldqty) as col from tblentry where fldstockid=&1 and fldcomp=&2 and fldstatus>&3"
    res2 = modDatabase.$myConn.Exec(sql2, sItem, compid, 0)
  Endif

  If res2.Available Then
    If res2!col Then
      curqty = res2!col
    Else
      curqty = 0
    Endif
  Else
    curqty = 0
  Endif
  Return curqty

End

Public Function GetToDispenseRateOneComp(sItem As String, compid As String, txtday As Float) As Float

  Dim sql2 As String
  Dim res2 As Result
  Dim xrate As Float

  If modBasic.$SkipExpiry = "ExpireOnUse" Then
    sql2 = "select fldstockno,fldexpiry,fldqty,fldstatus,fldsellpr from tblentry where fldstockid=&1 and fldcomp=&2 and fldstatus>&3 and fldexpiry>&4 and fldqty>&5 ORDER BY fldstatus ASC"
    res2 = modDatabase.$myConn.Exec(sql2, sItem, compid, 0, DateAdd(Date(), gb.Day, CInt(txtday)), 0)
  Else If modBasic.$SkipExpiry = "Expired" Then
    sql2 = "select fldstockno,fldexpiry,fldqty,fldstatus,fldsellpr from tblentry where fldstockid=&1 and fldcomp=&2 and fldstatus>&3 and fldexpiry>&4 and fldqty>&5 ORDER BY fldstatus ASC"
    res2 = modDatabase.$myConn.Exec(sql2, sItem, compid, 0, Date(), 0)
  Else
    sql2 = "select fldstockno,fldexpiry,fldqty,fldstatus,fldsellpr from tblentry where fldstockid=&1 and fldcomp=&2 and fldstatus>&3 and fldqty>&4 ORDER BY fldstatus ASC"
    res2 = modDatabase.$myConn.Exec(sql2, sItem, compid, 0, 0)
  Endif

  xrate = 0
  If res2.Available Then
    res2.MoveFirst
    xrate = res2!fldsellpr
  Endif

  Return xrate

End

Public Function GetToDispenseCostOneComp(sItem As String, compid As String, txtday As Float, txtqty As Float) As Float

  Dim sql2 As String
  Dim res2 As Result
  Dim cstamt As Float

  If modBasic.$SkipExpiry = "ExpireOnUse" Then
    sql2 = "select fldstockno,fldexpiry,fldqty,fldstatus,fldsellpr from tblentry where fldstockid=&1 and fldcomp=&2 and fldstatus>&3 and fldexpiry>&4 and fldqty>&5 ORDER BY fldstatus ASC"
    res2 = modDatabase.$myConn.Exec(sql2, sItem, compid, 0, DateAdd(Date(), gb.Day, CInt(txtday)), 0)
  Else If modBasic.$SkipExpiry = "Expired" Then
    sql2 = "select fldstockno,fldexpiry,fldqty,fldstatus,fldsellpr from tblentry where fldstockid=&1 and fldcomp=&2 and fldstatus>&3 and fldexpiry>&4 and fldqty>&5 ORDER BY fldstatus ASC"
    res2 = modDatabase.$myConn.Exec(sql2, sItem, compid, 0, Date(), 0)
  Else
    sql2 = "select fldstockno,fldexpiry,fldqty,fldstatus,fldsellpr from tblentry where fldstockid=&1 and fldcomp=&2 and fldstatus>&3 and fldqty>&4 ORDER BY fldstatus ASC"
    res2 = modDatabase.$myConn.Exec(sql2, sItem, compid, 0, 0)
  Endif

  cstamt = 0
  If res2.Available Then
    For Each res2
      If txtqty > 0
        If txtqty <= res2!fldqty Then
          cstamt = cstamt + txtqty * res2!fldsellpr
          txtqty = 0
          Break
        Else If txtqty > res2!fldqty Then
          cstamt = cstamt + res2!fldqty * res2!fldsellpr
          txtqty = txtqty - res2!fldqty
        Endif
      Endif
    Next
  Endif

  Return cstamt

End

Public Function GetCurrentExpiredStockOneComp(sItem As String, compid As String) As Boolean

  Dim rs5 As Result
  Dim ret As Boolean

  ret = False
  rs5 = modDatabase.$myConn.Exec("select fldexpiry from tblentry where fldstockid=&1 and fldcomp=&2 and fldstatus=&3", sItem, compid, 1)
  If rs5.Available = True Then
    If rs5!fldexpiry <= Now() Then
      ret = True
    Endif
  Endif

  Return ret

End

''--------------------------------------------- Tender QTY ------------------------------------------------
Public Function GetTenderItemQTY(sVendor As String, sRoute As String, sItem As String) As Float

  Dim res As Result
  Dim res1 As Result
  Dim xx As Float

  res = modDatabase.$myConn.Exec("select fldtotalqty from tbltenderlist where fldsuppname=&1 and fldsav=&2 and fldstockid=&3 and fldfromdate<=&4 and fldtodate>=&5 and flditemtype=&6", sVendor, True, sItem, modDate.StartSqlDate(Now()), modDate.EndSqlDate(Now()), "Brand")
  If res.Available Then
    xx = res!fldtotalqty
  Else
    If sRoute = "oral" Or sRoute = "liquid" Or sRoute = "fluid" Or sRoute = "injection" Or sRoute = "resp" Or sRoute = "topical" Or sRoute = "eye/ear" Or sRoute = "anal/vaginal" Then
      res1 = modDatabase.$myConn.Exec("select fldtotalqty from tbltenderlist where fldsuppname=&1 and fldsav=&2 and fldstockid in(select fldbrandid from tblmedbrand where flddrug=&3) and fldfromdate<=&4 and fldtodate>=&5 and flditemtype=&6", sVendor, True, modMedConstant.GetDrugFromStockID(sItem), modDate.StartSqlDate(Now()), modDate.EndSqlDate(Now()), "Generic")
      If res1.Available Then
        xx = res1!fldtotalqty
      Else
        xx = 0
      Endif
    Else If sRoute = "suture" Or sRoute = "msurg" Or sRoute = "ortho" Then
      res1 = modDatabase.$myConn.Exec("select fldtotalqty from tbltenderlist where fldsuppname=&1 and fldsav=&2 and fldstockid in(select fldbrandid from tblsurgbrand where fldsurgid=&3) and fldfromdate<=&4 and fldtodate>=&5 and flditemtype=&6", sVendor, True, GetSurgFromStockID(sItem), modDate.StartSqlDate(Now()), modDate.EndSqlDate(Now()), "Generic")
      If res1.Available Then
        xx = res1!fldtotalqty
      Else
        xx = 0
      Endif
    Else If sRoute = "extra" Then
      res1 = modDatabase.$myConn.Exec("select fldtotalqty from tbltenderlist where fldsuppname=&1 and fldsav=&2 and fldstockid in(select fldbrandid from tblextrabrand where fldextraid=&3) and fldfromdate<=&4 and fldtodate>=&5 and flditemtype=&6", sVendor, True, GetExtraFromStockID(sItem), modDate.StartSqlDate(Now()), modDate.EndSqlDate(Now()), "Generic")
      If res1.Available Then
        xx = res1!fldtotalqty
      Else
        xx = 0
      Endif
    Endif
  Endif

  Return xx

End

'NOTE: -----------------------------------Brand or Generic Mode -------------------------------------------
Public Sub DisplayDefaultConsumeMode(rbbrand As Radiobutton, rbgeneric As Radiobutton)

  Dim def As String

  def = modSettings.ShowSettingFromFIle("BrandOrGeneric/Consume")
  If def Then
    If def = "Brand" Then
      rbbrand.Value = True
    Else If def = "Generic" Then
      rbgeneric.Value = True
    Endif
  Else
    rbgeneric.Value = True
  Endif

End

