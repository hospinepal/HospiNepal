'NOTE: ----------------------------- COMBO for INVENTORY SELECTION ------------------------------------------------
Public Function GetComboControl(txtroute As String, txtitem As String, rbgeneric As RadioButton, rbbrand As RadioButton, Optional xCon As Connection) As Boolean

  Dim xx As Boolean
  Dim sql As String
  Dim res As Result
  Dim txt As String
  Dim sConn As Connection

  If xCon Then
    sConn = xCon
  Else
    sConn = modDatabase.$myConn
  Endif

  If txtroute = "Group" Then
    xx = True
  Else
    txt = modNonMedical.GetBillItemCategoryFromCombo(txtroute)
    If txt = "Medicines" Then
      If rbgeneric.Value = True Then
        sql = "select fldbrandid from tblmedbrand where fldbrandid=&1"
      Else If rbbrand.Value = True Then
        sql = "select fldbrand from tblmedbrand where fldbrand=&1"
      Endif
    Else If txt = "Surgicals" Then
      sql = "select fldbrandid from tblsurgbrand where fldbrandid=&1"
    Else If txt = "Extra Items" Then
      sql = "select fldbrandid from tblextrabrand where fldbrandid=&1"
    Endif
    res = sConn.Exec(sql, txtitem)
    xx = res.Available
  Endif
  Return xx

End

Public Function GetComboControlGeneric(txtroute As String, txtitem As String) As Boolean

  Dim xx As Boolean
  Dim sql As String
  Dim res As Result
  Dim txt As String

  If txtroute = "Group" Then
    xx = True
  Else
    txt = modNonMedical.GetBillItemCategoryFromCombo(txtroute)
    If txt = "Medicines" Then
      sql = "select fldbrandid from tblmedbrand where fldbrandid=&1"
    Else If txt = "Surgicals" Then
      sql = "select fldbrandid from tblsurgbrand where fldbrandid=&1"
    Else If txt = "Extra Items" Then
      sql = "select fldbrandid from tblextrabrand where fldbrandid=&1"
    Endif
    res = modDatabase.$myConn.Exec(sql, txtitem)
    xx = res.Available
  Endif
  Return xx

End

'USE FOR LOADIMG Medicine/Surgical LIST (purchase/Dispensing) ''use at ComboBox1_KeyRelease() For purchase Of all active items / updating outorder / e - prescription
Public Function ItemListForPurchaseResult(txtroute As String, BrandOrGeneric As String, textToCursor As String) As Result

  Dim sql As String
  Dim res As Result
  Dim sConn As Connection

  sConn = modDatabase.$medConn
  If txtroute = "oral" Or txtroute = "liquid" Or txtroute = "fluid" Or txtroute = "injection" Or txtroute = "resp" Or txtroute = "topical" Or txtroute = "eye/ear" Or txtroute = "anal/vaginal" Then
    If BrandOrGeneric = "Generic" Then '''for generic
      sql = "select tblmedbrand.fldbrandid as col from tblmedbrand where lower(tblmedbrand.fldbrandid) like &1 and tblmedbrand.fldactive=&2 and tblmedbrand.fldmaxqty<>&3 and tblmedbrand.flddrug in(select tbldrug.flddrug from tbldrug where tbldrug.fldroute=&4) ORDER BY tblmedbrand.fldbrandid ASC"
    Else If BrandOrGeneric = "Brand" Then '''for brand
      sql = "select tblmedbrand.fldbrand as col from tblmedbrand where lower(tblmedbrand.fldbrand) like &1 and tblmedbrand.fldactive=&2 and tblmedbrand.fldmaxqty<>&3 and tblmedbrand.flddrug in(select tbldrug.flddrug from tbldrug where tbldrug.fldroute=&4) ORDER BY tblmedbrand.fldbrand ASC"
    Endif
    res = sConn.Exec(sql, LCase(textToCursor) & "%", "Active", -1, txtroute)

  Else If txtroute = "IVpush" Or txtroute = "CIV" Or txtroute = "IIV" Or txtroute = "SC" Or txtroute = "IM" Or txtroute = "IT" Or txtroute = "IDer" Or txtroute = "ICar" Or txtroute = "ISyn" Then
    If BrandOrGeneric = "Generic" Then '''for generic
      sql = "select tblmedbrand.fldbrandid as col from tblmedbrand where lower(tblmedbrand.fldbrandid) like &1 and tblmedbrand.fldactive=&2 and tblmedbrand.fldmaxqty<>&3 and tblmedbrand.flddrug in(select tbllabel.flddrug from tbllabel where tbllabel.fldsubroute=&4) ORDER BY tblmedbrand.fldbrandid ASC"
    Else If BrandOrGeneric = "Brand" Then '''for brand
      sql = "select tblmedbrand.fldbrand as col from tblmedbrand where lower(tblmedbrand.fldbrand) like &1 and tblmedbrand.fldactive=&2 and tblmedbrand.fldmaxqty<>&3 and tblmedbrand.flddrug in(select tbllabel.flddrug from tbllabel where tbllabel.fldsubroute=&4) ORDER BY tblmedbrand.fldbrand ASC"
    Endif
    res = sConn.Exec(sql, LCase(textToCursor) & "%", "Active", 1, txtroute)

  Else If txtroute = "suture" Or txtroute = "msurg" Or txtroute = "ortho" Then
    sql = "select tblsurgbrand.fldbrandid as col from tblsurgbrand where lower(tblsurgbrand.fldbrandid) like &1 and tblsurgbrand.fldactive=&2 and tblsurgbrand.fldmaxqty<>&3 and tblsurgbrand.fldsurgid in(select tblsurgicals.fldsurgid from tblsurgicals where tblsurgicals.fldsurgcateg=&4) ORDER BY tblsurgbrand.fldbrandid ASC"
    res = sConn.Exec(sql, LCase(textToCursor) & "%", "Active", -1, txtroute)

  Else If txtroute = "extra" Then
    sql = "select tblextrabrand.fldbrandid as col from tblextrabrand where lower(tblextrabrand.fldbrandid) like &1 and tblextrabrand.fldactive=&2 and tblextrabrand.fldmaxqty<>&3 ORDER BY tblextrabrand.fldbrandid ASC"
    res = sConn.Exec(sql, LCase(textToCursor) & "%", "Active", -1)

  Endif

  Return res

End

