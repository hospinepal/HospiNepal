'NOTE: ----------------------------- Update Stock and Order -----------------------------
Public Sub AddToExistEntry(stockno As Long, qty As Float, sComp As String)

  Dim res As Result

  res = modDatabase.$myConn.Edit("tblentry", "fldstockno=&1 and fldcomp=&2", stockno, sComp)
  res["fldqty"] = res!fldqty + qty
  res["fldsav"] = True
  res["xyz"] = False
  res.Update()
  UpdateSockOrder(res!fldstockid, sComp)
  'dont catch error. allow to roll back

End

''update stock status
Public Sub UpdateSockOrder(stockid As String, compid As String)

  If modBasic.$OutOrder = "Manual" Then
    UpdateSockByManual(stockid, compid)
  Else If modBasic.$OutOrder = "FEFO" Then
    UpdateSockByExpiry(stockid, compid)
  Else
    UpdateSockByManual(stockid, compid)
  Endif

End

Public Sub UpdateSockByManual(stockid As String, compid As String)

  Dim res As Result
  Dim res1 As Result
  Dim res2 As Result
  Dim i As Integer

  res = modDatabase.$myConn.Edit("tblentry", "fldstockid=&1 and fldqty=&2 and fldcomp=&3 and fldstatus<>&4", stockid, 0, compid, 0)
  If res.Available = True Then
    For Each res
      res["fldstatus"] = 0
      res["xyz"] = False
      res.Update()
    Next
  Endif

  res2 = modDatabase.$myConn.Exec("select fldstockno from tblentry where fldstockid=&1 and fldqty>&2 and fldcomp=&3 ORDER by fldstatus ASC", stockid, 0, compid)
  If res2.Count > 0 Then
    res2.MoveFirst
    For i = 1 To res2.Count
      res1 = modDatabase.$myConn.Edit("tblentry", "fldstockno=&1", res2!fldstockno)
      res1["fldstatus"] = i
      res1["xyz"] = False
      res1.Update()
      res2.MoveNext
    Next
  Endif

End

Public Sub UpdateSockByExpiry(stockid As String, compid As String)

  Dim res As Result
  Dim res1 As Result
  Dim res2 As Result
  Dim res3 As Result
  Dim i As Integer

  res = modDatabase.$myConn.Edit("tblentry", "fldstockid=&1 and fldqty=&2 and fldcomp=&3", stockid, 0, compid)
  If res.Available = True Then
    For Each res
      res["fldstatus"] = 0
      res["xyz"] = False
      res.Update()
    Next
  Endif

  res3 = modDatabase.$myConn.Exec("select fldstockno,fldexpiry from tblentry where fldstockid=&1 and fldqty>&2 and fldcomp=&3 and fldexpiry<&4", stockid, 0, compid, Now())
  If res3.Available Then
    For Each res3
      res2 = modDatabase.$myConn.Edit("tblentry", "fldstockno=&1", res3!fldstockno)
      res2["fldstatus"] = 0
      res2["xyz"] = False
      res2.Update()
    Next
  Endif

  res1 = modDatabase.$myConn.Exec("select fldstockno,fldexpiry from tblentry where fldstockid=&1 and fldqty>&2 and fldcomp=&3 and fldexpiry>&4 order by fldexpiry ASC", stockid, 0, compid, Now())
  If res1.Available = True Then
    res1.MoveFirst
    For i = 1 To res1.Count
      res2 = modDatabase.$myConn.Edit("tblentry", "fldstockno=&1", res1!fldstockno)
      res2["fldstatus"] = i
      res2["xyz"] = False
      res2.Update()
      res1.MoveNext
    Next
  Endif

End

'update stock adjustment using curr value
Public Sub AdjustStockByCurrentQTY(id As Long, qty As Float)

  Dim res As Result

  res = modDatabase.$myConn.Edit("tbladjustment", "fldid=&1", id)
  res["fldcurrqty"] = qty
  res["xyz"] = False
  res.Update
  'dont catch error. allow to roll back

End

Public Sub BackupEntryStock(compid As String)

  Dim res2 As Result
  Dim res As Result
  Dim ref As ResultField

  res = modDatabase.$myConn.Exec("select *from tblentry where fldcomp=&1", compid)
  For Each res
    res2 = modDatabase.$myConn.Create("tblentrybackup")
    For Each ref In res.Fields
      res2[ref.Name] = res[ref.Name]
    Next
    res2["fldentrytime"] = Now()
    res2["flduser"] = modGeneralMain.$lbluser
    res2["xyz"] = False
    res2.Update
  Next

End

Public Sub AddAmountToVendor(txtsupp As String, txtamt As Float, txtpurtype As String)

  Dim res As Result

  res = modDatabase.$myConn.Edit("tblsupplier", "fldsuppname=&1", txtsupp)
  If txtpurtype = "Cash Payment" Then
    res["fldpaiddebit"] = res!fldpaiddebit + txtamt
    res["fldleftcredit"] = res!fldleftcredit + txtamt
  Else If txtpurtype = "Credit Payment" Then
    res["fldleftcredit"] = res!fldleftcredit + txtamt
  Else If txtpurtype = "Payment" Then
    res["fldpaiddebit"] = res!fldpaiddebit + txtamt
  Else If txtpurtype = "Credit Note" Then
    res["fldpaiddebit"] = res!fldpaiddebit + txtamt
  Endif
  res["xyz"] = False
  res.Update()
  'dont catch error. Error will toll back

End

