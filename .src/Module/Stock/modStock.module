'NOTE: -------------------------------------- stock related functions -------------------------------------------
Public Function GetStorageCodeFromStockNo(stockno As Integer) As String

  Dim res As Result
  Dim xx As String

  xx = modHelpVariable.GetCollectionValue($ItemStorageCodeData, CStr(stockno))
  If Not xx Then
    res = modDatabase.$myConn.Exec("select fldcode from tblentry where fldstockno=&1", stockno)
    If res.Available Then
      If res!fldcode Then
        xx = res!fldcode
        If modBasic.$LocalCache = "Yes" Then
          $ItemStorageCodeData.Add(xx, CStr(stockno))
        Endif
      Else
        xx = ""
      Endif
    Else
      xx = ""
    Endif
  Endif
  Return xx

End

