''--------------------- General functions ----------------------------------------
Public Sub DebugString(sText As String)

  If $DebugMode = True Then
    If MMain.$IsGUIApp = True Then
      Error Application.Name & ": " & Format(Now(), gb.GeneralDate) & " : " & sText
    Else
      Print Application.Name & ": " & Format(Now(), gb.GeneralDate) & " : " & sText
    Endif
  Endif

End

