Public Sub LoadClinicalLists()

  Dim aa As String[]
  Dim bb As String[]
  Dim cc As String[]

  $GenericMedName = modMedicine.GetGenericMedList()
  $ClinBodyFluidAll = modmedicine.GetBodyFluidList()
  $IPDDepartmentsAll = modMisc.GetDepartmentWithBedList()

  aa = modFillContainer.GetListFromResult(modDatabase.$myConn.Exec("select distinct(fldsymptom) as col from tblcomplaints where (fldcomp=&1 or fldcomp=&2)", modGeneralMain.compID, "%"))                           ''
  $ClinComplaintComp = aa.Sort()
  $ClinComplaintCompGrouped = modFixPatho.GetSymptomWithCategory(modBasic.$ClinComplaintComp)

  bb = modFillContainer.GetListFromResult(modDatabase.$myConn.Exec("select distinct(fldexamid) as col from tblcompexam where (fldcomp=&1 or fldcomp=&2) and fldcategory=&3", modGeneralMain.compID, "%", "Physician Examinations"))
  $ClinFindingComp = bb.Sort()
  $ClinFindingCompGrouped = modFixClinic.GetExamWithCategory(modBasic.$ClinFindingComp)

  cc = modFillContainer.GetListFromResult(modDatabase.$myConn.Exec("select distinct(fldexamid) as col from tblcompexam where (fldcomp=&1 or fldcomp=&2) and fldcategory=&3", modGeneralMain.compID, "%", "Nursing Examinations"))
  $ClinNursingComp = cc.Sort()

  $ClinDiagnoChapterGrouped = modICD.GetICDCapterList(modPathology.ICDChapterPath(), modPathology.ICDBlockPath())
  $ClinDiagnoChapterGrouped.Sort()

  $DemogList = modFillContainer.GetListFromResult(modDatabase.$myConn.Exec("select distinct(flddemoid) as col from tbldemographic where (fldcomp=&1 or fldcomp=&2)", modGeneralMain.compID, "%"))
  $ClinEssentialComp = modFillContainer.GetListFromResult(modDatabase.$myConn.Exec("select distinct(fldexamid) as col from tblcompexam where (fldcomp=&1 or fldcomp=&2) and fldcategory=&3", modGeneralMain.compID, "%", "Essential Examinations"))
  $ClinTriageComp = modFillContainer.GetListFromResult(modDatabase.$myConn.Exec("select distinct(fldexamid) as col from tblcompexam where (fldcomp=&1 or fldcomp=&2) and fldcategory=&3", modGeneralMain.compID, "%", "Triage Examinations"))
  $ClinDischargeComp = modFillContainer.GetListFromResult(modDatabase.$myConn.Exec("select distinct(fldexamid) as col from tblcompexam where (fldcomp=&1 or fldcomp=&2) and fldcategory=&3", modGeneralMain.compID, "%", "Discharge Examinations"))

  $sysExamList = modSysCons.GetSysconstList("Exam")
  $sysTestList = modSysCons.GetSysconstList("Test")
  $sysRadioList = modSysCons.GetSysconstList("Radio")
  $sysCustomList = modSysCons.GetSysconstList("Custom")

End

Public Sub DispLabelSettings()

  $DispLabelRegimen = modSettings.ShowSettingFromFIle("DispensingLabel/ShowRegimen")
  $DispLabelAutoEnable = modSettings.ShowSettingFromFIle("DispensingLabel/AutoEnable")

End
