Public Sub FillSurnameList()

  Dim xsurnamelist As String

  xsurnamelist = modSettings.ShowSettingFromFIle("RegistrationForm/SurnameList")
  If xsurnamelist Then
    If Exist(xsurnamelist) Then
      $SurNameList = modString.GetStringArrayFromFile(xsurnamelist)
    Endif
  Else
    $SurNameList = modMedicine.GetSurNameListFromDB()
  Endif

End

Public Sub FillAddressList()

  Dim xaddlist As String

  xaddlist = modSettings.ShowSettingFromFIle("RegistrationForm/AddressList")
  If xaddlist Then
    If Exist(xaddlist) Then
      $AddressList = modString.GetStringArrayFromFile(xaddlist)
    Endif
  Endif

End

Public Sub FillDistrictList()

  Dim xdistlist As String

  xdistlist = modSettings.ShowSettingFromFIle("RegistrationForm/DistrictList")
  If xdistlist Then
    If Exist(xdistlist) Then
      $DistrictList = modString.GetStringArrayFromFile(xdistlist, True)
    Endif
  Else
    $DistrictList = modMedicine.GetDistrictListFromDB()
  Endif

End

Public Sub FillRelationList()

  Dim xrelationlist As String

  xrelationlist = modSettings.ShowSettingFromFIle("RegistrationForm/RelationList")
  If xrelationlist Then
    If Exist(xrelationlist) Then
      $RelationList = modString.GetStringArrayFromFile(xrelationlist, True)
    Endif
  Else
    $RelationList = modMedicine.GetRelationListFromDB()
  Endif

End

Public Sub RegistrationFormTime()

  Dim xsta As String
  Dim xend As String

  xsta = modGlobalSetting.ShowSettingFromDB("EnableRegistrationForm/StartTime")
  If xsta
    If Val(xsta) Then
      $RegStartTime = Val(xsta)
    Else
      $RegStartTime = ""
    Endif
  Else
    $RegStartTime = ""
  Endif

  xend = modGlobalSetting.ShowSettingFromDB("EnableRegistrationForm/EndTime")
  If xend Then
    If Val(xend) Then
      $ResEndTime = Val(xend)
    Else
      $ResEndTime = ""
    Endif
  Else
    $ResEndTime = ""
  Endif

End

