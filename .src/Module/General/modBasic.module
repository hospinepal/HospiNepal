Private Sub LoadInfoMusic()

  Dim xmusic As String
  Dim xmusicvol As String

  xmusic = modSettings.ShowUserWiseSettingFromFIle("AppSetting_InformMusic")
  If xmusic Then
    If Exist(xmusic) Then
      $InfoMusic = xmusic
    Else
      $InfoMusic = ""
    Endif
  Else
    $InfoMusic = ""
  Endif

  xmusicvol = modSettings.ShowUserWiseSettingFromFIle("AppSetting_VolumeMusic")
  If xmusicvol Then
    $InfoMusicVol = CInt(xmusicvol)
  Endif

End

Private Sub GetDictionaryPathAll()

  Dim xdict As String

  $dictadvPath = modSettings.ShowSettingFromFIle("AdvancedDictionary/Path")
  xdict = modSettings.ShowUserWiseSettingFromFIle("AppSetting_Dictionary")
  If xdict And If Exist(xdict) Then
    $dictPathList = modString.GetStringArrayFromFile(xdict)
  Else
    $dictPathList = New String[]
  Endif

End

Public Sub LoadLocalMonths()

  Dim sForm As String
  Dim sFile As String

  Dim hFile As File
  Dim sLine As String
  Dim linWord As String[]

  If $DateFormat Then
    If $DateFormat = "BS Date" Then
      sForm = "BikramSambat"
    Endif
  Endif
  If sForm Then
    sFile = modHelpVariable.$localesDirectory &/ sForm
    If Exist(sFile) Then
      hFile = Open sFile
      DebugString("Open File " & sFile)
      For Each sLine In hFile.Lines
        linWord = Split(sLine, ",")
        If linWord[0] = "01" Then
          LocalJan = linWord[1]
        Else If linWord[0] = "02" Then
          LocalFeb = linWord[1]
        Else If linWord[0] = "03" Then
          LocalMar = linWord[1]
        Else If linWord[0] = "04" Then
          LocalApr = linWord[1]
        Else If linWord[0] = "05" Then
          LocalMay = linWord[1]
        Else If linWord[0] = "06" Then
          LocalJun = linWord[1]
        Else If linWord[0] = "07" Then
          LocalJul = linWord[1]
        Else If linWord[0] = "08" Then
          LocalAug = linWord[1]
        Else If linWord[0] = "09" Then
          LocalSep = linWord[1]
        Else If linWord[0] = "10" Then
          LocalOct = linWord[1]
        Else If linWord[0] = "11" Then
          LocalNov = linWord[1]
        Else If linWord[0] = "12" Then
          LocalDec = linWord[1]
        Endif
      Next
      hFile.Close()
    Endif

  Endif

End

Public Sub LoadLocalNumbers()

  If $NumFont Then
    Local0 = modApplication.ConvertToLocalNumber("0", $NumFont)
    Local1 = modApplication.ConvertToLocalNumber("1", $NumFont)
    Local2 = modApplication.ConvertToLocalNumber("2", $NumFont)
    Local3 = modApplication.ConvertToLocalNumber("3", $NumFont)
    Local4 = modApplication.ConvertToLocalNumber("4", $NumFont)
    Local5 = modApplication.ConvertToLocalNumber("5", $NumFont)
    Local6 = modApplication.ConvertToLocalNumber("6", $NumFont)
    Local7 = modApplication.ConvertToLocalNumber("7", $NumFont)
    Local8 = modApplication.ConvertToLocalNumber("8", $NumFont)
    Local9 = modApplication.ConvertToLocalNumber("9", $NumFont)
  Endif

End

