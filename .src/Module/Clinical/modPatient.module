Public Function GetQueNumber(sDept As String, sDate As Date, encid As String, sBillMode As String, sUserid As String) As String

  Dim res As Result
  Dim xx As String

  If sUserid Then
    If modBasic.$RegistQuotaQueMode = "ConsultOnly" Then
      res = modDatabase.$myConn.Exec("select fldencounterval from tblconsult where fldconsulttime>=&1 and fldconsulttime<=&2 and flduserid=&3 and fldcomp like &4 ORDER BY fldid ASC", modDate.StartSqlDate(sDate), modDate.EndSqlDate(sDate), sUserid, modGeneralMain.compID)                    ''
    Else If modBasic.$RegistQuotaQueMode = "Consult+Mode" Then
      res = modDatabase.$myConn.Exec("select fldencounterval from tblconsult where fldconsulttime>=&1 and fldconsulttime<=&2 and flduserid=&3 and fldbillingmode=&4 and fldcomp like &5 ORDER BY fldid ASC", modDate.StartSqlDate(sDate), modDate.EndSqlDate(sDate), sUserid, sBillMode, modGeneralMain.compID)                    ''
    Else
      res = modDatabase.$myConn.Exec("select fldencounterval from tblconsult where fldconsultname=&1 and fldconsulttime>=&2 and fldconsulttime<=&3 and fldbillingmode=&4 and flduserid=&5 and fldcomp like &6 ORDER BY fldid ASC", sDept, modDate.StartSqlDate(sDate), modDate.EndSqlDate(sDate), sBillMode, sUserid, modGeneralMain.compID)                    ''
    Endif
  Else
    res = modDatabase.$myConn.Exec("select fldencounterval from tblconsult where fldconsultname=&1 and fldconsulttime>=&2 and fldconsulttime<=&3 and fldbillingmode=&4 and fldcomp like &5 ORDER BY fldid ASC", sDept, modDate.StartSqlDate(sDate), modDate.EndSqlDate(sDate), sBillMode, modGeneralMain.compID)                    ''
  Endif

  If res.Available Then
    For Each res
      If res!fldencounterval = encid Then
        xx = CStr(res.Index + 1)
      Endif
    Next
  Else
    xx = ""
  Endif

  Return xx

End
