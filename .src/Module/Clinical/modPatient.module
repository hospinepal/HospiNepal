Public Sub RegistBlankPatient()

  Dim res As Result
  Dim dt As Date
  Dim yr As Integer

  yr = 0 - 25
  dt = DateAdd(Now(), gb.Year, yr)
  res = modDatabase.$myConn.Create("tblpatientinfo")
  res["fldpatientval"] = "1"
  res["fldptnamefir"] = "General"
  res["fldptnamelast"] = "Patient"
  res["fldethniccode"] = ""
  res["fldptaddvill"] = "Hospital"
  res["fldptadddist"] = "Hospital"
  res["fldptsex"] = "Male"
  res["fldptcontact"] = ""
  res["fldptguardian"] = ""
  res["fldrelation"] = ""
  res["fldptbirday"] = dt
  res["fldptadmindate"] = Now()
  res["fldemail"] = ""
  res["fldptcode"] = ""
  res["flddiscount"] = ""
  res["fldadmitfile"] = ""
  res["fldcomment"] = ""
  res["fldencrypt"] = False
  res["fldpassword"] = ""

  res["flduserid"] = modGeneralMain.$lbluser
  res["fldtime"] = Now()
  res["fldupuser"] = ""
  res["flduptime"] = ""
  res["xyz"] = False
  res.Update()

Catch

End

