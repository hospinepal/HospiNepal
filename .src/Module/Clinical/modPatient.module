''-------------------------- Encounter Lock ---------------------------------------
Public Function LockEncounterTable(encid As String, sType As String) As Boolean

  Dim res As Result
  Dim rs As Result
  Dim xx As Boolean

  rs = modDatabase.$myConn.Exec("select fldid from tblenclock where fldencounterval=&1 and fldlocktype=&2 and fldhostmac<>&3", encid, sType, modGeneralMain.$MACAddress)
  If rs.Available = False Then
    res = modDatabase.$myConn.Create("tblenclock")
    res["fldencounterval"] = encid
    res["fldlocktype"] = sType
    res["fldhostmac"] = modGeneralMain.$MACAddress
    res.Update
    xx = True
  Else
    xx = False
  Endif

  Return xx

End

Public Function LockEncounterDesk(encid As String) As Boolean

  Dim xx As Boolean

  If modBasic.$PatientEncLock = "Yes" Then
    xx = LockEncounterTable(encid, modHelpVariable.$LogInCategory)
  Else
    xx = True
  Endif
  Return xx
  ''dont catch error. Allow roll back

End

Public Sub ReleaseLockEncounter(encid As String, sType As String)

  modDatabase.$myConn.Delete("tblenclock", "fldencounterval=&1 and fldlocktype=&2 and fldhostmac=&3", encid, sType, modGeneralMain.$MACAddress)

End

Public Sub CLearAllEncounterLocks(sType As String)

  modDatabase.$myConn.Delete("tblenclock", "fldlocktype=&1", sType)
  Message.Info(("Locks Cleared"), ("OK"))

End

