Public Sub UpdateDateOfBirth(encid As String, age As Float, unit As String)

  Dim xsec As Integer
  Dim dt As Date

  If unit = "Hours" Then
    xsec = age * 60
  Else If unit = "Days" Then
    xsec = age * 60 * 24
  Else If unit = "Months" Then
    xsec = age * 60 * 24 * 30
  Else If unit = "Years" Then
    xsec = age * 60 * 24 * 365
  Endif
  xsec = 0 - xsec
  dt = DateAdd(Now(), gb.Minute, CInt(xsec))
  UpdatePatDOB(encid, dt)

End

Public Function GetAgeGroup(encid As String, Optional NowDate As Date) As String

  Dim xx As String
  Dim xnow As String

  If NowDate Then
    xnow = NowDate
  Else
    xnow = Now()
  Endif
  xx = GetAgeGroupFIxed(encid, xnow)
  Return xx

End

Public Function GetAgeGroupFIxed(encid As String, xnow As Date) As String

  Dim agrgrp As String
  Dim age As Float
  Dim xdate As Date

  xdate = GetPatientBirthDay(encid)
  If xdate Then
    age = DateDiff(xdate, xnow, gb.Day)
    If age >= 60 * 365 Then
      agrgrp = "Elderly"
    Else If age >= 20 * 365 And If age < 60 * 365 Then
      agrgrp = "Adult"
    Else If age >= 12 * 365 And If age < 20 * 365 Then
      agrgrp = "Adolescent"
    Else If age >= 2 * 365 And If age < 12 * 365 Then
      agrgrp = "Children"
    Else If age >= 365 And If age < 2 * 365 Then
      agrgrp = "Toddler"
    Else If age >= 30 And If age < 365 Then
      agrgrp = "Infant"
    Else If age < 30 Then
      agrgrp = "Neonate"
    Endif
  Else
    agrgrp = ""
  Endif

  Return agrgrp

End

Public Function GetAgeGroupCustom(encid As String, Optional NowDate As Date) As String

  Dim xx As String
  Dim age As Float
  Dim xdate As Date
  Dim xnow As Date

  Dim hFile As File
  Dim sline As String
  Dim agegrp As String[]

  If NowDate Then
    xnow = NowDate
  Else
    xnow = Now()
  Endif

  If Exist(modHelpVariable.AppDirectory &/ "agegrouping") Then
    xdate = GetPatientBirthDay(encid)
    If xdate Then
      age = DateDiff(xdate, xnow, gb.Day)
      hFile = Open modHelpVariable.AppDirectory &/ "agegrouping"
      For Each sline In hFile.Lines
        If Len(sline) Then
          agegrp = Split(sline, ";")
          If age >= CInt(agegrp[1]) And If age < CInt(agegrp[2]) Then
            xx = agegrp[0]
            Break
          Endif
        Endif
      Next
      hFile.Close()
    Endif

  Else
    xx = ""
  Endif

  Return xx

End

Public Function GetPatientAgeString(encid As String, dtnow As Date) As String

  Dim xage As String
  Dim xdate As Date

  xdate = GetPatientBirthDay(encid)
  If xdate Then
    xage = modDate.GetAgeString(xdate, dtnow)
  Else
    xage = "?"
  Endif

  Return xage

End

Public Function GetPatientPastAgeString(tbl As String, id As Variant) As String

  Dim sql As String
  Dim res As Result
  Dim xage As String
  Dim sid As String
  Dim stime As String
  Dim sencid As String
  Dim xdate As Date

  sid = "fldid"
  sencid = "fldencounterval"

  If tbl = "tblpatfindings" Then
    stime = "fldtime"
  Else If tbl = "tblpatlabtest" Then
    stime = "fldtime_sample"
  Else If tbl = "tblpatradiotest" Then
    stime = "fldtime_report"
  Else If tbl = "tblpatientexam" Then
    stime = "fldtime"
  Else If tbl = "tblpatdosing" Then
    stime = "fldtime"
  Else If tbl = "tblexamgeneral" Then
    stime = "fldtime"
  Else If tbl = "tblpatgeneral" Then
    stime = "fldtime"
  Else If tbl = "tblpatsubgeneral" Then
    stime = "fldtime"
  Else If tbl = "tblpataccgeneral" Then
    stime = "fldtime"
  Else If tbl = "tblpatplanning" Then
    stime = "fldtime"
  Else If tbl = "tblpattiming" Then
    stime = "fldfirsttime"
  Else If tbl = "tblpatientdate" Then
    stime = "fldtime"
  Else If tbl = "tblconsult" Then
    stime = "fldconsulttime"
  Else If tbl = "tblconfinement" Then
    stime = "flddeltime"
  Endif

  sql = Subst("select &1 as fldencid,&2 as fldtime from &3 where &4", sencid, stime, tbl, sid)
  res = modDatabase.$syConn.Exec(sql & "=&1", id)
  If res.Available Then
    xdate = GetPatientBirthDay(res!fldencid, modDatabase.$syConn)
    If xdate Then
      xage = modDate.GetAgeString(xdate, res!fldtime)
    Else
      xage = "?"
    Endif
  Else
    xage = ""
  Endif
  Return xage

End

