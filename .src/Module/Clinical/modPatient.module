Public Sub UpdatePatLocation(encid As String, bedno As String)

  Dim res As Result
  Dim res1 As Result
  Dim res2 As Result

  res = modDatabase.$myConn.Edit("tblencounter", "fldencounterval=&1", encid)
  res["fldcurrlocat"] = bedno
  res["xyz"] = False
  res.Update()

  res2 = modDatabase.$myConn.Edit("tbldepartmentbed", "fldencounterval=&1", encid)
  If res2.Available Then
    res2["fldencounterval"] = ""
    res2.Update
  Endif

  res1 = modDatabase.$myConn.Edit("tbldepartmentbed", "fldbed=&1", bedno)
  If res1.Available Then
    res1["fldencounterval"] = encid
    res1.Update
  Endif

  If bedno Then
    EnterPatientImpDate(encid, "Location Update", bedno)
  Endif

End

Public Function GetPatientDepartment(encid As String) As String

