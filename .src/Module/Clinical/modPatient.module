  res.Update
  'don't catch error

End

Public Sub AddConsultData(encid As String, consultname As String, consulttime As Date, Optional sComment As String, Optional sUser As String, Optional sBillMode As String)

  Dim res As Result
  Dim rs As Result
  Dim xx As String
  Dim sbill As String

  If sUser Then
    xx = sUser
  Else
    xx = ""
  Endif
  If sBillMode Then
    sbill = sBillMode
  Else
    sbill = ""
  Endif

  res = modDatabase.$myConn.Create("tblconsult")
  res["fldencounterval"] = encid
  res["fldconsultname"] = consultname
  res["fldconsulttime"] = consulttime
  res["fldcomment"] = sComment
  res["fldstatus"] = "Planned"
  res["flduserid"] = xx
  res["fldbillingmode"] = sbill
  res["fldorduserid"] = modGeneralMain.$lbluser
  res["fldtime"] = Now()
  res["fldcomp"] = modGeneralMain.compID
  res["fldsave"] = False
  res["xyz"] = False
  res.Update

  EnterPatientImpDate(encid, "Registered", "")
  rs = modDatabase.$myConn.Edit("tblencounter", "fldencounterval=&1", encid)
  If Not rs["fldcurrlocat"] Then
    rs["fldcurrlocat"] = consultname
  Endif
  If rs["fldadmission"] <> "Admitted" Then
    rs["fldadmission"] = "Registered"
  Endif
  rs["xyz"] = False
  rs.Update
  'don't catch error

End

Public Sub UpdateConsultData(id As Long, status As String, comment As String)

  Dim res As Result

  res = modDatabase.$myConn.Edit("tblconsult", "fldid=&1", id)
  res["fldcomment"] = comment
  res["fldstatus"] = status
  res["fldsave"] = True
  res["xyz"] = False
  res.Update
  'don't catch error

End

Public Function GetPatientCOnsultList(encid As String) As String[]

  Dim xxx As String[]
  Dim res As Result

  xxx = New String[]
  res = modDatabase.$myConn.Exec("select fldconsultname,fldconsulttime,fldstatus from tblconsult where fldencounterval=&1", encid)
  If res.Available Then
    For Each res
      If modBasic.$ShowDayMedReport = "Yes" Then
        xxx.Add(modReportVar.GetDateTimeReport(res!fldconsulttime, gb.GeneralDate) & " : " & res!fldconsultname & " (" & res!fldstatus & ")")
      Else
        xxx.Add(res!fldconsultname & " (" & res!fldstatus & ")")
      Endif
    Next
  Endif
  Return xxx

End

