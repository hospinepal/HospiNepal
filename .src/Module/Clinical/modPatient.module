Public Function GetAccDemographicOptionList(sName As String, sType As String) As String[]

  Dim res As Result
  Dim opt As String[]

  res = modDatabase.$myConn.Exec("select fldanswer from tblaccdemogoption where flddemoid=&1 and fldanswertype like &2 ORDER BY fldindex", sName, sType)
  opt = modFillContainer.GetListFromResult(res)

  Return opt

End

''------------------------------ Patient SUbscripts --------------------------------
Public Sub GetPatientNoPrefixes()

  Dim res As Result

  res = modDatabase.$myConn.Exec("select fldid,fldpatno,fldpatlen,fldencid,fldenclen,fldbooking,fldbooklen,fldhospcode from tblpatsubs")
  If res.Available Then
    res.MoveLast
    If res!fldhospcode Then
      modBasic.$HospCode = res!fldhospcode
    Else
      modBasic.$HospCode = ""
    Endif
    If res!fldpatno Then
      modBasic.$PatNoPrefix = res!fldpatno
    Else
      modBasic.$PatNoPrefix = ""
    Endif
    If res!fldencid Then
      modBasic.$EncIdPrefix = res!fldencid
    Else
      modBasic.$EncIdPrefix = ""
    Endif
    If res!fldbooking Then
      modBasic.$BookNoPrefix = res!fldbooking
    Else
      modBasic.$BookNoPrefix = ""
    Endif

    If res!fldpatlen Then
      modBasic.$PatNoLen = res!fldpatlen
    Else
      modBasic.$PatNoLen = 0
    Endif
    If res!fldenclen Then
      modBasic.$EncIdLen = res!fldenclen
    Else
      modBasic.$EncIdLen = 0
    Endif
    If res!fldbooklen Then
      modBasic.$BookNoLen = res!fldbooklen
    Else
      modBasic.$BookNoLen = 0
    Endif

  Else
    modBasic.$HospCode = ""
    modBasic.$PatNoPrefix = ""
    modBasic.$EncIdPrefix = ""
    modBasic.$BookNoPrefix = ""
    modBasic.$PatNoLen = 0
    modBasic.$EncIdLen = 0
    modBasic.$BookNoLen = 0
  Endif

End

''----------------------------------- BOOKING ------------------------------------------
Public Function GetPatFullNameBooking(bookid As String) As String

  Dim res As Result
  Dim xx As String
  Dim firname As String
  Dim lstname As String

  res = modDatabase.$myConn.Exec("select fldptnamefir,fldptnamelast from tblpatientbook where fldbookingval=&1", bookid)
  If res.Available Then
    If res!fldptnamefir Then
      firname = res!fldptnamefir
    Else
      firname = ""
    Endif
    If res!fldptnamelast Then
      lstname = res!fldptnamelast
    Else
      lstname = ""
    Endif

    If modBasic.$PatNameFormat = "Name+Surname" Then
      xx = firname & Space(1) & lstname
    Else If modBasic.$PatNameFormat = "Surname+Name" Then
      xx = lstname & Space(1) & firname
    Else
      xx = firname & Space(1) & lstname
    Endif

  Else
    xx = ""
  Endif

  Return xx

End

Public Sub UpdateBookingTable(bookid As String, patno As String)

  Dim res As Result

  res = modDatabase.$myConn.Edit("tblpatientbook", "fldbookingval=&1", bookid)
  res["fldpatientval"] = patno
  res["fldstate"] = "Done"
  res["xyz"] = False
  res.Update
  'don't catch error

End

Public Sub PrintRegistExtraReport(encid As String)

  Dim hCls As CReportCustom
  Dim res As Result
  Dim xregist As String
  Dim xlateregist As String

  res = modDatabase.$myConn.Exec("select fldvisit from tblencounter where fldencounterval=&1", encid)
  xregist = modSettings.ShowSettingFromFIle("RegistrationForm/Template")
  xlateregist = modSettings.ShowSettingFromFIle("RegistrationLaterForm/Template")
  If res!fldvisit Then
    If res!fldvisit = "NEW" Then
      If xregist Then
        hCls = New CReportCustom(encid, xregist)
        hCls.Preview()
      Endif
    Else If res!fldvisit = "OLD" Then
      If xregist Then
        hCls = New CReportCustom(encid, xregist)
        hCls.Preview()
      Endif
    Endif

  Else
    If xregist Then
      hCls = New CReportCustom(encid, xregist)
      hCls.Preview()
    Endif
  Endif

End

Public Sub PrintExtraReport(encid As String, sType As String)

  Dim hCls As CReportCustom
  Dim xval As String

  xval = modSettings.ShowSettingFromFIle("ExtraPrint/" & sType)
  If xval Then
    hCls = New CReportCustom(encid, xval, modSettings.ShowSettingFromFIle("ExtraPrintMode/" & sType))
    hCls.Preview()
  Endif

End

Public Function PatientParameterPresent(patno As String) As Boolean

  Dim sql As String
  Dim res As Result
  Dim xx As Boolean

  sql = "select fldptaddvill,fldptadddist,fldptcontact,fldptguardian,fldptbirday,fldptadmindate,fldemail,fldrelation,fldptcode from tblpatientinfo where fldpatientval = &1 "                                    ''"
  res = modDatabase.$myConn.Exec(sql, patno)

  xx = True
  If res.Available Then
    If modBasic.$RegistEssAddress = "Yes" Then
      If Not res!fldptaddvill Then
        xx = False
      Endif
    Endif

    If modBasic.$RegistEssDistrict = "Yes" Then
      If Not res!fldptadddist Then
        xx = False
      Endif
    Endif

    If modBasic.$RegistEssAge = "Yes" Then
      If Not res!fldptbirday Then
        xx = False
      Endif
    Endif

    If modBasic.$RegistEssGuardian = "Yes" Then
      If Not res!fldptguardian Then
        xx = False
      Endif
    Endif

    If modBasic.$RegistEssRelation = "Yes" Then
      If Not res!fldrelation Then
        xx = False
      Endif
    Endif

    If modBasic.$RegistEssContact = "Yes" Then
      If Not res!fldptcontact Then
        xx = False
      Endif
    Endif

    If modBasic.$RegistEssEMail = "Yes" Then
      If Not res!fldemail Then
        xx = False
      Endif
    Endif

    If modBasic.$RegistEssCode = "Yes" Then
      If Not res!fldptcode Then
        xx = False
      Endif
    Endif
  Endif
  Return xx

End

Public Sub PopUpPatientForm(encid As String, sTag As String)

  Dim hForm As FmIndexForm
  Dim patno As String
  Dim xset As String

  xset = modGlobalSetting.ShowSettingFromDB("PatientFormPopUp/" & sTag)
  If xset = "Yes" Then
    patno = GetPatientNoByEnc(encid)
    If PatientParameterPresent(patno) = False Then
      hForm = New FmIndexForm(patno, False)
      hForm.Show()
    Endif
  Endif

End

''------------------------------------ Assign device -------------------------------------------
Public Sub SetPatientDevice(encid As String, sType As String, sDevice As String)

  Dim rs As Result
  Dim res As Result

  modBasic.DebugString("Setting webcam device for patient")
  rs = modDatabase.$myConn.Exec("select flddevicepath from tblpatdevice where flddevicetype=&1 and fldencounterval=&2", sType, encid)
  If rs.Available = False Then
    res = modDatabase.$myConn.Create("tblpatdevice")
    res["fldencounterval"] = encid
    res["flddevicetype"] = sType
    res["flddevicepath"] = sDevice
    res["fldhostmac"] = modGeneralMain.$MACAddress
    res["fldhostuser"] = System.User.Name
    res["fldhostip"] = modGeneralMain.$localIP
    res["fldhostname"] = System.Host
    res["fldcomp"] = modGeneralMain.compID
    res.Update

  Else
    res = modDatabase.$myConn.Edit("tblpatdevice", "flddevicetype=&1 and fldencounterval=&2", sType, encid)
    res["flddevicepath"] = sDevice
    res["fldhostmac"] = modGeneralMain.$MACAddress
    res["fldhostuser"] = System.User.Name
    res["fldhostip"] = modGeneralMain.$localIP
    res["fldhostname"] = System.Host
    res["fldcomp"] = modGeneralMain.compID
    res.Update

  Endif

End

''---------------------------------------------- QUOTA (fixed parameters) ---------------------------------------------------------------
Public Function GetPatientQuota(sDept As String, sDate As Date, sBillMode As String, sUserid As String) As Integer

  Dim res As Result
  Dim res1 As Result
  Dim res2 As Result
  Dim xx As Integer

  If modBasic.$RegistQuotaQueMode = "ConsultOnly" Then
    res = modDatabase.$myConn.Exec("select SUM(fldquota) as tot from tbldepconsult where flddate>=&1 and flddate<=&2 and fldselect=&3 and flduserid=&4 and fldcomp like &5 and fldmethod=&6", modDate.StartSqlDate(sDate), modDate.EndSqlDate(sDate), "Specific", sUserid, modGeneralMain.compID, "ConsultOnly")
    If res!tot Then
      xx = res!tot
    Else
      res1 = modDatabase.$myConn.Exec("select SUM(fldquota) as tot from tbldepconsult where fldselect=&1 and flduserid=&2 and fldcomp like &3 and fldmethod=&4", modDate.GetWeekDay(sDate), sUserid, modGeneralMain.compID, "ConsultOnly")
      If res1!tot Then
        xx = res1!tot
      Else
        res2 = modDatabase.$myConn.Exec("select SUM(fldquota) as tot from tbldepconsult where fldselect=&1 and flduserid=&2 and fldcomp like &3 and fldmethod=&4", "AllDays", sUserid, modGeneralMain.compID, "ConsultOnly")
        If res2!tot Then
          xx = res2!tot
        Else
          xx = 0
        Endif
      Endif
    Endif

  Else If modBasic.$RegistQuotaQueMode = "Consult+Mode" Then
    res = modDatabase.$myConn.Exec("select SUM(fldquota) as tot from tbldepconsult where flddate>=&1 and flddate<=&2 and fldselect=&3 and fldbillingmode like &4 and flduserid=&5 and fldcomp like &6 and fldmethod=&7", modDate.StartSqlDate(sDate), modDate.EndSqlDate(sDate), "Specific", sBillMode, sUserid, modGeneralMain.compID, "Consult+Mode")
    If res!tot Then
      xx = res!tot
    Else
      res1 = modDatabase.$myConn.Exec("select SUM(fldquota) as tot from tbldepconsult where fldselect=&1 and fldbillingmode like &2 and flduserid=&3 and fldcomp like &4 and fldmethod=&5", modDate.GetWeekDay(sDate), sBillMode, sUserid, modGeneralMain.compID, "Consult+Mode")
      If res1!tot Then
        xx = res1!tot
      Else
        res2 = modDatabase.$myConn.Exec("select SUM(fldquota) as tot from tbldepconsult where fldselect=&1 and fldbillingmode like &2 and flduserid=&3 and fldcomp like &4 and fldmethod=&5", "AllDays", sBillMode, sUserid, modGeneralMain.compID, "Consult+Mode")
        If res2!tot Then
          xx = res2!tot
        Else
          xx = 0
        Endif
      Endif
    Endif

  Else
    If sUserid Then
      res = modDatabase.$myConn.Exec("select SUM(fldquota) as tot from tbldepconsult where flddate>=&1 and flddate<=&2 and (flddept like &3 or flddept=&7) and fldselect=&4 and fldbillingmode like &5 and flduserid=&6 and fldcomp like &8 and fldmethod=&9", modDate.StartSqlDate(sDate), modDate.EndSqlDate(sDate), sDept, "Specific", sBillMode, sUserid, "%", modGeneralMain.compID, "AllParam")
    Else
      res = modDatabase.$myConn.Exec("select SUM(fldquota) as tot from tbldepconsult where flddate>=&1 and flddate<=&2 and (flddept like &3 or flddept=&6) and fldselect=&4 and fldbillingmode like &5 and fldcomp like &7 and fldmethod=&8", modDate.StartSqlDate(sDate), modDate.EndSqlDate(sDate), sDept, "Specific", sBillMode, "%", modGeneralMain.compID, "AllParam")
    Endif
    If res!tot Then
      xx = res!tot
    Else
      If sUserid Then
        res1 = modDatabase.$myConn.Exec("select SUM(fldquota) as tot from tbldepconsult where flddept like &1 and fldselect=&2 and fldbillingmode like &3 and flduserid=&4 and fldcomp like &5 and fldmethod=&6", sDept, modDate.GetWeekDay(sDate), sBillMode, sUserid, modGeneralMain.compID, "AllParam")
      Else
        res1 = modDatabase.$myConn.Exec("select SUM(fldquota) as tot from tbldepconsult where flddept like &1 and fldselect=&2 and fldbillingmode like &3 and fldcomp like &4 and fldmethod=&5", sDept, modDate.GetWeekDay(sDate), sBillMode, modGeneralMain.compID, "AllParam")
      Endif
      If res1!tot Then
        xx = res1!tot
      Else
        If sUserid Then
          res2 = modDatabase.$myConn.Exec("select SUM(fldquota) as tot from tbldepconsult where flddept like &1 and fldselect=&2 and fldbillingmode like &3 and flduserid=&4 and fldcomp like &5 and fldmethod=&6", sDept, "AllDays", sBillMode, sUserid, modGeneralMain.compID, "AllParam")
        Else
          res2 = modDatabase.$myConn.Exec("select SUM(fldquota) as tot from tbldepconsult where flddept like &1 and fldselect=&2 and fldbillingmode like &3 and fldcomp like &4 and fldmethod=&5", sDept, "AllDays", sBillMode, modGeneralMain.compID, "AllParam")
        Endif
        If res2!tot Then
          xx = res2!tot
        Else
          xx = 0
        Endif
      Endif
    Endif

  Endif
  Return xx

End

Public Function GetUserPostingList(sDept As String, sDate As Date, sBillMode As String) As String[]

  Dim res As Result
  Dim res1 As Result
  Dim res2 As Result
  Dim xx As String[]
  Dim yy As String[]

  xx = New String[]
  If modBasic.$RegistQuotaQueMode = "ConsultOnly" Then
    res = modDatabase.$myConn.Exec("select distinct(flduserid) as doc from tbldepconsult where flddate>=&1 and flddate<=&2 and fldselect=&3 and fldcomp like &4 and fldmethod=&5", modDate.StartSqlDate(sDate), modDate.EndSqlDate(sDate), "Specific", modGeneralMain.compID, "ConsultOnly")
    If res.Available Then
      For Each res
        If res!doc Then
          xx.Add(res!doc)
        Endif
      Next
    Endif
    res1 = modDatabase.$myConn.Exec("select distinct(flduserid) as doc from tbldepconsult where fldselect=&1 and fldcomp like &2 and fldmethod=&3", modDate.GetWeekDay(sDate), modGeneralMain.compID, "ConsultOnly")
    If res1.Available Then
      For Each res1
        If res1!doc Then
          xx.Add(res1!doc)
        Endif
      Next
    Endif
    res2 = modDatabase.$myConn.Exec("select distinct(flduserid) as doc from tbldepconsult where fldselect=&1 and fldcomp like &2 and fldmethod=&3", "AllDays", modGeneralMain.compID, "ConsultOnly")
    If res2.Available Then
      For Each res2
        If res2!doc Then
          xx.Add(res2!doc)
        Endif
      Next
    Endif

  Else If modBasic.$RegistQuotaQueMode = "Consult+Mode" Then
    res = modDatabase.$myConn.Exec("select distinct(flduserid) as doc from tbldepconsult where flddate>=&1 and flddate<=&2 and fldselect=&3 and fldbillingmode like &4 and fldcomp like &5 and fldmethod=&6", modDate.StartSqlDate(sDate), modDate.EndSqlDate(sDate), "Specific", sBillMode, modGeneralMain.compID, "Consult+Mode")
    If res.Available Then
      For Each res
        If res!doc Then
          xx.Add(res!doc)
        Endif
      Next
    Endif
    res1 = modDatabase.$myConn.Exec("select distinct(flduserid) as doc from tbldepconsult where fldselect=&1 and fldbillingmode like &2 and fldcomp like &3 and fldmethod=&4", modDate.GetWeekDay(sDate), sBillMode, modGeneralMain.compID, "Consult+Mode")
    If res1.Available Then
      For Each res1
        If res1!doc Then
          xx.Add(res1!doc)
        Endif
      Next
    Endif
    res2 = modDatabase.$myConn.Exec("select distinct(flduserid) as doc from tbldepconsult where fldselect=&1 and fldbillingmode like &2 and fldcomp like &3 and fldmethod=&4", "AllDays", sBillMode, modGeneralMain.compID, "Consult+Mode")
    If res2.Available Then
      For Each res2
        If res2!doc Then
          xx.Add(res2!doc)
        Endif
      Next
    Endif

  Else
    res = modDatabase.$myConn.Exec("select distinct(flduserid) as doc from tbldepconsult where flddate>=&1 and flddate<=&2 and flddept like &3 and fldselect=&4 and fldbillingmode like &5 and fldcomp like &6 and fldmethod=&7", modDate.StartSqlDate(sDate), modDate.EndSqlDate(sDate), sDept, "Specific", sBillMode, modGeneralMain.compID, "AllParam")
    If res.Available Then
      For Each res
        If res!doc Then
          xx.Add(res!doc)
        Endif
      Next
    Endif
    res1 = modDatabase.$myConn.Exec("select distinct(flduserid) as doc from tbldepconsult where flddept like &1 and fldselect=&2 and fldbillingmode like &3 and fldcomp like &4 and fldmethod=&5", sDept, modDate.GetWeekDay(sDate), sBillMode, modGeneralMain.compID, "AllParam")
    If res1.Available Then
      For Each res1
        If res1!doc Then
          xx.Add(res1!doc)
        Endif
      Next
    Endif
    res2 = modDatabase.$myConn.Exec("select distinct(flduserid) as doc from tbldepconsult where flddept like &1 and fldselect=&2 and fldbillingmode like &3 and fldcomp like &4 and fldmethod=&5", sDept, "AllDays", sBillMode, modGeneralMain.compID, "AllParam")
    If res2.Available Then
      For Each res2
        If res2!doc Then
          xx.Add(res2!doc)
        Endif
      Next
    Endif

  Endif

  If xx.Count Then
    yy = modString.GetDistinctStringArray(xx)
  Else
    yy = xx
  Endif

  Return yy

End

''------------------------------------ Quota (patient parameters)
Public Function GetPatientBooked(sType As String, sDept As String, sDate As Date, sBillMode As String, sUserid As String) As Integer

  Dim res As Result
  Dim xx As Integer

  If modBasic.$RegistQuotaQueMode = "ConsultOnly" Then
    res = modDatabase.$myConn.Exec("select COUNT(fldbookingval) as tot from tblpatientbook where fldconsultdate>=&1 and fldconsultdate<=&2 and flduserid=&3 and fldstate like &4 and fldcomp=&5", modDate.StartSqlDate(sDate), modDate.EndSqlDate(sDate), sUserid, sType, modGeneralMain.compID)

  Else If modBasic.$RegistQuotaQueMode = "Consult+Mode" Then
    res = modDatabase.$myConn.Exec("select COUNT(fldbookingval) as tot from tblpatientbook where fldconsultdate>=&1 and fldconsultdate<=&2 and fldbillingmode like &3 and flduserid=&4 and fldstate like &5 and fldcomp=&6", modDate.StartSqlDate(sDate), modDate.EndSqlDate(sDate), sBillMode, sUserid, sType, modGeneralMain.compID)

  Else
    If sUserid Then
      res = modDatabase.$myConn.Exec("select COUNT(fldbookingval) as tot from tblpatientbook where fldconsultdate>=&1 and fldconsultdate<=&2 and fldadmitlocat like &3 and fldbillingmode like &4 and flduserid=&5 and fldstate like &6 and fldcomp=&7", modDate.StartSqlDate(sDate), modDate.EndSqlDate(sDate), sDept, sBillMode, sUserid, sType, modGeneralMain.compID)                                                  ''
    Else
      res = modDatabase.$myConn.Exec("select COUNT(fldbookingval) as tot from tblpatientbook where fldconsultdate>=&1 and fldconsultdate<=&2 and fldadmitlocat like &3 and fldbillingmode like &4 and fldstate like &5 and fldcomp=&6", modDate.StartSqlDate(sDate), modDate.EndSqlDate(sDate), sDept, sBillMode, sType, modGeneralMain.compID)                                                  ''
    Endif

  Endif
  If res!tot Then
    xx = res!tot
  Else
    xx = 0
  Endif
  Return xx

End

