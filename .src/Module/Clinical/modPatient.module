Public Function EnableClinicForm(xStatus As String) As Boolean

  Dim fme As Boolean

  If xStatus = "Registered" Or If xStatus = "Admitted" Then
    fme = True
  Else If xStatus = "Discharged" Or If xStatus = "LAMA" Or If xStatus = "Death" Or If xStatus = "Refer" Or If xStatus = "Absconder" Then
    fme = False
  Else If xStatus = "Recorded" Or If xStatus = "FollowUp" Then
    If modGlobalSetting.ShowSettingFromDB("GeneralSettings/Clinic_LockNonRegistered") = "Yes" Then
      fme = False
    Else
      fme = True
    Endif
  Endif
  Return fme

End

Public Function AllowEncIDHistory(encid As String, sCon As Connection) As Boolean

  Dim xval As Boolean
  Dim xx As String

  xx = CurrentAdmissionStatus(encid)
  If xx = "Discharged" Or If xx = "LAMA" Or If xx = "Death" Or If xx = "Refer" Or If xx = "Absconder" Then
    If GetPatPassCheck(sCon, GetPatientNoByEnc(encid)) = True Then
      xval = True
    Else
      xval = False
    Endif
  Else
    xval = True
  Endif
  Return xval

End

Public Function UpdateCurrentStatus(encid As String, status As String, sComment As String)

  Dim res As Result
  Dim res1 As Result

  res = modDatabase.$myConn.Edit("tblencounter", "fldencounterval=&1", encid)
  res["fldadmission"] = status
  If status = "Discharged" Or If status = "LAMA" Or If status = "Death" Or If status = "Refer" Or If status = "Absconder" Then
    res["flddod"] = Now()
  Endif
  res["xyz"] = False
  res.Update

  If status = "Discharged" Or If status = "LAMA" Or If status = "Death" Or If status = "Refer" Or If status = "Absconder" Then
    res1 = modDatabase.$myConn.Edit("tbldepartmentbed", "fldencounterval=&1", encid)
    If res1.Available Then
      res1["fldencounterval"] = ""
      res1.Update
    Endif
  Endif

  EnterPatientImpDate(encid, status, sComment)

End

