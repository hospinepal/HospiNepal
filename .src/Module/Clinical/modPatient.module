        bilmode = res!fldbillingmode
        If modBasic.$LocalCache = "Yes" Then
          $PatBillMode.Add(bilmode, encid)
        Endif
      Else
        bilmode = ""
      Endif
    Else
      bilmode = ""
    Endif
  Endif
  Return bilmode

End

