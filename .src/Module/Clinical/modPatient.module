  xval = GetEncoutnerCountFromPatNo(ptno)
  If xval Then
    xx = "OLD"
  Else
    xx = "NEW"
  Endif
  Return xx

End

Public Function GetPatientEncFromID(tbl As String, id As Variant) As String

  Dim sql As String
  Dim res As Result
  Dim xenc As String
  Dim sid As String
  Dim sencid As String

  If tbl = "tblpatfindings" Then
    sid = "fldid"
    sencid = "fldencounterval"
  Else If tbl = "tblpatlabtest" Then
    sid = "fldid"
    sencid = "fldencounterval"
  Else If tbl = "tblpatradiotest" Then
    sid = "fldid"
    sencid = "fldencounterval"
  Else If tbl = "tblpatientexam" Then
    sid = "fldid"
    sencid = "fldencounterval"
  Else If tbl = "tblpatdosing" Then
    sid = "fldid"
    sencid = "fldencounterval"
  Else If tbl = "tblexamgeneral" Then
    sid = "fldid"
    sencid = "fldencounterval"
  Else If tbl = "tblpatgeneral" Then
    sid = "fldid"
    sencid = "fldencounterval"
  Else If tbl = "tblpatsubgeneral" Then
    sid = "fldid"
    sencid = "fldencounterval"
  Else If tbl = "tblencounter" Then
    sid = "fldencounterval"
    sencid = "fldencounterval"
  Else If tbl = "tblpatplanning" Then
    sid = "fldid"
    sencid = "fldencounterval"
  Else If tbl = "tblconfinement" Then
    sid = "fldid"
    sencid = "fldencounterval"
  Else If tbl = "tblpatientdate" Then
    sid = "fldid"
    sencid = "fldencounterval"
  Endif

  sql = Subst("select &1 as fldencid from &2 where &3", sencid, tbl, sid)
  res = modDatabase.$myConn.Exec(sql & "=&1", id)
  If res.Available Then
    If res!fldencid Then
      xenc = res!fldencid
    Else
      xenc = ""
    Endif
  Else
    xenc = ""
  Endif
  Return xenc

End

Public Function GetPatPassCheck(sCon As Connection, patno As String) As Boolean

  Dim res As Result
  Dim xx As Boolean
  Dim xval As String
  Dim xpass As String

  res = sCon.Exec("select fldpassword from tblpatientinfo where fldpatientval=&1", patno)
  If res.Available Then
    If res!fldpassword Then
      xval = InputPassword(("Provide Patient Password"), "Password", "")
      If xval Then
        xpass = modPassword.EncryptSimple(xval)
        If res!fldpassword = xpass Then
          xx = True
        Else
          xx = False
        Endif
      Else
        xx = False
      Endif
    Else
      xx = True
    Endif
  Else
    xx = False
  Endif
  Return xx

End

''------------------------ Billing Mode
Public Function GetPatBillingMode(encid As String) As String

  Dim res As Result
