  res = modDatabase.$myConn.Exec("select flddept from tbldepartmentbed where fldbed in(select fldcurrlocat from tblencounter where fldencounterval=&1)", encid)
  If res.Available Then
    If res!flddept Then
      bedno = res!flddept
    Else
      bedno = ""
    Endif
  Else
    bedno = ""
  Endif
  Return bedno

End

