Public Function PaientAllTestNameArray(encid As String) As String[]

  Dim res As Result
  Dim xx As String[]

  res = modDatabase.$myConn.Exec("select distinct(fldtestid) as col from tblpatlabtest where fldencounterval=&1 and (fldstatus=&2 or fldstatus=&3)", encid, "Reported", "Verified")
  xx = modFillContainer.GetListFromResult(res)

  Return xx.Sort()

End

