' Gambas module file

'''----------------------------- Procedures for test ------------------------------------------------------------
Public Sub InsertLabTestOrder(encid As String, strTest As String, strType As String, strMethod As String, grpid As Long, sRefer As String, sBillNo As String, sComment As String)

  Dim res As Result

  res = modDatabase.$myConn.Create("tblpatlabtest")
  res["fldencounterval"] = encid
  res["fldtestid"] = strTest
  res["fldmethod"] = strMethod
  res["fldgroupid"] = grpid
  res["fldsampleid"] = ""
  res["fldsampletype"] = ""
  res["fldreportquali"] = ""
  res["fldreportquanti"] = 0
  res["fldfilepath"] = ""
  res["fldstatus"] = "Ordered"
  res["fldprint"] = False
  res["fldabnormal"] = False
  res["xyz"] = False
  res["fldrefername"] = sRefer
  res["fldcondition"] = ""
  res["fldcomment"] = sComment
  res["fldbillno"] = sBillNo
  res["flvisible"] = "Visible"

  res["fldtestunit"] = ""
  res["fldtest_type"] = strType
  res["fldchk"] = False
  res["fldorder"] = 0

  res["flduserid_sample"] = ""
  res["fldtime_sample"] = ""
  res["fldcomp_sample"] = modGeneralMain.compID
  res["fldsave_sample"] = False
  res["flduptime_sample"] = ""

  res["flduserid_start"] = ""
  res["fldtime_start"] = ""
  res["fldcomp_start"] = ""
  res["fldsave_start"] = False
  res["flduptime_start"] = ""

  res["flduserid_report"] = ""
  res["fldtime_report"] = ""
  res["fldcomp_report"] = ""
  res["fldsave_report"] = False
  res["flduptime_report"] = ""

  res["flduserid_verify"] = ""
  res["fldtime_verify"] = ""
  res["fldcomp_verify"] = ""
  res["fldsave_verify"] = False
  res["flduptime_verify"] = ""

  res.Update()
  'don't catch error

End

Public Sub UpdateLabTestSample(id As Long, sampleID As String, strTampleType As String, strRefer As String, strCondi As String, strComment As String, sBillNo As String, Optional sDate As Date)

  Dim res As Result

  res = modDatabase.$myConn.Edit("tblpatlabtest", "fldid=&1", id)
  res["fldsampleid"] = sampleID
  res["fldsampletype"] = strTampleType
  res["fldstatus"] = "Sampled"
  If strRefer Then
    res["fldrefername"] = strRefer
  Endif
  If strCondi Then
    res["fldcondition"] = strCondi
  Endif
  If strComment Then
    res["fldcomment"] = strComment
  Endif
  If sBillNo Then
    res["fldbillno"] = sBillNo
  Endif

  res["flduserid_sample"] = modGeneralMain.$lbluser
  If sDate Then
    res["fldtime_sample"] = sDate
    res["flduptime_sample"] = Now()
  Else
    If res!fldtime_sample Then
      res["flduptime_sample"] = Now()
    Else
      res["fldtime_sample"] = Now()
    Endif
  Endif
  res["fldcomp_sample"] = modGeneralMain.compID
  res["fldsave_sample"] = True
  res["xyz"] = False
  res.Update()
  'don't catch error

End

Public Sub InsertLabSubTest(encid As String, pttestid As Long, subtestList As String[])

  Dim res2 As Result
  Dim xx As String

  For Each xx In subtestList
    res2 = modDatabase.$myConn.Create("tblpatlabsubtest")
    res2["fldencounterval"] = encid
    res2["fldtestid"] = pttestid
    res2["fldsubtest"] = xx
    res2["fldtanswertype"] = modFixLab.GetSubTestOption(GetTestnameFromTestID(pttestid), xx)
    res2["fldreport"] = ""
    res2["fldsave"] = False
    res2["fldabnormal"] = False
    res2["fldchk"] = False
    res2["fldorder"] = 0
    res2["fldfilepath"] = ""
    res2["xyz"] = False
    res2.Update()
  Next
  'don't catch error

End

Public Sub UpdateLabTestReportQuali(id As Long, strReport As String, abn As Boolean, Optional KeyList As String)

  Dim res As Result

  res = modDatabase.$myConn.Edit("tblpatlabtest", "fldid=&1", id)
  res["fldreportquali"] = strReport
  If IsFloat(strReport) = True Then
    res["fldreportquanti"] = CFloat(strReport)
  Else
    res["fldreportquanti"] = 0
  Endif
  If KeyList Then
    res["fldfilepath"] = KeyList
  Endif
  res["fldstatus"] = "Reported"
  res["flduserid_report"] = modGeneralMain.$lbluser
  If res!fldtime_report Then
    res["flduptime_report"] = Now()
  Else
    res["fldtime_report"] = Now()
  Endif
  res["fldcomp_report"] = modGeneralMain.compID
  res["fldsave_report"] = True
  res["fldabnormal"] = abn
  res["xyz"] = False
  res.Update()
  'don't catch error

End

