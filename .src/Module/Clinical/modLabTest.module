'NOTE: -------------------------------- LAB SETTINGS ---------------------------------------
Public Sub DisplayDefaultTestUnit(rbSI As Radiobutton, rbMetric As Radiobutton)

  Dim def As String

  def = modSettings.ShowSettingFromFIle("TestUnit/Default")
  If def Then
    If def = "SI" Then
      rbSI.Value = True
    Else If def = "Metric" Then
      rbMetric.Value = True
    Endif
  Else
    rbMetric.Value = True
  Endif

End

Public Function GetTestUnitFromButton(rbsi As RadioButton, rbmetric As RadioButton) As String

  Dim unt As String

  If rbsi.Value = True Then
    unt = "SI"
  Else If rbmetric.Value = True Then
    unt = "Metric"
  Else
    unt = "Metric"
  Endif
  Return unt

End

Public Function GetAutoIncreasingNo() As String

  Dim xsampauto As String
  Dim xprefix As String

  xprefix = modBasic.$LabSamplePrefix
  If modBasic.$LabAutoSampNo = "Yes" Then
    xsampauto = xprefix & CStr(modNonMedical.CurrentLabNo())
  Else
    xsampauto = xprefix
  Endif
  Return xsampauto

End

Public Function ListFooterNoteList() As String[]

  Dim i As Integer
  Dim xx As String
  Dim xval As String[]

  xval = New String[]
  For i = 1 To 50
    xx = modSettings.ShowSettingFromFIle("FooterNote/Name_" & CStr(i))
    If xx Then
      xval.Add(xx)
    Endif
  Next
  Return xval

End

