Public Sub mnudel_Click()

  If GridView1.Rows.Selection.Count > 0 Then
    modDatabase.$myConn.Delete("tblpatbilling", "fldid=&1 and fldsave=&2 and fldprint=&3 and fldstatus=&4", GridView1[GridView1.Row, 0].Text, False, False, "Punched")
    ShowReturnGrid()
  Endif

End

Public Sub mnudelall_Click()

  Dim i As Integer

  For i = 0 To GridView1.Rows.Count - 1
    modDatabase.$myConn.Delete("tblpatbilling", "fldid=&1 and fldsave=&2 and fldprint=&3 and fldstatus=&4", GridView1[i, 0].Text, False, False, "Punched")
  Next
  ShowReturnGrid()

End

Public Sub mnusave_Click()

  If $encid Then
    SaveReturnData()
    If ShowBilling() = True Then
      hPatient1.txtdiscamt.SetFocus
    Endif
  Endif

End

Private Sub SaveReturnData()

  Dim sql As String
  Dim res As Result
  Dim res1 As Result
  Dim res3 As Result

  sql = "select fldid,flditemtype,flditemno,flditemname,flditemqty,fldparent,fldencounterval from tblpatbilling where fldencounterval=&1 and fldsave=&2 and fldprint=&3 and fldordcomp=&4 and fldstatus=&5 and flditemqty<&6 and (flditemtype<>&7 or flditemtype<>&8 or flditemtype<>&9)"
  res = modDatabase.$myConn.Exec(sql, $encid, False, False, modGeneralMain.compID, "Punched", 0, "Medicines", "Surgicals", "Extra Items")
  If res.Available = True Then
    Inc Application.Busy
    modDatabase.$myConn.Begin
    For Each res
      res1 = modDatabase.$myConn.Exec("select flditemqty,fldretqty from tblpatbilling where fldid=&1", res!fldparent)
      If (0 - res!flditemqty) <= (res1!flditemqty - res1!fldretqty) Then
        ''update parent bill with return qty
        modBillings.UpdateReturnBillQTY(res!fldparent, res!fldencounterval, res!flditemname, res!flditemqty)
        ''update current record
        res3 = modDatabase.$myConn.Edit("tblpatbilling", "fldid=&1", res!fldid)
        res3["fldstatus"] = "Done"
        res3["fldsave"] = True
        res3["flduserid"] = modGeneralMain.$lbluser
        res3["fldtime"] = Now()
        res3["fldcomp"] = modGeneralMain.compID
        res3["xyz"] = False
        res3.Update()
      Endif
    Next
    modDatabase.$myConn.Commit
    Dec Application.Busy
    ShowReturnGrid()
    ShowReturnDoneGrid()
  Endif

Catch
  modDatabase.$myConn.Rollback
  Dec Application.Busy
  modHelpVariable.CreateErrorReport()

End

Public Sub cmbroute_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbroute)
  modFillContainer.RestrictComboToContent(cmbroute)

End

Public Sub cmbmedicine_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbmedicine)
  modFillContainer.RestrictComboToContent(cmbmedicine)

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub GridView1_Menu()

  mnuhide.Popup

End

Public Sub rbBill_Click()

  modSettings.SaveSettingsToFile("Billing/ReturnMode", "Invoice")
  txtbill.SetFocus

End

Public Sub rbEncid_Click()

  modSettings.SaveSettingsToFile("Billing/ReturnMode", "Encounter")
  txtbill.SetFocus

End

Public Sub mnualitem_Click()

  Dim res As Result
  Dim rsx As Result
  Dim qty As Float

  If rbBill.Value = True Then
    rsx = modDatabase.$myConn.Exec("select fldid from tblpatbilling where fldretbill=&1", Trim(txtbill.Text))
    If rsx.Available = False Then

      res = modDatabase.$myConn.Exec("select fldid,fldencounterval,flditemtype,flditemno,flditemname,flditemrate,flditemqty,fldtaxper,flddiscper,fldparent,fldpayto,fldrefer,fldtarget,fldbillno,fldbillingmode from tblpatbilling where fldbillno=&1 and (fldstatus=&2 or fldstatus=&3)", Trim(txtbill.Text), "Cleared", "Sampled")
      If res.Available Then
        Inc Application.Busy
        modDatabase.$myConn.Begin
        For Each res
          qty = 0 - res!flditemqty
          modBillings.InsertBlankBillItem(res!fldencounterval, res!fldbillingmode, res!flditemtype, res!flditemno, res!flditemname, res!flditemrate, qty, res!fldtaxper, res!flddiscper, "Punched", res!fldid, False, False, res!fldtarget, res!fldpayto, res!fldrefer, cmbreason.Text, res!fldbillno)
        Next
        modDatabase.$myConn.Commit
        Dec Application.Busy
        ShowReturnGrid()
        cmbroute.SetFocus
      Endif

    Endif
  Endif

Catch
  modDatabase.$myConn.Rollback
  Dec Application.Busy
  modHelpVariable.CreateErrorReport()

End

Public Sub txtbill_KeyPress()

  If Key.Code = Key.Down Then
    If modBasic.$AutoEncSuffix = "Yes" Then
      txtbill.Text = txtbill.Text & modBasic.$HospCode
    Endif
  Else
    modGeneralMain.InputUpCaseOnly()
  Endif

End
