# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,52,64)
  Text = ("New Consultation")
  Resizable = False
  { !txtencid TextBox
    MoveScaled(14,1,17,3)
    #Public = True
  }
  { btnshow Button
    MoveScaled(38,1,13,3)
    Text = Shortcut(("Show"), "S")
    Picture = Picture["icon:/small/play"]
  }
  { cmbbillmode ComboBox
    MoveScaled(14,9,37,3)
  }
  { cmbdept ComboBox
    MoveScaled(14,13,37,3)
    Sorted = True
  }
  { dtconsultdate DateChooser
    MoveScaled(1,21,50,30)
  }
  { dtconsultime DateBox
    MoveScaled(8,52,13,3)
    Mode = DateChooser.TimeOnly
  }
  { btnconsult ButtonBox
    MoveScaled(14,17,34,3)
    Picture = Picture["icon:/small/people"]
    ReadOnly = True
  }
  { TextArea1 TextArea
    MoveScaled(1,56,50,7)
    Tag = "Auto"
    Wrap = True
    ScrollBar = Scroll.Vertical
  }
  { btnadd Button
    MoveScaled(28,52,11,3)
    Text = ("Add")
    Picture = Picture["icon:/small/add"]
  }
  { Label1 Label
    MoveScaled(1,1,12,3)
    Text = ("Encounter ID")
    Border = Border.Plain
  }
  { Label2 Label
    MoveScaled(1,5,12,3)
    Text = ("Pat Name")
    Border = Border.Plain
  }
  { txtpatientname TextBox
    MoveScaled(14,5,37.5333,3)
    Font = Font["Bold"]
    ReadOnly = True
  }
  { Label4 Label
    MoveScaled(1,13,12,3)
    Text = ("Department")
    Border = Border.Plain
  }
  { Label5 Label
    MoveScaled(1,52,6,3)
    Text = ("Time")
    Border = Border.Plain
  }
  { dtnepcal ToolButton
    MoveScaled(22,52,3,3)
    Picture = Picture["icon:/small/calendar"]
  }
  { Label20 Label
    MoveScaled(1,17,12,3)
    Text = ("Consultant")
    Border = Border.Plain
  }
  { btnsms ToolButton
    MoveScaled(48,17,3,3)
    Picture = Picture["icon:/small/phone"]
  }
  { Label3 Label
    MoveScaled(1,9,12,3)
    Text = ("Billing Mode")
    Border = Border.Plain
  }
  { btnbill Button
    MoveScaled(40,52,11,3)
    Text = ("Bill")
    Picture = Picture["icon:/small/bookmark"]
  }
}
