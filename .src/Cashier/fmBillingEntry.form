# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,116,13)
  Tag = "Billing Form"
  { Panel2 Panel
    MoveScaled(0,0,116,13)
    { !txtdiscamt ValueBox
      MoveScaled(56,1,11,3)
      #Public = True
      ReadOnly = True
    }
    { txttaxamt ValueBox
      MoveScaled(56,5,11,3)
      ReadOnly = True
    }
    { txtrecvamt ValueBox
      MoveScaled(101,1,15,3)
      Font = Font["Bold"]
    }
    { btnsave Button
      MoveScaled(87,9,14,3)
      Enabled = False
      Tag = "Auto"
      Text = Shortcut(("Print"), "P")
      Picture = Picture["icon:/small/print"]
    }
    { btnblank Button
      MoveScaled(101,9,15,3)
      Tag = "Auto"
      Text = Shortcut(("Clear"), "C")
      Picture = Picture["icon:/small/clear"]
    }
    { Label1 Label
      MoveScaled(0,1,12.7333,3)
      Text = ("Prev Deposit")
      Border = Border.Plain
    }
    { Label2 Label
      MoveScaled(0,5,12.7333,3)
      Text = ("Amount Due")
      Border = Border.Plain
    }
    { Label4 Label
      MoveScaled(41,5,5.5333,3)
      Text = ("TAX")
      Border = Border.Plain
    }
    { Label5 Label
      MoveScaled(41,1,5.5333,3)
      Text = ("DISC")
      Border = Border.Plain
    }
    { Label6 Label
      MoveScaled(41,9,10.5333,3)
      Text = ("Total AMT")
      Border = Border.Plain
    }
    { txttotalamt ValueBox
      MoveScaled(52,9,15,3)
      ReadOnly = True
    }
    { Label7 Label
      MoveScaled(87,1,13.5333,3)
      Text = ("Recv Amount")
      Border = Border.Plain
    }
    { Label8 Label
      MoveScaled(87,5,13.5333,3)
      Text = ("Curr Deposit")
      Border = Border.Plain
    }
    { Label3 Label
      MoveScaled(53,5,2,3)
      Text = ("%")
      Alignment = Align.Center
      Border = Border.Plain
    }
    { Label10 Label
      MoveScaled(53,1,2,3)
      Text = ("%")
      Alignment = Align.Center
      Border = Border.Plain
    }
    { Panel1 Panel
      MoveScaled(0,9,28,3)
      { rbcash RadioButton
        MoveScaled(0,0,13,3)
        Text = ("Cash Mode")
      }
      { rbcredit RadioButton
        MoveScaled(14,0,14,3)
        Text = ("Credit Mode")
      }
    }
    { txttaxper ValueBox
      MoveScaled(47,5,6,3)
      Enabled = False
      ReadOnly = True
    }
    { txtdiscper ValueBox
      MoveScaled(47,1,6,3)
      Enabled = False
      ReadOnly = True
    }
    { txtcurrdeposit ValueBox
      MoveScaled(101,5,15,3)
      Font = Font["Bold"]
      ReadOnly = True
    }
    { txtprevdeposit ValueBox
      MoveScaled(13,1,15,3)
      Font = Font["Bold"]
      ReadOnly = True
    }
    { txtamtdue ValueBox
      MoveScaled(13,5,15,3)
      Font = Font["Bold"]
      ReadOnly = True
    }
    { btncalc Button
      MoveScaled(83,9,3,3)
      Picture = Picture["icon:/small/calculator"]
    }
    { txtvalcalc ValueBox
      MoveScaled(76,9,6,3)
      Visible = False
    }
    { chkcheq CheckBox
      MoveScaled(76,1,10,3)
      Text = ("Cheque")
    }
    { btndisccategory ToolButton
      MoveScaled(67,1,2.5333,3)
      Picture = Picture["icon:/small/right"]
    }
    { btntaxcategory ToolButton
      MoveScaled(67,5,2.5333,3)
      Picture = Picture["icon:/small/right"]
    }
  }
}
