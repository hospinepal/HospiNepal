''========================================================= Pharmacy =====================================
Public Sub rbgeneric_Click()

  modSettings.SaveSettingsToFile("BrandOrGeneric/Dispensing", "Generic")

End

Public Sub rbrand_Click()

  modSettings.SaveSettingsToFile("BrandOrGeneric/Dispensing", "Brand")

End

Private Function GetBrandGenerricType() As String

  Dim brandOrGeneric As String

  If rbrand.Value = True Then
    brandOrGeneric = "Brand"
  Else
    brandOrGeneric = "Generic"
  Endif
  Return brandOrGeneric

End

Public Sub rborder_Click()

  If txtencid.Text Then
    FillDosingGrid()
  Endif

End

Public Sub rbdisp_Click()

  If txtencid.Text Then
    FillDosingGrid()
  Endif

End

Public Sub FillDosingGrid()

  Dim sql As String
  Dim Column As Integer
  Dim fld As ResultField

  If rborder.Value = True Then
    sql = "select fldid,fldtime_order,fldroute,flditem,flddose,fldfreq,flddays,fldqtydisp,fldlabel,flduserid_order,flddiscper,fldtaxper from tblpatdosing where fldencounterval=&1 and fldsave_order=&2 ORDER BY fldid DESC"                                                   ''
    $rData3 = modDatabase.$myConn.Exec(sql, Trim(txtencid.Text), False)
  Else If rbdisp.Value = True Then
    sql = "select fldid,fldtime_order,fldroute,flditem,flddose,fldfreq,flddays,(fldqtydisp-fldqtyret) as qty,fldlabel,flduserid_order,flddiscper,fldtaxper from tblpatdosing where fldencounterval=&1 and fldcomp=&2 and fldsave_order=&3 ORDER BY fldid DESC"                                                   ''
    $rData3 = modDatabase.$myConn.Exec(sql, Trim(txtencid.Text), modGeneralMain.compID, True)
  Endif

  GridView3.Clear
  GridView3.Columns.Count = $rData3.Fields.Count
  GridView3.Rows.Count = $rData3.Count

  For Each $rData3
    Column = 0
    For Each fld In $rData3.Fields
      modGeneralMain.GridExplicitDecoration(GridView3, $rData3.Index, Column)
      If Column = 1 Then
        GridView3[$rData3.Index, Column].Text = modReportVar.GetDateTimeReport($rData3["fldtime_order"], gb.GeneralDate)
      Else If Column = 8 Then
        GridView3[$rData3.Index, Column].Picture = Picture[modGridView.SetGridCheckIcon($rData3["fldlabel"])]
        GridView3[$rData3.Index, Column].Text = ""
      Else
        GridView3[$rData3.Index, Column].Text = $rData3[fld.Name]
      Endif
      Column = Column + 1
    Next
  Next
  GridView3.Row = 0

  With GridView3
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 60 * modBasic.$AppWidthRatio
    .Columns[1].Width = 150 * modBasic.$AppWidthRatio
    .Columns[2].Width = 75 * modBasic.$AppWidthRatio
    .Columns[3].Width = 350 * modBasic.$AppWidthRatio
    .Columns[4].Width = 75 * modBasic.$AppWidthRatio
    .Columns[5].Width = 50 * modBasic.$AppWidthRatio
    .Columns[6].Width = 50 * modBasic.$AppWidthRatio
    .Columns[7].Width = 50 * modBasic.$AppWidthRatio
    .Columns[8].Width = 20
    .Columns[9].Width = 75 * modBasic.$AppWidthRatio
    .Columns[10].Width = 75 * modBasic.$AppWidthRatio
    .Columns[11].Width = 75 * modBasic.$AppWidthRatio

    .Columns[0].Text = "ID"
    .Columns[1].Text = "DateTime"
    .Columns[2].Text = "Route"
    .Columns[3].Text = "Particulars"
    .Columns[4].Text = "Dose"
    .Columns[5].Text = "Freq"
    .Columns[6].Text = "Day"
    .Columns[7].Text = "QTY"
    .Columns[9].Text = "User"
    .Columns[10].Text = "Disc%"
    .Columns[11].Text = "Tax%"
  End With
  txtsubtotalitem.Value = Round(TotalDispensedAmount(), -2)

End

Private Function TotalDispensedAmount() As Float

  Dim amt As Float
  Dim i As Integer
  Dim xval As Float
  Dim discper As Float
  Dim taxper As Float

  amt = 0
  For i = 0 To GridView3.Rows.Count - 1
    If GridView3[i, 10].Text Then
      taxper = GridView3[i, 10].Text
    Else
      taxper = 0
    Endif
    If GridView3[i, 11].Text Then
      discper = GridView3[i, 11].Text
    Else
      discper = 0
    Endif
    xval = 0
    xval = modStock.GetToDispenseCostOneComp(GridView3[i, 3].Text, modBasic.$BillTargetPharmacy, CFloat(GridView3[i, 6].Text), CFloat(GridView3[i, 7].Text))
    amt = amt + xval * (1 - discper / 100) * (1 + taxper / 100)
  Next

  Return amt

End

''--------------------- Array for Items to Load ----------------------------
Private Sub IniateCategoryPharmArray()

  $MSurgicalLst = New String[]
  $ExtraItemLst = New String[]
  $OralBrandLst = New String[]
  $OralGenricLst = New String[]
  $InjBrandLst = New String[]
  $InjGenricLst = New String[]
  $LiqBrandLst = New String[]
  $LiqGenricLst = New String[]

End

Private Function GetPharmCategoryArray(sRoute As String, sMode As String) As String[]

  Dim xarry As String[]

  If sRoute = "oral" Then
    If sMode = "Brand" Then
      If Not $OralBrandLst.Count Then
        $OralBrandLst.Insert(modFillContainer.GetListFromResult(modStock.FillMedicinesDispensingComboResult(sRoute, sMode, "", modBasic.$BillTargetPharmacy)))
      Endif
      xarry = $OralBrandLst
    Else If sMode = "Generic" Then
      If Not $OralGenricLst.Count Then
        $OralGenricLst.Insert(modFillContainer.GetListFromResult(modStock.FillMedicinesDispensingComboResult(sRoute, sMode, "", modBasic.$BillTargetPharmacy)))
      Endif
      xarry = $OralGenricLst
    Endif

  Else If sRoute = "liquid" Then
    If sMode = "Brand" Then
      If Not $LiqBrandLst.Count Then
        $LiqBrandLst.Insert(modFillContainer.GetListFromResult(modStock.FillMedicinesDispensingComboResult(sRoute, sMode, "", modBasic.$BillTargetPharmacy)))
      Endif
      xarry = $LiqBrandLst
    Else If sMode = "Generic" Then
      If Not $LiqGenricLst.Count Then
        $LiqGenricLst.Insert(modFillContainer.GetListFromResult(modStock.FillMedicinesDispensingComboResult(sRoute, sMode, "", modBasic.$BillTargetPharmacy)))
      Endif
      xarry = $LiqGenricLst
    Endif

  Else If sRoute = "injection" Then
    If sMode = "Brand" Then
      If Not $InjBrandLst.Count Then
        $InjBrandLst.Insert(modFillContainer.GetListFromResult(modStock.FillMedicinesDispensingComboResult(sRoute, sMode, "", modBasic.$BillTargetPharmacy)))
      Endif
      xarry = $InjBrandLst
    Else If sMode = "Generic" Then
      If Not $InjGenricLst.Count Then
        $InjGenricLst.Insert(modFillContainer.GetListFromResult(modStock.FillMedicinesDispensingComboResult(sRoute, sMode, "", modBasic.$BillTargetPharmacy)))
      Endif
      xarry = $InjGenricLst
    Endif

  Else If sRoute = "msurg" Then
    If Not $MSurgicalLst.Count Then
      $MSurgicalLst.Insert(modFillContainer.GetListFromResult(modStock.FillMedicinesDispensingComboResult(sRoute, sMode, "", modBasic.$BillTargetPharmacy)))
    Endif
    xarry = $MSurgicalLst

  Else If sRoute = "extra" Then
    If Not $ExtraItemLst.Count Then
      $ExtraItemLst.Insert(modFillContainer.GetListFromResult(modStock.FillMedicinesDispensingComboResult(sRoute, sMode, "", modBasic.$BillTargetPharmacy)))
    Endif
    xarry = $ExtraItemLst

  Else
    xarry = modFillContainer.GetListFromResult(modStock.FillMedicinesDispensingComboResult(sRoute, sMode, "", modBasic.$BillTargetPharmacy))
  Endif

  Return xarry

End

''------------------medicine entry ---------------------------------------
Public Sub cmbroute_Click()

  chksavenew.Value = False
  cmbmedicine.Clear
  cmbmedicine.Text = ""
  txtdose.Enabled = True
  cmbfreq.Enabled = True
  txtday.Enabled = True

End

Public Sub cmbroute_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbroute)
  modFillContainer.RestrictComboToContent(cmbroute)

End

Public Sub cmbmedicine_GotFocus()

  Dim res As Result

  If Not cmbroute.Text Then
    cmbroute.SetFocus

  Else If cmbroute.Text Then
    If Not cmbmedicine.Text Then
      If modBasic.$ItemListFormat = "ComboBox" Then
      Else
        txtdose.Tag = "Auto"
        txtdose.Parent.Tag = "Auto"

        If modBasic.$LocalCache = "Yes" Then
          cmbmedicine.Enabled = False
          cmbmedicine.Text = GridViewNew("Select Particulars", GetPharmCategoryArray(cmbroute.Text, GetBrandGenerricType()), False)
          cmbmedicine.Enabled = True
        Else
          res = modStock.FillMedicinesDispensingComboResult(cmbroute.Text, GetBrandGenerricType(), "", modBasic.$BillTargetPharmacy)
          cmbmedicine.Enabled = False
          cmbmedicine.Text = GridViewNew("Select Particulars", modFillContainer.GetListFromResult(res), False)
          cmbmedicine.Enabled = True
        Endif

        If Not cmbmedicine.Text Then
          txtdose.SetFocus
        Endif
      Endif
    Endif

  Endif

End

Public Sub cmbmedicine_KeyRelease()

  modStock.FillMedicinesDispensingCombo(cmbroute.Text, cmbmedicine, GetBrandGenerricType(), modBasic.$BillTargetPharmacy)

End

Public Sub txtdose_GotFocus()

  If cmbmedicine.Text Then
    If modStock.GetComboControl(cmbroute.Text, cmbmedicine.Text, rbgeneric, rbrand, modDatabase.$medConn) = False Then
      cmbmedicine.Text = ""
      Balloon.Warning(("Item not listed"), cmbmedicine)
      Balloon.Delay = modBasic.$BalloonDelay
      cmbroute.SetFocus
    Else

      txtinventory.Value = modStock.GetCurrentStockOneComp(cmbmedicine.Text, modBasic.$BillTargetPharmacy)
      If modStock.GetCurrentExpiredStockOneComp(cmbmedicine.Text, modBasic.$BillTargetPharmacy) = True Then
        txtinventory.Background = Color.Orange
      Else
        txtinventory.Background = Color.LightGray
      Endif
      If cmbroute.Text = "suture" Or If cmbroute.Text = "msurg" Or If cmbroute.Text = "ortho" Or If cmbroute.Text = "extra" Then
        txtdose.Enabled = False
        cmbfreq.Enabled = False
        txtday.Enabled = False
        txtqtymed.SetFocus
      Else
        If rbrand.Value = True Then
          cmbmedicine.Text = modMedConstant.ConvertBrandToGeneric(cmbroute.Text, cmbmedicine.Text)
        Endif
        txtdose.Enabled = True
        cmbfreq.Enabled = True
        txtday.Enabled = True

        If modBasic.$MedDoseRecommend = "Yes" Then
          txtdose.Value = modMedDosing.RecommendedDoseDrug(Trim(txtencid.Text), cmbmedicine.Text)
          cmbfreq.Text = modMedDosing.RecommendedFrequencyDrug(Trim(txtencid.Text), cmbmedicine.Text)
        Endif

      Endif

    Endif
  Endif

End

Public Sub cmbfreq_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbfreq)
  modFillContainer.RestrictComboToContent(cmbfreq)

End

Public Sub txtday_LostFocus()

  Dim xval As Float

  If txtdose.Value And If cmbfreq.Text Then
    xval = modMedConstant.GetQuantityDosing(cmbmedicine.Text, txtdose.Value, cmbfreq.Text, txtday.Value)
    lblqty.Text = Round(xval, -1)
    txtqtymed.Value = Ceil(xval)
  Endif

End

Public Sub txtqtymed_GotFocus()

  If txtdose.Value And If cmbfreq.Text Then
    If Not txtday.Value Then
      txtday.SetFocus
    Endif
  Endif

End

Public Sub chksavenew_GotFocus()

  Dim xx As Float

  If Not txtqtymed.Value Then
    txtqtymed.SetFocus
  Else
    xx = modStock.GetToDispenseStockOneComp(cmbmedicine.Text, modBasic.$BillTargetPharmacy, txtday.Value)
    If txtqtymed.Value > xx Then
      txtqtymed.SetFocus
      Balloon.Warning(("QTY Allowed: ") & xx, txtqtymed)
      Balloon.Delay = modBasic.$BalloonDelay
    Endif
  Endif

End

Public Sub chksavenew_Click()

  If chksave.Value Then
    If txtencid.Text And If cmbroute.Text And If cmbmedicine.Text And If txtqtymed.Value Then
      EnterDosingRecord()
      cmbroute.SetFocus
    Endif
  Endif

End

Public Sub chksavenew_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    chksavenew.Value = True
    chksavenew_Click()
  Endif

End

''----------------------------- save entry and display grid ------------------------------
Private Sub EnterDosingRecord()

  Dim sType As String
  Dim txprescriber As String
  Dim txpresno As String
  Dim dispmode As String
  Dim xtax As Float
  Dim discval As Float
  Dim itemtype As String

  sType = modPatient.CurrentAdmissionStatus(Trim(txtencid.Text))
  dispmode = "OPD"

  If chksave.Value = True Then
    If txtencid.Text And If cmbroute.Text And If cmbmedicine.Text And If txtqtymed.Value Then

      If cmbroute.Text = "suture" Or If cmbroute.Text = "msurg" Or If cmbroute.Text = "ortho" Or If cmbroute.Text = "extra" Then
        itemtype = modNonMedical.GetBillItemCategoryFromCombo(cmbroute.Text)
        xtax = modNonMedical.ShowTaxValues(itemtype, cmbmedicine.Text)
        discval = modNonMedical.DiscPercentForItem(Trim(txtencid.Text), itemtype, cmbmedicine.Text)
        Inc Application.Busy
        modPharmacy.InsertNonMedDosingEntry(Trim(txtencid.Text), cmbroute.Text, cmbmedicine.Text, txtqtymed.Value, sType, 0, xtax, discval, "UseOwn", dispmode)
        Dec Application.Busy

      Else
        If modMedConstant.GetNarcoticType(cmbmedicine.Text) = "Yes" Then
          txprescriber = MedicalSelectedUser(("Select Narcotic Prescriber"), modBasic.$OPConsulUserList)
          txpresno = modGeneral.GetPrescriberCodeFromName(txprescriber)
          If Not txpresno Then
            txpresno = InputBox(("Prescriber's Registration No"), ("Narcotic Record"), "")
          Endif
        Else
          txprescriber = ""
          txpresno = ""
        Endif
        itemtype = modNonMedical.GetBillItemCategoryFromCombo(cmbroute.Text)
        xtax = modNonMedical.ShowTaxValues(itemtype, cmbmedicine.Text)
        discval = modNonMedical.DiscPercentForItem(Trim(txtencid.Text), itemtype, cmbmedicine.Text)
        Inc Application.Busy
        modPharmacy.InsertDosingEntry(Trim(txtencid.Text), cmbroute.Text, cmbmedicine.Text, txtdose.Value, cmbfreq.Text, txtday.Value, txtqtymed.Value, sType, txprescriber, txpresno, 0, xtax, discval, "UseOwn", dispmode)                    '
        Dec Application.Busy
      Endif

      BlankDosingBox()
      FillDosingGrid()
    Endif
  Endif

End

Public Sub GridView3_Click()

  Dim xval As Float
  Dim yval As String
  Dim col As Integer
  Dim row As Integer

  Dim fixtax As String
  Dim fixdisc As String

  col = GridView3.Column
  row = GridView3.Row
  If GridView3.Column = 8 Then
    If GridView3[GridView3.Row, 4].Text And If GridView3[GridView3.Row, 5].Text And If GridView3[GridView3.Row, 6].Text Then
      modGridView.CheckUncheckGrid(modDatabase.$myConn, GridView3, 8, "fldlabel", "fldid", "tblpatdosing", GridView3[GridView3.Row, 0].Text)
    Endif

  Else If GridView3.Column = 4 Then
    xval = InputValue(GridView3[GridView3.Row, 3].Text, ("Change Value"), GridView3[GridView3.Row, 4].Text)
    If xval > 0 Then
      modPharmacy.UpdateDoseBefDispensing(GridView3[GridView3.Row, 0].Text, xval)
      FillDosingGrid()
    Endif
  Else If GridView3.Column = 5 Then
    yval = InputCombo(GridView3[GridView3.Row, 3].Text, ("Change Value"), modMedicine.FrequencyCombo(), GridView3[GridView3.Row, 5].Text, True)
    If yval Then
      modPharmacy.UpdateFreqBefDispensing(GridView3[GridView3.Row, 0].Text, yval)
      FillDosingGrid()
    Endif
  Else If GridView3.Column = 6 Then
    xval = InputValue(GridView3[GridView3.Row, 3].Text, ("Change Value"), GridView3[GridView3.Row, 6].Text)
    If xval > 0 Then
      modPharmacy.UpdateDaysBefDispensing(GridView3[GridView3.Row, 0].Text, xval)
      FillDosingGrid()
    Endif
  Else If GridView3.Column = 7 Then
    xval = InputValue(GridView3[GridView3.Row, 3].Text, ("Change Value"), GridView3[GridView3.Row, 7].Text)
    If xval > 0 Then
      modPharmacy.UpdateQTYBefDispensing(GridView3[GridView3.Row, 0].Text, xval)
      FillDosingGrid()
    Endif

  Else If GridView3.Column = 11 Then
    fixtax = modBasic.$BillFixTax
    If fixtax = "No" Then
      If modSettings.ShowSettingFromFIle("BillingSettings/EditTaxDiscount") = "Amount" Then
      Else
        xval = InputValue(GridView3[GridView3.Row, 3].Text, ("Change Tax Percentage"), GridView3[GridView3.Row, 11].Text)
        If xval >= 0 And If xval <= 100 Then
          modPharmacy.UpdateTaxPerDispensing(GridView3[GridView3.Row, 0].Text, xval)
          FillDosingGrid()
        Endif
      Endif
    Endif
  Else If GridView3.Column = 10 Then
    fixdisc = modBasic.$BillFixDisc
    If fixdisc = "No" Then
      If modSettings.ShowSettingFromFIle("BillingSettings/EditTaxDiscount") = "Amount" Then
      Else
        xval = InputValue(GridView3[GridView3.Row, 3].Text, ("Change Discount Percentage"), GridView3[GridView3.Row, 10].Text)
        If xval >= 0 And If xval <= 100 Then
          modPharmacy.UpdateDiscPerDispensing(GridView3[GridView3.Row, 0].Text, xval)
          FillDosingGrid()
        Endif
      Endif
    Endif

  Endif
  GridView3.Column = col
  GridView3.Row = row

End

''--------------------------------- billing---------------------------
Private Sub PharmacySave()

  Dim sql1 As String
  Dim res1 As Result

  Dim tax As Float
  Dim disc As Float

  Dim res2 As Result
  Dim sql2 As String
  Dim qtynew As Float

  Dim patno As String
  Dim DiscType As String

  If txtencid.Text And If cmbmode.Text Then
    patno = $PatientNum
    DiscType = $DiscPackage

    If rborder.Value = True Then
      sql1 = "select fldid,fldtime,fldroute,flditem,flddose,fldfreq,flddays,fldqtydisp,fldlabel,flditemtype,fldtaxper,flddiscper from tblpatdosing where fldencounterval=&1 and fldsave_order=&2 and fldqtydisp>&3"                                                   ''
      res1 = modDatabase.$myConn.Exec(sql1, Trim(txtencid.Text), False, 0)
      If res1.Available = True Then

        Inc Application.Busy
        modDatabase.$myConn.Begin
        For Each res1
          'get tax and discount percentages
          If res1!fldtaxper Then
            tax = res1!fldtaxper
          Else
            tax = 0
          Endif
          If res1!flddiscper Then
            disc = res1!flddiscper
          Else
            disc = 0
          Endif

          qtynew = res1!fldqtydisp
          While qtynew > 0
            'get stockno, rate and quantity based on expiry check
            If modBasic.$SkipExpiry = "ExpireOnUse" Then
              sql2 = "select fldstockno,fldstockid,fldcategory,fldexpiry,fldqty,fldstatus,fldsellpr from tblentry where fldstockid=&1 and fldcomp=&2 and fldstatus=&3 and fldexpiry>&4 and fldqty>&5"
              res2 = modDatabase.$myConn.Exec(sql2, res1!flditem, modBasic.$BillTargetPharmacy, 1, DateAdd(modDate.StartSqlDate(Now()), gb.Day, CInt(res1!flddays)), 0)
            Else If modBasic.$SkipExpiry = "Expired" Then
              sql2 = "select fldstockno,fldstockid,fldcategory,fldexpiry,fldqty,fldstatus,fldsellpr from tblentry where fldstockid=&1 and fldcomp=&2 and fldstatus=&3 and fldexpiry>&4 and fldqty>&5"
              res2 = modDatabase.$myConn.Exec(sql2, res1!flditem, modBasic.$BillTargetPharmacy, 1, modDate.StartSqlDate(Now()), 0)
            Else
              sql2 = "select fldstockno,fldstockid,fldcategory,fldexpiry,fldqty,fldstatus,fldsellpr from tblentry where fldstockid=&1 and fldcomp=&2 and fldstatus=&3 and fldqty>&4"
              res2 = modDatabase.$myConn.Exec(sql2, res1!flditem, modBasic.$BillTargetPharmacy, 1, 0)
            Endif
            If res2.Count = 0 Then
              Break
            Else If res2.Count > 0 Then
              If qtynew <= res2!fldqty Then
                modBillings.InsertBlankBillItem(Trim(txtencid.Text), cmbmode.Text, res2!fldcategory, res2!fldstockno, res2!fldstockid, res2!fldsellpr, qtynew, tax, disc, "Done", res1!fldid, True, False)
                modStock.AddToExistEntry(res2!fldstockno, (0 - qtynew), modBasic.$BillTargetPharmacy)
                qtynew = 0
              Else If qtynew > res2!fldqty Then
                modBillings.InsertBlankBillItem(Trim(txtencid.Text), cmbmode.Text, res2!fldcategory, res2!fldstockno, res2!fldstockid, res2!fldsellpr, res2!fldqty, tax, disc, "Done", res1!fldid, True, False)
                modStock.AddToExistEntry(res2!fldstockno, (0 - res2!fldqty), modBasic.$BillTargetPharmacy)
                qtynew = qtynew - res2!fldqty
              Endif
            Endif
          Wend

          If qtynew > 0 Then
            modPharmacy.DuplicateRecordWithQTY(res1!fldid, qtynew)
            modPharmacy.UpdateQTYBefDispensing(res1!fldid, res1!fldqtydisp - qtynew)
          Endif
          modPharmacy.UpdateDispensing(res1!fldid, False)
        Next
        modDatabase.$myConn.Commit
        Dec Application.Busy

      Endif
    Endif

  Endif

Catch
  modDatabase.$myConn.Rollback
  Dec Application.Busy
  modHelpVariable.CreateErrorReport()

End

Public Sub GridView3_Menu()

  mnupharm.Popup

End

Public Sub mnuselallph_Click()

  Dim i As Integer

  For i = 0 To GridView3.Rows.Count - 1
    If GridView3[i, 4].Text And If GridView3[i, 5].Text And If GridView3[i, 6].Text Then
      GridView3[i, 8].Picture = modBasic.$PictureChecked
    Endif
  Next

End

Public Sub mnudselalph_Click()

  Dim i As Integer

  For i = 0 To GridView3.Rows.Count - 1
    GridView3[i, 8].Picture = modBasic.$PictureUnchecked
  Next

End

Public Sub mnudelph_Click()

  If rborder.Value = True Then
    If GridView3.Rows.Selection.Count > 0 Then
      modDatabase.$myConn.Delete("tblpatdosing", "fldid=&1 and fldsave_order=&2", GridView3[GridView3.Row, 0].Text, False)
      FillDosingGrid()
    Endif
  Endif

End

Public Sub mnudelallph_Click()

  Dim i As Integer

  If rborder.Value = True Then
    For i = 0 To GridView3.Rows.Count - 1
      modDatabase.$myConn.Delete("tblpatdosing", "fldid=&1 and fldsave_order=&2", GridView3[i, 0].Text, False)
    Next
    FillDosingGrid()
  Endif

End

Public Sub mnustock_Click()

  Dim hForm As FRequest
  Dim sql As String
  Dim res As Result

  If GridView3.Rows.Selection.Count > 0 Then
    sql = "select fldstockno,fldstockid,fldbatch,fldexpiry,fldqty,fldsellpr,fldstatus,fldcomp from tblentry where fldstockid=&1"
    res = modDatabase.$myConn.Exec(sql, GridView3[GridView3.Row, 3].Text)
    If res.Available Then
      hForm = New FRequest(res, GridView3[GridView3.Row, 3].Text, "StockDB", False)
      hForm.ShowModal
    Endif
  Endif

End

Public Sub mnucost_Click()

  Dim xx As String
  Dim cstamt As Float
  Dim discper As Float
  Dim taxper As Float

  If GridView3.Rows.Selection.Count > 0 Then
    cstamt = modStock.GetToDispenseCostOneComp(GridView3[GridView3.Row, 3].Text, modBasic.$BillTargetPharmacy, CFloat(GridView3[GridView3.Row, 6].Text), CFloat(GridView3[GridView3.Row, 7].Text))
    taxper = GridView3[GridView3.Row, 10].Text
    discper = GridView3[GridView3.Row, 11].Text

    xx = "<b>" & GridView3[GridView3.Row, 3].Text & "</b>" & "<br>"
    xx = xx & "Item Cost: " & modReportVar.GetLocaleNumberFormat(cstamt, gb.Currency) & "<br>"
    xx = xx & "Tax: " & modReportVar.GetLocaleNumberFormat(cstamt * taxper / 100, gb.Currency) & "<br>"
    xx = xx & "Disc: " & modReportVar.GetLocaleNumberFormat(cstamt * discper / 100, gb.Currency) & "<br>"
    xx = xx & "Total: " & modReportVar.GetLocaleNumberFormat(cstamt * (1 - discper / 100) * (1 + taxper / 100), gb.Currency)
    Message.Info(xx, ("OK"))
  Endif

End

Public Sub txtencid_KeyPress()

  If Key.Code = Key.Down Then
    If Not txtencid.Text Then
      txtencid.Text = PatSearch("Encounter")
      txtencid.SetFocus
    Else
      If modBasic.$AutoEncSuffix = "Yes" Then
        txtencid.Text = txtencid.Text & modBasic.$HospCode
      Endif
    Endif
  Else
    modGeneralMain.InputUpCaseOnly()
  Endif

End
