End

Public Sub ShowCashCreditMode()

  If hPatient.GetCashCreditMode() = "CASH" Then
    lcdmode.Text = "CASH"
    lcdmode.Foreground = Color.Green
  Else If hPatient.GetCashCreditMode() = "CREDIT" Then
    lcdmode.Text = "CREDIT"
    lcdmode.Foreground = Color.Blue
  Endif

End

Public Sub cmbtype_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbtype)
  modFillContainer.RestrictComboToContent(cmbtype)

End

Public Sub cmbitem_GotFocus()

  Dim res As Result
  Dim xdata As String[]
  Dim xcode As String

  If Not cmbtype.Text Then
    cmbtype.SetFocus

  Else If cmbtype.Text Then
    If cmbtype.Text = "Group" Then

    Else
      If Not cmbitem.Text Then
        If modBasic.$ItemListFormat = "ComboBox" Then
        Else

          If modBasic.$LocalCache = "Yes" Then
            cmbitem.Text = CashGridList(GetCategoryArray(cmbtype.Text))
          Else
            xdata = New String[]
            res = modDatabase.$myConn.Exec("select flditemname,fldcode,flditemcost,flditemunit from tblservicecost where flditemtype=&1 and (fldgroup=&2 or fldgroup=&4) and fldstatus=&3" & GetCashSectionQuery(cmbtype.Text) & " ORDER BY flditemname ASC", modNonMedical.GetBillItemCategoryFromCombo(cmbtype.Text), cmbmode.Text, "Active", "%", GetCashSectionValue(cmbtype.Text))                                                           ''
            If res.Available Then
              For Each res
                If res!fldcode Then
                  xcode = res!fldcode
                Else
                  xcode = ""
                Endif
                xdata.Add(res!flditemname & "|" & xcode & "|" & CStr(modNonMedical.GetCurrConvertAmount(res!flditemcost, res!flditemunit)))
              Next
              cmbitem.Text = CashGridList(xdata)
            Endif
          Endif

          txtdisc.SetFocus
        Endif
      Endif
    Endif
  Endif

End

Public Sub cmbitem_KeyRelease()

  If cmbtype.Text = "Group" Then
    modNonMedical.NonStockGroupItem(cmbitem)
  Else
    GetNonStockCashBilling(cmbitem, cmbtype.Text, cmbmode.Text)
  Endif

End

Public Sub txtdisc_GotFocus()

  Dim xtype As String

  If cmbitem.Text Then
    If cmbtype.Text = "Group" Then
    Else
      If modNonMedical.GetControlServCombo(cmbitem.Text) = False Then
        cmbitem.Text = ""
        Balloon.Warning(("Item not listed"), cmbitem)
        Balloon.Delay = modBasic.$BalloonDelay
        cmbtype.SetFocus
      Else
        xtype = modNonMedical.GetBillItemCategoryFromCombo(cmbtype.Text)
        txtrate.Value = modNonMedical.GetCashBillItemCost(cmbitem.Text, xtype)
        lblratemode.Text = modNonMedical.GetBillingTargeDept(cmbitem.Text, xtype)
        If cmbdisctype.Text Then
          txtdisc.Value = modNonMedical.DiscPercentForCategoryValue(cmbdisctype.Text, xtype, cmbitem.Text)
        Else
          txtdisc.Value = modNonMedical.DiscPercentForItem(Trim(txtencid.Text), xtype, cmbitem.Text)
        Endif
        txtax.Value = modNonMedical.ShowTaxValues(xtype, cmbitem.Text)
      Endif
    Endif

    If modGridView.GetItemPresentGrid(GridView1, 4, cmbitem.Text) = True Then
      Balloon.Warning(("Item already punched"), cmbitem)
      Balloon.Delay = modBasic.$BalloonDelay
    Endif

  Endif

End

Public Sub txtqty_LostFocus()

  Dim xx As Float

  If Not txtqty.Value Then
    txtqty.SetFocus
  Else
    If cmbtype.Text = "Group" Then
    Else
      xx = Round(txtrate.Value * txtqty.Value, -2)
      xx = xx * (1 - txtdisc.Value / 100)
      xx = xx * (1 + txtax.Value / 100)
      txtotal.Value = xx
    Endif
    chksave.SetFocus
  Endif

End

Private Function GetIDBillingItemForGroup(encid As String, sItem As String, sRate As Float, BillingMode As String, sComp As String) As Long

  Dim res As Result
  Dim xx As Long

  res = modDatabase.$myConn.Exec("select fldid from tblpatbilling where fldencounterval=&1 and fldbillingmode=&2 and flditemname=&3 and flditemrate=&4 and fldordcomp=&5 and fldsave=&6 and fldprint=&7 and fldstatus=&8", encid, BillingMode, sItem, sRate, sComp, False, False, "Punched")
  If res.Available Then
    res.MoveLast
    xx = res!fldid
  Endif
  Return xx

End

Private Sub InsertCashGroupEntry(sPay As String)

  Dim res As Result

  res = modDatabase.$myConn.Exec("select flditemname,flditemtype,flditemqty from tblservicegroup where fldgroup=&1 and flditemname in(select flditemname from tblservicecost where fldgroup=&2 or fldgroup=&3)", cmbitem.Text, cmbmode.Text, "%")
  If res.Available Then
    Inc Application.Busy
    modDatabase.$myConn.Begin
    For Each res
      modBillings.ServiceBillBlank(Trim(txtencid.Text), cmbmode.Text, res!flditemtype, res!flditemname, txtqty.Value * res!flditemqty, txtax.Value, txtdisc.Value, "Punched", 0, False, False, sPay, btnconsult.Tag)
    Next
    modDatabase.$myConn.Commit
    Dec Application.Busy
  Endif

Catch
  modDatabase.$myConn.Rollback
  Dec Application.Busy
  modHelpVariable.CreateErrorReport()
  modNonMedical.ReleaseLockTable("Invoice")

End

Private Sub AddEntryToBill()

  Dim sPay As String
  Dim xid As Long

  If $ShowAutoPay = "All" Then
    sPay = MedicalSelectedUser(("Select Payable User"), modBasic.$PayUserList)
  Else If $ShowAutoPay = cmbmode.Text Then
    sPay = MedicalSelectedUser(("Select Payable User"), modBasic.$PayUserList)
  Endif

  If cmbtype.Text = "Group" Then
    InsertCashGroupEntry(sPay)

  Else
    Inc Application.Busy
    modDatabase.$myConn.Begin
    If modBasic.$BillPunchItems = "Yes" Then
      xid = GetIDBillingItemForGroup(Trim(txtencid.Text), cmbitem.Text, txtrate.Value, cmbmode.Text, modGeneralMain.compID)
      If xid Then
        modBillings.UpdateGroupBillQTY(xid, Trim(txtencid.Text), cmbitem.Text, txtqty.Value)
      Else
        modBillings.ServiceBillBlank(Trim(txtencid.Text), cmbmode.Text, cmbtype.Text, cmbitem.Text, txtqty.Value, txtax.Value, txtdisc.Value, "Punched", 0, False, False, sPay, btnconsult.Tag)
      Endif
    Else
      modBillings.ServiceBillBlank(Trim(txtencid.Text), cmbmode.Text, cmbtype.Text, cmbitem.Text, txtqty.Value, txtax.Value, txtdisc.Value, "Punched", 0, False, False, sPay, btnconsult.Tag)                          ''
    Endif
    modDatabase.$myConn.Commit
    Dec Application.Busy
  Endif
  ShowNewEntry()

Catch
  modDatabase.$myConn.Rollback
  Dec Application.Busy
  modHelpVariable.CreateErrorReport()

End

Public Sub chksave_Click()

  If txtencid.Text And txtqty.Value > 0 Then
    If chksave.Value = True Then
      If cmbtype.Text And If cmbitem.Text And If txtqty.Value Then
        AddEntryToBill()
        BlankForEntry()
        cmbtype.SetFocus
      Endif
    Endif
  Endif

End

Public Sub chksave_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    chksave.Value = True
    chksave_Click()
  Endif

End

Private Sub ExecuteNewQuery()

  Dim sql As String
  Dim xcomp As String

  If chkall.Value Then
    xcomp = "%"
  Else
    xcomp = modGeneralMain.compID
  Endif

  sql = "select fldid,fldordtime,flditemtype,flditemno,flditemname,flditemrate,flditemqty,flddiscper,fldtaxper,fldditemamt,fldpayto,fldrefer,fldtaxamt,flddiscamt,fldbillingmode,fldsample from tblpatbilling where fldencounterval=&1 and fldsave=&2 and fldprint=&3 and fldordcomp like &4 and fldstatus=&5 ORDER BY fldid DESC"                                       ''
  $rData = modDatabase.$myConn.Exec(sql, Trim(txtencid.Text), False, False, xcomp, "Punched")

End

Private Sub ShowNewEntry()

  Dim xitem As Float
  Dim xx As Float
  Dim disc As Float
  Dim tax As Float
  Dim Column As Integer
  Dim fld As ResultField

  ExecuteNewQuery()
  GridView1.Clear
  GridView1.Columns.Count = $rData.Fields.Count
  GridView1.Rows.Count = $rData.Count

  xitem = 0
  tax = 0
  disc = 0
  xx = 0
  For Each $rData
    xitem = xitem + $rData!flditemrate * $rData!flditemqty
    tax = tax + $rData!fldtaxamt
    disc = disc + $rData!flddiscamt
    xx = xx + $rData!fldditemamt
    Column = 0
    For Each fld In $rData.Fields
      modGeneralMain.GridExplicitDecoration(GridView1, $rData.Index, Column)
      If Column = 1 Then
        GridView1[$rData.Index, Column].Text = modReportVar.GetDateTimeReport($rData["fldordtime"], gb.GeneralDate)
      Else If Column = 10 Then
        GridView1[$rData.Index, Column].Text = modGeneral.GetUserFullName($rData[fld.Name])
      Else If Column = 11 Then
        GridView1[$rData.Index, Column].Text = modGeneral.GetUserFullName($rData[fld.Name])
      Else
        GridView1[$rData.Index, Column].Text = $rData[fld.Name]
      Endif
      Column = Column + 1
    Next
  Next
  GridView1.Row = 0

  With GridView1
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Text = "SN"
    .Columns[1].Text = "DateTime"
    .Columns[2].Text = "Category"
    .Columns[3].Text = "Code"
    .Columns[4].Text = "Particulars"
    .Columns[5].Text = "Rate"
    .Columns[6].Text = "QTY"
    .Columns[7].Text = "Disc %"
    .Columns[8].Text = "Tax %"
    .Columns[9].Text = "Total"
    .Columns[10].Text = "Payable"
    .Columns[11].Text = "Referral"

    .Columns[0].Width = 65 * modBasic.$AppWidthRatio
    .Columns[1].Width = 150 * modBasic.$AppWidthRatio
    .Columns[2].Width = 125 * modBasic.$AppWidthRatio
    .Columns[3].Width = 40 * modBasic.$AppWidthRatio
    .Columns[4].Width = 300 * modBasic.$AppWidthRatio
    .Columns[5].Width = 75 * modBasic.$AppWidthRatio
    .Columns[6].Width = 50 * modBasic.$AppWidthRatio
    .Columns[7].Width = 50 * modBasic.$AppWidthRatio
    .Columns[8].Width = 50 * modBasic.$AppWidthRatio
    .Columns[9].Width = 75 * modBasic.$AppWidthRatio
    .Columns[10].Width = 120 * modBasic.$AppWidthRatio
    .Columns[11].Width = 120 * modBasic.$AppWidthRatio
    .Columns[12].Width = 1
    .Columns[13].Width = 1
    .Columns[14].Width = 1
    .Columns[15].Width = 1
  End With
  txtsubtotalnew.Value = Round(xitem, -2)
  txttotaxnew.Value = Round(tax, -2)
  txtdiscnew.Value = Round(disc, -2)
  txtnetotalnew.Value = Round(xx, -2)

  txttotnew.Value = txtnetotalnew.Value + txtnetotalitem.Value

End

Private Sub ExecuteOldQuery()

  Dim sql As String

  sql = "select fldid,fldtime,flditemtype,flditemno,flditemname,flditemrate,flditemqty,flddiscper,fldtaxper,fldditemamt,fldpayto,fldrefer,fldtaxamt,flddiscamt,fldbillingmode,fldsample from tblpatbilling where fldencounterval=&1 and fldsave=&2 and fldprint=&3"
  $rData1 = modDatabase.$myConn.Exec(sql, Trim(txtencid.Text), True, False)

End

Private Sub ShowOldEntry()

  Dim xitem As Float
  Dim xx As Float
  Dim disc As Float
  Dim tax As Float
  Dim Column As Integer
  Dim fld As ResultField

  ExecuteOldQuery()
  GridView2.Clear
  GridView2.Columns.Count = $rData1.Fields.Count
  GridView2.Rows.Count = $rData1.Count

  xitem = 0
  tax = 0
  disc = 0
  xx = 0
  For Each $rData1
    xitem = xitem + $rData1!flditemrate * $rData1!flditemqty
    tax = tax + $rData1!fldtaxamt
    disc = disc + $rData1!flddiscamt
    xx = xx + $rData1!fldditemamt
    Column = 0
    For Each fld In $rData1.Fields
      modGeneralMain.GridExplicitDecoration(GridView2, $rData1.Index, Column)
      If Column = 1 Then
        GridView2[$rData1.Index, Column].Text = modReportVar.GetDateTimeReport($rData1["fldtime"], gb.GeneralDate)
      Else If Column = 10 Then
        GridView2[$rData1.Index, Column].Text = modGeneral.GetUserFullName($rData1[fld.Name])
      Else If Column = 11 Then
        GridView2[$rData1.Index, Column].Text = modGeneral.GetUserFullName($rData1[fld.Name])
      Else
        GridView2[$rData1.Index, Column].Text = $rData1[fld.Name]
      Endif
      Column = Column + 1
    Next
  Next
  GridView2.Row = 0

  With GridView2
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Text = "SN"
    .Columns[1].Text = "DateTime"
    .Columns[2].Text = "Category"
    .Columns[3].Text = "Code"
    .Columns[4].Text = "Particulars"
    .Columns[5].Text = "Rate"
    .Columns[6].Text = "QTY"
    .Columns[7].Text = "Disc %"
    .Columns[8].Text = "Tax %"
    .Columns[9].Text = "Total"
    .Columns[10].Text = "Payable"
    .Columns[11].Text = "Referral"

    .Columns[0].Width = 50 * modBasic.$AppWidthRatio
    .Columns[1].Width = 150 * modBasic.$AppWidthRatio
    .Columns[2].Width = 125 * modBasic.$AppWidthRatio
    .Columns[3].Width = 40 * modBasic.$AppWidthRatio
    .Columns[4].Width = 300 * modBasic.$AppWidthRatio
    .Columns[5].Width = 75 * modBasic.$AppWidthRatio
    .Columns[6].Width = 50 * modBasic.$AppWidthRatio
    .Columns[7].Width = 50 * modBasic.$AppWidthRatio
    .Columns[8].Width = 50 * modBasic.$AppWidthRatio
    .Columns[9].Width = 75 * modBasic.$AppWidthRatio
    .Columns[10].Width = 120 * modBasic.$AppWidthRatio
    .Columns[11].Width = 120 * modBasic.$AppWidthRatio
    .Columns[12].Width = 1
    .Columns[13].Width = 1
    .Columns[14].Width = 1
    .Columns[15].Width = 1
  End With
  txtsubtotasave.Value = Round(xitem, -2)
  txttotaxsave.Value = Round(tax, -2)
  txtdiscsave.Value = Round(disc, -2)
  txtnetotalsave.Value = Round(xx, -2)

  txttotsaved.Value = Round(xx, -2)
  If ShowBilling() = True
    hPatient.ShowBillingDatainBox()
  Endif

End

