Public Sub Form_Open()

  modGeneralMain.ArrangeEmbedForms(Me, Panel1, "Vertical")
  Me.Icon = Picture[modGeneralMain.$strLogo]
  $BillingOption = modBasic.$BillCashOption
  If ShowBilling() = False Then
    Panel2.Enabled = False
  Else If ShowBilling() = True Then
    hPatient = New FmBillingEntry(Panel2)
  Endif

  ''--------------------- Cashier -------------
  cmbtype.List = ["Test", "Service", "Procedure", "Equipment", "Radio", "Others", "Group"]
  cmbmode.List = modBasic.$BillBillingMode
  cmbdisctype.List = modBasic.$BillDiscountType
  modBillings.SetCashBillingTaxDiscountText(txtax, txtdisc)
  modSettings.ShowCheckBox(chkall, "BillingOption/AllLocations")
  GetCashModList()
  $ShowAutoPay = modSettings.ShowSettingFromFIle("BillingSettings/AutoDisplayPayable")

  ''--------------Pharmacy------------------
  cmbroute.List = modMedicine.ComboRoute()
  cmbroute.Add("Group")
  cmbfreq.List = modMedicine.FrequencyCombo()
  modStock.DisplayDefaultDispensingMode(rbrand, rbgeneric)
  rborder.Value = True
  IniateCategoryPharmArray()
  txtpharmacy.Text = modBasic.$BillTargetPharmacy
  If txtpharmacy.Text Then
    Panel6.Enabled = True
  Endif

  modGeneralMain.SetEncIDPrefix(txtencid)
  txtencid.SetFocus

End

Public Sub Form_Activate()

  If txtencid.Text = "" Then
    BlankAll()
    txtencid.SetFocus
  Endif

End

Private Sub BlankAll()

  BlankForEntry()
  txtencid.Text = ""
  txtpatientname.Text = ""
  txtgender.Text = ""
  txtpatlocation.Text = ""

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub Form_Close()

  If txtencid.Text Then
    modPatient.ReleaseLockEncounter(Trim(txtencid.Text), modHelpVariable.$LogInCategory)
  Endif
  If ShowBilling() = True
    hPatient.Close
  Endif
  modGeneralMain.RecordFormExit(Me)

End

Public Sub mnusearch_Click()

  txtencid.Text = PatSearch("Encounter")

End

Public Sub Form_KeyRelease()

  If Key.Code = Key["O"] And If Key.Control Then
    btnwebcam_Click()
  Else If Key.Code = Key["F"] And If Key.Control Then
    txtencid.Text = GetEncid()
  Else If Key.Code = Key["R"] And If Key.Control Then
    btnconsult_Click()

  Else If Key.Code = Key.F5 Then
    TabStrip1.Index = 0
    cmbtype.SetFocus
  Else If Key.Code = Key.F6 Then
    TabStrip1.Index = 1
    cmbroute.SetFocus
  Else If Key.Code = Key.F7 Then
    TabStrip1.Index = 2

  Else If Key.Code = Key.F12 Then
    If txtencid.Text Then
      If txtpatientname.Text Then
        SaveGridData()
        PharmacySave()
        Wait
        If ShowBilling() = True Then
          If hPatient.Enabled = True Then
            hPatient.DirectCashBilling()
          Endif
        Else
          ShowOldEntry()
          ShowNewEntry()
          FillDosingGrid()
        Endif
      Endif
    Endif

  Else
    modGeneralmain.GoToNextControlTab()
  Endif

End

Public Sub btnshow_GotFocus()

  btnshow_Click()

End

Public Sub btnshow_Click()

  Dim res As Result

  If Not txtencid.Text Then Return
  If modPatient.LockEncounterDesk(Trim(txtencid.Text)) = False Then
    TabStrip1.Enabled = False
    Panel2.Enabled = False
    txtencid.Text = ""
    Balloon.Warning(("Encounter Locked"), btnshow)
    Balloon.Delay = modBasic.$BalloonDelay
    txtencid.SetFocus
  Endif

  If txtencid.Text Then
    IniateCategoryArray()
    modSettings.SaveValuesToLog("LastValue/Encounter", Trim(txtencid.Text))
    If ShowBilling() = True Then
      hPatient.$encid = Trim(txtencid.Text)
      hPatient.$billtype = "CashBilling"
    Endif

    res = modDatabase.$myConn.Exec("select fldpatientval from tblencounter where fldencounterval=&1", Trim(txtencid.Text))
    If res.Available = False Then
      modLinkDB.CheckEncDataRemote(Trim(txtencid.Text))
      txtencid.SetFocus
    Else
      txtpatientname.Text = modPatient.GetPatientNameByEnc(Trim(txtencid.Text))
      If txtpatientname.Text Then
        txtgender.Text = modPatient.GetPatientAgeString(Trim(txtencid.Text), Now()) & "/" & Left(modPatient.GetPatientSex(Trim(txtencid.Text)), 1)
        txtpatlocation.Text = modPatient.GetLocationSetting(Trim(txtencid.Text))
        $PatientNum = modPatient.GetPatientNoByEnc(Trim(txtencid.Text))
        $sTatus = modPatient.CurrentAdmissionStatus(Trim(txtencid.Text))
        TabStrip1.Enabled = True
        Panel2.Enabled = True
        If ShowBilling() = True
          hPatient.SetDefaultModeCashCredit()
        Endif
        If $sTatus = "Admitted" Then
          If modBasic.$BillLockAdmitted = "Yes" Then
            If hPatient Then
              hPatient.Enabled = False
            Endif
          Endif
          If modBasic.$BillIsolateCashBilling = "Yes" Then
            chkall.Value = False
            chkall.Enabled = False
          Endif
        Endif
        ShowOldEntry()
        ShowNewEntry()
        FillDosingGrid()

        BlankForEntry()
        BlankDosingBox()
        txtencid.ReadOnly = True
        modBillings.GetBillingComboDefaultMode(cmbmode, Trim(txtencid.Text), modGeneralMain.compID)
        $DiscPackage = modNonMedical.ShowDiscountCategEnc(Trim(txtencid.Text))
        If modBasic.$BillFixDisc = "No" Then
          cmbdisctype.Enabled = True
        Else
          cmbdisctype.Text = ""
        Endif
        modImage.ShowPhotoSplash("Patient", $PatientNum)
        modPatient.PopUpPatientForm(Trim(txtencid.Text), Me.Tag)
        ShowCashCreditMode()
        cmbtype.SetFocus
      Else
        TabStrip1.Enabled = False
        Panel2.Enabled = False
        Balloon.Warning(("Encounter ID not found"), btnshow)
        Balloon.Delay = modBasic.$BalloonDelay
        txtencid.SetFocus
      Endif
    Endif
  Endif

End

Private Function ShowBilling() As Boolean

  Dim xx As Boolean

  If $BillingOption = "No" Then
    xx = False
  Else
    xx = True
  Endif
  Return xx

End

Private Sub BlankForEntry()

  cmbtype.Text = ""
  cmbitem.Text = ""
  txtax.Value = 0
  txtdisc.Value = 0
  txtotal.Value = 0
  txtqty.Value = 1
  txtrate.Value = 0

End

Private Sub BlankDosingBox()

  cmbroute.Text = ""
  cmbmedicine.Text = ""
  cmbfreq.Text = ""
  txtdose.Value = 0
  txtday.Value = 0
  lblqty.Text = ""
  txtqtymed.Value = 0
  txtdose.Enabled = True
  cmbfreq.Enabled = True
  txtday.Enabled = True
  txtinventory.Value = 0

End

Public Sub tlbtnpayment_Click()

  If txtencid.Text Then
    modNonMedical.CurrentPayStatusMsg(Trim(txtencid.Text))
  Endif

End

Public Sub btnconsult_Click()

  btnconsult.Tag = MedicalSelectedUser(("Select Referral User"), modBasic.$ReferUserList)
  btnconsult.Text = modGeneral.GetUserFullName(btnconsult.Tag)

End

Public Sub btnconsult_Change()

  If btnconsult.Text = "" Then
    btnconsult.Tag = ""
  Endif

End

''=============================================== CASHIER ======================================
''------------------ Array List for Items ------------------
Private Sub IniateCategoryArray()

  $TestArray = New String[]
  $ServiceArray = New String[]
  $ProcedureArray = New String[]
  $EquipmentArray = New String[]
  $RadioArray = New String[]
  $OthersArray = New String[]

End

Private Function GetCashSectionQuery(sType As String) As String

  Dim xcateg As String

  If sType = "Test" Then
    If modBasic.$BillTestSection Then
      xcateg = " and fldreport like &5"
    Else
      xcateg = ""
    Endif

  Else If sType = "Service" Then
    If modBasic.$BillServiceSection Then
      xcateg = " and fldreport like &5"
    Else
      xcateg = ""
    Endif

  Else If sType = "Procedure" Then
    If modBasic.$BillProcSection Then
      xcateg = " and fldreport like &5"
    Else
      xcateg = ""
    Endif

  Else If sType = "Equipment" Then
    If modBasic.$BillEquipSection Then
      xcateg = " and fldreport like &5"
    Else
      xcateg = ""
    Endif

  Else If sType = "Radio" Then
    If modBasic.$BillRadioSection Then
      xcateg = " and fldreport like &5"
    Else
      xcateg = ""
    Endif

  Else If sType = "Others" Then
    If modBasic.$BillOtherSection Then
      xcateg = " and fldreport like &5"
    Else
      xcateg = ""
    Endif

  Endif
  Return xcateg

End

Private Function GetCashSectionValue(sType As String) As String

  Dim xcateg As String

  If sType = "Test" Then
    If modBasic.$BillTestSection Then
      xcateg = modBasic.$BillTestSection
    Else
      xcateg = "%"
    Endif

  Else If sType = "Service" Then
    If modBasic.$BillServiceSection Then
      xcateg = modBasic.$BillServiceSection
    Else
      xcateg = "%"
    Endif

  Else If sType = "Procedure" Then
    If modBasic.$BillProcSection Then
      xcateg = modBasic.$BillProcSection
    Else
      xcateg = "%"
    Endif

  Else If sType = "Equipment" Then
    If modBasic.$BillEquipSection Then
      xcateg = modBasic.$BillEquipSection
    Else
      xcateg = "%"
    Endif

  Else If sType = "Radio" Then
    If modBasic.$BillRadioSection Then
      xcateg = modBasic.$BillRadioSection
    Else
      xcateg = "%"
    Endif

  Else If sType = "Others" Then
    If modBasic.$BillOtherSection Then
      xcateg = modBasic.$BillOtherSection
    Else
      xcateg = "%"
    Endif

  Endif
  Return xcateg

End

Private Function GetCategoryArray(sType As String) As String[]

  Dim xarry As String[]

  If sType = "Test" Then
    If Not $TestArray.Count Then
      $TestArray.Insert(GetCashierArray(sType))
    Endif
    xarry = $TestArray

  Else If sType = "Service" Then
    If Not $ServiceArray.Count Then
      $ServiceArray.Insert(GetCashierArray(sType))
    Endif
    xarry = $ServiceArray

  Else If sType = "Procedure" Then
    If Not $ProcedureArray.Count Then
      $ProcedureArray.Insert(GetCashierArray(sType))
    Endif
    xarry = $ProcedureArray

  Else If sType = "Equipment" Then
    If Not $EquipmentArray.Count Then
      $EquipmentArray.Insert(GetCashierArray(sType))
    Endif
    xarry = $EquipmentArray

  Else If sType = "Radio" Then
    If Not $RadioArray.Count Then
      $RadioArray.Insert(GetCashierArray(sType))
    Endif
    xarry = $RadioArray

  Else If sType = "Others" Then
    If Not $OthersArray.Count Then
      $OthersArray.Insert(GetCashierArray(sType))
    Endif
    xarry = $OthersArray
  Endif

  Return xarry

End

Private Function GetCashierArray(sType As String) As String[]

  Dim res As Result
  Dim xdata As String[]
  Dim xcode As String

  res = modDatabase.$myConn.Exec("select flditemname,fldcode,flditemcost,flditemunit from tblservicecost where flditemtype=&1 and (fldgroup=&2 or fldgroup=&4) and fldstatus=&3" & GetCashSectionQuery(sType) & " ORDER BY flditemname ASC", modNonMedical.GetBillItemCategoryFromCombo(sType), cmbmode.Text, "Active", "%", GetCashSectionValue(sType))
  xdata = New String[]
  If res.Available Then
    For Each res
      If res!fldcode Then
        xcode = res!fldcode
      Else
        xcode = ""
      Endif
      xdata.Add(res!flditemname & "|" & xcode & "|" & CStr(modNonMedical.GetCurrConvertAmount(res!flditemcost, res!flditemunit)))
    Next
  Endif
  Return xdata

End

Private Sub ClearCashArray()

  $TestArray.Clear()
  $ServiceArray.Clear()
  $ProcedureArray.Clear()
  $EquipmentArray.Clear()
  $RadioArray.Clear()
  $OthersArray.Clear()

End

Public Sub cmbmode_Change()

  ClearCashArray()

End

Private Sub GetNonStockCashBilling(ComboBox1 As ComboBox, sType As String, txtmode As String)

  Dim sql As String
  Dim res As Result
  Dim textToCursor As String
  Dim textPosition As Integer

  textPosition = ComboBox1.Pos
  textToCursor = Mid(ComboBox1.Text, 1, textPosition)

  If Key.Code = Key.BackSpace Then
    ComboBox1.Clear
  Else
    If Key.Code = Key.Down Then
      ComboBox1.Clear
      If Not ComboBox1.Count Then
        sql = "select flditemname as col from tblservicecost where flditemtype=&1 and (fldgroup like &2 or fldgroup=&6) and fldstatus=&3 and lower(flditemname) like &4" & GetCashSectionQuery(sType)
        res = modDatabase.$myConn.Exec(sql, modNonMedical.GetBillItemCategoryFromCombo(sType), txtmode, "Active", LCase(textToCursor) & "%", GetCashSectionValue(sType), "%")
        modFillContainer.FillComboBox(ComboBox1, res)
      Endif
      ComboBox1.Popup
    Endif
  Endif

End

