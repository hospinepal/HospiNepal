' Gambas class file

Private $encid As String

Public Sub _new(encid As String)

  $encid = encid
  txtencid.Text = $encid

End

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me, "False")
  cmbdept.List = modMisc.GetDepartmentAllList("Consultation")
  cmbbillmode.List = modBasic.$BillBillingMode
  dtconsultdate.Value = Now()
  dtconsultime.Value = Now()
  If txtencid.Text Then
    btnshow_Click()
  Else
    txtencid.SetFocus
  Endif

End

Public Sub btnshow_Click()

  txtpatientname.Text = modPatient.GetPatientNameByEnc(Trim(txtencid.Text))
  modBillings.GetBillingComboDefaultMode(cmbbillmode, Trim(txtencid.Text), modGeneralMain.compID)

End

Public Sub dtnepcal_Click()

  Dim xx As String

  xx = BSDateFormat(("Enter BS Date in yyyy/mm/dd format"), ("Date Converter"), modDate.ConvertToLocaldate(dtconsultdate.Value))
  If xx Then
    dtconsultdate.Value = modDate.ConvertToEnglishdate(xx)
  Endif

End

Public Sub btnadd_Click()

  Dim sDate As Date

  sDate = Date(Year(dtconsultdate.Value), Month(dtconsultdate.Value), Day(dtconsultdate.Value), Hour(dtconsultime.Value), Minute(dtconsultime.Value), Second(dtconsultime.Value))                                                                   ''
  If sDate And If cmbdept.Text And If cmbbillmode.Text Then
    modPatient.AddConsultData(Trim(txtencid.Text), cmbdept.Text, sDate, TextArea1.Text, btnconsult.Tag, cmbbillmode.Text)
    Balloon.Info(("Consultation Planned"), btnadd)
    Balloon.Delay = modBasic.$BalloonDelay
  Endif

End

Public Sub btnbill_Click()

  Dim billItem As String
  Dim xauto As String
  Dim xmess As String

  If cmbdept.Text And If cmbbillmode.Text Then
    If Message.Question(("Insert Auto Billing for selected Consultation"), ("No"), ("Yes")) = 2 Then

      xauto = modBasic.$AutoBillService
      If xauto Then
        billItem = modNonMedical.GetDepartmentChargeMode(cmbdept.Text)
        If billItem Then

          Inc Application.Busy
          modDatabase.$myConn.Begin
          If xauto = "Yes" Or If xauto = "Full" Then
            modBillings.ServiceBillBlankTaxDisc($encid, cmbbillmode.Text, "Service", billItem, 1, "Done", 0, True, False, btnconsult.Tag)
            xmess = xauto & (" Auto Billing Completed")
          Else If xauto = "Partial" Then
            modBillings.ServiceBillBlankTaxDisc($encid, cmbbillmode.Text, "Service", billItem, 1, "Punched", 0, False, False, btnconsult.Tag)
            xmess = xauto & (" Auto Billing Completed")
          Endif
          modDatabase.$myConn.Commit
          Dec Application.Busy

          If xmess Then
            Balloon.Info(xmess, btnbill)
            Balloon.Delay = modBasic.$BalloonDelay
          Endif

        Endif
      Endif

    Endif
  Endif

Catch
  modDatabase.$myConn.Rollback

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.Esc Then
    Me.Close
  Else
    modGeneralmain.GoToNextControlTab()
  Endif

End

Public Sub btnconsult_Click()

  If modBasic.$LockConsultant = "LockByQuota" Then
    btnconsult.Tag = MedicalSelectedUser(("Select Consultant"), modPatient.GetUserPostingList(cmbdept.Text, dtconsultdate.Value, cmbbillmode.Text))
  Else
    btnconsult.Tag = MedicalSelectedUser(("Select Consultant"), modBasic.$OPConsulUserList)
  Endif
  btnconsult.Text = modGeneral.GetUserFullName(btnconsult.Tag)

End

Public Sub btnshow_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    btnshow_Click()
  Endif

End

Public Sub cmbbillmode_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbbillmode)
  modFillContainer.RestrictComboToContent(cmbbillmode)

End

Public Sub cmbbillmode_LostFocus()

  modFillContainer.RestrictCombo(cmbbillmode)

End

Public Sub cmbdept_KeyRelease()

  modFillContainer.AutoFillComboBox(cmbdept)
  modFillContainer.RestrictComboToContent(cmbdept)

End

Public Sub cmbdept_LostFocus()

  modFillContainer.RestrictCombo(cmbdept)

End

Public Sub btnconsult_Change()

  If btnconsult.Text = "" Then
    btnconsult.Tag = ""
  Endif

End

Public Sub txtencid_KeyPress()

  If Key.Code = Key.Down Then
    If modBasic.$AutoEncSuffix = "Yes" Then
      txtencid.Text = txtencid.Text & modBasic.$HospCode
    Endif
  Else
    modGeneralMain.InputUpCaseOnly()
  Endif

End
