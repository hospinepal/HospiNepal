  Dim xPath As String

  If $sType = "Registration List" Then
    xPath = modCHTMLPatSummary.ShowRegisterConsultReport(dtfir.Value, dtlast.Value, cmbselect.Text, cmbbillmode.Text, cmbilled.Text, cmbregtype.Text, cmbcomp.Text, btnconsult.Tag)
