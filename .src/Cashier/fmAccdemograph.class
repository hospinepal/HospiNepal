' Gambas class file

Private $rData As Result
Private $aMyFields As String[]
Private $encid As String

Public Sub _new(encid As String)

  $encid = encid

End

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me, "False")
  ListBox1.List = modBasic.$DemogAccList
  txtpatientname.Text = modPatient.GetPatientNameByEnc($encid)
  txtgender.Text = modPatient.GetPatientSex($encid)
  txtpatientaddress.Text = modPatient.GetPatientAddressByEnc($encid)
  txtpatientcontact.Text = modPatient.GetLocationSetting($encid)
  ShowExamGrid()

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.Esc Then
    Me.Close
  Endif

End

Private Sub ShowExamGrid()

  $rData = modDatabase.$myConn.Exec("select fldid,flditem,fldreportquali from tblpataccgeneral where fldencounterval=&1 and fldinput=&2 ORDER by fldid DESC", $encid, "Demographics")                                                                                 ''
  $aMyFields = New String[]
  modGridView.ReadSmallData(GridView1, $rData, $aMyFields)

  With GridView1
    .Columns[0].Width = 1
    .Columns[1].Width = 150 * modBasic.$AppWidthRatio
    .Columns[2].Width = 300 * modBasic.$AppWidthRatio

    .Columns[1].Text = "Variable"
    .Columns[2].Text = "Value"
  End With

End

Public Sub GridView1_Data(Row As Integer, Column As Integer)

  $rData.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView1, Row)
  GridView1.Data.Text = $rData[$aMyFields[Column]]

End

Public Sub ListBox1_Click()

  Dim sType As String
  Dim opt As String[]
  Dim strLst As String[]
  Dim xx As String
  Dim yy As Variant[]

  sType = modPatient.GetAccDemographicType(ListBox1.Text)
  If sType = "Single Selection" Then
    opt = modPatient.GetAccDemographicOptionList(ListBox1.Text, sType)
    strLst = SubChoose(opt, "Single Selection", ListBox1.Text)
    If strLst Then
      For Each xx In strLst
        modNonMedical.AddAccGeneralQualiData($encid, "Demographics", ListBox1.Text, xx, "", Now(), True)
      Next
    Endif

  Else If sType = "Multiple Selection" Then
    opt = modPatient.GetAccDemographicOptionList(ListBox1.Text, sType)
    strLst = SubChoose(opt, "Multiple Selection", ListBox1.Text)
    If strLst Then
      For Each xx In strLst
        modNonMedical.AddAccGeneralQualiData($encid, "Demographics", ListBox1.Text, xx, "", Now(), True)
      Next
    Endif

  Else If sType = "Quantitative" Then
    yy = GetQuantiValues("Demographics", $encid, ListBox1.Text, 0, 0, 0)
    If yy Then
      modNonMedical.AddAccGeneralQuantiData($encid, "Demographics", ListBox1.Text, yy[0], "", Now(), True)
    Endif

  Else
    xx = GetTextArea(ListBox1.Text, "")
    If xx Then
      modNonMedical.AddAccGeneralQualiData($encid, "Demographics", ListBox1.Text, xx, "", Now(), True)
    Endif
  Endif
  ShowExamGrid()

End

Public Sub ListBox1_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    ListBox1_Click()
  Endif

End

Public Sub GridView1_Click()

  Dim sType As String
  Dim opt As String[]
  Dim strLst As String[]
  Dim xx As String
  Dim yy As Variant[]
  Dim Row As Integer
  Dim Column As Integer

  If GridView1.Rows.Selection.Count > 0 Then
    Row = GridView1.Row
    Column = GridView1.Column

    sType = modPatient.GetAccDemographicType(GridView1[GridView1.Row, 1].Text)
    If sType = "Single Selection" Then
      opt = modPatient.GetAccDemographicOptionList(GridView1[GridView1.Row, 1].Text, sType)
      strLst = SubChoose(opt, "Single Selection", GridView1[GridView1.Row, 1].Text)
      If strLst Then
        For Each xx In strLst
          modNonMedical.UpdateAccGeneralQualiData(GridView1[GridView1.Row, 0].Text, GridView1[GridView1.Row, 1].Text, xx, "", Now(), True)
        Next
      Endif

    Else If sType = "Multiple Selection" Then
      opt = modPatient.GetAccDemographicOptionList(GridView1[GridView1.Row, 1].Text, sType)
      strLst = SubChoose(opt, "Multiple Selection", GridView1[GridView1.Row, 1].Text)
      If strLst Then
        For Each xx In strLst
          modNonMedical.UpdateAccGeneralQualiData(GridView1[GridView1.Row, 0].Text, GridView1[GridView1.Row, 1].Text, xx, "", Now(), True)
        Next
      Endif

    Else If sType = "Quantitative" Then
      yy = GetQuantiValues("Demographics", $encid, ListBox1.Text, 0, 0, CFloat(GridView1[GridView1.Row, 2].Text))
      If yy Then
        modNonMedical.UpdateAccGeneralQuantiData(GridView1[GridView1.Row, 0].Text, GridView1[GridView1.Row, 1].Text, yy[0], "", Now(), True)
      Endif

    Else
      xx = GetTextArea(GridView1[GridView1.Row, 1].Text, GridView1[GridView1.Row, 2].Text)
      If xx Then
        modNonMedical.UpdateAccGeneralQualiData(GridView1[GridView1.Row, 0].Text, GridView1[GridView1.Row, 1].Text, xx, "", Now(), True)
      Endif
    Endif
    ShowExamGrid()
    GridView1.Row = Row
    GridView1.Column = Column
  Endif

End

Public Sub btnreport_Click()

  modCHTMLReport.ExportGridToHTML(GridView1, "DEMOGRAPHIC VALUES", modReportVar.GetDateTimeReport(Now(), gb.GeneralDate))

End
