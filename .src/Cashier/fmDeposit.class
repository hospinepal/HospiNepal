' Gambas class file

Private $rData1 As Result
Private $aMyFields1 As String[]
Private $rData2 As Result
Private $aMyFields2 As String[]
Private $rData3 As Result
Private $aMyFields3 As String[]

Private $DisplayMiniCalc As String
Private $PostInvoicePrint As String
Private $InvoicePrintTime As String

Public Sub Form_Open()

  modGeneralMain.ArrangeEmbedForms(Me, Panel1, "Vertical")
  Me.Icon = Picture[modGeneralMain.$strLogo]
  If ShowBilling() = True Then
    Panel2.Enabled = True
  Endif
  $DisplayMiniCalc = modBasic.$BillAfterPrintDisplay
  $PostInvoicePrint = modBasic.$BillWithInvoicePrint
  $InvoicePrintTime = modBasic.$BillPrintTime
  cmbcheque.List = modBasic.$BillBankList

  If modBasic.$AutoDiaryNo = "Yes" Then
    btndiary.Enabled = False
    txtfileno.ReadOnly = True
  Endif
  modGeneralMain.SetEncIDPrefix(txtencid)
  txtencid.SetFocus

End

Public Sub Form_Activate()

  If txtencid.Text = "" Then
    txtencid.SetFocus
  Endif

End

Public Sub Form_Close()

  If txtencid.Text Then
    modPatient.ReleaseLockEncounter(Trim(txtencid.Text), modHelpVariable.$LogInCategory)
  Endif

  modGeneralMain.RecordFormExit(Me)

End

Public Sub mnusearch_Click()

  txtencid.Text = PatSearch("Encounter")

End

Public Sub Form_KeyRelease()

  If Key.Code = Key["O"] And If Key.Control Then
    btnwebcam_Click()
  Else If Key.Code = Key.F1 Then
    Frame1.Index = 0
  Else If Key.Code = Key.F2 Then
    Frame1.Index = 1
  Else If Key.Code = Key["F"] And If Key.Control Then
    txtencid.Text = GetEncid()
  Else
    modGeneralmain.GoToNextControlTab()
  Endif

End

Public Sub mnulastencid_Click()

  txtencid.Text = modSettings.ShowLogValues("LastValue/Encounter")

End

Private Function ShowBilling() As Boolean

  Dim xx As Boolean

  If modGlobalSetting.ShowSettingFromDB("BillingOption/DepositBilling") = "No" Then
    xx = False
  Else
    xx = True
  Endif
  Return xx

End

Public Sub btnshow_GotFocus()

  btnshow_Click()

End

Public Sub btnshow_Click()

  Dim res As Result

  If Not txtencid.Text Then Return
  If modPatient.LockEncounterDesk(Trim(txtencid.Text)) = False Then
    txtencid.Text = ""
    Balloon.Warning(("Encounter Locked"), btnshow)
    Balloon.Delay = modBasic.$BalloonDelay
    txtencid.SetFocus
  Endif

  If txtencid.Text Then
    modSettings.SaveValuesToLog("LastValue/Encounter", Trim(txtencid.Text))
    res = modDatabase.$myConn.Exec("select fldpatientval from tblencounter where fldencounterval=&1", Trim(txtencid.Text))
    If res.Available = False Then
      modLinkDB.CheckEncDataRemote(Trim(txtencid.Text))
      txtencid.SetFocus
    Else
      txtpatientname.Text = modPatient.GetPatientNameByEnc(Trim(txtencid.Text))
      If txtpatientname.Text Then
        txtgender.Text = modPatient.GetPatientAgeString(Trim(txtencid.Text), Now()) & "/" & Left(modPatient.GetPatientSex(Trim(txtencid.Text)), 1)
        txtpatlocation.Text = modPatient.GetLocationSetting(Trim(txtencid.Text))
        txtprevdeposit.Value = modNonMedical.GetPatientDeposit(Trim(txtencid.Text))

        txtexpense.Value = Round(modNonMedical.TotalExpenseAmountbyPatient(modDatabase.$myConn, Trim(txtencid.Text)), -2)
        txtpayment.Value = Round(modNonMedical.TotalPaidAmountbyPatient(modDatabase.$myConn, Trim(txtencid.Text)), -2)

        txtfileno.Text = modPatient.GetPatientFileByEnc(Trim(txtencid.Text))
        cmbcomment.Text = modPatient.GetPatientCommentByEnc(Trim(txtencid.Text))

        modImage.ShowPhotoSplash("Patient", modPatient.GetPatientNoByEnc(Trim(txtencid.Text)))
        modPatient.PopUpPatientForm(Trim(txtencid.Text), Me.Tag)
        Frame1.Enabled = True
        txtencid.ReadOnly = False
        ShowAllEncounters()
        txtrecvamt.SetFocus
      Else
        Balloon.Warning(("Encounter ID not found"), btnshow)
        Balloon.Delay = modBasic.$BalloonDelay
        txtencid.SetFocus
      Endif
    Endif
  Endif

End

Public Sub btnwebcam_Click()

  txtencid.Text = modDevice.ChooseBarCodeSource()
  txtencid.SetFocus
  txtencid.Pos = Len(txtencid.Text)

End

Public Sub mnublnk_Click()

  Me.Close
  Wait
  modHelpVariable.AddNewFormToWorkspace(fmDeposit)

End

Public Sub Form_Resize()

  modGeneralMain.ShowSelectedFormMenu(Me)

End

Public Sub mnubed_Click()

  Dim hForm As FmBedManage

  If txtencid.Text Then
    If modPatient.CurrentAdmissionStatus(Trim(txtencid.Text)) = "Admitted" Then
      hForm = New FmBedManage(Trim(txtencid.Text), txtpatlocation)
      hForm.ShowModal
    Endif
  Endif

End

Public Sub tlbtnpayment_Click()

  If txtencid.Text Then
    modNonMedical.CurrentPayStatusMsg(Trim(txtencid.Text))
  Endif

End

Public Sub btnsms_Click()

  Dim xval As Boolean

  If btnconsult.Tag Then
    xval = modDevice.SendSMSToInpatDoc(Trim(txtencid.Text), modGeneral.GetUserContact(btnconsult.Tag))
    If xval Then
      Balloon.Info(("Message saved"), btnsms)
      Balloon.Delay = modBasic.$BalloonDelay
    Endif
  Endif

End

''------------------------------------------ Deposit transection -----------------------------------------
Public Sub btnblank_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    btnblank_Click()
  Endif

End

Public Sub btnblank_Click()

  Me.Close
  modHelpVariable.AddNewFormToWorkspace(fmDeposit)

End

Public Sub btnsave_KeyRelease()

  If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    btnsave_Click()
  Endif

End

Public Sub btnsave_Click()

  Dim txttitle As String
  Dim $billno As String
  Dim scheq As String
  Dim sbank As String
  Dim $hReport As CRegistLabel
  Dim xline As String
  Dim idLock As Boolean
  Dim xxx As Boolean

  If txtencid.Text Then
    Inc Application.Busy
    scheq = Trim(txtcheque.Text)
    sbank = cmbcheque.Text
    txtprevdeposit.Value = modNonMedical.GetPatientDeposit(Trim(txtencid.Text))
    txtrecvamt.Value = modBillings.GetRoundupAccToSetting(txtrecvamt.Value)
    txtcurrdeposit.Value = txtrecvamt.Value + txtprevdeposit.Value

    If txtcurrdeposit.Value >= 0 Then
      xxx = True
    Else
      If txtrecvamt.Value > 0 Then
        xxx = True
      Else
        xxx = False
      Endif
    Endif

    If xxx = True Then
      txttitle = "DEPOSIT INVOICE"
      idLock = modNonMedical.LockTableForID("Invoice")
      If idLock = True Then
        modDatabase.$myConn.Begin

        $billno = modNonMedical.InvoiceString("Cash Deposit")
        If $billno Then
          modBillings.InsertBillDetail(Trim(txtencid.Text), $billno, "Credit", txtprevdeposit.Value, 0, 0, 0, 0, txtrecvamt.Value, txtcurrdeposit.Value, scheq, sbank)
          modNonMedical.UpdatePatientDeposit(Trim(txtencid.Text), txtcurrdeposit.Value)
        Endif

        modDatabase.$myConn.Commit
        modNonMedical.ReleaseLockTable("Invoice")
      Endif
      btnsave.Enabled = False
    Endif
    Dec Application.Busy

    If $billno Then
      If $InvoicePrintTime = "Later" Then
      Else
        modBILLFormat.BillingInvoice($billno, txttitle, False, False)
      Endif
      If $PostInvoicePrint = "Sticker" Then
        $hReport = New CRegistLabel(Trim(txtencid.Text))
        modPrint.PrintPopUp(Trim(txtencid.Text), $hReport.RegistLabelPath(), "LabelSize")
      Else If $PostInvoicePrint = "Prescription" Then
        modPatient.PrintRegistExtraReport(Trim(txtencid.Text))
      Endif
    Endif

  Endif

  If $DisplayMiniCalc = "Calculator" Then
    btncalc_Click()
  Else If $DisplayMiniCalc = "InvoiceInfo" Then
    If txtencid.Text Then
      xline = "<b>EncID:</b> " & Trim(txtencid.Text) & "<br>"
      xline = xline & "<b>Name:</b> " & modPatient.GetPatientNameByEnc(Trim(txtencid.Text)) & "<br>"
      xline = xline & "<b>Invoice:</b> " & $billno & "<br>"
      xline = xline & "<b>RecvAMT:</b> " & modReportVar.GetLocaleNumberFormat(txtrecvamt.Value, gb.Currency)
      Message.Info(xline, ("OK"))
    Endif
  Endif

Catch
  modDatabase.$myConn.Rollback
  If idLock = True Then
    modNonMedical.ReleaseLockTable("Invoice")
  Endif
  Dec Application.Busy

End

Public Sub btncalc_Click()

  Dim hForm As FmMiniCalc

  hForm = New FmMiniCalc(txtrecvamt.Value)
  hForm.ShowModal

End

Public Sub btnsave_GotFocus()

  btnsave.Font.Bold = True

End

Public Sub btnsave_LostFocus()

  btnsave.Font.Bold = False

End

Public Sub btnblank_GotFocus()

  btnblank.Font.Bold = True

End

Public Sub btnblank_LostFocus()

  btnblank.Font.Bold = False

End

''---------------------------Expense/Invoice grid -------------------------------------
Private Sub FillExpenseGrid()

  Dim sql As String

  sql = "select fldid,fldtime,flditemtype,flditemname,flditemrate,fldtaxper,flddiscper,flditemqty,fldditemamt as tot,fldbillno from tblpatbilling where fldencounterval=&1 and fldsave=&2"
  $rData1 = modDatabase.$myConn.Exec(sql, Trim(txtencid.Text), True)
  $aMyFields1 = New String[]
  modGridView.ReadSmallData(GridView1, $rData1, $aMyFields1)
  With GridView1
    .Columns[0].Width = 1
    .Columns[1].Width = 125 * modBasic.$AppWidthRatio
    .Columns[2].Width = 1
    .Columns[3].Width = 200 * modBasic.$AppWidthRatio
    .Columns[4].Width = 100 * modBasic.$AppWidthRatio
    .Columns[5].Width = 50 * modBasic.$AppWidthRatio
    .Columns[6].Width = 50 * modBasic.$AppWidthRatio
    .Columns[7].Width = 50 * modBasic.$AppWidthRatio
    .Columns[8].Width = 120 * modBasic.$AppWidthRatio
    .Columns[9].Width = 100 * modBasic.$AppWidthRatio

    .Columns[1].Text = "DateTime"
    .Columns[3].Text = "Particulars"
    .Columns[4].Text = "Rate"
    .Columns[5].Text = "Tax(%)"
    .Columns[6].Text = "Disc(%)"
    .Columns[7].Text = "QTY"
    .Columns[8].Text = "Amount"
    .Columns[9].Text = "Invoice"
  End With

End

Public Sub GridView1_Data(Row As Integer, Column As Integer)

  $rData1.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView1, Row)
  If Column = 1 Then
    GridView1.Data.Text = modReportVar.GetDateTimeReport($rData1[$aMyFields1[Column]], gb.GeneralDate)
  Else If Column = 4 Then
    GridView1.Data.Text = modReportVar.GetLocaleNumberFormat($rData1[$aMyFields1[Column]], gb.Currency)
  Else If Column = 5 Then
    GridView1.Data.Text = modReportVar.GetLocaleNumberFormat($rData1[$aMyFields1[Column]], -2)
  Else If Column = 6 Then
    GridView1.Data.Text = modReportVar.GetLocaleNumberFormat($rData1[$aMyFields1[Column]], -2)
  Else If Column = 7 Then
    GridView1.Data.Text = modReportVar.GetLocaleNumberFormat($rData1[$aMyFields1[Column]], -2)
  Else If Column = 8 Then
    GridView1.Data.Text = modReportVar.GetLocaleNumberFormat($rData1[$aMyFields1[Column]], gb.Currency)
  Else
    GridView1.Data.Text = $rData1[$aMyFields1[Column]]
  Endif

End

Public Sub btnrefreshA_Click()

  FillExpenseGrid()

End

Public Sub btnexpoA_Click()

  modCHTMLReport.ExportGridToHTML(GridView1, "EXPENSE REPORT: " & txtencid.Text, modReportVar.GetDateTimeReport(Now(), gb.GeneralDate))

End

Private Sub InvoiceGrid()

  Dim sql As String

  sql = "select fldid,fldtime,fldbillno,flditemamt,fldtaxamt,flddiscountamt,fldreceivedamt,fldcurdeposit,fldbilltype from tblpatbilldetail where fldencounterval=&1"
  $rData2 = modDatabase.$myConn.Exec(sql, Trim(txtencid.Text))
  $aMyFields2 = New String[]
  modGridView.ReadSmallData(GridView2, $rData2, $aMyFields2)
  With GridView2
    .Columns[0].Width = 1
    .Columns[1].Width = 125 * modBasic.$AppWidthRatio
    .Columns[2].Width = 100 * modBasic.$AppWidthRatio
    .Columns[3].Width = 100 * modBasic.$AppWidthRatio
    .Columns[4].Width = 100 * modBasic.$AppWidthRatio
    .Columns[5].Width = 100 * modBasic.$AppWidthRatio
    .Columns[6].Width = 100 * modBasic.$AppWidthRatio
    .Columns[7].Width = 100 * modBasic.$AppWidthRatio
    .Columns[8].Width = 75 * modBasic.$AppWidthRatio

    .Columns[1].Text = "DateTime"
    .Columns[2].Text = "Invoice"
    .Columns[3].Text = "ItemAMT"
    .Columns[4].Text = "TaxAMT"
    .Columns[5].Text = "DiscAMT"
    .Columns[6].Text = "RecvAMT"
    .Columns[7].Text = "CurDeposit"
    .Columns[8].Text = "Type"
  End With

End

