''--------------------------------------- Admission procedures ------------------------------------------
Public Sub btnconsult_Click()

  btnconsult.Tag = MedicalSelectedUser(("Select Consultant"), modBasic.$IPConsultUserList)
  btnconsult.Text = modGeneral.GetUserFullName(btnconsult.Tag)

End

Public Sub btnconsult_Change()

  If btnconsult.Text = "" Then
    btnconsult.Tag = ""
  Endif

End

Public Sub btnokadmit_Click()

  If txtencid.Text Then
    If chkadmison.Value = True Then
      Inc Application.Busy

      modDatabase.$myConn.Begin
      If modBasic.$AutoDiaryNo = "Yes" Then
        If Not txtfileno.Text Then
          txtfileno.Text = CStr(modNonMedical.CurrentAdmitFile())
          modPatient.UpdatePatFile(Trim(txtencid.Text), Trim(txtfileno.Text))
        Endif
      Endif

      modPatient.GetPatientAdmission(Trim(txtencid.Text))
      If btnconsult.Tag Then
        modPatient.UpdateAttendingConsultant(Trim(txtencid.Text), btnconsult.Tag)
      Endif
      modDatabase.$myConn.Commit

      Dec Application.Busy
      ShowAllEncounters()
      Balloon.Info(("Patient admitted"), btnokadmit)
      Balloon.Delay = modBasic.$BalloonDelay
    Endif
  Endif

Catch
  modDatabase.$myConn.Rollback
  Dec Application.Busy
  modHelpVariable.CreateErrorReport()

End

Public Sub btnstatus_Click()

  Dim status As String[] = ["Discharged", "LAMA", "Death", "Refer", "Absconder"]
  Dim xx As String

  xx = InputCombo(("Do you want to mark ") & modPatient.GetPatientNameByEnc(Trim(txtencid.Text)), "Enc: " & Trim(txtencid.Text), status, "", True)
  If xx Then
    modBillings.ExitPatientWithBillingOfService(Trim(txtencid.Text))
    modPatient.UpdateCurrentStatus(Trim(txtencid.Text), xx, "")
    ShowAllEncounters()
  Endif

End

''--------------------------------Indexing ---------------------------------------
Public Sub btncomment_Click()

  If txtencid.Text And If cmbcomment.Text Then
    modPatient.UpdatePatComment(Trim(txtencid.Text), Trim(cmbcomment.Text))
    Balloon.Info(("Information Updated"), btncomment)
    Balloon.Delay = modBasic.$BalloonDelay
  Endif

End

Public Sub btndiary_Click()

  If txtencid.Text And If txtfileno.Text Then
    modPatient.UpdatePatFile(Trim(txtencid.Text), Trim(txtfileno.Text))
    Balloon.Info(("Information Updated"), btndiary)
    Balloon.Delay = modBasic.$BalloonDelay
  Endif

End

Private Sub ShowAllEncounters()

  Dim sql As String

  sql = "select fldencounterval,fldregdate,fldadmission,fldbillingmode,flddisctype,flddoa,fldadmitlocat,flddod,fldcurrlocat,flduserid,fldfollowdate from tblencounter where fldpatientval=&1"
  $rData3 = modDatabase.$myConn.Exec(sql, modPatient.GetPatientNoByEnc(Trim(txtencid.Text)))
  $aMyFields3 = New String[]
  modGridView.ReadSmallData(GridView3, $rData3, $aMyFields3)
  With GridView3
    .Columns[0].Width = 100 * modBasic.$AppWidthRatio
    .Columns[1].Width = 150 * modBasic.$AppWidthRatio
    .Columns[2].Width = 100 * modBasic.$AppWidthRatio
    .Columns[3].Width = 100 * modBasic.$AppWidthRatio
    .Columns[4].Width = 100 * modBasic.$AppWidthRatio
    .Columns[5].Width = 100 * modBasic.$AppWidthRatio
    .Columns[6].Width = 100 * modBasic.$AppWidthRatio
    .Columns[7].Width = 100 * modBasic.$AppWidthRatio
    .Columns[8].Width = 100 * modBasic.$AppWidthRatio
    .Columns[9].Width = 150 * modBasic.$AppWidthRatio
    .Columns[10].Width = 100 * modBasic.$AppWidthRatio

    .Columns[0].Text = "EncID"
    .Columns[1].Text = "RegDate"
    .Columns[2].Text = "Status"
    .Columns[3].Text = "BillMode"
    .Columns[4].Text = "Discount"
    .Columns[5].Text = "DOA"
    .Columns[6].Text = "RegdDept"
    .Columns[7].Text = "DiscDate"
    .Columns[8].Text = "CurDept"
    .Columns[9].Text = "Consultant"
    .Columns[10].Text = "FollowUp"
  End With

End

Public Sub GridView3_Data(Row As Integer, Column As Integer)

  $rData3.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView3, Row)
  If Column = 1 Then
    GridView3.Data.Text = modReportVar.GetDateTimeReport($rData3[$aMyFields3[Column]], gb.GeneralDate)
  Else If Column = 5 Then
    GridView3.Data.Text = modReportVar.GetDateTimeReport($rData3[$aMyFields3[Column]], gb.MediumDate)
  Else If Column = 7 Then
    GridView3.Data.Text = modReportVar.GetDateTimeReport($rData3[$aMyFields3[Column]], gb.MediumDate)
  Else If Column = 9 Then
    GridView3.Data.Text = modGeneral.GetUserFullName($rData3[$aMyFields3[Column]])
  Else If Column = 10 Then
    GridView3.Data.Text = modReportVar.GetDateTimeReport($rData3[$aMyFields3[Column]], gb.MediumDate)
  Else
    GridView3.Data.Text = $rData3[$aMyFields3[Column]]
  Endif

End

