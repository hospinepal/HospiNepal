Public Sub chkcheq_Click()

  If chkcheq.Value = True Then
    txtcheque.Text = ""
    cmbcheque.Text = ""
    panelcheque.Visible = True
  Else If chkcheq.Value = False Then
    txtcheque.Text = ""
    cmbcheque.Text = ""
    panelcheque.Visible = False
  Endif

End
