Public Sub mnuadminform_Click()

  Dim hCls As CReportCustom
  Dim xPath As String

  If txtencid.Text Then
    If modPatient.CurrentAdmissionStatus(Trim(txtencid.Text)) = "Admitted" Then
      If modSettings.ShowSettingFromFIle("Admission Report/Name") Then
        hCls = New CReportCustom(Trim(txtencid.Text), "Admission Report", "ReportSize", "Metric")
        hCls.Preview()
      Else
        xPath = modPatReports.ShowAdmissionSheet(Trim(txtencid.Text))
        modPrint.OpenHTMLPreview(Trim(txtencid.Text), xPath, "ReportSize")
      Endif
    Endif
  Endif

End

