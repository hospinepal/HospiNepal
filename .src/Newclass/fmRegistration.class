Public Sub txtnamelast_GotFocus()

  Dim xbool As Boolean

  If modBasic.$RegistGridFormat = "Yes" Then
    If Not txtnamelast.Text Then
      If modBasic.$SurNameList Then
        If modBasic.$LockSurName = "Yes" Then
          xbool = False
        Else
          xbool = True
        Endif
        txtnamelast.Enabled = False
        txtnamelast.Text = GridViewNew("Select SurName", modBasic.$SurNameList, xbool)
        txtnamelast.Enabled = True
      Endif
    Endif
  Endif

End

