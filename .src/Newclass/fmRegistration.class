Public Sub btnnepdate_Click()

  Dim xdate As Date
  Dim xnow As Date

  If dtdobmain.Value Then
    xnow = dtdobmain.Value
  Else
    xnow = Now()
  Endif
  xdate = GetDateValue(("Select Date Time of Birth"), "DateTime", xnow)
  If xdate Then
    dtdobmain.Value = xdate
  Endif
  If dtdobmain.Value Then
    $selDate = True
    modDate.DateToYearandMonth(dtdobmain.Value, txtyears, txtmonths, btnyear, btnmon)
  Endif

End

