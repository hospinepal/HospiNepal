' Gambas class file

Private $sTitle As String
Private $sUser As String[]
Private $sValue As String

Public Sub Run(sTitle As String, sUser As String[]) As String

  $sTitle = sTitle
  $sUser = sUser

  If Me.ShowModal() Then Return $sValue

End

Public Sub Form_Open()

  Me.Center
  Me.Title = $sTitle
  FillUserList()
  txtsearch.SetFocus

End

Private Sub FillUserList()

  Dim pic1 As Picture
  Dim xx As String

  ListView1.Clear()
  pic1 = Picture["icon:/small/identity"]
  If $sUser Then
    For Each xx In $sUser
      If LCase(xx) Like LCase(txtsearch.Text) & "*" Then
        ListView1.Add(xx, modGeneral.GetUserFullName(xx), pic1)
      Endif
    Next
  Endif

End

Private Sub AddSelected()

  If ListView1.Selection.Count > 0 Then
    If ListView1.Current.Key Then
      $sValue = ListView1.Current.Key
      Me.Close(True)
    Endif
  Endif

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.Esc Then
    Me.Close
  Else If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
    AddSelected()
  Endif

End

Public Sub btnsel_Click()

  AddSelected()

End

Public Sub txtsearch_KeyRelease()

  If Key.Code = Key.Down Then
    ListView1.SetFocus
  Else
    FillUserList()
  Endif

End

Public Sub txtsearch_KeyPress()

  modGeneralMain.InputTextSearchKeyOnly()

End
