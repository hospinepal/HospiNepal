' Gambas class file

Private $rData As Result
Private $aMyFields As String[]

Private $sType As String
Private $sValue As String

Public Sub Run(sType As String) As String

  $sType = sType
  If Me.ShowModal() Then Return $sValue

End

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me, "False")

  If $sType = "Pharmacy" Then
    cmbdept.List = modBasic.$AllCompList
    cmbdept.Add("%")
    cmbdept.Text = modSettings.ShowSettingFromFIle("Pharmacy/DefaultCompID")
    If cmbdept.Text = "%" Then
    Else
      lbldept.Text = modGeneral.GetCompNameFromCompID(cmbdept.Text)
    Endif

  Else If $sType = "Clinic" Then
    If modBasic.$FixedDepartment Then
      cmbdept.Text = modBasic.$FixedDepartment
    Else
      cmbdept.List = modMisc.GetDepartmentAllList("Consultation")
      cmbdept.Add("%")
      cmbdept.Text = modSettings.ShowSettingFromFIle("Clinic/DefaultOPD")
    Endif

  Else If $sType = "Procedure" Then
    cmbdept.Text = modSettings.ShowSettingFromFIle("Procedure/DefaultCompID")

  Endif
  cmbdept.SetFocus

End

Public Sub cmbdept_Click()

  If $sType = "Pharmacy" Then
    If cmbdept.Text = "%" Then
    Else
      lbldept.Text = modGeneral.GetCompNameFromCompID(cmbdept.Text)
    Endif
  Else If $sType = "Clinic" Then
  Else If $sType = "Procedure" Then
  Endif

End

Public Sub btnrefresh_Click()

  If $sType = "Pharmacy" Then
    modSettings.SaveSettingsToFile("Pharmacy/DefaultCompID", cmbdept.Text)
    FillPharmGrid()
  Else If $sType = "Clinic" Then
    modSettings.SaveSettingsToFile("Clinic/DefaultOPD", cmbdept.Text)
    FillClinicGrid()
  Else If $sType = "Procedure" Then
    modSettings.SaveSettingsToFile("Procedure/DefaultCompID", cmbdept.Text)
    FillProcedureGrid()
  Endif
  GridView1.SetFocus

End

Private Sub FillProcedureGrid()

  Dim sql As String

  If modBasic.$LockToOwnProcedure = "Yes" Then
    sql = "select fldencounterval,fldencounterval,fldencounterval,fldencounterval,flditem,fldid,fldid from tblpatgeneral where fldinput=&1 and fldreportquali=&2 and fldcomp like &3 GROUP BY fldencounterval"
  Else
    sql = "select fldencounterval,fldencounterval,fldencounterval,fldencounterval,flditem,fldid,fldid from tblpatgeneral where fldinput=&1 and fldreportquali=&2 GROUP BY fldencounterval"
  Endif
  $rData = modDatabase.$myConn.Exec(sql, "Procedures", "Planned", modGeneralMain.compID)
  $aMyFields = New String[]
  modGridView.ReadSmallData(GridView1, $rData, $aMyFields)
  With GridView1
    .Columns[0].Width = 1
    .Columns[1].Width = 100 * modBasic.$AppWidthRatio
    .Columns[2].Width = 200 * modBasic.$AppWidthRatio
    .Columns[3].Width = 1
    .Columns[4].Width = 300 * modBasic.$AppWidthRatio
    .Columns[5].Width = 1
    .Columns[6].Width = 25 * modBasic.$AppWidthRatio
    .Columns[1].Text = "ENCID"
    .Columns[2].Text = "Name"
    .Columns[4].Text = "Particulars"
  End With

End

Private Sub FillPharmGrid()

  Dim sql As String

  If cmbdept.Text = "%" Then
    sql = "select fldencounterval,fldencounterval,fldencounterval,fldencounterval,fldstatus,fldid,fldid from tblpatdosing where fldsave_order=&1 and fldsave=&2 and fldorder=&3 and fldcurval=&4 GROUP BY fldencounterval"
  Else
    sql = "select fldencounterval,fldencounterval,fldencounterval,fldencounterval,fldstatus,fldid,fldid from tblpatdosing where fldsave_order=&1 and fldsave=&2 and fldorder=&3 and fldcurval=&4 and fldcomp_order=&5 GROUP BY fldencounterval"
  Endif
  $rData = modDatabase.$myConn.Exec(sql, False, True, "Request", "Continue", cmbdept.Text)
  $aMyFields = New String[]
  modGridView.ReadSmallData(GridView1, $rData, $aMyFields)
  With GridView1
    .Columns[0].Width = 1
    .Columns[1].Width = 100 * modBasic.$AppWidthRatio
    .Columns[2].Width = 200 * modBasic.$AppWidthRatio
    .Columns[3].Width = 125 * modBasic.$AppWidthRatio
    .Columns[4].Width = 75 * modBasic.$AppWidthRatio
    .Columns[5].Width = 1
    .Columns[6].Width = 25 * modBasic.$AppWidthRatio
    .Columns[1].Text = "ENCID"
    .Columns[2].Text = "Name"
    .Columns[3].Text = "Location"
    .Columns[4].Text = "Status"
  End With

End

Private Sub FillClinicGrid()

  Dim sql As String

  If modBasic.$FixedDepartment Then
    sql = "select fldencounterval,fldconsultname,fldencounterval,fldconsulttime,fldid,fldid,fldid from tblconsult where fldconsulttime>=&1 and fldconsulttime<=&2 and fldstatus=&3 and fldconsultname=&4"                                               ''
    $rData = modDatabase.$myConn.Exec(sql, modDate.StartSqlDate(Now()), modDate.EndSqlDate(Now()), "Planned", modBasic.$FixedDepartment)
  Else
    If cmbdept.Text = "%" Then
      sql = "select fldencounterval,fldconsultname,fldencounterval,fldconsulttime,fldid,fldid,fldid from tblconsult where fldconsulttime>=&1 and fldconsulttime<=&2 and fldstatus=&3"                                               ''
    Else
      sql = "select fldencounterval,fldconsultname,fldencounterval,fldconsulttime,fldid,fldid,fldid from tblconsult where fldconsulttime>=&1 and fldconsulttime<=&2 and fldstatus=&3 and fldconsultname=&4"
    Endif
    $rData = modDatabase.$myConn.Exec(sql, modDate.StartSqlDate(Now()), modDate.EndSqlDate(Now()), "Planned", cmbdept.Text)
  Endif
  $aMyFields = New String[]
  modGridView.ReadSmallData(GridView1, $rData, $aMyFields)
  With GridView1
    .Columns[0].Width = 1
    .Columns[1].Width = 125 * modBasic.$AppWidthRatio
    .Columns[2].Width = 200 * modBasic.$AppWidthRatio
    .Columns[3].Width = 125 * modBasic.$AppWidthRatio
    .Columns[4].Width = 25 * modBasic.$AppWidthRatio
    .Columns[5].Width = 1
    .Columns[6].Width = 25 * modBasic.$AppWidthRatio
    .Columns[1].Text = "Consult"
    .Columns[2].Text = "Name"
    .Columns[3].Text = "Time"
  End With

End

Public Sub GridView1_Data(Row As Integer, Column As Integer)

  $rData.MoveTo(Row)
  modGeneralMain.GridViewDecoration(GridView1, Row)
  If Column = 2 Then
    GridView1.Data.Text = modPatient.GetPatientNameByEnc($rData[$aMyFields[Column]])
  Else If Column = 6 Then
    GridView1.Data.Picture = Picture["icon:/small/apply"]
    GridView1.Data.Text = ""
  Else If Column = 3 Then
    If $sType = "Pharmacy" Then
      GridView1.Data.Text = modPatient.GetPatientLocation($rData[$aMyFields[Column]])
    Else If $sType = "Clinic" Then
      GridView1.Data.Text = Time($rData[$aMyFields[Column]])
    Else If $sType = "Procedure" Then
      GridView1.Data.Text = $rData[$aMyFields[Column]]
    Endif
  Else If Column = 4 Then
    GridView1.Data.Text = ""
    If $sType = "Pharmacy" Then
      GridView1.Data.Text = $rData[$aMyFields[Column]]
    Else If $sType = "Procedure" Then
      GridView1.Data.Text = $rData[$aMyFields[Column]]
    Else If $sType = "Clinic" Then
      If CheckBox1.Value = True Then
        GridView1.Data.Picture = Picture[modBillings.GetBillingStatusIconConsult($rData[$aMyFields[Column]])]
      Endif
    Endif
  Else
    GridView1.Data.Text = $rData[$aMyFields[Column]]
  Endif

End

Public Sub GridView1_KeyPress()

  If GridView1.Rows.Selection.Count > 0 Then
    If Key.Code = Key.Return Or If Key.Code = Key.Enter Or If Key.Code = Key.AltKey Then
      $sValue = GridView1[GridView1.Row, 0].Text
      Me.Close(True)
    Endif
  Endif

End

Public Sub GridView1_Click()

  If GridView1.Column = 6 Then
    $sValue = GridView1[GridView1.Row, 0].Text
    Me.Close(True)
  Endif

End

Public Sub Form_KeyRelease()

  If Key.Code = Key.Esc Then
    Me.Close
  Endif

End
