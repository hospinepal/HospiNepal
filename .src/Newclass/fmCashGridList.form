# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,86,60)
  Text = ("Item Grid")
  Resizable = False
  { txtname TextBox
    MoveScaled(4,1,39,3.3333)
    ToolTip = ("Write few alphabets of Item name and press Down arrow")
  }
  { GridView1 GridView
    MoveScaled(1,5,84,54)
    Mode = Select.Single
    AutoResize = False
  }
  { txtcode TextBox
    MoveScaled(69,1,16,3.3333)
    ToolTip = ("Write few alphabets of Item Code and press Down arrow")
  }
  { Panel1 Panel
    MoveScaled(46,1,20,3)
    { rbtext RadioButton
      MoveScaled(1,0.2667,7,3)
      Text = ("Text")
    }
    { rbcode RadioButton
      MoveScaled(10,0,9,3)
      Text = ("Code")
    }
  }
  { chkleftmain CheckBox
    MoveScaled(1,1,3,3.3333)
  }
}
