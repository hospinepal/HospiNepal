# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,110,40)
  Text = ("Verification List")
  Resizable = False
  { mnufile Menu
    Visible = False
    { mnuverify Menu
      Text = ("Mark Verified")
      Shortcut = "Ctrl+V"
    }
    { mnumark Menu
      Text = ("Mark Checked")
      Shortcut = "Ctrl+H"
    }
    { mnureport Menu
      Text = ("Edit Value")
    }
  }
  { txtsearch TextBox
    MoveScaled(1,0.625,18.75,3)
  }
  { btnrefresh Button
    MoveScaled(80,0.625,7,3)
    Picture = Picture["icon:/small/refresh"]
  }
  { GridView1 GridView
    MoveScaled(1,4,108,35)
    Mode = Select.Single
    Header = GridView.Horizontal
    AutoResize = False
  }
  { Panel2 Panel
    MoveScaled(88,0.625,21,3)
    { rbsi RadioButton
      MoveScaled(0,0,9,3)
      Text = ("SI Unit")
    }
    { rbmetric RadioButton
      MoveScaled(10,0,10,3)
      Text = ("Metric")
    }
  }
  { Label5 Label
    MoveScaled(22,0.625,5,3)
    Text = ("Flag")
    Border = Border.Plain
  }
  { cmbflag ComboBox
    MoveScaled(27,0.625,12,3)
  }
  { chkdate CheckBox
    MoveScaled(41,0.625,13,3)
    Text = ("Samp Date")
  }
  { dtsample DateBox
    MoveScaled(55,0.625,16,3)
    Enabled = False
  }
  { dtnepfir ToolButton
    MoveScaled(71,0.625,3,3)
    Enabled = False
    Picture = Picture["icon:/small/calendar"]
  }
}
