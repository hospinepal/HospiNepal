''================================== USER SETTING ====================================================
Private Sub GeneralSetting()

  txtmusicpath.Text = modSettings.ShowSettingFromVar("AppSetting_InformMusic/" & modGeneralMain.$lbluser)
  If txtmusicpath.Text = "" Then
    txtmusicpath.Text = modHelpVariable.$mediaDirectory &/ "notify.ogg"
  Endif
  If modSettings.ShowSettingFromVar("AppSetting_VolumeMusic/" & modGeneralMain.$lbluser) Then
    txtvolmusic.Value = CInt(modSettings.ShowSettingFromVar("AppSetting_VolumeMusic/" & modGeneralMain.$lbluser))
  Endif
  txtdict.Text = modSettings.ShowSettingFromVar("AppSetting_Dictionary/" & modGeneralMain.$lbluser)

  If modSettings.ShowSettingFromVar("AppSetting_LockTime/" & modGeneralMain.$lbluser) Then
    txtlock.Value = CFloat(modSettings.ShowSettingFromVar("AppSetting_LockTime/" & modGeneralMain.$lbluser))
  Endif

  If modSettings.ShowSettingFromVar("AppSetting_ImageSplash/" & modGeneralMain.$lbluser) Then
    txtsplash.Value = CFloat(modSettings.ShowSettingFromVar("AppSetting_ImageSplash/" & modGeneralMain.$lbluser))
  Endif

  cmbspread.Text = modSettings.ShowSettingFromVar("AppSetting_Spreadsheet/" & modGeneralMain.$lbluser)
  cmbmedview.Text = modSettings.ShowSettingFromVar("AppSetting_ItemView/" & modGeneralMain.$lbluser)
  cmbrowser.Text = modSettings.ShowSettingFromVar("AppSetting_ReportBrowser/" & modGeneralMain.$lbluser)

  cmbmultimed.Text = modSettings.ShowSettingFromVar("AppSetting_MediaPlayerFormat/" & modGeneralMain.$lbluser)

  modSettings.ShowCheckBoxVar(chkadleft, "DisableAdvertise_Left/" & modGeneralMain.$lbluser)
  modSettings.ShowCheckBoxVar(chkadright, "DisableAdvertise_Right/" & modGeneralMain.$lbluser)

End

'music path
Public Sub txtmusicpath_Click()

  Dialog.Filter = ["*.ogg;*.mp3", "Audio files"]
  If Dialog.OpenFile() Then Return
  Try txtmusicpath.Text = Dialog.Path

End

Public Sub btnmusic_Click()

  modSettings.SaveSettingsToVar("AppSetting_InformMusic/" & modGeneralMain.$lbluser, txtmusicpath.Text)
  If Exist(txtmusicpath.Text) Then
    modBasic.$InfoMusic = txtmusicpath.Text
  Endif
  modSettings.SaveSettingsToVar("AppSetting_VolumeMusic/" & modGeneralMain.$lbluser, txtvolmusic.Value)
  If txtvolmusic.Value Then
    modBasic.$InfoMusicVol = txtvolmusic.Value
  Endif
  Balloon.Info(("Information saved"), btnmusic)
  Balloon.Delay = modBasic.$BalloonDelay

End

