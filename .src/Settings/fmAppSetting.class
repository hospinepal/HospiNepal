''================================== DESIGN ================================================
Private Sub ShowDesignSetting()

  txtimagpath.Text = modSettings.ShowSettingFromVar("AppSetting_DeskPicture/" & modGeneralMain.$lbluser)
  If modSettings.ShowSettingFromVar("AppSetting_DeskBackColor/" & modGeneralMain.$lbluser) Then
    txtdeskbackcolor.Value = CInt(modSettings.ShowSettingFromVar("AppSetting_DeskBackColor/" & modGeneralMain.$lbluser))
  Endif
  If txtimagpath.Text = "" Then
    txtimagpath.Text = modHelpVariable.$mediaDirectory &/ "background.jpg"
  Endif

  txtformback.Text = modSettings.ShowSettingFromVar("AppSetting_FormPicture/" & modGeneralMain.$lbluser)
  If modSettings.ShowSettingFromVar("AppSetting_FormBackColor/" & modGeneralMain.$lbluser) Then
    txtformbackcolor.Value = CInt(modSettings.ShowSettingFromVar("AppSetting_FormBackColor/" & modGeneralMain.$lbluser))
  Endif
  If modSettings.ShowSettingFromVar("AppSetting_FormForeColor/" & modGeneralMain.$lbluser) Then
    txtformforecolor.Value = CInt(modSettings.ShowSettingFromVar("AppSetting_FormForeColor/" & modGeneralMain.$lbluser))
  Endif

  If txtformback.Text = "" Then
    txtformback.Text = modHelpVariable.$mediaDirectory &/ "background.jpg"
  Endif

  cmbtab.Text = modSettings.ShowSettingFromVar("AppSetting_TabPosition/" & modGeneralMain.$lbluser)

  If modSettings.ShowSettingFromVar("AppSetting_DeskHeaderHeight/" & modGeneralMain.$lbluser) Then
    cmbheadsize.Value = CInt(modSettings.ShowSettingFromVar("AppSetting_DeskHeaderHeight/" & modGeneralMain.$lbluser))
  Endif
  cmbheadtext.Text = modSettings.ShowSettingFromVar("AppSetting_DeskHeaderText/" & modGeneralMain.$lbluser)
  txtheadimage.Text = modSettings.ShowSettingFromVar("AppSetting_DeskHeaderPicture/" & modGeneralMain.$lbluser)
  If modSettings.ShowSettingFromVar("AppSetting_DeskHeaderFont/" & modGeneralMain.$lbluser) Then
    txtheadfont.Value = modSettings.ShowSettingFromVar("AppSetting_DeskHeaderFont/" & modGeneralMain.$lbluser)
  Endif

  If modSettings.ShowSettingFromVar("AppSetting_DeskHeaderBackColor/" & modGeneralMain.$lbluser) Then
    txtheadbackcolor.Value = CInt(modSettings.ShowSettingFromVar("AppSetting_DeskHeaderBackColor/" & modGeneralMain.$lbluser))
  Endif
  If modSettings.ShowSettingFromVar("AppSetting_DeskHeaderForeColor/" & modGeneralMain.$lbluser) Then
    txtheadforecolor.Value = CInt(modSettings.ShowSettingFromVar("AppSetting_DeskHeaderForeColor/" & modGeneralMain.$lbluser))
  Endif

End

