' Gambas class file

Public Sub btnuserprofile_Click()

  Dim hForm As FmReportUsers

  hForm = New FmReportUsers(txtuser.Text)
  hForm.ShowModal

End

Public Sub btnbackup_Click()

  Dim sPass As String
  Dim xtar As String
  Dim arcmd As String[]

  sPass = InputPassword(("Enter Password for Super User"), ("Super User"), "")
  If sPass Then
    xtar = Temp(modHelpVariable.AppName) & ".tar"
    arcmd = ["tar", "-C", Desktop.ConfigDir, "-cvf", xtar, modHelpVariable.AppName]
    modBasic.DebugString("Execute " & arcmd.Join(Space(1)))
    Exec arcmd Wait
    modHelpVariable.CopyAsRoot(xtar, modHelpVariable.$appetcFolder, sPass)
    Balloon.Info(("Setting File copied"), btnbackup)
    Balloon.Delay = modBasic.$BalloonDelay
  Endif

End

Public Sub btnrestore_Click()

  modHelpVariable.RestoreConfigSettings()
  Balloon.Info(("Setting File copied"), btnrestore)
  Balloon.Delay = modBasic.$BalloonDelay

End

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me)
  txtuser.Text = modGeneralMain.$lbluser
  cmbspread.List = modMedicine.FillExportType()
  cmbmedview.List = ["ComboBox", "GridView"]
  cmbrowser.List = ["BuiltIn", "External"]
  cmbmultimed.List = ["Embedded", "External"]
  cmbhelp.List = ["Offline", "Online"]
  cmbgnupg.List = modMisc.GetGNUPGKeyList()
  cmbheadtext.List = ["{HospitalName}", "{HospitalAddress}", "{Department}", "{CurrentDate}", "{CurrentUser}"]
  cmblocal.List = modApplication.GetLocaleList()
  cmbweek.List = ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"]
  cmbterminal.List = ["Enable", "Disable"]
  cmbemailclient.List = ["SMTP Client", "Desktop Client"]
  cmbtheme.List = Stock.Themes
  cmbshellpath.List = ["/bin/sh", "/bin/bash", "/bin/dash"]

  GetControlSettings()
  ShowDesignSetting()
  GeneralSetting()
  ShowScripting()
  ShowAllUserSetting()
  ShowOptionSettings()

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

''================================ Controls =============================
Private Sub GetControlSettings()

  If modSettings.ShowSettingFromVar("AppSetting_DataViewEvenRowBackColor/" & modGeneralMain.$lbluser) Then
    txtevenbackcolor.Value = CInt(modSettings.ShowSettingFromVar("AppSetting_DataViewEvenRowBackColor/" & modGeneralMain.$lbluser))
  Endif
  If modSettings.ShowSettingFromVar("AppSetting_DataViewEvenRowForeColor/" & modGeneralMain.$lbluser) Then
    txtevenforecolor.Value = CInt(modSettings.ShowSettingFromVar("AppSetting_DataViewEvenRowForeColor/" & modGeneralMain.$lbluser))
  Endif

  If modSettings.ShowSettingFromVar("AppSetting_DataViewOddRowBackColor/" & modGeneralMain.$lbluser) Then
    txtoddbackcolor.Value = CInt(modSettings.ShowSettingFromVar("AppSetting_DataViewOddRowBackColor/" & modGeneralMain.$lbluser))
  Endif
  If modSettings.ShowSettingFromVar("AppSetting_DataViewOddRowForeColor/" & modGeneralMain.$lbluser) Then
    txtoddforecolor.Value = CInt(modSettings.ShowSettingFromVar("AppSetting_DataViewOddRowForeColor/" & modGeneralMain.$lbluser))
  Endif

  txtlabelfont.Value = modSettings.ShowSettingFromVar("AppSetting_TextLabelFont/" & modGeneralMain.$lbluser)
  If modSettings.ShowSettingFromVar("AppSetting_TextLabelForeColor/" & modGeneralMain.$lbluser) Then
    txtlabelbackcolor.Value = modSettings.ShowSettingFromVar("AppSetting_TextLabelForeColor/" & modGeneralMain.$lbluser)
  Endif

End

