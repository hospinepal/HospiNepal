Public Sub btndownhelp_Click()

  Dim arcmd As String[]
  Dim sLink As String

  Inc Application.Busy
  sLink = modWeb.GetHelpZipLink()
  arcmd = ["wget", sLink, "-P", modHelpVariable.AppDirectory]
  modBasic.DebugString("Execute " & arcmd.Join(Space(1)))
  Exec arcmd Wait
  Dec Application.Busy

End

Public Sub btnbaloon_Click()

  modSettings.SaveSettingsToFile("GeneralSettings/BalloonDelay", txtbaloon.Value)
  If txtbaloon.Value Then
    modBasic.$BalloonDelay = txtbaloon.Value
  Endif
  Balloon.Info(("Information saved"), btnbaloon)
  Balloon.Delay = modBasic.$BalloonDelay

End

