'''----------------------------------------------- SMS FTP -------------------------------------

Public Sub btnsms_Click()

  modSettings.SaveSettingsToFile("Laboratory/Patient_EnableSMS", cmbsms.Text)
  modSettings.SaveSettingsToFile("Laboratory/Patient_SMSText", txtsms.Text)
  Balloon.Info(("Information saved"), btnsms)
  Balloon.Delay = modBasic.$BalloonDelay

End

Private Sub SMSwithFTP()

  cmbsms.Text = modSettings.ShowSettingFromFIle("Laboratory/Patient_EnableSMS")
  txtsms.Text = modSettings.ShowSettingFromFIle("Laboratory/Patient_SMSText")

  cmbsmsabn.Text = modSettings.ShowSettingFromFIle("Laboratory/AbnormalVal_AutoSMS")
  txtsmabnorm.Text = modSettings.ShowSettingFromFIle("Laboratory/AbnormalVal_SMSText")

End

Public Sub btnvarpatient_Click()

  Dim hform As FmMedVariableEdit

  hform = New FmMedVariableEdit(modString.GetLastWordPosition(txtsms.Text), txtsms, 2)
  hform.ShowModal

End

Public Sub btnvarconsltnt_Click()

  Dim hform As FmMedVariableEdit

  hform = New FmMedVariableEdit(modString.GetLastWordPosition(txtsmabnorm.Text), txtsmabnorm, 2)
  hform.ShowModal

End

Public Sub btnsmsabn_Click()

  modSettings.SaveSettingsToFile("Laboratory/AbnormalVal_AutoSMS", cmbsmsabn.Text)
  modSettings.SaveSettingsToFile("Laboratory/AbnormalVal_SMSText", txtsmabnorm.Text)
  Balloon.Info(("Information saved"), btnsmsabn)
  Balloon.Delay = modBasic.$BalloonDelay

End

''-------------------------------------- Footer List -------------------------------------------
Public Sub txtfootlink_Click()

  If Dialog.OpenFile() Then Return
  txtfootlink.Text = Dialog.Path

End

Public Sub btnfootadd_Click()

  modSettings.SaveSettingsToFile("FooterNote/Name_" & CStr(lstfooter.List.Count + 1), txtfootname.Text)
  modSettings.SaveSettingsToFile("FooterNote/Link_" & CStr(lstfooter.List.Count + 1), txtfootlink.Text)
  lstfooter.List = modLabTest.ListFooterNoteList()
  Balloon.Info(("Information saved"), btnfootadd)
  Balloon.Delay = modBasic.$BalloonDelay

End

Public Sub lstfooter_Click()

  txtfootindex.Text = CStr(lstfooter.Index)
  txtfootname.Text = modSettings.ShowSettingFromFIle("FooterNote/Name_" & CStr(lstfooter.Index + 1))
  txtfootlink.Text = modSettings.ShowSettingFromFIle("FooterNote/Link_" & CStr(lstfooter.Index + 1))

End

Public Sub btnfootedit_Click()

  If txtfootindex.Text Then
    modSettings.SaveSettingsToFile("FooterNote/Name_" & CStr(CInt(txtfootindex.Text) + 1), txtfootname.Text)
    modSettings.SaveSettingsToFile("FooterNote/Link_" & CStr(CInt(txtfootindex.Text) + 1), txtfootlink.Text)
    Balloon.Info(("Information updated"), btnfootedit)
    Balloon.Delay = modBasic.$BalloonDelay
  Endif

End

