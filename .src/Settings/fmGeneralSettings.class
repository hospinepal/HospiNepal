' Gambas class file

Private $TableList As String[]

Public Sub btnshowsetting_Click()

  IconPanel1.Enabled = True

  GeneralSecurity()
  ShowEncounterLockSetting()
  ReportLogger()
  WebCamShot()
  DisplayMessageLog()
  GeneralSetting()
  UploadSetting()

  DisplayF1Setting()
  ShowF2Setting()
  GeneralAccessSetting()

End

Public Sub cmbtarget_Click()

  lblcomp.Text = modGeneral.GetCompNameFromCompID(cmbtarget.Text)

End

Public Sub cmbtarget_GotFocus()

  IconPanel1.Enabled = False

End

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me)
  cmbtarget.List = modBasic.$AllCompList
  cmbtarget.Text = modGeneralMain.compID
  $TableList = modDatabase.FillDBTables(True)

  cmbencrypdf.List = ["Yes", "No"]
  cmbuppersonal.List = ["DB", "FTP"]
  cmbuppatient.List = ["DB", "FTP"]
  cmbuplog.List = ["DB", "FTP"]
  cmbuplogin.List = ["DB", "FTP"]
  cmbupgnupg.List = ["DB", "FTP"]
  cmbupready.List = ["DB", "FTP"]
  cmbupmedimage.List = ["DB", "FTP"]
  cmbupiresearch.List = ["DB", "FTP"]
  cmbupofficedocs.List = ["DB", "FTP"]

  cmblabadd.List = ["Yes", "No"]
  cmbradioadd.List = ["Yes", "No"]
  cmbsampldtlock.List = ["Yes", "No"]
  cmbreclinic.List = ["Yes", "No"]
  cmbregpatno.List = ["Yes", "No"]
  cmbenclock.List = ["Yes", "No"]
  cmbschedule.List = ["Yes", "No"]
  cmbpatencrp.List = ["Yes", "No"]
  cmbbillrepo.List = ["Yes", "No"]

  cmbF1clin.List = ["Yes", "No"]
  cmbF1disp.List = ["Yes", "No"]
  cmbF1sampl.List = ["Yes", "No"]
  cmbF1cash.List = ["Yes", "No"]

  cmbF2clinic.List = ["Yes", "No"]
  cmbF2disp.List = ["Yes", "No"]
  cmbF2proce.List = ["Yes", "No"]

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

''----------------------------- General Security ----------------------------------
Public Sub GeneralSecurity()

  cmbenclock.Text = modGlobalSetting.ShowSettingFromDBAny("TableLock/EncounterLock", cmbtarget.Text)
  cmbschedule.Text = modGlobalSetting.ShowSettingFromDBAny("RemoteExec/ScheduleTask", cmbtarget.Text)
  cmbpatencrp.Text = modGlobalSetting.ShowSettingFromDBAny("PatientInfo/Encryption", cmbtarget.Text)
  modGlobalSetting.ShowTableSettingDB(ListBox1, cmbtarget.Text, "DisableSQLQuery")

End

Public Sub btnaddtable_Click()

  modGlobalSetting.AddTableListDB(cmbtarget.Text, "DisableSQLQuery", $TableList, ListBox1)
  modGlobalSetting.ShowTableSettingDB(ListBox1, cmbtarget.Text, "DisableSQLQuery")

End

Public Sub ListBox1_Menu()

  mnufilesql.Popup

End

Public Sub mnudel_Click()

  modDatabase.$myConn.Delete("tbltabsettings", "fldcomp=&1 and fldcategory=&2 and fldvalue=&3", cmbtarget.Text, "DisableSQLQuery/TableList", ListBox1.Text)                                   ''
  modGlobalSetting.ShowTableSettingDB(ListBox1, cmbtarget.Text, "DisableSQLQuery")

End

Public Sub mnudelall_Click()

  Dim xx As String

  Inc Application.Busy
  For Each xx In ListBox1.List
    modDatabase.$myConn.Delete("tbltabsettings", "fldcomp=&1 and fldcategory=&2 and fldvalue=&3", cmbtarget.Text, "DisableSQLQuery/TableList", xx)                                   ''
  Next
  Dec Application.Busy
  modGlobalSetting.ShowTableSettingDB(ListBox1, cmbtarget.Text, "DisableSQLQuery")

End

Public Sub btnenclock_Click()

  modGlobalSetting.SaveSettingToDB("TableLock/EncounterLock", cmbenclock.Text, cmbtarget.Text)
  Balloon.Info(("Information saved"), btnenclock)
  Balloon.Delay = modBasic.$BalloonDelay

End

Public Sub btnschedule_Click()

  modGlobalSetting.SaveSettingToDB("RemoteExec/ScheduleTask", cmbschedule.Text, cmbtarget.Text)
  Balloon.Info(("Information saved"), btnschedule)
  Balloon.Delay = modBasic.$BalloonDelay

End

Public Sub btnpatencryp_Click()

  modGlobalSetting.SaveSettingToDB("PatientInfo/Encryption", cmbpatencrp.Text, cmbtarget.Text)
  Balloon.Info(("Information saved"), btnpatencryp)
  Balloon.Delay = modBasic.$BalloonDelay

End

Public Sub btnregistlock_Click()

  If txtlockregist.Value Then
    modGlobalSetting.SaveSettingToDB("EncounterLock/Registration_Days", txtlockregist.Value, cmbtarget.Text)
    modGlobalSetting.EnterSettingFromDB(chkregistcashier, "EncounterLock/Registration_Cashier", cmbtarget.Text)
    modGlobalSetting.EnterSettingFromDB(chkregistclinician, "EncounterLock/Registration_Clinician", cmbtarget.Text)
    modGlobalSetting.EnterSettingFromDB(chkregistdispensar, "EncounterLock/Registration_Dispensar", cmbtarget.Text)
    modGlobalSetting.EnterSettingFromDB(chkregisttechnician, "EncounterLock/Registration_Technician", cmbtarget.Text)
    Balloon.Info(("Information saved"), btnregistlock)
    Balloon.Delay = modBasic.$BalloonDelay
  Endif

End

Public Sub btnexitlock_Click()

  If txtlockexit.Value Then
    modGlobalSetting.SaveSettingToDB("EncounterLock/DischargeExit_Days", txtlockexit.Value, cmbtarget.Text)
    modGlobalSetting.EnterSettingFromDB(chkexitcashier, "EncounterLock/DischargeExit_Cashier", cmbtarget.Text)
    modGlobalSetting.EnterSettingFromDB(chkexitdispensar, "EncounterLock/DischargeExit_Dispensar", cmbtarget.Text)
    Balloon.Info(("Information saved"), btnexitlock)
    Balloon.Delay = modBasic.$BalloonDelay
  Endif

End

Private Sub ShowEncounterLockSetting()

  If modGlobalSetting.ShowSettingFromDBAny("EncounterLock/Registration_Days", cmbtarget.Text) Then
    txtlockregist.Value = CInt(modGlobalSetting.ShowSettingFromDBAny("EncounterLock/Registration_Days", cmbtarget.Text))
  Endif
  modGlobalSetting.ShowCheckBoxFromDBAny(chkregistcashier, "EncounterLock/Registration_Cashier", cmbtarget.Text)
  modGlobalSetting.ShowCheckBoxFromDBAny(chkregistclinician, "EncounterLock/Registration_Clinician", cmbtarget.Text)
  modGlobalSetting.ShowCheckBoxFromDBAny(chkregistdispensar, "EncounterLock/Registration_Dispensar", cmbtarget.Text)
  modGlobalSetting.ShowCheckBoxFromDBAny(chkregisttechnician, "EncounterLock/Registration_Technician", cmbtarget.Text)

  If modGlobalSetting.ShowSettingFromDBAny("EncounterLock/DischargeExit_Days", cmbtarget.Text) Then
    txtlockexit.Value = CInt(modGlobalSetting.ShowSettingFromDBAny("EncounterLock/DischargeExit_Days", cmbtarget.Text))
  Endif
  modGlobalSetting.ShowCheckBoxFromDBAny(chkexitcashier, "EncounterLock/DischargeExit_Cashier", cmbtarget.Text)
  modGlobalSetting.ShowCheckBoxFromDBAny(chkexitdispensar, "EncounterLock/DischargeExit_Dispensar", cmbtarget.Text)

End

