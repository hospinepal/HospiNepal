' Gambas class file

Public Sub Form_Open()

  modGeneralMain.ArrangeFormCentre(Me)
  cmbtype1.List = ["Test", "Exam"]
  cmbtype2.List = ["Test", "Exam"]
  cmbtype3.List = ["Test", "Exam"]
  cmbtype4.List = ["Test", "Exam"]
  cmbtype5.List = ["Test", "Exam"]
  cmbtype6.List = ["Test", "Exam"]
  cmbtype7.List = ["Test", "Exam"]
  cmbtype8.List = ["Test", "Exam"]
  cmbtype9.List = ["Test", "Exam"]
  cmbtype10.List = ["Test", "Exam"]

  ShowReport(0)

End

Public Sub Form_Close()

  modGeneralMain.RecordFormExit(Me)

End

Public Sub Form_KeyRelease()

  modGeneralmain.GoToNextControlTab()

End

Private Sub FillItemList(cmbitem As ComboBox, cmbexamname As ComboBox)

  If cmbitem.Text = "Test" Then
    cmbexamname.List = modMedicine.FillLabTestCombo("%")
  Else If cmbitem.Text = "Exam" Then
    cmbexamname.List = modMedicine.FillExamQualiOrQuantiCombo("%")
  Endif

End

Public Sub cmbtype1_LostFocus()

  FillItemList(cmbtype1, cmbitem1)

End

