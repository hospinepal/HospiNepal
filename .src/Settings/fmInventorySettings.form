# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,79,54)
  Text = ("Inventory Setting")
  Resizable = False
  { Frame5 Frame
    MoveScaled(1,1,77,7)
    Text = ("Default Profit Margin")
    { Label10 Label
      MoveScaled(1,3,12,3)
      Text = ("Medicines")
      Border = Border.Plain
    }
    { Label12 Label
      MoveScaled(40,3,11,3)
      Text = ("Surgicals")
      Border = Border.Plain
    }
    { txtpromed ValueBox
      MoveScaled(14,3,12,3)
      ToolTip = ("Write default profit margin for medicines to appear in purchase entry")
    }
    { txtprosurg ValueBox
      MoveScaled(52,3,11,3)
      ToolTip = ("Write default profit margin for surgicals and orthopedics to appear in purchase entry")
    }
    { btnprofit ToolButton
      MoveScaled(72,3,3.1333,3)
      Picture = Picture["icon:/small/apply"]
    }
  }
  { Frame4 Frame
    MoveScaled(1,21,77,31)
