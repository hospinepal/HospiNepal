    }
    { txtlockpurchase ValueBox
      MoveScaled(56,7,15,3)
      ToolTip = ("Write if you want to avoid purchase entry of items whose expiry date is less than mentioned number of days")
    }
    { Label14 Label
      MoveScaled(1,11,54,3)
      Text = ("Restrict Item Return if expiry date is less than (days)")
      Border = Border.Plain
    }
    { txtlockreturn ValueBox
      MoveScaled(56,11,15,3)
      ToolTip = ("Write if you want to avoid pharmacy return of items whose expiry date is less than mentioned number of days")
    }
    { btnskipexpiry ToolButton
      MoveScaled(72,3,3.1333,3)
      Picture = Picture["icon:/small/apply"]
    }
    { btnlockpurchase ToolButton
      MoveScaled(72,7,3.1333,3)
      Picture = Picture["icon:/small/apply"]
    }
    { btnlockreturn ToolButton
      MoveScaled(72,11,3.1333,3)
      Picture = Picture["icon:/small/apply"]
    }
    { Label3 Label
      MoveScaled(1,23,23,3)
      Text = ("List of Manufacturer")
