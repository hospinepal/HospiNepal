    }
    { btnserialopen ToolButton
      MoveScaled(72,15,3.1333,3)
      Picture = Picture["icon:/small/apply"]
    }
    { Label6 Label
      MoveScaled(1,19,47,3)
      Text = ("Hide Item Storage Location using SerialPort")
