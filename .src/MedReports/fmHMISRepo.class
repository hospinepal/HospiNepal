''====================== Delivery Types Report ===================
Private Function GetDeliveryTypeEnc(encid As String) As String

  Dim res As Result
  Dim xval As String

  res = modDatabase.$syConn.Exec("select flddeltype from tblconfinement where fldencounterval=&1", encid)
  If res.Available Then
    res.MoveFirst
    If res!flddeltype Then
      xval = res!flddeltype
    Else
      xval = ""
    Endif
  Else
    xval = ""
  Endif
  Return xval

End

Private Sub DeliveryTypeReport()

  Dim xlist1 As String
  Dim xlist2 As String
  Dim xlist3 As String

  Dim xsponlist As String[]
  Dim xinstlist As String[]
  Dim xcesrlist As String[]

  Dim res1 As Result
  Dim res2 As Result
  Dim res3 As Result

  Dim xdeltype As String
  Dim xsponval As Integer
  Dim xinstval As Integer
  Dim xcessval As Integer

  fmDelTypes.Close()
  fmDelTypes.ShowModal()

  Inc Application.Busy
  xlist1 = modSettings.ShowSettingFromFIle("DeliveryTypes/Spontaneous")
  If xlist1 Then
    xsponlist = Split(xlist1, ";")
  Else
    xsponlist = New String[]
  Endif
  xlist2 = modSettings.ShowSettingFromFIle("DeliveryTypes/Instrument")
  If xlist2 Then
    xinstlist = Split(xlist2, ";")
  Else
    xinstlist = New String[]
  Endif
  xlist3 = modSettings.ShowSettingFromFIle("DeliveryTypes/Caeserian")
  If xlist3 Then
    xcesrlist = Split(xlist3, ";")
  Else
    xcesrlist = New String[]
  Endif

  GridView1.Clear()
  GridView1.Columns.Count = 4
  GridView1.Rows.Count = 3

  With GridView1
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 150 * modBasic.$AppWidthRatio
    .Columns[1].Width = 100 * modBasic.$AppWidthRatio
    .Columns[2].Width = 100 * modBasic.$AppWidthRatio
    .Columns[3].Width = 100 * modBasic.$AppWidthRatio

    .Columns[0].Text = "Delivery Type"
    .Columns[1].Text = "Cephalic"
    .Columns[2].Text = "Shoulder"
    .Columns[3].Text = "Breech"
  End With

  GridView1[0, 0].Text = "Spontaneous"
  GridView1[1, 0].Text = "Vacuum/Forcep"
  GridView1[2, 0].Text = "Surgery"

  xsponval = 0
  xinstval = 0
  xcessval = 0
  res1 = modDatabase.$syConn.Exec("select distinct(fldencounterval) as col from tblconfinement where flddeltime>=&1 and flddeltime<=&2 and fldencounterval in(select fldencounterval from tblexamgeneral where fldinput=&3 and fldtype=&4 and flditem=&5 and fldreportquali=&6)", modDate.StartSqlDate(dtfir.Value), modDate.EndSqlDate(dtlast.Value), "Obstetrics", "Qualitative", "Presentation", "Cephalic")
  If res1.Available Then
    For Each res1
      xdeltype = GetDeliveryTypeEnc(res1!col)
      If xdeltype Then
        If xsponlist.Exist(xdeltype) = True Then
          xsponval = xsponval + 1
        Endif
        If xinstlist.Exist(xdeltype) = True Then
          xinstval = xinstval + 1
        Endif
        If xcesrlist.Exist(xdeltype) = True Then
          xcessval = xcessval + 1
        Endif
      Endif
    Next
  Endif
  GridView1[0, 1].Text = xsponval
  GridView1[1, 1].Text = xinstval
  GridView1[2, 1].Text = xcessval
  $ProgressBar1.Value = 0.33
  Wait

  xsponval = 0
  xinstval = 0
  xcessval = 0
  res2 = modDatabase.$syConn.Exec("select distinct(fldencounterval) as col from tblconfinement where flddeltime>=&1 and flddeltime<=&2 and fldencounterval in(select fldencounterval from tblexamgeneral where fldinput=&3 and fldtype=&4 and flditem=&5 and fldreportquali=&6)", modDate.StartSqlDate(dtfir.Value), modDate.EndSqlDate(dtlast.Value), "Obstetrics", "Qualitative", "Presentation", "Shoulder")
  If res2.Available Then
    For Each res2
      xdeltype = GetDeliveryTypeEnc(res2!col)
      If xdeltype Then
        If xsponlist.Exist(xdeltype) = True Then
          xsponval = xsponval + 1
        Endif
        If xinstlist.Exist(xdeltype) = True Then
          xinstval = xinstval + 1
        Endif
        If xcesrlist.Exist(xdeltype) = True Then
          xcessval = xcessval + 1
        Endif
      Endif
    Next
  Endif
  GridView1[0, 2].Text = xsponval
  GridView1[1, 2].Text = xinstval
  GridView1[2, 2].Text = xcessval
  $ProgressBar1.Value = 0.66
  Wait

  xsponval = 0
  xinstval = 0
  xcessval = 0
  res3 = modDatabase.$syConn.Exec("select distinct(fldencounterval) as col from tblconfinement where flddeltime>=&1 and flddeltime<=&2 and fldencounterval in(select fldencounterval from tblexamgeneral where fldinput=&3 and fldtype=&4 and flditem=&5 and fldreportquali=&6)", modDate.StartSqlDate(dtfir.Value), modDate.EndSqlDate(dtlast.Value), "Obstetrics", "Qualitative", "Presentation", "Breech")
  If res3.Available Then
    For Each res3
      xdeltype = GetDeliveryTypeEnc(res3!col)
      If xdeltype Then
        If xsponlist.Exist(xdeltype) = True Then
          xsponval = xsponval + 1
        Endif
        If xinstlist.Exist(xdeltype) = True Then
          xinstval = xinstval + 1
        Endif
        If xcesrlist.Exist(xdeltype) = True Then
          xcessval = xcessval + 1
        Endif
      Endif
    Next
  Endif
  GridView1[0, 3].Text = xsponval
  GridView1[1, 3].Text = xinstval
  GridView1[2, 3].Text = xcessval
  $ProgressBar1.Value = 1
  Wait

  GridView1.Row = 0
  Dec Application.Busy

End

''======================== Delivery QTY ==========================
Private Function GetEncCountDel(encid As String) As Integer

  Dim res As Result
  Dim xval As Integer

  res = modDatabase.$syConn.Exec("select COUNT(fldencounterval) as col from tblconfinement where fldencounterval=&1 and flddelresult=&2", encid, "Live Baby")
  If res.Available Then
    If res!col Then
      xval = res!col
    Else
      xval = 0
    Endif
  Else
    xval = 0
  Endif
  Return xval

End

Private Sub GetLiveDeliveryBabyQTY()

  Dim res1 As Result
  Dim res2 As Result
  Dim res3 As Result
  Dim xcount As Integer

  Dim xsingle As Integer
  Dim xdouble As Integer
  Dim xmultiple As Integer

  GridView1.Clear()
  GridView1.Columns.Count = 4
  GridView1.Rows.Count = 3

  With GridView1
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 150 * modBasic.$AppWidthRatio
    .Columns[1].Width = 100 * modBasic.$AppWidthRatio
    .Columns[2].Width = 100 * modBasic.$AppWidthRatio
    .Columns[3].Width = 100 * modBasic.$AppWidthRatio

    .Columns[0].Text = "Variable"
    .Columns[1].Text = "Single Baby"
    .Columns[2].Text = "Double Baby"
    .Columns[3].Text = "Multiple Baby"
  End With

  Inc Application.Busy
  xsingle = 0
  xdouble = 0
  xmultiple = 0
  res1 = modDatabase.$syConn.Exec("select distinct(fldencounterval) as col from tblconfinement where flddeltime>=&1 and flddeltime<=&2 and flddelresult=&3", modDate.StartSqlDate(dtfir.Value), modDate.EndSqlDate(dtlast.Value), "Live Baby")
  If res1.Available Then
    For Each res1
      xcount = GetEncCountDel(res1!col)
      If xcount = 1 Then
        xsingle = xsingle + 1
      Else If xcount = 2 Then
        xdouble = xdouble + 1
      Else If xcount > 2 Then
        xmultiple = xmultiple + 1
      Endif
    Next
  Endif
  GridView1[0, 0].Text = "Total Mothers"
  GridView1[0, 1].Text = xsingle
  GridView1[0, 2].Text = xdouble
  GridView1[0, 3].Text = xmultiple
  $ProgressBar1.Value = 0.33
  Wait

  xsingle = 0
  xdouble = 0
  xmultiple = 0
  res2 = modDatabase.$syConn.Exec("select distinct(fldencounterval) as col from tblconfinement where flddeltime>=&1 and flddeltime<=&2 and flddelresult=&3 and fldbabypatno in(select fldpatientval from tblpatientinfo where fldptsex=&4)", modDate.StartSqlDate(dtfir.Value), modDate.EndSqlDate(dtlast.Value), "Live Baby", "Female")
  If res2.Available Then
    For Each res2
      xcount = GetEncCountDel(res2!col)
      If xcount = 1 Then
        xsingle = xsingle + 1
      Else If xcount = 2 Then
        xdouble = xdouble + 1
      Else If xcount > 2 Then
        xmultiple = xmultiple + 1
      Endif
    Next
  Endif
  GridView1[1, 0].Text = "Live Baby(Female)"
  GridView1[1, 1].Text = xsingle
  GridView1[1, 2].Text = xdouble
  GridView1[1, 3].Text = xmultiple
  $ProgressBar1.Value = 0.66
  Wait

  xsingle = 0
  xdouble = 0
  xmultiple = 0
  res3 = modDatabase.$syConn.Exec("select distinct(fldencounterval) as col from tblconfinement where flddeltime>=&1 and flddeltime<=&2 and flddelresult=&3 and fldbabypatno in(select fldpatientval from tblpatientinfo where fldptsex=&4)", modDate.StartSqlDate(dtfir.Value), modDate.EndSqlDate(dtlast.Value), "Live Baby", "Male")
  If res3.Available Then
    For Each res3
      xcount = GetEncCountDel(res3!col)
      If xcount = 1 Then
        xsingle = xsingle + 1
      Else If xcount = 2 Then
        xdouble = xdouble + 1
      Else If xcount > 2 Then
        xmultiple = xmultiple + 1
      Endif
    Next
  Endif
  GridView1[2, 0].Text = "Live Baby(Male)"
  GridView1[2, 1].Text = xsingle
  GridView1[2, 2].Text = xdouble
  GridView1[2, 3].Text = xmultiple
  $ProgressBar1.Value = 1
  Wait

  GridView1.Row = 0
  Dec Application.Busy

End

''==================== Birth weight =========================
Private Sub BirthWeightreportCompli()

  Dim res1 As Result
  Dim res2 As Result
  Dim res3 As Result

  Dim xtotal As Integer
  Dim xrespd As Integer
  Dim xmalfrm As Integer

  GridView1.Clear()
  GridView1.Columns.Count = 4
  GridView1.Rows.Count = 3

  With GridView1
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 150 * modBasic.$AppWidthRatio
    .Columns[1].Width = 100 * modBasic.$AppWidthRatio
    .Columns[2].Width = 100 * modBasic.$AppWidthRatio
    .Columns[3].Width = 100 * modBasic.$AppWidthRatio

    .Columns[0].Text = "Birth Weight"
    .Columns[1].Text = "Total"
    .Columns[2].Text = "Asphyxia"
    .Columns[3].Text = "Malformations"
  End With

  Inc Application.Busy
  xtotal = 0
  xrespd = 0
  xmalfrm = 0
  res1 = modDatabase.$syConn.Exec("select fldencounterval,fldcomplication from tblconfinement where flddeltime>=&1 and flddeltime<=&2 and flddelwt<&3", modDate.StartSqlDate(dtfir.Value), modDate.EndSqlDate(dtlast.Value), 1500)
  If res1.Available Then
    xtotal = res1.Count
    For Each res1
      If res1!fldcomplication And If res1!fldcomplication = "Asphyxia" Then
        xrespd = xrespd + 1
      Else If res1!fldcomplication And If res1!fldcomplication = "Malformations" Then
        xmalfrm = xmalfrm + 1
      Endif
    Next
  Endif
  GridView1[0, 0].Text = "Very Low(<1.5Kg)"
  GridView1[0, 1].Text = xtotal
  GridView1[0, 2].Text = xrespd
  GridView1[0, 3].Text = xmalfrm
  $ProgressBar1.Value = 0.33
  Wait

  xtotal = 0
  xrespd = 0
  xmalfrm = 0
  res2 = modDatabase.$syConn.Exec("select fldencounterval,fldcomplication from tblconfinement where flddeltime>=&1 and flddeltime<=&2 and flddelwt>=&3 and flddelwt<&4", modDate.StartSqlDate(dtfir.Value), modDate.EndSqlDate(dtlast.Value), 1500, 2500)
  If res2.Available Then
    xtotal = res2.Count
    For Each res2
      If res2!fldcomplication And If res2!fldcomplication = "Asphyxia" Then
        xrespd = xrespd + 1
      Else If res2!fldcomplication And If res2!fldcomplication = "Malformations" Then
        xmalfrm = xmalfrm + 1
      Endif
    Next
  Endif
  GridView1[1, 0].Text = "Low(1.5-2.5Kg)"
  GridView1[1, 1].Text = xtotal
  GridView1[1, 2].Text = xrespd
  GridView1[1, 3].Text = xmalfrm
  $ProgressBar1.Value = 0.66
  Wait

  xtotal = 0
  xrespd = 0
  xmalfrm = 0
  res3 = modDatabase.$syConn.Exec("select fldencounterval,fldcomplication from tblconfinement where flddeltime>=&1 and flddeltime<=&2 and flddelwt>=&3", modDate.StartSqlDate(dtfir.Value), modDate.EndSqlDate(dtlast.Value), 2500)
  If res3.Available Then
    xtotal = res3.Count
    For Each res3
      If res3!fldcomplication And If res3!fldcomplication = "Asphyxia" Then
        xrespd = xrespd + 1
      Else If res3!fldcomplication And If res3!fldcomplication = "Malformations" Then
        xmalfrm = xmalfrm + 1
      Endif
    Next
  Endif
  GridView1[2, 0].Text = "Normal(>=2.5Kg)"
  GridView1[2, 1].Text = xtotal
  GridView1[2, 2].Text = xrespd
  GridView1[2, 3].Text = xmalfrm
  $ProgressBar1.Value = 1
  Wait

  GridView1.Row = 0
  Dec Application.Busy

End

''================== Death Report ==============================
Public Sub GetDeathReportHMIS()

  Dim res1x As Result
  Dim res1y As Result
  Dim res2x As Result
  Dim res2y As Result
  Dim res3x As Result
  Dim res4x As Result
  Dim res4y As Result
  Dim res5x As Result
  Dim res5y As Result

  Dim xtotfemale As Integer
  Dim xtotmale As Integer
  Dim xstr As String
  Dim aa As Integer

  GridView1.Clear()
  GridView1.Columns.Count = 3
  GridView1.Rows.Count = 5

  With GridView1
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 200 * modBasic.$AppWidthRatio
    .Columns[1].Width = 100 * modBasic.$AppWidthRatio
    .Columns[2].Width = 100 * modBasic.$AppWidthRatio

    .Columns[0].Text = "Category"
    .Columns[1].Text = "Female"
    .Columns[2].Text = "Male"
  End With

  Inc Application.Busy
  xstr = modMedReports.GetAgeStringByTable("tblpatientdate", modDatabase.$syConn)
  GridView1[0, 0].Text = "Early Neonatal(0-6 days)"
  GridView1[1, 0].Text = "Late Neonatal(7-27 days)"
  GridView1[2, 0].Text = "Maternal (All)"
  GridView1[3, 0].Text = "Post Operative"
  GridView1[4, 0].Text = "Others"

  xtotfemale = 0
  xtotmale = 0

  'early neonatal female
  aa = 0
  res1x = modDatabase.$syConn.Exec("select count(fldencounterval) as col from tblpatientdate where fldtime>=&1 and fldtime<=&2 and fldhead=&3 and fldencounterval in(select fldencounterval from tblencounter where fldpatientval in(select fldpatientval from tblpatientinfo where fldptsex like &4 and fldptbirday like &5 and " & xstr & ">=&6 and " & xstr & "<&7))", modDate.StartSqlDate(dtfir.Value), modDate.EndSqlDate(dtlast.Value), "Death", "Female", "%", 0, 7)
  If res1x.Available Then
    If res1x!col Then
      aa = res1x!col
    Endif
  Endif
  xtotfemale = xtotfemale + aa
  GridView1[0, 1].Text = aa
  $ProgressBar1.Value = 0.1
  Wait

  ''early neonatal male
  aa = 0
  res1y = modDatabase.$syConn.Exec("select count(fldencounterval) as col from tblpatientdate where fldtime>=&1 and fldtime<=&2 and fldhead=&3 and fldencounterval in(select fldencounterval from tblencounter where fldpatientval in(select fldpatientval from tblpatientinfo where fldptsex like &4 and fldptbirday like &5 and " & xstr & ">=&6 and " & xstr & "<&7))", modDate.StartSqlDate(dtfir.Value), modDate.EndSqlDate(dtlast.Value), "Death", "Male", "%", 0, 7)
  If res1x.Available Then
    If res1y!col Then
      aa = res1y!col
    Endif
  Endif
  xtotmale = xtotmale + aa
  GridView1[0, 2].Text = aa
  $ProgressBar1.Value = 0.2
  Wait

  ''late neonatal female
  aa = 0
  res2x = modDatabase.$syConn.Exec("select count(fldencounterval) as col from tblpatientdate where fldtime>=&1 and fldtime<=&2 and fldhead=&3 and fldencounterval in(select fldencounterval from tblencounter where fldpatientval in(select fldpatientval from tblpatientinfo where fldptsex like &4 and fldptbirday like &5 and " & xstr & ">=&6 and " & xstr & "<&7))", modDate.StartSqlDate(dtfir.Value), modDate.EndSqlDate(dtlast.Value), "Death", "Female", "%", 7, 27)
  If res2x.Available Then
    If res2x!col Then
      aa = res2x!col
    Endif
  Endif
  xtotfemale = xtotfemale + aa
  GridView1[1, 1].Text = aa
  $ProgressBar1.Value = 0.3
  Wait

  ''late neonatal male
  aa = 0
  res2y = modDatabase.$syConn.Exec("select count(fldencounterval) as col from tblpatientdate where fldtime>=&1 and fldtime<=&2 and fldhead=&3 and fldencounterval in(select fldencounterval from tblencounter where fldpatientval in(select fldpatientval from tblpatientinfo where fldptsex like &4 and fldptbirday like &5 and " & xstr & ">=&6 and " & xstr & "<&7))", modDate.StartSqlDate(dtfir.Value), modDate.EndSqlDate(dtlast.Value), "Death", "Male", "%", 7, 27)
  If res2y.Available Then
    If res2y!col Then
      aa = res2y!col
    Endif
  Endif
  xtotmale = xtotmale + aa
  GridView1[1, 2].Text = aa
  $ProgressBar1.Value = 0.4
  Wait

  ''delivery
  aa = 0
  res3x = modDatabase.$syConn.Exec("select count(fldencounterval) as col from tblpatientdate where fldtime>=&1 and fldtime<=&2 and fldhead=&3 and fldencounterval in(select fldencounterval from tblconfinement)", modDate.StartSqlDate(dtfir.Value), modDate.EndSqlDate(dtlast.Value), "Death")
  If res3x.Available Then
    If res3x!col Then
      aa = res3x!col
    Endif
  Endif
  xtotfemale = xtotfemale + aa
  GridView1[2, 1].Text = aa
  GridView1[2, 2].Text = 0
  $ProgressBar1.Value = 0.6
  Wait

  ''post operative female
  aa = 0
  res4x = modDatabase.$syConn.Exec("select count(fldencounterval) as col from tblpatientdate where fldtime>=&1 and fldtime<=&2 and fldhead=&3 and fldencounterval in(select fldencounterval from tblpatgeneral where fldreportquali=&4) and fldencounterval in(select fldencounterval from tblencounter where fldpatientval in(select fldpatientval from tblpatientinfo where fldptsex like &5))", modDate.StartSqlDate(dtfir.Value), modDate.EndSqlDate(dtlast.Value), "Death", "Done", "Female")
  If res4x.Available Then
    If res4x!col Then
      aa = res4x!col
    Endif
  Endif
  xtotfemale = xtotfemale + aa
  GridView1[3, 1].Text = aa
  $ProgressBar1.Value = 0.7
  Wait

  ''post operative male
  aa = 0
  res4y = modDatabase.$syConn.Exec("select count(fldencounterval) as col from tblpatientdate where fldtime>=&1 and fldtime<=&2 and fldhead=&3 and fldencounterval in(select fldencounterval from tblpatgeneral where fldreportquali=&4) and fldencounterval in(select fldencounterval from tblencounter where fldpatientval in(select fldpatientval from tblpatientinfo where fldptsex like &5))", modDate.StartSqlDate(dtfir.Value), modDate.EndSqlDate(dtlast.Value), "Death", "Done", "Male")
  If res4y.Available Then
    If res4y!col Then
      aa = res4y!col
    Endif
  Endif
  xtotmale = xtotmale + aa
  GridView1[3, 2].Text = aa
  $ProgressBar1.Value = 0.8
  Wait

  ''others female
  aa = 0
  res5x = modDatabase.$syConn.Exec("select count(fldencounterval) as col from tblpatientdate where fldtime>=&1 and fldtime<=&2 and fldhead=&3 and fldencounterval in(select fldencounterval from tblencounter where fldpatientval in(select fldpatientval from tblpatientinfo where fldptsex like &4))", modDate.StartSqlDate(dtfir.Value), modDate.EndSqlDate(dtlast.Value), "Death", "Female")
  If res5x.Available Then
    If res5x!col Then
      aa = res5x!col
    Endif
  Endif
  GridView1[4, 1].Text = aa - xtotfemale
  $ProgressBar1.Value = 0.9
  Wait

  ''others male
  aa = 0
  res5y = modDatabase.$syConn.Exec("select count(fldencounterval) as col from tblpatientdate where fldtime>=&1 and fldtime<=&2 and fldhead=&3 and fldencounterval in(select fldencounterval from tblencounter where fldpatientval in(select fldpatientval from tblpatientinfo where fldptsex like &4))", modDate.StartSqlDate(dtfir.Value), modDate.EndSqlDate(dtlast.Value), "Death", "Male")
  If res5y.Available Then
    If res5y!col Then
      aa = res5y!col
    Endif
  Endif
  GridView1[4, 2].Text = aa - xtotmale
  $ProgressBar1.Value = 1
  Wait

  GridView1.Row = 0
  Dec Application.Busy

End

''========================= Laboratory ===========================
Private Sub GetLaboratoryHMISReport()

  Dim sList As String[]
  Dim sTest As String
  Dim res1 As Result
  Dim res2 As Result
  Dim Row As Integer

  Dim xabn As Integer
  Dim xtot As Integer

  sList = modFillContainer.GetListFromResult(modDatabase.$syConn.Exec("select fldtestid from tbltest where fldcategory=&1", cmbcategory.Text))
  GridView1.Clear()
  GridView1.Columns.Count = 3
  GridView1.Rows.Count = sList.Count

  With GridView1
    .Rows.Height = 25 * modBasic.$AppHeightRatio
    .Columns[0].Width = 200 * modBasic.$AppWidthRatio
    .Columns[1].Width = 100 * modBasic.$AppWidthRatio
    .Columns[2].Width = 100 * modBasic.$AppWidthRatio

    .Columns[0].Text = "Test Name"
    .Columns[1].Text = "Abnormal"
    .Columns[2].Text = "Total"
  End With

  Inc Application.Busy

  Row = 0
  For Each sTest In sList
    xabn = 0
    res1 = modDatabase.$syConn.Exec("select count(fldid) as col from tblpatlabtest where fldtestid=&1 and fldtime_sample>=&2 and fldtime_sample<=&3 and fldsave_report=&4 and fldabnormal=&5", sTest, modDate.StartSqlDate(dtfir.Value), modDate.EndSqlDate(dtlast.Value), True, True)
    If res1.Available Then
      If res1!col Then
        xabn = res1!col
      Endif
    Endif

    xtot = 0
    res2 = modDatabase.$syConn.Exec("select count(fldid) as col from tblpatlabtest where fldtestid=&1 and fldtime_sample>=&2 and fldtime_sample<=&3 and fldsave_report=&4", sTest, modDate.StartSqlDate(dtfir.Value), modDate.EndSqlDate(dtlast.Value), True)
    If res2.Available Then
      If res2!col Then
        xtot = res2!col
      Endif
    Endif
    GridView1[Row, 0].Text = sTest
    GridView1[Row, 1].Text = xabn
    GridView1[Row, 2].Text = xtot

    Row = Row + 1
    $ProgressBar1.Value = Row / sList.Count
    Wait
  Next

  GridView1.Row = 0
  Dec Application.Busy

End

''============================== ALL REPORTS ==========================
Public Sub btnall_Click()

  Dim $BillingReport As CReportHTML
  Dim asx As New String[0]
  Dim xPath As String
  Dim xicdlist As String[]
  Dim xicd As String
  Dim xlablist As String[]
  Dim xlab As String

  $BillingReport = New CReportHTML(["Data"], modHelpVariable.$htmlDirectory, "", "")
  $BillingReport.UserData.Add("HMIS REPORT", "PARAM1")
  $BillingReport.UserData.Add(modReportVar.GetDateTimeReport(dtfir.Value, gb.MediumDate) & " TO " & modReportVar.GetDateTimeReport(dtlast.Value, gb.MediumDate), "PARAM2")

  GridView1.Clear()
  $ProgressBar1 = New ProgressBar(Me)

  GetHospitalService()
  Wait
  $BillingReport.AddSection("Hospital Services")
  With asx
    .Add(modString.GetGridViewRichText(GridView1))
  End With
  $BillingReport.Add(asx)
  asx.Clear()
  GridView1.Clear()
  With asx
    .Add("*****")
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  GetEmergencyServices()
  Wait
  $BillingReport.AddSection("Emergency Services")
  With asx
    .Add(modString.GetGridViewRichText(GridView1))
  End With
  $BillingReport.Add(asx)
  asx.Clear()
  GridView1.Clear()
  With asx
    .Add("*****")
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  GetRadiologyService()
  Wait
  $BillingReport.AddSection("Radiology Services")
  With asx
    .Add(modString.GetGridViewRichText(GridView1))
  End With
  $BillingReport.Add(asx)
  asx.Clear()
  GridView1.Clear()
  With asx
    .Add("*****")
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  ShowInpatientsOutcome()
  Wait
  $BillingReport.AddSection("Inpatient Outcome")
  With asx
    .Add(modString.GetGridViewRichText(GridView1))
  End With
  $BillingReport.Add(asx)
  asx.Clear()
  GridView1.Clear()
  With asx
    .Add("*****")
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  GetAgeWiseMorbidity("InPatient")
  Wait
  $BillingReport.AddSection("Inpatient Morbidity")
  With asx
    .Add(modString.GetGridViewRichText(GridView1))
  End With
  $BillingReport.Add(asx)
  asx.Clear()
  GridView1.Clear()
  With asx
    .Add("*****")
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  $BillingReport.AddSection("Outpatient Morbidity")
  xicdlist = modFillContainer.GetListFromResult(modDatabase.$myConn.Exec("select distinct(fldgroupname) as col from tbldiagnogroup"))
  If Not xicdlist Or If xicdlist.Count = 0 Then
    xicdlist = ["%"]
  Endif
  For Each xicd In xicdlist
    cmbcategory.Text = xicd
    GetNewOPDMorbidity()
    Wait
    $BillingReport.AddChapter(xicd)
    With asx
      .Add(modString.GetGridViewRichText(GridView1))
    End With
    $BillingReport.Add(asx)
    asx.Clear()
    GridView1.Clear()
  Next
  With asx
    .Add("*****")
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  FillMaternalAgeData()
  Wait
  $BillingReport.AddSection("Maternal Age")
  With asx
    .Add(modString.GetGridViewRichText(GridView1))
  End With
  $BillingReport.Add(asx)
  asx.Clear()
  GridView1.Clear()
  With asx
    .Add("*****")
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  GetGravidaReport()
  Wait
  $BillingReport.AddSection("Gravida Info")
  With asx
    .Add(modString.GetGridViewRichText(GridView1))
  End With
  $BillingReport.Add(asx)
  asx.Clear()
  GridView1.Clear()
  With asx
    .Add("*****")
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  DeliveryTypeReport()
  Wait
  $BillingReport.AddSection("Delivery Type")
  With asx
    .Add(modString.GetGridViewRichText(GridView1))
  End With
  $BillingReport.Add(asx)
  asx.Clear()
  GridView1.Clear()
  With asx
    .Add("*****")
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  GetLiveDeliveryBabyQTY()
  Wait
  $BillingReport.AddSection("Live Deliveries")
  With asx
    .Add(modString.GetGridViewRichText(GridView1))
  End With
  $BillingReport.Add(asx)
  asx.Clear()
  GridView1.Clear()
  With asx
    .Add("*****")
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  BirthWeightreportCompli()
  Wait
  $BillingReport.AddSection("Birth Weight")
  With asx
    .Add(modString.GetGridViewRichText(GridView1))
  End With
  $BillingReport.Add(asx)
  asx.Clear()
  GridView1.Clear()
  With asx
    .Add("*****")
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  GetDeathReportHMIS()
  Wait
  $BillingReport.AddSection("Death Info")
  With asx
    .Add(modString.GetGridViewRichText(GridView1))
  End With
  $BillingReport.Add(asx)
  asx.Clear()
  GridView1.Clear()
  With asx
    .Add("*****")
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  $BillingReport.AddSection("Laboratory")
  xlablist = modMedicine.GetPathoCategoryList("Test")
  For Each xlab In xlablist
    cmbcategory.Text = xlab
    GetLaboratoryHMISReport()
    Wait
    $BillingReport.AddChapter(xlab)
    With asx
      .Add(modString.GetGridViewRichText(GridView1))
    End With
    $BillingReport.Add(asx)
    asx.Clear()
    GridView1.Clear()
  Next
  With asx
    .Add("*****")
  End With
  $BillingReport.Add(asx)
  asx.Clear()

  xPath = $BillingReport.NewHTMLPath()
  modPrint.DisplayReportExport(xPath)

End
