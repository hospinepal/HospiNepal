' Gambas class file

Private $DelTypes As String[]

Public Sub Form_Open()

  Dim xlist1 As String
  Dim xlist2 As String
  Dim xlist3 As String

  modGeneralMain.ArrangeFormCentre(Me, "False")
  $DelTypes = modFillContainer.GetListFromResult(modDatabase.$myConn.Exec("select flditem as col from tbldelivery"))                                              ''
  $DelTypes.Sort()
  xlist1 = modSettings.ShowSettingFromFIle("DeliveryTypes/Spontaneous")
  If xlist1 Then
    ListBox1.List = Split(xlist1, ";")
  Endif
  xlist2 = modSettings.ShowSettingFromFIle("DeliveryTypes/Instrument")
  If xlist2 Then
    ListBox2.List = Split(xlist2, ";")
  Endif
  xlist3 = modSettings.ShowSettingFromFIle("DeliveryTypes/Caeserian")
  If xlist3 Then
    ListBox3.List = Split(xlist3, ";")
  Endif

End

Private Function GetDelList() As String[]

  Dim xlist As String[]
  Dim xxx As String[]

  xlist = New String[]
  If ListBox1.List.Count Then
    xlist.Insert(ListBox1.List)
  Endif
  If ListBox2.List.Count Then
    xlist.Insert(ListBox2.List)
  Endif
  If ListBox3.List.Count Then
    xlist.Insert(ListBox3.List)
  Endif

  xxx = modString.GetRemainingArray($DelTypes, xlist)
  Return xxx

End

Public Sub btnaddspont_Click()

  Dim xx As String[]
  Dim sItem As String

  xx = SelectListView("Select Delivery Types", GetDelList(), False)
  If xx Then
    For Each sItem In xx
      ListBox1.Add(sItem)
    Next
  Endif

End

Public Sub btnaddinstr_Click()

  Dim xx As String[]
  Dim sItem As String

  xx = SelectListView("Select Delivery Types", GetDelList(), False)
  If xx Then
    For Each sItem In xx
      ListBox2.Add(sItem)
    Next
  Endif

End

Public Sub btnaddsurg_Click()

  Dim xx As String[]
  Dim sItem As String

  xx = SelectListView("Select Delivery Types", GetDelList(), False)
  If xx Then
    For Each sItem In xx
      ListBox3.Add(sItem)
    Next
  Endif

End

Public Sub btnsave_Click()

  modSettings.SaveSettingsToFile("DeliveryTypes/Spontaneous", ListBox1.List.Join(";"))
  modSettings.SaveSettingsToFile("DeliveryTypes/Instrument", ListBox2.List.Join(";"))
  modSettings.SaveSettingsToFile("DeliveryTypes/Caeserian", ListBox3.List.Join(";"))
  Balloon.Info(("Information saved"), btnsave)
  Balloon.Delay = modBasic.$BalloonDelay

End

Public Sub btnclose_Click()

  Me.Close()

End

Public Sub btnclear_Click()

  ListBox1.Clear()
  ListBox2.Clear()
  ListBox3.Clear()

End
