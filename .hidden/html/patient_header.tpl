<table class='header_table' style="text-align: left; width: 100%;" border="0" cellpadding="2" cellspacing="0" id="headtable">
  <tbody>
    <tr>
      <td style="vertical-align: top; width: 40%;"><span style="font-weight: bold;">Name&nbsp;&nbsp;&nbsp; :</span> {PatientName}<br>
      </td>
      <td style="vertical-align: top; width: 25%;"><span style="font-weight: bold;">EncID :</span> {Encounter}<br>
      </td>
      <td colspan="1" rowspan="4" style="vertical-align: middle; width: 35%; text-align: center;"><img style="width: 80%; height: 80%;" alt="" src={barcodelink}></td>
    </tr>
    <tr>
      <td style="vertical-align: top;"><span style="font-weight: bold;">Age/Sex :</span> {Age/Sex}<br>
      </td>
      <td style="vertical-align: top;"><span style="font-weight: bold;">DOReg&nbsp;&nbsp; :</span> {RegistrationDate}<br>
      </td>
    </tr>
    <tr>
      <td style="vertical-align: top;"><span style="font-weight: bold;">Address :</span> {PatientAddress}<br>
      </td>
      <td style="vertical-align: top;"><span style="font-weight: bold;">Phone&nbsp; :</span> {ContactNo}<br>
      </td>
    </tr>
    <tr>
      <td colspan="2" rowspan="1" style="vertical-align: top;"><span style="font-weight: bold;">{Report}&nbsp; :</span> {PARAM1}<br>
      </td>
    </tr>
  </tbody>
</table>

